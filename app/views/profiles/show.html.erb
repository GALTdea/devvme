<% content_for :title, "#{@user.display_name} - Profile" %>

<div class="min-h-screen bg-gradient-to-br from-cream-50 via-primary-50 to-secondary-50 dark:from-charcoal-900 dark:via-charcoal-800 dark:to-secondary-900 transition-all duration-300 py-8">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Profile Header -->
    <div class="relative overflow-hidden bg-white dark:bg-charcoal-800 rounded-2xl shadow-xl mb-8 border border-primary-200 dark:border-charcoal-700 transition-all duration-300 hover:shadow-2xl">
      <!-- Background Pattern -->
      <div class="absolute inset-0 bg-gradient-to-r from-primary-600/5 to-secondary-600/5 dark:from-primary-400/5 dark:to-secondary-400/5"></div>
      <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="none" fill-rule="evenodd"%3E%3Cg fill="%2310b981" fill-opacity="0.03"%3E%3Ccircle cx="30" cy="30" r="2"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')]"></div>
      
      <div class="relative px-8 py-12">
        <div class="flex flex-col lg:flex-row lg:items-start lg:space-x-8">
          <!-- Avatar and Basic Info -->
          <div class="flex-shrink-0 mb-8 lg:mb-0">
            <!-- Terminal-style frame -->
            <div class="relative bg-charcoal-900 dark:bg-charcoal-950 rounded-lg p-3 border border-charcoal-600 shadow-lg">
              <!-- Terminal header -->
              <div class="flex items-center justify-between mb-3 px-2">
                <div class="flex space-x-1.5">
                  <div class="w-3 h-3 bg-danger-500 rounded-full"></div>
                  <div class="w-3 h-3 bg-warning-500 rounded-full"></div>
                  <div class="w-3 h-3 bg-primary-500 rounded-full"></div>
                </div>
                <div class="text-xs font-mono text-charcoal-400">~/developer</div>
              </div>
              
              <!-- Avatar container -->
              <div class="relative group">
                <% if @user.avatar.attached? %>
                  <%= image_tag @user.avatar_medium, 
                        class: "profile-avatar w-32 h-32 rounded-xl object-cover border-2 border-primary-400 shadow-lg group-hover:shadow-primary-500/50 transition-all duration-300",
                        alt: "#{@user.display_name}'s avatar" %>
                <% else %>
                  <div class="profile-avatar w-32 h-32 rounded-xl bg-gradient-to-br from-primary-500 to-secondary-600 flex items-center justify-center border-2 border-primary-400 shadow-lg group-hover:shadow-primary-500/50 transition-all duration-300">
                    <svg class="w-16 h-16 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                  </div>
                <% end %>
                
                <!-- Online status indicator -->
                <div class="absolute -bottom-1 -right-1 w-6 h-6 bg-primary-500 rounded-full border-2 border-charcoal-900 flex items-center justify-center">
                  <div class="w-2 h-2 bg-white rounded-full animate-pulse"></div>
                </div>
              </div>
              
              <!-- Terminal command -->
              <div class="mt-3 px-2">
                <div class="text-xs font-mono text-primary-400">
                  <span class="text-charcoal-500">$</span> whoami
                </div>
                <div class="text-xs font-mono text-cream-200 mt-1">
                  <%= @user.username %>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Profile Info -->
          <div class="flex-1 min-w-0">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-6">
              <div class="mb-4 sm:mb-0">
                <h1 class="text-4xl lg:text-5xl font-bold text-charcoal-900 dark:text-cream-50 mb-2 animate-fade-in">
                  <%= @user.display_name %>
                </h1>
                <p class="text-xl text-charcoal-600 dark:text-charcoal-400 mb-4 font-mono">
                  @<%= @user.username %>
                </p>
                
                <!-- Developer Status Badges -->
                <div class="flex flex-wrap items-center gap-3 mb-4">
                  <!-- Availability Status -->
                  <div class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-primary-100 text-primary-800 dark:bg-primary-900/30 dark:text-primary-300 border border-primary-200 dark:border-primary-700">
                    <div class="w-2 h-2 bg-primary-500 rounded-full mr-2 animate-pulse"></div>
                    Available for hire
                  </div>
                  
                  <!-- Years Coding -->
                  <div class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-secondary-100 text-secondary-800 dark:bg-secondary-900/30 dark:text-secondary-300 border border-secondary-200 dark:border-secondary-700">
                    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    3+ years coding
                  </div>
                </div>
              </div>
              
              <!-- Action Buttons -->
              <div class="flex flex-wrap gap-3 no-print">
                <!-- Share Profile Button -->
                <div data-controller="share-button"
                     data-share-button-url-value="<%= @public_profile_url %>"
                     data-share-button-title-value="<%= @user.display_name %>'s Profile">
                  <button data-action="click->share-button#share"
                          class="inline-flex items-center px-4 py-2 bg-charcoal-800 hover:bg-charcoal-900 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-cream-100 font-mono text-sm rounded-lg border border-charcoal-600 hover:border-accent-500 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5">
                    <span class="text-accent-400 mr-2">$</span>
                    <span>share --profile</span>
                  </button>
                </div>
                
                <!-- Edit Profile Button -->
                <%= link_to edit_profile_path, 
                    class: "inline-flex items-center px-4 py-2 bg-charcoal-800 hover:bg-charcoal-900 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-cream-100 font-mono text-sm rounded-lg border border-charcoal-600 hover:border-primary-500 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5" do %>
                  <span class="text-primary-400 mr-2">$</span>
                  <span>vim profile.rb</span>
                <% end %>
              </div>
            </div>
            
            <!-- Bio -->
            <% if @user.bio.present? %>
              <p class="text-charcoal-700 dark:text-charcoal-300 text-lg leading-relaxed mb-4">
                <%= simple_format(@user.bio, {}, wrapper_tag: "span") %>
              </p>
            <% else %>
              <p class="text-charcoal-500 dark:text-charcoal-400 italic text-lg mb-4">
                // TODO: Add an awesome bio
              </p>
            <% end %>
            
            <!-- Contact Info -->
            <div class="flex items-center text-sm text-charcoal-600 dark:text-charcoal-400 mb-4">
              <svg class="mr-2 h-4 w-4 text-pink-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <span class="font-mono"><%= @user.email %></span>
            </div>
            
            <!-- Social Links -->
            <div class="flex flex-wrap gap-4">
              <% if @user.github_url.present? %>
                <%= link_to @user.github_url, target: "_blank", rel: "noopener noreferrer",
                    class: "inline-flex items-center px-4 py-2 bg-charcoal-900 hover:bg-charcoal-800 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-cream-100 font-mono text-sm rounded-lg border border-charcoal-600 hover:border-primary-500 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5 no-print" do %>
                  <span class="text-primary-400 mr-2">$</span>
                  <span>git clone github</span>
                <% end %>
              <% end %>
              
              <% if @user.linkedin_url.present? %>
                <%= link_to @user.linkedin_url, target: "_blank", rel: "noopener noreferrer",
                    class: "inline-flex items-center px-3 py-2 border border-gray-300 dark:border-gray-600 shadow-sm text-sm leading-4 font-medium rounded-md text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500" do %>
                  <svg class="mr-2 h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M6.29 18.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0020 3.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.073 4.073 0 01.8 7.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 010 16.407a11.616 11.616 0 006.29 1.84" />
                  </svg>
                  LinkedIn
                <% end %>
              <% end %>
              
              <% if @user.website_url.present? %>
                <%= link_to @user.website_url, target: "_blank", rel: "noopener noreferrer",
                    class: "inline-flex items-center px-3 py-2 border border-gray-300 dark:border-gray-600 shadow-sm text-sm leading-4 font-medium rounded-md text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500" do %>
                  <svg class="mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9v-9m0 9a9 9 0 009-9M3 12a9 9 0 019-9" />
                  </svg>
                  Website
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Profile Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <!-- Total Projects -->
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
                  Total Projects
                </dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white">
                  <%= @user.projects_count %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <!-- Published Projects -->
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
                  Published Projects
                </dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white">
                  <%= @user.published_projects_count %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <!-- Profile Completion -->
      <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
                  Profile Complete
                </dt>
                <dd class="text-lg font-medium text-gray-900 dark:text-white">
                  <%= @user.profile_completion_percentage %>%
                </dd>
              </dl>
            </div>
          </div>
          <div class="mt-3">
            <div class="w-full bg-gray-200 rounded-full h-2 dark:bg-gray-700">
              <div class="bg-blue-600 h-2 rounded-full" style="width: <%= @user.profile_completion_percentage %>%"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Featured Blog Posts Section -->
    <% featured_blog_posts = @user.featured_blog_posts(3) %>
    <% if featured_blog_posts.any? %>
      <div class="mb-8">
        <div class="sm:flex sm:items-center sm:justify-between mb-6">
          <h2 class="text-lg font-medium text-gray-900 dark:text-white">Featured Blog Posts</h2>
          <%= link_to public_blog_index_path, class: "mt-3 sm:mt-0 text-sm font-medium text-primary-600 hover:text-primary-500 dark:text-primary-400 dark:hover:text-primary-300" do %>
            View all posts
            <span aria-hidden="true"> →</span>
          <% end %>
        </div>

        <!-- Blog Posts Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% featured_blog_posts.each do |blog_post| %>
            <article class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg hover:shadow-lg transition-shadow">
              <!-- Blog Post Header -->
              <div class="p-6">
                <div class="flex items-center justify-between mb-3">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">
                    <svg class="mr-1 h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                    Featured
                  </span>
                  <time class="text-xs text-gray-500 dark:text-gray-400">
                    <%= time_ago_in_words(blog_post.published_at) %> ago
                  </time>
                </div>
                
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2 line-clamp-2">
                  <%= link_to blog_post.title, public_blog_post_path(blog_post), 
                      class: "hover:text-primary-600 dark:hover:text-primary-400 transition-colors" %>
                </h3>
                
                <p class="text-sm text-gray-600 dark:text-gray-400 mb-4 line-clamp-3">
                  <%= blog_post.excerpt || truncate(strip_tags(blog_post.content), length: 120) %>
                </p>
                
                <div class="flex items-center justify-between text-sm text-gray-500 dark:text-gray-400">
                  <div class="flex items-center">
                    <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    </svg>
                    <%= pluralize(blog_post.views_count, 'view') %>
                  </div>
                  <div class="flex items-center">
                    <svg class="mr-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <%= pluralize(blog_post.reading_time, 'min') %> read
                  </div>
                </div>
              </div>
            </article>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Recent Projects Section -->
    <% recent_projects = @user.recent_projects(6) %>
    <div class="mb-8">
      <div class="sm:flex sm:items-center sm:justify-between mb-6">
        <h2 class="text-lg font-medium text-gray-900 dark:text-white">Recent Projects</h2>
        <% if recent_projects.any? %>
          <%= link_to "#", class: "mt-3 sm:mt-0 text-sm font-medium text-primary-600 hover:text-primary-500 dark:text-primary-400 dark:hover:text-primary-300" do %>
            View all projects
            <span aria-hidden="true"> →</span>
          <% end %>
        <% end %>
      </div>

      <% if recent_projects.any? %>
        <!-- Projects Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% recent_projects.each do |project| %>
            <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg hover:shadow-lg transition-shadow">
              <!-- Project Thumbnail -->
              <div class="aspect-w-16 aspect-h-9 bg-gray-200 dark:bg-gray-700">
                <% if project.thumbnail.attached? %>
                  <%= image_tag project.thumbnail, class: "w-full h-48 object-cover" %>
                <% else %>
                  <div class="flex items-center justify-center h-48">
                    <svg class="h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                    </svg>
                  </div>
                <% end %>
</div>

              <!-- Project Content -->
              <div class="p-6">
                <div class="flex items-center justify-between mb-2">
                  <h3 class="text-lg font-medium text-gray-900 dark:text-white truncate">
                    <%= project.title %>
                  </h3>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                    Published
                  </span>
                </div>
                <p class="text-sm text-gray-600 dark:text-gray-400 mb-4 line-clamp-2">
                  <%= truncate(project.description, length: 100) %>
                </p>
                <div class="flex items-center justify-between">
                  <div class="flex space-x-2">
                    <% if project.github_url.present? %>
                      <%= link_to project.github_url, target: "_blank", class: "text-gray-400 hover:text-gray-500 dark:hover:text-gray-300" do %>
                        <span class="sr-only">GitHub</span>
                        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd" />
                        </svg>
                      <% end %>
                    <% end %>
                    <% if project.demo_url.present? %>
                      <%= link_to project.demo_url, target: "_blank", class: "text-gray-400 hover:text-gray-500 dark:hover:text-gray-300" do %>
                        <span class="sr-only">Live Demo</span>
                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                      <% end %>
                    <% end %>
                  </div>
                  <time class="text-xs text-gray-500 dark:text-gray-400">
                    <%= time_ago_in_words(project.created_at) %> ago
                  </time>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <!-- Empty State -->
        <div class="text-center py-12">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No projects yet</h3>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
            Your published projects will appear here.
          </p>
        </div>
      <% end %>
    </div>

    <!-- Profile Completion Prompt -->
    <% if @user.profile_completion_percentage < 100 %>
      <div class="bg-blue-50 dark:bg-blue-900 border border-blue-200 dark:border-blue-700 rounded-md p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-blue-400" fill="currentColor" viewBox="0 0 20 20">
