<% content_for :title, "Edit Profile" %>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Edit Profile</h1>
      <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
        Update your profile information and social links to showcase your developer identity.
      </p>
    </div>

    <!-- Profile Form -->
    <div class="bg-white dark:bg-gray-800 shadow rounded-lg">
      <%= form_with model: @user, url: profile_path, method: :patch, local: true, 
                    class: "space-y-6 p-6", data: { controller: "image-preview" } do |form| %>
        
        <!-- Error Messages -->
        <% if @user.errors.any? %>
          <div id="alert-danger" class="flex items-center p-4 mb-4 text-danger-800 rounded-lg bg-danger-50 dark:bg-secondary-800 dark:text-danger-400" role="alert">
            <svg class="flex-shrink-0 w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z"/>
            </svg>
            <span class="sr-only">Error</span>
            <div class="ms-3 text-sm font-medium">
              <% @user.errors.full_messages.each do |message| %>
                <div class="error-message"><%= message %></div>
              <% end %>
            </div>
          </div>
        <% end %>
        
        <!-- Avatar Upload Section -->
        <div class="space-y-4">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white">Profile Picture</h3>
          
          <div class="flex items-center space-x-6">
            <!-- Avatar Preview -->
            <div class="relative">
              <%= image_tag "", 
                  data: { 
                    image_preview_target: "preview", 
                    current_image: (@user.avatar.attached? ? url_for(@user.avatar_medium) : "")
                  },
                  class: "w-24 h-24 rounded-full object-cover border-4 border-white shadow-lg #{'hidden' unless @user.avatar.attached?}" %>
              
              <!-- Placeholder when no avatar -->
              <div class="w-24 h-24 rounded-full bg-gray-300 dark:bg-gray-600 flex items-center justify-center placeholder #{'hidden' if @user.avatar.attached?}">
                <svg class="w-8 h-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
            </div>
            
            <!-- Upload Controls -->
            <div class="flex-1">
              <div class="flex flex-col sm:flex-row sm:items-center sm:space-x-4 space-y-2 sm:space-y-0">
                <%= form.file_field :avatar, 
                    data: { 
                      image_preview_target: "input", 
                      action: "change->image-preview#preview" 
                    },
                    accept: "image/*",
                    class: "text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-primary-50 file:text-primary-700 hover:file:bg-primary-100 dark:file:bg-primary-900 dark:file:text-primary-300" %>
                
                <p class="text-xs text-gray-500 dark:text-gray-400">
                  PNG, JPG up to 5MB. Recommended: 200x200px
                </p>
              </div>
              
              <% if @user.errors[:avatar].any? %>
                <div class="mt-1 text-sm text-red-600 dark:text-red-400">
                  <%= @user.errors[:avatar].first %>
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <hr class="border-gray-200 dark:border-gray-700">

        <!-- Basic Information -->
        <div class="space-y-4">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white">Basic Information</h3>
          
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
            <!-- Username -->
            <div>
              <%= form.label :username, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :username, 
                  class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm #{'border-red-300 focus:border-red-500 focus:ring-red-500' if @user.errors[:username].any?}" %>
              <% if @user.errors[:username].any? %>
                <div class="mt-1 text-sm text-red-600 dark:text-red-400">
                  <%= @user.errors[:username].first %>
                </div>
              <% else %>
                <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                  Your unique username for your profile URL
                </p>
              <% end %>
            </div>

            <!-- Full Name -->
            <div>
              <%= form.label :full_name, "Full Name", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :full_name, 
                  class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm #{'border-red-300 focus:border-red-500 focus:ring-red-500' if @user.errors[:full_name].any?}" %>
              <% if @user.errors[:full_name].any? %>
                <div class="mt-1 text-sm text-red-600 dark:text-red-400">
                  <%= @user.errors[:full_name].first %>
                </div>
              <% else %>
                <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                  Your professional display name
                </p>
              <% end %>
            </div>
          </div>

          <!-- Email (readonly) -->
          <div>
            <%= form.label :email, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
            <%= form.email_field :email, 
                readonly: true,
                disabled: true,
                class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-100 dark:text-gray-400 bg-gray-50 shadow-sm sm:text-sm cursor-not-allowed" %>
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
              Email is managed through <%= link_to "account settings", edit_user_registration_path, class: "text-primary-600 dark:text-primary-400 hover:underline" %>
            </p>
          </div>

          <!-- Bio -->
          <div>
            <%= form.label :bio, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
            <%= form.text_area :bio, 
                rows: 4,
                class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm #{'border-red-300 focus:border-red-500 focus:ring-red-500' if @user.errors[:bio].any?}" %>
            <% if @user.errors[:bio].any? %>
              <div class="mt-1 text-sm text-red-600 dark:text-red-400">
                <%= @user.errors[:bio].first %>
              </div>
            <% else %>
              <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                Tell visitors about yourself and your expertise (max 500 characters)
              </p>
            <% end %>
          </div>

          <!-- Job Title and Location -->
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
            <!-- Job Title -->
            <div>
              <%= form.label :job_title, "Job Title", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :job_title, 
                  class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm #{'border-red-300 focus:border-red-500 focus:ring-red-500' if @user.errors[:job_title].any?}" %>
              <% if @user.errors[:job_title].any? %>
                <div class="mt-1 text-sm text-red-600 dark:text-red-400">
                  <%= @user.errors[:job_title].first %>
                </div>
              <% else %>
                <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                  Your current job title or role
                </p>
              <% end %>
            </div>

            <!-- Location -->
            <div>
              <%= form.label :location, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <%= form.text_field :location, 
                  class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm #{'border-red-300 focus:border-red-500 focus:ring-red-500' if @user.errors[:location].any?}" %>
              <% if @user.errors[:location].any? %>
                <div class="mt-1 text-sm text-red-600 dark:text-red-400">
                  <%= @user.errors[:location].first %>
                </div>
              <% else %>
                <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                  Your city, state, or country
                </p>
              <% end %>
            </div>
          </div>

          <!-- Headline -->
          <div>
            <%= form.label :headline, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
            <%= form.text_field :headline, 
                class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm #{'border-red-300 focus:border-red-500 focus:ring-red-500' if @user.errors[:headline].any?}" %>
            <% if @user.errors[:headline].any? %>
              <div class="mt-1 text-sm text-red-600 dark:text-red-400">
                <%= @user.errors[:headline].first %>
              </div>
            <% else %>
              <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                A short, compelling description of what you do
              </p>
            <% end %>
          </div>

          <!-- Contact Email -->
          <div>
            <%= form.label :contact_email, "Contact Email", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
            <%= form.email_field :contact_email, 
                class: "mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm #{'border-red-300 focus:border-red-500 focus:ring-red-500' if @user.errors[:contact_email].any?}" %>
            <% if @user.errors[:contact_email].any? %>
              <div class="mt-1 text-sm text-red-600 dark:text-red-400">
                <%= @user.errors[:contact_email].first %>
              </div>
            <% else %>
              <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                Public contact email for professional inquiries
              </p>
            <% end %>
          </div>

          <!-- Skills -->
          <div data-controller="technology-tags" 
               data-technology-tags-technologies-value="<%= @user.skills.to_json %>">
            <%= form.label :skills_list, "Skills", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
            <div data-technology-tags-target="container" 
                 class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm focus-within:border-primary-500 focus-within:ring-primary-500 sm:text-sm <%= 'border-red-300 focus-within:border-red-500 focus-within:ring-red-500' if @user.errors[:skills].any? %>">
              <div data-technology-tags-target="tagsContainer" 
                   class="flex flex-wrap gap-2 p-3 min-h-[2.5rem]">
                <!-- Tags will be rendered here by JavaScript -->
              </div>
              <input type="text" 
                     data-technology-tags-target="input"
                     data-action="keydown->technology-tags#handleKeydown blur->technology-tags#handleBlur"
                     placeholder="Add a skill and press Enter..."
                     class="w-full px-3 pb-3 pt-1 border-0 bg-transparent text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:ring-0 sm:text-sm">
            </div>
            <%= form.hidden_field :skills_list, data: { technology_tags_target: "hiddenField" } %>
            <% if @user.errors[:skills].any? %>
              <div class="mt-1 text-sm text-red-600 dark:text-red-400">
                <%= @user.errors[:skills].first %>
              </div>
            <% else %>
              <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                Add your technical skills by typing and pressing Enter. Maximum 10 skills allowed.
              </p>
            <% end %>
          </div>
        </div>

        <hr class="border-gray-200 dark:border-gray-700">

        <!-- Social Links -->
        <div class="space-y-4">
          <h3 class="text-lg font-medium text-gray-900 dark:text-white">Social Links</h3>
          
          <div class="space-y-4">
            <!-- GitHub URL -->
            <div>
              <%= form.label :github_url, "GitHub Profile", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <div class="mt-1 flex rounded-md shadow-sm">
                <span class="inline-flex items-center px-3 rounded-l-md border border-r-0 border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-600 text-gray-500 dark:text-gray-400 text-sm">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd" />
                  </svg>
                </span>
                <%= form.url_field :github_url, 
                    placeholder: "https://github.com/yourusername",
                    class: "flex-1 min-w-0 block w-full px-3 py-2 rounded-none rounded-r-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white focus:border-primary-500 focus:ring-primary-500 sm:text-sm #{'border-red-300 focus:border-red-500 focus:ring-red-500' if @user.errors[:github_url].any?}" %>
              </div>
              <% if @user.errors[:github_url].any? %>
                <div class="mt-1 text-sm text-red-600 dark:text-red-400">
                  <%= @user.errors[:github_url].first %>
                </div>
              <% end %>
            </div>

            <!-- LinkedIn URL -->
            <div>
              <%= form.label :linkedin_url, "LinkedIn Profile", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <div class="mt-1 flex rounded-md shadow-sm">
                <span class="inline-flex items-center px-3 rounded-l-md border border-r-0 border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-600 text-gray-500 dark:text-gray-400 text-sm">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M6.29 18.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0020 3.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.073 4.073 0 01.8 7.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 010 16.407a11.616 11.616 0 006.29 1.84" />
                  </svg>
                </span>
                <%= form.url_field :linkedin_url, 
                    placeholder: "https://linkedin.com/in/yourusername",
                    class: "flex-1 min-w-0 block w-full px-3 py-2 rounded-none rounded-r-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white focus:border-primary-500 focus:ring-primary-500 sm:text-sm #{'border-red-300 focus:border-red-500 focus:ring-red-500' if @user.errors[:linkedin_url].any?}" %>
              </div>
              <% if @user.errors[:linkedin_url].any? %>
                <div class="mt-1 text-sm text-red-600 dark:text-red-400">
                  <%= @user.errors[:linkedin_url].first %>
                </div>
              <% end %>
            </div>

            <!-- Website URL -->
            <div>
              <%= form.label :website_url, "Personal Website", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
              <div class="mt-1 flex rounded-md shadow-sm">
                <span class="inline-flex items-center px-3 rounded-l-md border border-r-0 border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-600 text-gray-500 dark:text-gray-400 text-sm">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9v-9m0 9a9 9 0 009-9M3 12a9 9 0 019-9" />
                  </svg>
                </span>
                <%= form.url_field :website_url, 
                    placeholder: "https://yourwebsite.com",
                    class: "flex-1 min-w-0 block w-full px-3 py-2 rounded-none rounded-r-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white focus:border-primary-500 focus:ring-primary-500 sm:text-sm #{'border-red-300 focus:border-red-500 focus:ring-red-500' if @user.errors[:website_url].any?}" %>
              </div>
              <% if @user.errors[:website_url].any? %>
                <div class="mt-1 text-sm text-red-600 dark:text-red-400">
                  <%= @user.errors[:website_url].first %>
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <!-- Form Actions -->
        <div class="flex items-center justify-between pt-6 border-t border-gray-200 dark:border-gray-700">
          <div class="flex space-x-3">
            <%= form.submit "Save Changes", 
                class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500" %>
            
            <%= link_to "Cancel", profile_path, 
                class: "inline-flex justify-center py-2 px-4 border border-gray-300 dark:border-gray-600 shadow-sm text-sm font-medium rounded-md text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500" %>
          </div>
          
          <%= link_to profile_path, class: "text-sm text-primary-600 dark:text-primary-400 hover:text-primary-500" do %>
            Preview Profile →
          <% end %>
        </div>

      <% end %>
    </div>
  </div>
</div>
