<% page_title(@page_title) %>
<% meta_description("Activate your developer account on Devv.me") %>

<div class="min-h-screen bg-gradient-to-br from-cream-50 via-primary-50 to-secondary-50 dark:from-charcoal-900 dark:via-charcoal-800 dark:to-secondary-900 transition-all duration-300">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <!-- Header -->
    <div class="text-center mb-8">
      <h1 class="text-4xl lg:text-5xl font-bold text-charcoal-900 dark:text-cream-50 mb-4">
        🎉 Activate Your Account
      </h1>
      <p class="text-xl text-charcoal-600 dark:text-charcoal-400 max-w-2xl mx-auto">
        Create a password to activate your Devv.me account.
      </p>
    </div>

    <!-- Progress Indicator -->
    <div class="mb-8">
      <div class="flex items-center justify-center space-x-4">
        <div class="flex items-center">
          <div class="w-8 h-8 bg-primary-500 rounded-full flex items-center justify-center text-white font-bold text-sm">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <span class="ml-2 text-sm font-medium text-charcoal-700 dark:text-charcoal-300">Invitation</span>
        </div>
        <div class="w-12 h-1 bg-primary-500 rounded"></div>
        <div class="flex items-center">
          <div class="w-8 h-8 bg-amber-500 rounded-full flex items-center justify-center text-white font-bold text-sm">2</div>
          <span class="ml-2 text-sm font-medium text-amber-700 dark:text-amber-300">Activate</span>
        </div>
        <div class="w-12 h-1 bg-charcoal-200 dark:bg-charcoal-700 rounded"></div>
        <div class="flex items-center">
          <div class="w-8 h-8 bg-charcoal-300 dark:bg-charcoal-600 rounded-full flex items-center justify-center text-white font-bold text-sm">3</div>
          <span class="ml-2 text-sm font-medium text-charcoal-500 dark:text-charcoal-400">Profile</span>
        </div>
      </div>
    </div>

    <!-- Account Setup Form -->
    <%= form_with model: @user, url: activate_invitation_account_path(@user.invitation_token), method: :post, local: true, class: "space-y-6" do |form| %>
      <div class="bg-white dark:bg-charcoal-800 rounded-2xl shadow-xl border border-primary-200 dark:border-charcoal-700 overflow-hidden">
        <div class="bg-gradient-to-r from-primary-500 to-secondary-500 px-6 py-4">
          <h2 class="text-xl font-bold text-white flex items-center">
            <svg class="w-6 h-6 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v-2l-4.257-4.257A6 6 0 0117 9z" />
            </svg>
            Create Your Password
          </h2>
        </div>
        
        <div class="p-6 space-y-6">
          <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-700 rounded-lg p-4">
            <div class="flex items-start">
              <svg class="w-6 h-6 text-blue-500 mr-3 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <p class="text-blue-800 dark:text-blue-300 text-sm">
                  <strong>Email:</strong> <%= @user.email %><br>
                  Create a secure password to activate your account. After this step, you'll be able to complete your profile.
                </p>
              </div>
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <%= form.label :password, "Password", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
              <%= form.password_field :password, 
                  class: "w-full px-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                  placeholder: "Enter a secure password",
                  minlength: 6,
                  required: true,
                  autofocus: true %>
              <p class="mt-1 text-xs text-charcoal-500 dark:text-charcoal-400">Minimum 6 characters</p>
            </div>
            
            <div>
              <%= form.label :password_confirmation, "Confirm Password", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
              <%= form.password_field :password_confirmation, 
                  class: "w-full px-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                  placeholder: "Confirm your password",
                  required: true %>
            </div>
          </div>
        </div>
      </div>
      
      <div class="text-center space-y-4">
        <%= form.submit "Create Account & Continue", 
            class: "w-full md:w-auto inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-primary-500 to-secondary-500 hover:from-primary-600 hover:to-secondary-600 text-white font-bold text-lg rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1" %>
        
        <div>
          <%= link_to invitation_path(@user.invitation_token), 
              class: "inline-flex items-center px-6 py-3 bg-charcoal-200 hover:bg-charcoal-300 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-charcoal-800 dark:text-charcoal-200 font-semibold rounded-lg transition-colors" do %>
            <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Preview
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
