<% page_title(@page_title) %>
<% meta_description("Complete your developer profile setup on Devv.me") %>

<div class="min-h-screen bg-gradient-to-br from-cream-50 via-primary-50 to-secondary-50 dark:from-charcoal-900 dark:via-charcoal-800 dark:to-secondary-900 transition-all duration-300">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <!-- Header -->
    <div class="text-center mb-8">
      <h1 class="text-4xl lg:text-5xl font-bold text-charcoal-900 dark:text-cream-50 mb-4">
        🎉 Complete Your Profile
      </h1>
      <p class="text-xl text-charcoal-600 dark:text-charcoal-400 max-w-2xl mx-auto">
        You're almost there! Set up your account and review your profile information to get started.
      </p>
    </div>

    <!-- Progress Indicator -->
    <div class="mb-8">
      <div class="flex items-center justify-center space-x-4">
        <div class="flex items-center">
          <div class="w-8 h-8 bg-primary-500 rounded-full flex items-center justify-center text-white font-bold text-sm">1</div>
          <span class="ml-2 text-sm font-medium text-charcoal-700 dark:text-charcoal-300">Invitation</span>
        </div>
        <div class="w-12 h-1 bg-primary-500 rounded"></div>
        <div class="flex items-center">
          <div class="w-8 h-8 bg-amber-500 rounded-full flex items-center justify-center text-white font-bold text-sm">2</div>
          <span class="ml-2 text-sm font-medium text-amber-700 dark:text-amber-300">Setup</span>
        </div>
        <div class="w-12 h-1 bg-charcoal-200 dark:bg-charcoal-700 rounded"></div>
        <div class="flex items-center">
          <div class="w-8 h-8 bg-charcoal-300 dark:bg-charcoal-600 rounded-full flex items-center justify-center text-white font-bold text-sm">3</div>
          <span class="ml-2 text-sm font-medium text-charcoal-500 dark:text-charcoal-400">Active</span>
        </div>
      </div>
    </div>

    <!-- Alternative: Sign in to existing account (for users not signed in) -->
    <% unless user_signed_in? %>
      <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-700 rounded-2xl p-6 mb-8">
        <h3 class="text-lg font-semibold text-blue-900 dark:text-blue-200 mb-2">Already have an account?</h3>
        <p class="text-blue-800 dark:text-blue-300 text-sm mb-4">
          If you already have a Devv.me account with this email address, sign in instead.
        </p>
        
        <%= form_with url: update_invitation_path(@user.invitation_token), method: :patch, local: true, class: "space-y-4" do |signin_form| %>
          <div class="grid md:grid-cols-2 gap-4">
            <%= signin_form.email_field "user[email]", value: @user.email, 
                class: "px-4 py-3 border border-blue-300 dark:border-blue-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-blue-900/30 dark:text-blue-100",
                placeholder: "Your email" %>
            <%= signin_form.password_field "user[password]", 
                class: "px-4 py-3 border border-blue-300 dark:border-blue-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-blue-900/30 dark:text-blue-100",
                placeholder: "Your password" %>
          </div>
          
          <%= signin_form.hidden_field :sign_in_existing, value: "true" %>
          
          <div>
            <%= signin_form.submit "Sign In to Existing Account", 
                class: "inline-flex items-center px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors" %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%= form_with model: @user, url: update_invitation_path(@user.invitation_token), method: :patch, local: true, class: "space-y-8" do |form| %>
      
      <!-- Account Setup Section -->
      <div class="bg-white dark:bg-charcoal-800 rounded-2xl shadow-xl border border-primary-200 dark:border-charcoal-700 overflow-hidden">
        <div class="bg-gradient-to-r from-primary-500 to-secondary-500 px-6 py-4">
          <h2 class="text-xl font-bold text-white flex items-center">
            <svg class="w-6 h-6 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v-2l-4.257-4.257A6 6 0 0117 9z" />
            </svg>
            Account Setup
          </h2>
        </div>
        
        <div class="p-6">
          <% unless user_signed_in? %>
            <!-- Password Setup for New Users -->
            <div class="mb-6">
              <h3 class="text-lg font-semibold text-charcoal-900 dark:text-cream-50 mb-4">Create Your Password</h3>
              
              <div class="grid md:grid-cols-2 gap-4">
                <div>
                  <%= form.label :password, "Password", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
                  <%= form.password_field :password, 
                      class: "w-full px-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                      placeholder: "Enter a secure password",
                      minlength: 6,
                      required: true %>
                  <p class="mt-1 text-xs text-charcoal-500 dark:text-charcoal-400">Minimum 6 characters</p>
                </div>
                
                <div>
                  <%= form.label :password_confirmation, "Confirm Password", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
                  <%= form.password_field :password_confirmation, 
                      class: "w-full px-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                      placeholder: "Confirm your password",
                      required: true %>
                </div>
              </div>
            </div>
          <% else %>
            <!-- User is already signed in -->
            <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-700 rounded-lg p-4">
              <div class="flex items-center">
                <svg class="w-6 h-6 text-green-500 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div>
                  <h4 class="font-semibold text-green-900 dark:text-green-200">You're signed in!</h4>
                  <p class="text-green-800 dark:text-green-300 text-sm">
                    Signed in as <%= current_user.email %>. Review your profile below and activate it.
                  </p>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Profile Information Section -->
      <div class="bg-white dark:bg-charcoal-800 rounded-2xl shadow-xl border border-primary-200 dark:border-charcoal-700 overflow-hidden">
        <div class="bg-gradient-to-r from-secondary-500 to-accent-500 px-6 py-4">
          <h2 class="text-xl font-bold text-white flex items-center">
            <svg class="w-6 h-6 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            Profile Information
          </h2>
        </div>
        
        <div class="p-6 space-y-6">
          <!-- Basic Information -->
          <div>
            <h3 class="text-lg font-semibold text-charcoal-900 dark:text-cream-50 mb-4">Basic Information</h3>
            
            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <%= form.label :full_name, "Full Name", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
                <%= form.text_field :full_name, 
                    class: "w-full px-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-secondary-500 focus:border-secondary-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                    placeholder: "Your full name" %>
              </div>
              
              <div>
                <%= form.label :job_title, "Job Title", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
                <%= form.text_field :job_title, 
                    class: "w-full px-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-secondary-500 focus:border-secondary-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                    placeholder: "e.g., Senior Developer, Product Manager" %>
              </div>
              
              <div>
                <%= form.label :location, "Location", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
                <%= form.text_field :location, 
                    class: "w-full px-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-secondary-500 focus:border-secondary-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                    placeholder: "City, State/Country" %>
              </div>
              
              <div>
                <%= form.label :contact_email, "Contact Email", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
                <%= form.email_field :contact_email, 
                    class: "w-full px-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-secondary-500 focus:border-secondary-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                    placeholder: "Public contact email (optional)" %>
              </div>
            </div>
          </div>
          
          <!-- Professional Information -->
          <div>
            <h3 class="text-lg font-semibold text-charcoal-900 dark:text-cream-50 mb-4">Professional Information</h3>
            
            <div class="space-y-4">
              <div>
                <%= form.label :headline, "Professional Headline", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
                <%= form.text_field :headline, 
                    class: "w-full px-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-secondary-500 focus:border-secondary-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                    placeholder: "A brief professional headline",
                    maxlength: 100 %>
                <p class="mt-1 text-xs text-charcoal-500 dark:text-charcoal-400">A short, impactful statement about your professional focus</p>
              </div>
              
              <div>
                <%= form.label :bio, "Bio", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
                <%= form.text_area :bio, 
                    class: "w-full px-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-secondary-500 focus:border-secondary-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                    placeholder: "Tell us about yourself, your experience, and what you're passionate about...",
                    rows: 4 %>
              </div>
              
              <div>
                <%= form.label :skills, "Skills", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
                <div data-controller="skills-input" data-skills-input-initial-value="<%= @user.skills&.join(',') %>">
                  <input type="text" 
                         data-skills-input-target="input"
                         class="w-full px-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-secondary-500 focus:border-secondary-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors"
                         placeholder="Type skills and press Enter (e.g., JavaScript, React, Node.js)">
                  
                  <div data-skills-input-target="skillsList" class="mt-2 flex flex-wrap gap-2"></div>
                  
                  <!-- Hidden field to store skills -->
                  <%= form.hidden_field :skills, value: @user.skills&.join(','), data: { skills_input_target: "hiddenField" } %>
                </div>
                <p class="mt-1 text-xs text-charcoal-500 dark:text-charcoal-400">Add your technical skills, programming languages, frameworks, etc.</p>
              </div>
            </div>
          </div>
          
          <!-- Social Links -->
          <div>
            <h3 class="text-lg font-semibold text-charcoal-900 dark:text-cream-50 mb-4">Social Links</h3>
            
            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <%= form.label :github_url, "GitHub Profile", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
                <div class="relative">
                  <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="w-5 h-5 text-charcoal-400" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                    </svg>
                  </div>
                  <%= form.url_field :github_url, 
                      class: "w-full pl-10 pr-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-secondary-500 focus:border-secondary-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                      placeholder: "https://github.com/username" %>
                </div>
              </div>
              
              <div>
                <%= form.label :linkedin_url, "LinkedIn Profile", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
                <div class="relative">
                  <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="w-5 h-5 text-charcoal-400" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                    </svg>
                  </div>
                  <%= form.url_field :linkedin_url, 
                      class: "w-full pl-10 pr-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-secondary-500 focus:border-secondary-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                      placeholder: "https://linkedin.com/in/username" %>
                </div>
              </div>
              
              <div>
                <%= form.label :website_url, "Personal Website", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
                <%= form.url_field :website_url, 
                    class: "w-full px-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-secondary-500 focus:border-secondary-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                    placeholder: "https://yourwebsite.com" %>
              </div>
              
              <div>
                <%= form.label :twitter_url, "Twitter/X Profile", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
                <%= form.text_field :twitter_url, 
                    class: "w-full px-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-secondary-500 focus:border-secondary-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                    placeholder: "@username or https://twitter.com/username" %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="text-center space-y-4">
        <%= form.submit "🚀 Activate My Profile", 
            class: "inline-flex items-center px-8 py-4 bg-gradient-to-r from-primary-500 to-secondary-500 hover:from-primary-600 hover:to-secondary-600 text-white font-bold text-lg rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1" %>
        
        <div>
          <%= link_to invitation_path(@user.invitation_token), 
              class: "inline-flex items-center px-6 py-3 bg-charcoal-200 hover:bg-charcoal-300 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-charcoal-800 dark:text-charcoal-200 font-semibold rounded-lg transition-colors" do %>
            <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Preview
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Skills Input JavaScript -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  const skillsController = {
    connect() {
      this.skills = this.data.get('initial-value') ? this.data.get('initial-value').split(',').filter(s => s.trim()) : [];
      this.renderSkills();
      this.setupInput();
    },
    
    setupInput() {
      this.inputTarget.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ',') {
          e.preventDefault();
          this.addSkill();
        }
      });
    },
    
    addSkill() {
      const skill = this.inputTarget.value.trim();
      if (skill && !this.skills.includes(skill)) {
        this.skills.push(skill);
        this.inputTarget.value = '';
        this.renderSkills();
        this.updateHiddenField();
      }
    },
    
    removeSkill(skill) {
      this.skills = this.skills.filter(s => s !== skill);
      this.renderSkills();
      this.updateHiddenField();
    },
    
    renderSkills() {
      this.skillsListTarget.innerHTML = this.skills.map(skill => 
        `<span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-primary-100 text-primary-800 dark:bg-primary-900/30 dark:text-primary-300">
          ${skill}
          <button type="button" onclick="skillsController.removeSkill('${skill}')" class="ml-2 text-primary-600 hover:text-primary-800">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </span>`
      ).join('');
    },
    
    updateHiddenField() {
      this.hiddenFieldTarget.value = this.skills.join(',');
    }
  };
  
  // Initialize skills controller
  const skillsElement = document.querySelector('[data-controller="skills-input"]');
  if (skillsElement) {
    skillsController.inputTarget = skillsElement.querySelector('[data-skills-input-target="input"]');
    skillsController.skillsListTarget = skillsElement.querySelector('[data-skills-input-target="skillsList"]');
    skillsController.hiddenFieldTarget = skillsElement.querySelector('[data-skills-input-target="hiddenField"]');
    skillsController.data = {
      get: (key) => skillsElement.dataset[key.replace(/-([a-z])/g, (g) => g[1].toUpperCase())]
    };
    window.skillsController = skillsController;
    skillsController.connect();
  }
});
</script>
