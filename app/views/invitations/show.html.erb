<% page_title(@page_title) %>
<% meta_description("Claim your developer profile on Devv.me - #{@user.display_name}") %>

<div class="min-h-screen bg-gradient-to-br from-cream-50 via-primary-50 to-secondary-50 dark:from-charcoal-900 dark:via-charcoal-800 dark:to-secondary-900 transition-all duration-300">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <!-- Header -->
    <div class="text-center mb-8">
      <h1 class="text-4xl lg:text-5xl font-bold text-charcoal-900 dark:text-cream-50 mb-4">
        🚀 You've Been Invited!
      </h1>
      <p class="text-xl text-charcoal-600 dark:text-charcoal-400 max-w-2xl mx-auto">
        A professional developer profile has been created for you on Devv.me. 
        Review your profile and claim it to get started.
      </p>
    </div>

    <!-- Invitation Status Card -->
    <div class="bg-white dark:bg-charcoal-800 rounded-2xl shadow-xl mb-8 border border-primary-200 dark:border-charcoal-700 overflow-hidden">
      <!-- Status Header -->
      <div class="bg-gradient-to-r from-amber-500 to-orange-500 px-6 py-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center">
            <div class="w-3 h-3 bg-white rounded-full animate-pulse mr-3"></div>
            <span class="text-white font-semibold">Profile Ready to Claim</span>
          </div>
          <div class="text-white text-sm">
            <% if @invitation_data[:days_remaining] > 0 %>
              Expires in <%= pluralize(@invitation_data[:days_remaining], 'day') %>
            <% else %>
              Expires today
            <% end %>
          </div>
        </div>
      </div>

      <!-- Profile Preview -->
      <div class="p-6">
        <div class="flex flex-col lg:flex-row lg:items-start lg:space-x-8">
          <!-- Avatar and Basic Info -->
          <div class="flex-shrink-0 mb-6 lg:mb-0">
            <div class="relative bg-charcoal-900 dark:bg-charcoal-950 rounded-lg p-3 border border-charcoal-600 shadow-lg">
              <!-- Terminal header -->
              <div class="flex items-center justify-between mb-3 px-2">
                <div class="flex space-x-1.5">
                  <div class="w-3 h-3 bg-danger-500 rounded-full"></div>
                  <div class="w-3 h-3 bg-warning-500 rounded-full"></div>
                  <div class="w-3 h-3 bg-primary-500 rounded-full"></div>
                </div>
                <div class="text-xs font-mono text-charcoal-400">~/developer</div>
              </div>
              
              <!-- Avatar -->
              <div class="relative group">
                <% if @user.avatar.attached? %>
                  <%= image_tag @user.avatar_medium, 
                        class: "w-24 h-24 rounded-xl object-cover border-2 border-amber-400 shadow-lg",
                        alt: "#{@user.display_name}'s avatar" %>
                <% else %>
                  <div class="w-24 h-24 rounded-xl bg-gradient-to-br from-amber-500 to-orange-600 flex items-center justify-center border-2 border-amber-400 shadow-lg">
                    <svg class="w-12 h-12 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                  </div>
                <% end %>
                
                <!-- Unclaimed indicator -->
                <div class="absolute -bottom-1 -right-1 w-6 h-6 bg-amber-500 rounded-full border-2 border-charcoal-900 flex items-center justify-center">
                  <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                  </svg>
                </div>
              </div>
              
              <!-- Terminal command -->
              <div class="mt-3 px-2">
                <div class="text-xs font-mono text-primary-400">
                  <span class="text-charcoal-500">$</span> whoami
                </div>
                <div class="text-xs font-mono text-cream-200 mt-1">
                  <%= @user.username %>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Profile Details -->
          <div class="flex-1 min-w-0">
            <h2 class="text-3xl font-bold text-charcoal-900 dark:text-cream-50 mb-2">
              <%= @user.display_name %>
            </h2>
            <p class="text-lg text-charcoal-600 dark:text-charcoal-400 mb-4 font-mono">
              @<%= @user.username %>
            </p>
            
            <!-- Profile Completion -->
            <div class="mb-6">
              <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-medium text-charcoal-700 dark:text-charcoal-300">Profile Completion</span>
                <span class="text-sm font-bold text-primary-600 dark:text-primary-400"><%= @invitation_data[:profile_completion] %>%</span>
              </div>
              <div class="w-full bg-charcoal-200 dark:bg-charcoal-700 rounded-full h-2">
                <div class="bg-gradient-to-r from-primary-500 to-secondary-500 h-2 rounded-full transition-all duration-300" 
                     style="width: <%= @invitation_data[:profile_completion] %>%"></div>
              </div>
            </div>
            
            <!-- Profile Info -->
            <div class="space-y-3">
              <% if @user.job_title.present? %>
                <div class="flex items-center text-charcoal-600 dark:text-charcoal-400">
                  <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2-2v2m8 0V6a2 2 0 012 2v6a2 2 0 01-2 2H8a2 2 0 01-2-2V8a2 2 0 012-2h8zM16 10h.01M8 10h.01" />
                  </svg>
                  <%= @user.job_title %>
                </div>
              <% end %>
              
              <% if @user.location.present? %>
                <div class="flex items-center text-charcoal-600 dark:text-charcoal-400">
                  <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <%= @user.location %>
                </div>
              <% end %>
              
              <div class="flex items-center text-charcoal-600 dark:text-charcoal-400">
                <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <%= @user.email %>
              </div>
            </div>
            
            <!-- Skills Preview -->
            <% if @user.skills.present? && @user.skills.any? %>
              <div class="mt-6">
                <h3 class="text-sm font-semibold text-charcoal-700 dark:text-charcoal-300 mb-2">Skills</h3>
                <div class="flex flex-wrap gap-2">
                  <% @user.skills.first(6).each do |skill| %>
                    <span class="inline-flex items-center px-2 py-1 rounded text-xs font-mono font-medium bg-primary-100 text-primary-700 dark:bg-primary-900/30 dark:text-primary-300">
                      <%= skill %>
                    </span>
                  <% end %>
                  <% if @user.skills.length > 6 %>
                    <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium text-charcoal-500 dark:text-charcoal-400">
                      +<%= @user.skills.length - 6 %> more
                    </span>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="text-center space-y-4">
      <%= link_to verify_invitation_path(@user.invitation_token), 
          class: "inline-flex items-center px-8 py-4 bg-gradient-to-r from-amber-500 to-orange-500 hover:from-amber-600 hover:to-orange-600 text-white font-bold text-lg rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1" do %>
        <svg class="w-6 h-6 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v-2l-4.257-4.257A6 6 0 0117 9z" />
        </svg>
        Verify & Claim Your Profile
      <% end %>
      
      <div class="text-center">
        <%= link_to @invitation_data[:profile_url], 
            class: "inline-flex items-center px-6 py-3 bg-charcoal-800 hover:bg-charcoal-900 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-cream-100 font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5",
            target: "_blank" do %>
          <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
          Preview Profile
        <% end %>
      </div>
    </div>

    <!-- Information Section -->
    <div class="mt-12 bg-white dark:bg-charcoal-800 rounded-2xl shadow-lg p-6 border border-primary-200 dark:border-charcoal-700">
      <h3 class="text-xl font-bold text-charcoal-900 dark:text-cream-50 mb-4">What happens when you claim your profile?</h3>
      
      <div class="grid md:grid-cols-2 gap-6">
        <div class="space-y-4">
          <div class="flex items-start">
            <div class="w-8 h-8 bg-primary-100 dark:bg-primary-900/30 rounded-full flex items-center justify-center mr-3 mt-1">
              <svg class="w-4 h-4 text-primary-600 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-charcoal-900 dark:text-cream-50">Set Your Password</h4>
              <p class="text-charcoal-600 dark:text-charcoal-400 text-sm">Create a secure password to access your account</p>
            </div>
          </div>
          
          <div class="flex items-start">
            <div class="w-8 h-8 bg-secondary-100 dark:bg-secondary-900/30 rounded-full flex items-center justify-center mr-3 mt-1">
              <svg class="w-4 h-4 text-secondary-600 dark:text-secondary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-charcoal-900 dark:text-cream-50">Complete Your Profile</h4>
              <p class="text-charcoal-600 dark:text-charcoal-400 text-sm">Review and update your information</p>
            </div>
          </div>
          
          <div class="flex items-start">
            <div class="w-8 h-8 bg-accent-100 dark:bg-accent-900/30 rounded-full flex items-center justify-center mr-3 mt-1">
              <svg class="w-4 h-4 text-accent-600 dark:text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-charcoal-900 dark:text-cream-50">Go Live</h4>
              <p class="text-charcoal-600 dark:text-charcoal-400 text-sm">Your profile becomes fully active and discoverable</p>
            </div>
          </div>
        </div>
        
        <div class="space-y-4">
          <div class="flex items-start">
            <div class="w-8 h-8 bg-warning-100 dark:bg-warning-900/30 rounded-full flex items-center justify-center mr-3 mt-1">
              <svg class="w-4 h-4 text-warning-600 dark:text-warning-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-charcoal-900 dark:text-cream-50">Add Projects</h4>
              <p class="text-charcoal-600 dark:text-charcoal-400 text-sm">Showcase your work with rich project descriptions</p>
            </div>
          </div>
          
          <div class="flex items-start">
            <div class="w-8 h-8 bg-pink-100 dark:bg-pink-900/30 rounded-full flex items-center justify-center mr-3 mt-1">
              <svg class="w-4 h-4 text-pink-600 dark:text-pink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-charcoal-900 dark:text-cream-50">Write Blog Posts</h4>
              <p class="text-charcoal-600 dark:text-charcoal-400 text-sm">Share your knowledge and experiences</p>
            </div>
          </div>
          
          <div class="flex items-start">
            <div class="w-8 h-8 bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center mr-3 mt-1">
              <svg class="w-4 h-4 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
            <div>
              <h4 class="font-semibold text-charcoal-900 dark:text-cream-50">Get Discovered</h4>
              <p class="text-charcoal-600 dark:text-charcoal-400 text-sm">Connect with employers and collaborators</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Expiration Warning -->
    <% if @invitation_data[:days_remaining] <= 7 %>
      <div class="mt-8 bg-gradient-to-r from-red-50 to-orange-50 dark:from-red-900/20 dark:to-orange-900/20 border-2 border-red-200 dark:border-red-700 rounded-2xl p-6">
        <div class="flex items-center">
          <svg class="w-8 h-8 text-red-500 mr-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div>
            <h3 class="text-lg font-bold text-red-800 dark:text-red-200">
              ⏰ Invitation expires in <%= pluralize(@invitation_data[:days_remaining], 'day') %>!
            </h3>
            <p class="text-red-700 dark:text-red-300">
              Don't miss out! Claim your profile before <%= @invitation_data[:expires_at].strftime("%B %d, %Y") %> to keep access.
            </p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
