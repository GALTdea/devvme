<% page_title(@page_title) %>
<% meta_description("Complete your developer profile on Devv.me") %>

<div class="min-h-screen bg-gradient-to-br from-cream-50 via-primary-50 to-secondary-50 dark:from-charcoal-900 dark:via-charcoal-800 dark:to-secondary-900 transition-all duration-300">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <!-- Header -->
    <div class="text-center mb-8">
      <h1 class="text-4xl lg:text-5xl font-bold text-charcoal-900 dark:text-cream-50 mb-4">
        ✨ Complete Your Profile
      </h1>
      <p class="text-xl text-charcoal-600 dark:text-charcoal-400 max-w-2xl mx-auto">
        You're almost done! Add your information to showcase your professional identity.
      </p>
    </div>

    <!-- Progress Indicator -->
    <div class="mb-8">
      <div class="flex items-center justify-center space-x-4">
        <div class="flex items-center">
          <div class="w-8 h-8 bg-primary-500 rounded-full flex items-center justify-center text-white font-bold text-sm">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <span class="ml-2 text-sm font-medium text-charcoal-700 dark:text-charcoal-300">Invitation</span>
        </div>
        <div class="w-12 h-1 bg-primary-500 rounded"></div>
        <div class="flex items-center">
          <div class="w-8 h-8 bg-primary-500 rounded-full flex items-center justify-center text-white font-bold text-sm">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <span class="ml-2 text-sm font-medium text-charcoal-700 dark:text-charcoal-300">Activated</span>
        </div>
        <div class="w-12 h-1 bg-amber-500 rounded"></div>
        <div class="flex items-center">
          <div class="w-8 h-8 bg-amber-500 rounded-full flex items-center justify-center text-white font-bold text-sm">3</div>
          <span class="ml-2 text-sm font-medium text-amber-700 dark:text-amber-300">Profile</span>
        </div>
      </div>
    </div>

    <!-- Success Message -->
    <div class="mb-8">
      <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-700 rounded-2xl p-6">
        <div class="flex items-center">
          <svg class="w-8 h-8 text-green-500 mr-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div>
            <h3 class="text-lg font-semibold text-green-900 dark:text-green-200">Account Activated!</h3>
            <p class="text-green-800 dark:text-green-300 text-sm">
              You're now signed in as <strong><%= current_user.email %></strong>. Complete your profile below to get started on Devv.me.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Profile Completion Form -->
    <%= form_with model: @user, url: update_invitation_path(@user.invitation_token), method: :patch, local: true, class: "space-y-8" do |form| %>
      
      <!-- Basic Information Section -->
      <div class="bg-white dark:bg-charcoal-800 rounded-2xl shadow-xl border border-amber-200 dark:border-amber-700 overflow-hidden">
        <div class="bg-gradient-to-r from-amber-500 to-amber-600 px-6 py-4">
          <h2 class="text-xl font-bold text-white flex items-center">
            <svg class="w-6 h-6 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            Basic Information
          </h2>
        </div>
        
        <div class="p-6">
          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <%= form.label :full_name, "Full Name", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
              <%= form.text_field :full_name, 
                  class: "w-full px-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-amber-500 focus:border-amber-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                  placeholder: "Your full name",
                  autofocus: true %>
            </div>
            
            <div>
              <%= form.label :job_title, "Job Title", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
              <%= form.text_field :job_title, 
                  class: "w-full px-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-amber-500 focus:border-amber-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                  placeholder: "e.g., Senior Developer, Product Manager" %>
            </div>
            
            <div>
              <%= form.label :location, "Location", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
              <%= form.text_field :location, 
                  class: "w-full px-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-amber-500 focus:border-amber-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                  placeholder: "City, State/Country" %>
            </div>
            
            <div>
              <%= form.label :contact_email, "Contact Email", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
              <%= form.email_field :contact_email, 
                  class: "w-full px-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-amber-500 focus:border-amber-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                  placeholder: "Public contact email (optional)" %>
            </div>
          </div>
        </div>
      </div>

      <!-- Professional Information Section -->
      <div class="bg-white dark:bg-charcoal-800 rounded-2xl shadow-xl border border-secondary-200 dark:border-charcoal-700 overflow-hidden">
        <div class="bg-gradient-to-r from-secondary-500 to-accent-500 px-6 py-4">
          <h2 class="text-xl font-bold text-white flex items-center">
            <svg class="w-6 h-6 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Professional Information
          </h2>
        </div>
        
        <div class="p-6 space-y-4">
          <div>
            <%= form.label :headline, "Professional Headline", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
            <%= form.text_field :headline, 
                class: "w-full px-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-secondary-500 focus:border-secondary-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                placeholder: "A brief professional headline",
                maxlength: 100 %>
            <p class="mt-1 text-xs text-charcoal-500 dark:text-charcoal-400">A short, impactful statement about your professional focus</p>
          </div>
          
          <div>
            <%= form.label :bio, "Bio", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
            <%= form.text_area :bio, 
                class: "w-full px-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-secondary-500 focus:border-secondary-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                placeholder: "Tell us about yourself, your experience, and what you're passionate about...",
                rows: 4 %>
          </div>
          
          <div>
            <%= form.label :skills_list, "Skills", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
            <div data-controller="skills-input" data-skills-input-initial-value="<%= @user.skills&.join(',') %>">
              <input type="text" 
                     data-skills-input-target="input"
                     class="w-full px-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-secondary-500 focus:border-secondary-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors"
                     placeholder="Type skills and press Enter (e.g., JavaScript, React, Node.js)">
              
              <div data-skills-input-target="skillsList" class="mt-2 flex flex-wrap gap-2"></div>
              
              <!-- Hidden field to store skills as comma-separated string -->
              <%= form.hidden_field :skills_list, value: @user.skills&.join(','), data: { skills_input_target: "hiddenField" } %>
            </div>
            <p class="mt-1 text-xs text-charcoal-500 dark:text-charcoal-400">Add your technical skills, programming languages, frameworks, etc.</p>
          </div>
        </div>
      </div>

      <!-- Social Links Section -->
      <div class="bg-white dark:bg-charcoal-800 rounded-2xl shadow-xl border border-primary-200 dark:border-charcoal-700 overflow-hidden">
        <div class="bg-gradient-to-r from-primary-500 to-secondary-500 px-6 py-4">
          <h2 class="text-xl font-bold text-white flex items-center">
            <svg class="w-6 h-6 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
            Social Links
          </h2>
        </div>
        
        <div class="p-6">
          <div class="grid md:grid-cols-2 gap-4">
            <div>
              <%= form.label :github_url, "GitHub Profile", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
              <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                  <svg class="w-5 h-5 text-charcoal-400" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                </div>
                <%= form.url_field :github_url, 
                    class: "w-full pl-10 pr-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                    placeholder: "https://github.com/username" %>
              </div>
            </div>
            
            <div>
              <%= form.label :linkedin_url, "LinkedIn Profile", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
              <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                  <svg class="w-5 h-5 text-charcoal-400" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </div>
                <%= form.url_field :linkedin_url, 
                    class: "w-full pl-10 pr-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                    placeholder: "https://linkedin.com/in/username" %>
              </div>
            </div>
            
            <div>
              <%= form.label :website_url, "Personal Website", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
              <%= form.url_field :website_url, 
                  class: "w-full px-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                  placeholder: "https://yourwebsite.com" %>
            </div>
            
            <div>
              <%= form.label :twitter_url, "Twitter/X Profile", class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-2" %>
              <%= form.text_field :twitter_url, 
                  class: "w-full px-4 py-3 border border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                  placeholder: "@username or https://twitter.com/username" %>
            </div>
          </div>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="text-center space-y-4">
        <%= form.submit "🚀 Complete My Profile", 
            class: "inline-flex items-center px-8 py-4 bg-gradient-to-r from-primary-500 to-secondary-500 hover:from-primary-600 hover:to-secondary-600 text-white font-bold text-lg rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1" %>
        
        <div>
          <%= link_to dashboard_path, 
              class: "inline-flex items-center px-6 py-3 bg-charcoal-200 hover:bg-charcoal-300 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-charcoal-800 dark:text-charcoal-200 font-semibold rounded-lg transition-colors" do %>
            <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
            Skip for Now - Go to Dashboard
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Skills Input JavaScript -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  const skillsController = {
    connect() {
      this.skills = this.data.get('initial-value') ? this.data.get('initial-value').split(',').filter(s => s.trim()) : [];
      this.renderSkills();
      this.setupInput();
    },
    
    setupInput() {
      this.inputTarget.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ',') {
          e.preventDefault();
          this.addSkill();
        }
      });
    },
    
    addSkill() {
      const skill = this.inputTarget.value.trim();
      if (skill && !this.skills.includes(skill)) {
        this.skills.push(skill);
        this.inputTarget.value = '';
        this.renderSkills();
        this.updateHiddenField();
      }
    },
    
    removeSkill(skill) {
      this.skills = this.skills.filter(s => s !== skill);
      this.renderSkills();
      this.updateHiddenField();
    },
    
    renderSkills() {
      this.skillsListTarget.innerHTML = this.skills.map(skill => 
        `<span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-secondary-100 text-secondary-800 dark:bg-secondary-900/30 dark:text-secondary-300">
          ${skill}
          <button type="button" onclick="skillsController.removeSkill('${skill}')" class="ml-2 text-secondary-600 hover:text-secondary-800">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </span>`
      ).join('');
    },
    
    updateHiddenField() {
      this.hiddenFieldTarget.value = this.skills.join(',');
    }
  };
  
  // Initialize skills controller
  const skillsElement = document.querySelector('[data-controller="skills-input"]');
  if (skillsElement) {
    skillsController.inputTarget = skillsElement.querySelector('[data-skills-input-target="input"]');
    skillsController.skillsListTarget = skillsElement.querySelector('[data-skills-input-target="skillsList"]');
    skillsController.hiddenFieldTarget = skillsElement.querySelector('[data-skills-input-target="hiddenField"]');
    skillsController.data = {
      get: (key) => skillsElement.dataset[key.replace(/-([a-z])/g, (g) => g[1].toUpperCase())]
    };
    window.skillsController = skillsController;
    skillsController.connect();
  }
});
</script>

