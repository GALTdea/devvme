<% page_title(@page_title) %>
<% meta_description("Verify your access to claim your developer profile on Devv.me") %>

<div class="min-h-screen bg-gradient-to-br from-cream-50 via-primary-50 to-secondary-50 dark:from-charcoal-900 dark:via-charcoal-800 dark:to-secondary-900 transition-all duration-300">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <!-- Header -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-20 h-20 bg-primary-100 dark:bg-primary-900/30 rounded-full mb-4">
        <svg class="w-10 h-10 text-primary-600 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v-2l-4.257-4.257A6 6 0 0117 9z" />
        </svg>
      </div>
      
      <h1 class="text-4xl lg:text-5xl font-bold text-charcoal-900 dark:text-cream-50 mb-4">
        🔐 Verify Your Identity
      </h1>
      <p class="text-xl text-charcoal-600 dark:text-charcoal-400 max-w-xl mx-auto">
        Please enter the 6-digit access code from your invitation email to continue claiming your profile.
      </p>
    </div>

    <!-- Progress Indicator -->
    <div class="mb-8">
      <div class="flex items-center justify-center space-x-4">
        <div class="flex items-center">
          <div class="w-8 h-8 bg-primary-500 rounded-full flex items-center justify-center text-white font-bold text-sm">1</div>
          <span class="ml-2 text-sm font-medium text-charcoal-700 dark:text-charcoal-300">Invitation</span>
        </div>
        <div class="w-12 h-1 bg-primary-500 rounded"></div>
        <div class="flex items-center">
          <div class="w-8 h-8 bg-amber-500 rounded-full flex items-center justify-center text-white font-bold text-sm">2</div>
          <span class="ml-2 text-sm font-medium text-amber-700 dark:text-amber-300">Verify</span>
        </div>
        <div class="w-12 h-1 bg-charcoal-200 dark:bg-charcoal-700 rounded"></div>
        <div class="flex items-center">
          <div class="w-8 h-8 bg-charcoal-300 dark:bg-charcoal-600 rounded-full flex items-center justify-center text-white font-bold text-sm">3</div>
          <span class="ml-2 text-sm font-medium text-charcoal-500 dark:text-charcoal-400">Setup</span>
        </div>
        <div class="w-12 h-1 bg-charcoal-200 dark:bg-charcoal-700 rounded"></div>
        <div class="flex items-center">
          <div class="w-8 h-8 bg-charcoal-300 dark:bg-charcoal-600 rounded-full flex items-center justify-center text-white font-bold text-sm">4</div>
          <span class="ml-2 text-sm font-medium text-charcoal-500 dark:text-charcoal-400">Active</span>
        </div>
      </div>
    </div>

    <!-- Profile Info Card -->
    <div class="bg-white dark:bg-charcoal-800 rounded-2xl shadow-xl border border-primary-200 dark:border-charcoal-700 overflow-hidden mb-8">
      <div class="bg-gradient-to-r from-primary-500 to-secondary-500 px-6 py-4">
        <h2 class="text-xl font-bold text-white flex items-center">
          <svg class="w-6 h-6 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          Claiming Profile For
        </h2>
      </div>
      
      <div class="p-6">
        <div class="flex items-center space-x-4">
          <% if @user.avatar.attached? %>
            <%= image_tag @user.avatar.variant(resize_to_fill: [80, 80]), 
                class: "w-20 h-20 rounded-full border-4 border-primary-200 dark:border-primary-700" %>
          <% else %>
            <div class="w-20 h-20 rounded-full bg-gradient-to-br from-primary-400 to-secondary-400 flex items-center justify-center text-white text-3xl font-bold border-4 border-primary-200 dark:border-primary-700">
              <%= @user.display_name[0].upcase %>
            </div>
          <% end %>
          
          <div>
            <h3 class="text-2xl font-bold text-charcoal-900 dark:text-cream-50">
              <%= @user.display_name %>
            </h3>
            <p class="text-charcoal-600 dark:text-charcoal-400">
              @<%= @user.username %> • <%= @user.email %>
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Verification Form -->
    <div class="bg-white dark:bg-charcoal-800 rounded-2xl shadow-xl border border-primary-200 dark:border-charcoal-700 overflow-hidden">
      <div class="bg-gradient-to-r from-amber-500 to-orange-500 px-6 py-4">
        <h2 class="text-xl font-bold text-white flex items-center">
          <svg class="w-6 h-6 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
          Enter Access Code
        </h2>
      </div>
      
      <div class="p-6">
        <%= form_with url: verify_invitation_code_path(@user.invitation_token), method: :post, local: true, class: "space-y-6" do |form| %>
          
          <div>
            <label class="block text-sm font-medium text-charcoal-700 dark:text-charcoal-300 mb-3">
              6-Digit Access Code
            </label>
            
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <svg class="w-5 h-5 text-charcoal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14" />
                </svg>
              </div>
              
              <%= text_field_tag :access_code, nil,
                  class: "w-full pl-12 pr-4 py-4 text-center text-2xl font-mono font-bold tracking-widest border-2 border-charcoal-300 dark:border-charcoal-600 rounded-lg focus:ring-2 focus:ring-amber-500 focus:border-amber-500 dark:bg-charcoal-700 dark:text-cream-50 transition-colors",
                  placeholder: "000000",
                  maxlength: 6,
                  pattern: "[0-9]{6}",
                  inputmode: "numeric",
                  autocomplete: "off",
                  required: true,
                  autofocus: true %>
            </div>
            
            <p class="mt-2 text-sm text-charcoal-600 dark:text-charcoal-400">
              Check your invitation email for the 6-digit access code
            </p>
          </div>

          <!-- Info Box -->
          <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-700 rounded-lg p-4">
            <div class="flex items-start">
              <svg class="w-5 h-5 text-blue-500 mt-0.5 mr-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div class="text-sm text-blue-800 dark:text-blue-200">
                <p class="font-semibold mb-1">Can't find your access code?</p>
                <p>The 6-digit code was sent to <strong><%= @user.email %></strong> in your invitation email. Check your spam folder if you don't see it.</p>
              </div>
            </div>
          </div>

          <!-- Submit Button -->
          <div class="text-center">
            <%= form.submit "✓ Verify Access Code", 
                class: "w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-amber-500 to-orange-500 hover:from-amber-600 hover:to-orange-600 text-white font-bold text-lg rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Security Notice -->
    <div class="mt-8 text-center">
      <div class="inline-flex items-start bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-700 rounded-lg px-4 py-3 text-left">
        <svg class="w-5 h-5 text-green-500 mr-2 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <div class="text-sm text-green-800 dark:text-green-200">
          <p class="font-semibold">🔒 Security Protected</p>
          <p>This verification ensures only you can claim your profile</p>
        </div>
      </div>
    </div>

    <!-- Back Link -->
    <div class="mt-6 text-center">
      <%= link_to invitation_path(@user.invitation_token), 
          class: "inline-flex items-center px-4 py-2 text-charcoal-600 dark:text-charcoal-400 hover:text-charcoal-800 dark:hover:text-charcoal-200 transition-colors" do %>
        <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Invitation Details
      <% end %>
    </div>
  </div>
</div>

<!-- Auto-format access code input -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  const accessCodeInput = document.querySelector('input[name="access_code"]');
  
  if (accessCodeInput) {
    // Only allow numbers
    accessCodeInput.addEventListener('input', function(e) {
      this.value = this.value.replace(/[^0-9]/g, '');
    });
    
    // Auto-submit when 6 digits are entered
    accessCodeInput.addEventListener('input', function(e) {
      if (this.value.length === 6) {
        // Optional: auto-submit the form
        // this.form.submit();
      }
    });
  }
});
</script>

