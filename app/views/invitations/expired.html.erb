<% page_title("Invitation Expired - #{@user.display_name}") %>
<% meta_description("This invitation has expired. Contact support for assistance.") %>

<div class="min-h-screen bg-gradient-to-br from-cream-50 via-red-50 to-orange-50 dark:from-charcoal-900 dark:via-red-900/20 dark:to-orange-900/20 transition-all duration-300">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <!-- Header -->
    <div class="text-center mb-8">
      <div class="w-24 h-24 bg-red-100 dark:bg-red-900/30 rounded-full flex items-center justify-center mx-auto mb-6 border-4 border-red-200 dark:border-red-700">
        <svg class="w-12 h-12 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      
      <h1 class="text-4xl lg:text-5xl font-bold text-red-800 dark:text-red-200 mb-4">
        ⏰ Invitation Expired
      </h1>
      <p class="text-xl text-red-700 dark:text-red-300 max-w-2xl mx-auto">
        Unfortunately, this invitation link has expired. But don't worry - we can help you get access to your profile!
      </p>
    </div>

    <!-- Expired Notice Card -->
    <div class="bg-white dark:bg-charcoal-800 rounded-2xl shadow-xl mb-8 border-2 border-red-200 dark:border-red-700 overflow-hidden">
      <!-- Status Header -->
      <div class="bg-gradient-to-r from-red-500 to-orange-500 px-6 py-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center">
            <svg class="w-6 h-6 text-white mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-white font-semibold">Invitation Expired</span>
          </div>
          <div class="text-white text-sm">
            Expired on <%= (@user.invitation_sent_at + 30.days).strftime("%B %d, %Y") %>
          </div>
        </div>
      </div>

      <!-- Profile Info -->
      <div class="p-6">
        <div class="flex flex-col lg:flex-row lg:items-start lg:space-x-8">
          <!-- Avatar and Basic Info -->
          <div class="flex-shrink-0 mb-6 lg:mb-0">
            <div class="relative bg-charcoal-900 dark:bg-charcoal-950 rounded-lg p-3 border border-charcoal-600 shadow-lg opacity-75">
              <!-- Terminal header -->
              <div class="flex items-center justify-between mb-3 px-2">
                <div class="flex space-x-1.5">
                  <div class="w-3 h-3 bg-red-500 rounded-full"></div>
                  <div class="w-3 h-3 bg-orange-500 rounded-full"></div>
                  <div class="w-3 h-3 bg-gray-500 rounded-full"></div>
                </div>
                <div class="text-xs font-mono text-charcoal-400">~/expired</div>
              </div>
              
              <!-- Avatar -->
              <div class="relative group">
                <% if @user.avatar.attached? %>
                  <%= image_tag @user.avatar_medium, 
                        class: "w-24 h-24 rounded-xl object-cover border-2 border-red-400 shadow-lg opacity-75",
                        alt: "#{@user.display_name}'s avatar" %>
                <% else %>
                  <div class="w-24 h-24 rounded-xl bg-gradient-to-br from-red-500 to-orange-600 flex items-center justify-center border-2 border-red-400 shadow-lg opacity-75">
                    <svg class="w-12 h-12 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                  </div>
                <% end %>
                
                <!-- Expired indicator -->
                <div class="absolute -bottom-1 -right-1 w-6 h-6 bg-red-500 rounded-full border-2 border-charcoal-900 flex items-center justify-center">
                  <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </div>
              </div>
              
              <!-- Terminal command -->
              <div class="mt-3 px-2">
                <div class="text-xs font-mono text-red-400">
                  <span class="text-charcoal-500">$</span> status
                </div>
                <div class="text-xs font-mono text-red-300 mt-1">
                  expired
                </div>
              </div>
            </div>
          </div>
          
          <!-- Profile Details -->
          <div class="flex-1 min-w-0">
            <h2 class="text-3xl font-bold text-charcoal-900 dark:text-cream-50 mb-2">
              <%= @user.display_name %>
            </h2>
            <p class="text-lg text-charcoal-600 dark:text-charcoal-400 mb-4 font-mono">
              @<%= @user.username %>
            </p>
            
            <!-- Expiration Info -->
            <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-700 rounded-lg p-4 mb-6">
              <h3 class="font-semibold text-red-800 dark:text-red-200 mb-2">Invitation Details</h3>
              <div class="space-y-2 text-sm">
                <div class="flex justify-between">
                  <span class="text-red-700 dark:text-red-300">Sent:</span>
                  <span class="text-red-800 dark:text-red-200 font-medium">
                    <%= @user.invitation_sent_at.strftime("%B %d, %Y at %I:%M %p") %>
                  </span>
                </div>
                <div class="flex justify-between">
                  <span class="text-red-700 dark:text-red-300">Expired:</span>
                  <span class="text-red-800 dark:text-red-200 font-medium">
                    <%= (@user.invitation_sent_at + 30.days).strftime("%B %d, %Y at %I:%M %p") %>
                  </span>
                </div>
                <div class="flex justify-between">
                  <span class="text-red-700 dark:text-red-300">Days Overdue:</span>
                  <span class="text-red-800 dark:text-red-200 font-medium">
                    <%= (Date.current - (@user.invitation_sent_at + 30.days).to_date).to_i %> days
                  </span>
                </div>
              </div>
            </div>
            
            <!-- Profile Status -->
            <div class="space-y-3">
              <div class="flex items-center text-charcoal-600 dark:text-charcoal-400">
                <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <%= @user.email %>
              </div>
              
              <div class="flex items-center text-red-600 dark:text-red-400">
                <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
                Profile Status: Unclaimed (Expired)
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- What to Do Next -->
    <div class="bg-white dark:bg-charcoal-800 rounded-2xl shadow-xl mb-8 border border-blue-200 dark:border-blue-700 overflow-hidden">
      <div class="bg-gradient-to-r from-blue-500 to-cyan-500 px-6 py-4">
        <h2 class="text-xl font-bold text-white flex items-center">
          <svg class="w-6 h-6 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          What You Can Do
        </h2>
      </div>
      
      <div class="p-6">
        <div class="grid md:grid-cols-2 gap-6">
          <div class="space-y-4">
            <div class="flex items-start">
              <div class="w-8 h-8 bg-blue-100 dark:bg-blue-900/30 rounded-full flex items-center justify-center mr-3 mt-1">
                <svg class="w-4 h-4 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h4 class="font-semibold text-charcoal-900 dark:text-cream-50">Contact Support</h4>
                <p class="text-charcoal-600 dark:text-charcoal-400 text-sm">Get a new invitation link sent to your email</p>
              </div>
            </div>
            
            <div class="flex items-start">
              <div class="w-8 h-8 bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center mr-3 mt-1">
                <svg class="w-4 h-4 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h4 class="font-semibold text-charcoal-900 dark:text-cream-50">Profile Still Available</h4>
                <p class="text-charcoal-600 dark:text-charcoal-400 text-sm">Your profile information is safe and preserved</p>
              </div>
            </div>
            
            <div class="flex items-start">
              <div class="w-8 h-8 bg-purple-100 dark:bg-purple-900/30 rounded-full flex items-center justify-center mr-3 mt-1">
                <svg class="w-4 h-4 text-purple-600 dark:text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <div>
                <h4 class="font-semibold text-charcoal-900 dark:text-cream-50">Quick Process</h4>
                <p class="text-charcoal-600 dark:text-charcoal-400 text-sm">New invitation can be sent within minutes</p>
              </div>
            </div>
          </div>
          
          <div class="space-y-4">
            <div class="bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-700 rounded-lg p-4">
              <h4 class="font-semibold text-yellow-800 dark:text-yellow-200 mb-2">💡 Good News!</h4>
              <ul class="text-yellow-700 dark:text-yellow-300 text-sm space-y-1">
                <li>• Your profile data is completely safe</li>
                <li>• No information has been lost</li>
                <li>• You can still claim your profile</li>
                <li>• The process is quick and easy</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="text-center space-y-4">
      <%= link_to "mailto:support@devv.me?subject=Expired Profile Invitation - #{@user.username}&body=Hi,%0D%0A%0D%0AMy profile invitation has expired and I would like to request a new one.%0D%0A%0D%0AProfile Details:%0D%0A- Username: #{@user.username}%0D%0A- Email: #{@user.email}%0D%0A- Original invitation sent: #{@user.invitation_sent_at.strftime('%B %d, %Y')}%0D%0A%0D%0AThank you!", 
          class: "inline-flex items-center px-8 py-4 bg-gradient-to-r from-blue-500 to-cyan-500 hover:from-blue-600 hover:to-cyan-600 text-white font-bold text-lg rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1" do %>
        <svg class="w-6 h-6 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        Request New Invitation
      <% end %>
      
      <div class="text-center">
        <%= link_to @invitation_data[:profile_url], 
            class: "inline-flex items-center px-6 py-3 bg-charcoal-800 hover:bg-charcoal-900 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-cream-100 font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5",
            target: "_blank" do %>
          <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
          View Profile Anyway
        <% end %>
      </div>
      
      <div class="text-center">
        <%= link_to root_path, 
            class: "inline-flex items-center px-6 py-3 bg-charcoal-200 hover:bg-charcoal-300 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-charcoal-800 dark:text-charcoal-200 font-semibold rounded-lg transition-colors" do %>
          <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          Back to Home
        <% end %>
      </div>
    </div>

    <!-- Support Information -->
    <div class="mt-12 bg-gray-50 dark:bg-charcoal-800 rounded-2xl shadow-lg p-6 border border-gray-200 dark:border-charcoal-700">
      <h3 class="text-lg font-bold text-charcoal-900 dark:text-cream-50 mb-4 text-center">Need Help?</h3>
      
      <div class="text-center space-y-2">
        <p class="text-charcoal-600 dark:text-charcoal-400">
          Email us at <a href="mailto:support@devv.me" class="text-blue-600 dark:text-blue-400 hover:underline font-medium">support@devv.me</a>
        </p>
        <p class="text-charcoal-500 dark:text-charcoal-400 text-sm">
          We typically respond within 24 hours and can send you a new invitation right away.
        </p>
      </div>
    </div>
  </div>
</div>
