<%# SEO Meta Tags %>
<% page_title(@blog_post.title) %>
<% 
  # Cache the processed content to avoid multiple processing
  # Get excerpt or generate from content based on editor mode
  content_excerpt = @blog_post.excerpt.presence
  if content_excerpt.blank?
    if @blog_post.editor_mode == 'rich_text' && @blog_post.content_html.present?
      content_excerpt = truncate(strip_tags(@blog_post.content_html.to_s), length: 160)
    else
      content_excerpt = truncate(strip_tags(@blog_post.content), length: 160)
    end
  end
%>
<% meta_description(content_excerpt) %>
<% meta_keywords([@blog_post.title.split, "blog", "devvme", "programming", "development"].flatten.join(", ")) %>

<%# Open Graph and Twitter Card Tags %>
<% 
  post_url = public_blog_post_url(@blog_post)
  description = content_excerpt
%>
<% open_graph_tags(
  title: @blog_post.title,
  description: description,
  url: post_url,
  type: "article"
) %>

<% twitter_card_tags(
  title: @blog_post.title,
  description: description
) %>

<%# Canonical URL %>
<% canonical_url(post_url) %>

<%# Structured Data (JSON-LD) %>
<% blog_post_schema(@blog_post) %>

<div class="container mx-auto px-4 py-8 max-w-4xl">
  <!-- Breadcrumb -->
  <nav class="flex items-center space-x-2 text-sm text-gray-500 dark:text-gray-400 mb-8">
    <%= link_to public_blog_index_path, 
        class: "hover:text-gray-700 dark:hover:text-gray-300 transition-colors" do %>
      Blog
    <% end %>
    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
      <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
    </svg>
    <span class="text-gray-900 dark:text-white truncate"><%= @blog_post.title %></span>
  </nav>

  <!-- Article Header -->
  <header class="mb-8">
    <!-- Owner Action Navbar -->
    <% if user_signed_in? && current_user == @blog_post.user %>
      <div class="mb-6 p-3 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-700 rounded-lg">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-2 text-sm text-blue-700 dark:text-blue-300">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span>You own this post</span>
          </div>
          <div class="flex items-center space-x-2">
            <%= link_to edit_blog_post_path(@blog_post), 
                class: "inline-flex items-center px-3 py-1.5 text-xs font-medium text-blue-700 dark:text-blue-300 bg-blue-100 dark:bg-blue-800 hover:bg-blue-200 dark:hover:bg-blue-700 rounded-md transition-colors" do %>
              <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
              Edit
            <% end %>
            <%= link_to blog_post_path(@blog_post), 
                class: "inline-flex items-center px-3 py-1.5 text-xs font-medium text-blue-700 dark:text-blue-300 bg-blue-100 dark:bg-blue-800 hover:bg-blue-200 dark:hover:bg-blue-700 rounded-md transition-colors" do %>
              <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V4a2 2 0 114 0v2m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2"/>
              </svg>
              Manage
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-6 leading-tight">
      <%= @blog_post.title %>
    </h1>

    <!-- Excerpt -->
    <% if @blog_post.excerpt.present? %>
      <p class="text-xl text-gray-600 dark:text-gray-300 mb-6 leading-relaxed">
        <%= @blog_post.excerpt %>
      </p>
    <% end %>

    <!-- Author and Meta Info -->
    <div class="flex flex-wrap items-center justify-between gap-4 pb-6 border-b border-gray-200 dark:border-gray-700">
      <div class="flex items-center space-x-4">
        <!-- Author info -->
        <%= link_to public_profile_path(@blog_post.user), class: "flex items-center hover:bg-gray-50 dark:hover:bg-gray-800 rounded-lg p-2 -m-2 transition-colors" do %>
          <div class="w-10 h-10 bg-blue-600 text-white rounded-full flex items-center justify-center font-semibold mr-3">
            <%= @blog_post.user.display_name.first.upcase %>
          </div>
          <div>
            <p class="text-sm font-medium text-gray-900 dark:text-white">
              <%= @blog_post.user.display_name %>
            </p>
            <p class="text-xs text-gray-500 dark:text-gray-400">
              Author
            </p>
          </div>
        <% end %>

        <!-- Meta information -->
        <div class="hidden sm:flex items-center space-x-4 text-sm text-gray-500 dark:text-gray-400">
          <div class="flex items-center">
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3a4 4 0 118 0v4m-4 12v-4m0 0a4 4 0 118 0 4 4 0 11-8 0z"/>
            </svg>
            <time datetime="<%= @blog_post.published_at.iso8601 %>">
              <%= @blog_post.published_at.strftime("%B %d, %Y") %>
            </time>
          </div>

          <div class="flex items-center">
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span><%= @blog_post.reading_time %> min read</span>
          </div>

          <div class="flex items-center">
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            <span><%= pluralize(@blog_post.word_count, 'word') %></span>
          </div>
        </div>
      </div>

      <!-- Social sharing buttons -->
      <div class="flex items-center space-x-2">
        <!-- Share button -->
        <button data-controller="share-button" 
                data-share-button-url-value="<%= request.original_url %>"
                data-share-button-title-value="<%= @blog_post.title %>"
                data-share-button-text-value="<%= @blog_post.excerpt %>"
                class="p-2 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300 transition-colors"
                title="Share">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.367 2.684 3 3 0 00-5.367-2.684z"/>
          </svg>
        </button>

        <!-- Twitter share -->
        <a href="https://twitter.com/intent/tweet?url=<%= CGI.escape(request.original_url) %>&text=<%= CGI.escape(@blog_post.title) %>"
           target="_blank"
           rel="noopener noreferrer"
           class="p-2 text-gray-500 hover:text-blue-400 dark:text-gray-400 dark:hover:text-blue-400 transition-colors"
           title="Share on Twitter">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
          </svg>
        </a>

        <!-- LinkedIn share -->
        <a href="https://www.linkedin.com/sharing/share-offsite/?url=<%= CGI.escape(request.original_url) %>"
           target="_blank"
           rel="noopener noreferrer"
           class="p-2 text-gray-500 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400 transition-colors"
           title="Share on LinkedIn">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>

        <!-- Print button -->
        <button onclick="window.print()" 
                class="p-2 text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300 transition-colors"
                title="Print">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2z"/>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <!-- Article Content with Sidebar -->
  <div class="flex flex-col lg:flex-row gap-8">
    <!-- Table of Contents (Desktop) -->
    <% if @toc.present? %>
      <aside class="lg:w-64 lg:shrink-0">
        <div class="sticky top-8">
          <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-4 border border-gray-200 dark:border-gray-700">
            <%== @toc %>
          </div>
        </div>
      </aside>
    <% end %>

    <!-- Main Content -->
    <main class="flex-1 min-w-0">
      <!-- Table of Contents (Mobile) -->
      <% if @toc.present? %>
        <div class="lg:hidden mb-8">
          <details class="bg-gray-50 dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700">
            <summary class="p-4 cursor-pointer font-medium text-gray-900 dark:text-white">
              Table of Contents
            </summary>
            <div class="px-4 pb-4">
              <%== @toc %>
            </div>
          </details>
        </div>
      <% end %>

      <!-- Article Content -->
      <article class="prose prose-lg dark:prose-invert max-w-none print:max-w-full">
        <% if @blog_post.editor_mode == 'rich_text' && @blog_post.content_html.present? %>
          <!-- Rich Text Content (HTML) -->
          <div class="trix-content">
            <%= @blog_post.content_html.to_s.html_safe %>
          </div>
        <% else %>
          <!-- Markdown Content -->
          <div data-controller="blog-viewer" 
               data-blog-viewer-content-value="<%= html_escape(@blog_post.content) %>">
            <!-- Markdown content will be rendered here -->
          </div>
        <% end %>
      </article>
    </main>
  </div>

  <!-- Article Footer -->
  <footer class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700">
    <!-- Author bio -->
    <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-6 mb-8">
      <%= link_to public_profile_path(@blog_post.user), class: "block hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg p-4 -m-4 transition-colors" do %>
        <div class="flex items-start space-x-4">
          <div class="w-16 h-16 bg-blue-600 text-white rounded-full flex items-center justify-center font-semibold text-xl">
            <%= @blog_post.user.display_name.first.upcase %>
          </div>
          <div class="flex-1">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">
              <%= @blog_post.user.display_name %>
            </h3>
            <% if @blog_post.user.bio.present? %>
              <p class="text-gray-600 dark:text-gray-300 text-sm mb-3">
                <%= @blog_post.user.bio %>
              </p>
            <% end %>
            <p class="text-blue-600 dark:text-blue-400 text-sm font-medium">
              View Profile →
            </p>
          </div>
        </div>
      <% end %>
      
      <!-- External links section -->
      <% if @blog_post.user.website_url.present? || @blog_post.user.github_url.present? || @blog_post.user.linkedin_url.present? %>
        <div class="flex items-center space-x-4 text-sm mt-4 pt-4 border-t border-gray-200 dark:border-gray-600">
          <% if @blog_post.user.website_url.present? %>
            <a href="<%= @blog_post.user.website_url %>" 
               target="_blank" 
               rel="noopener noreferrer"
               class="text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors"
               onclick="event.stopPropagation()">
              Website
            </a>
          <% end %>
          <% if @blog_post.user.github_url.present? %>
            <a href="<%= @blog_post.user.github_url %>" 
               target="_blank" 
               rel="noopener noreferrer"
               class="text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors"
               onclick="event.stopPropagation()">
              GitHub
            </a>
          <% end %>
          <% if @blog_post.user.linkedin_url.present? %>
            <a href="<%= @blog_post.user.linkedin_url %>" 
               target="_blank" 
               rel="noopener noreferrer"
               class="text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors"
               onclick="event.stopPropagation()">
              LinkedIn
            </a>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Navigation between posts -->
    <% if @previous_post || @next_post %>
      <nav class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
        <% if @previous_post %>
          <div class="flex-1">
            <%= link_to public_blog_post_path(@previous_post), 
                class: "group block p-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg hover:shadow-md transition-shadow" do %>
              <div class="flex items-center text-blue-600 dark:text-blue-400 text-sm mb-1">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                </svg>
                Previous
              </div>
              <div class="text-gray-900 dark:text-white font-medium group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors line-clamp-2">
                <%= @previous_post.title %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="flex-1"></div>
        <% end %>

        <% if @next_post %>
          <div class="flex-1">
            <%= link_to public_blog_post_path(@next_post), 
                class: "group block p-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg hover:shadow-md transition-shadow text-right" do %>
              <div class="flex items-center justify-end text-blue-600 dark:text-blue-400 text-sm mb-1">
                Next
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                </svg>
              </div>
              <div class="text-gray-900 dark:text-white font-medium group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors line-clamp-2">
                <%= @next_post.title %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="flex-1"></div>
        <% end %>
      </nav>
    <% end %>

    <!-- Comments Section Placeholder -->
    <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700">
      <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-6">Comments</h3>
      
      <!-- Comment placeholder notice -->
      <div class="bg-blue-50 dark:bg-blue-900 border border-blue-200 dark:border-blue-700 rounded-lg p-6 text-center">
        <svg class="mx-auto h-12 w-12 text-blue-400 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
        </svg>
        <h4 class="text-lg font-medium text-blue-900 dark:text-blue-100 mb-2">
          Comments Coming Soon!
        </h4>
        <p class="text-blue-800 dark:text-blue-200">
          We're working on adding a comment system to enable discussions on blog posts. 
          Stay tuned for this feature in future updates.
        </p>
        <div class="mt-4 text-sm text-blue-700 dark:text-blue-300">
          <p>In the meantime, feel free to share this post on social media or reach out directly:</p>
          <div class="flex justify-center space-x-4 mt-3">
            <button onclick="navigator.share({title: '<%= @blog_post.title %>', url: '<%= public_blog_post_url(@blog_post) %>'})" 
                    class="inline-flex items-center px-3 py-1 rounded-md bg-blue-100 dark:bg-blue-800 text-blue-700 dark:text-blue-200 hover:bg-blue-200 dark:hover:bg-blue-700 transition-colors">
              <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.367 2.684 3 3 0 00-5.367-2.684z" />
              </svg>
              Share
            </button>
            <a href="https://twitter.com/intent/tweet?text=<%= CGI.escape(@blog_post.title) %>&url=<%= CGI.escape(public_blog_post_url(@blog_post)) %>" 
               target="_blank" 
               rel="noopener noreferrer"
               class="inline-flex items-center px-3 py-1 rounded-md bg-blue-100 dark:bg-blue-800 text-blue-700 dark:text-blue-200 hover:bg-blue-200 dark:hover:bg-blue-700 transition-colors">
              <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                <path d="M6.29 18.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0020 3.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.073 4.073 0 01.8 7.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 010 16.407a11.616 11.616 0 006.29 1.84"/>
              </svg>
              Tweet
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Back to blog -->
    <div class="text-center">
      <%= link_to public_blog_index_path, 
          class: "inline-flex items-center px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Back to Blog
      <% end %>
    </div>
  </footer>
</div>

<% content_for :head do %>
  <style>
    /* Enhanced typography for blog content */
    .prose {
      line-height: 1.75;
      max-width: none;
    }
    
    .prose h1 {
      @apply text-3xl font-bold text-gray-900 dark:text-white mt-8 mb-4 first:mt-0;
    }
    
    .prose h2 {
      @apply text-2xl font-bold text-gray-900 dark:text-white mt-8 mb-4 first:mt-0;
    }
    
    .prose h3 {
      @apply text-xl font-bold text-gray-900 dark:text-white mt-6 mb-3 first:mt-0;
    }
    
    .prose h4 {
      @apply text-lg font-bold text-gray-900 dark:text-white mt-6 mb-3 first:mt-0;
    }
    
    .prose p {
      @apply text-gray-700 dark:text-gray-300 mb-4 leading-relaxed;
    }
    
    .prose code {
      @apply bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200 px-2 py-1 rounded text-sm;
    }
    
    .prose pre {
      @apply bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg overflow-x-auto my-6;
    }
    
    .prose pre code {
      @apply bg-transparent text-gray-100 p-0 text-sm;
    }
    
    .prose blockquote {
      @apply border-l-4 border-blue-500 pl-6 italic text-gray-600 dark:text-gray-400 bg-gray-50 dark:bg-gray-800 py-4 rounded-r-lg my-6;
    }
    
    .prose ul, .prose ol {
