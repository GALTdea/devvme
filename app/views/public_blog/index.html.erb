<%# SEO Meta Tags %>
<% page_title("Blog") %>
<% meta_description("Insights, tutorials, and thoughts on software development, technology, and building things. #{@total_posts} posts published.") %>
<% meta_keywords("blog, programming, development, software, tutorials, technology, devvme") %>

<%# Open Graph and Twitter Card Tags %>
<% 
  blog_url = public_blog_index_url
  description = "Insights, tutorials, and thoughts on software development, technology, and building things."
%>

<% open_graph_tags(
  title: "Blog - Devvme App",
  description: description,
  url: blog_url,
  type: "website"
) %>

<% twitter_card_tags(
  title: "Blog - Devvme App",
  description: description
) %>

<%# Canonical URL %>
<% canonical_url(blog_url) %>

<div class="container mx-auto px-4 py-8 max-w-7xl">
  <!-- Hero Section -->
  <div class="text-center mb-12">
    <h1 class="text-4xl md:text-6xl font-bold text-gray-900 dark:text-white mb-4">
      Blog
    </h1>
    <p class="text-xl text-gray-600 dark:text-gray-300 mb-6 max-w-2xl mx-auto">
      Insights, tutorials, and thoughts on software development, technology, and building things.
    </p>
    <div class="text-sm text-gray-500 dark:text-gray-400">
      <%= pluralize(@total_posts, 'post') %> published
    </div>
  </div>

  <!-- Action Bar for Logged-in Users -->
  <% if user_signed_in? %>
    <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-700 rounded-lg p-4 mb-8 max-w-4xl mx-auto">
      <div class="flex items-center justify-between">
        <div class="flex items-center space-x-2 text-sm text-blue-700 dark:text-blue-300">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          <span>Welcome back, <%= current_user.display_name %></span>
        </div>
        <div class="flex items-center space-x-2">
          <%= link_to new_blog_post_path, 
              class: "inline-flex items-center px-4 py-2 text-sm font-medium text-blue-700 dark:text-blue-300 bg-blue-100 dark:bg-blue-800 hover:bg-blue-200 dark:hover:bg-blue-700 rounded-md transition-colors" do %>
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
            </svg>
            Write New Post
          <% end %>
          <%= link_to blog_posts_path, 
              class: "inline-flex items-center px-4 py-2 text-sm font-medium text-blue-700 dark:text-blue-300 bg-blue-100 dark:bg-blue-800 hover:bg-blue-200 dark:hover:bg-blue-700 rounded-md transition-colors" do %>
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V4a2 2 0 114 0v2m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2"/>
            </svg>
            Manage Posts
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Search -->
  <div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-4 mb-8 max-w-2xl mx-auto">
    <%= form_with url: public_blog_index_path, method: :get, local: true, class: "flex gap-3" do |form| %>
      <%= form.text_field :search, 
          value: params[:search],
          placeholder: "Search articles...",
          class: "flex-1 px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
      
      <%= form.submit "Search", 
          class: "px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors" %>
      
      <% if params[:search].present? %>
        <%= link_to public_blog_index_path, 
            class: "px-6 py-3 bg-gray-300 hover:bg-gray-400 text-gray-700 font-medium rounded-lg transition-colors" do %>
          Clear
        <% end %>
      <% end %>
    <% end %>
  </div>

  <!-- Search Results Info -->
  <% if params[:search].present? %>
    <div class="text-center mb-8">
      <p class="text-gray-600 dark:text-gray-400">
        <% if @blog_posts&.any? %>
          Found <%= pluralize(@pagy.count, 'result') %> for "<em><%= params[:search] %></em>"
        <% else %>
          No results found for "<em><%= params[:search] %></em>"
        <% end %>
      </p>
    </div>
  <% end %>

  <!-- Blog Posts Grid -->
  <% if @blog_posts&.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
      <% @blog_posts.each do |post| %>
        <article class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden hover:shadow-lg transition-shadow group">
          <!-- Post Header -->
          <div class="p-6">
            <!-- Meta info -->
            <div class="flex items-center text-sm text-gray-500 dark:text-gray-400 mb-3">
              <div class="flex items-center">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
                <span><%= post.user.display_name %></span>
              </div>
              <span class="mx-2">•</span>
              <div class="flex items-center">
                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3a4 4 0 118 0v4m-4 12v-4m0 0a4 4 0 118 0 4 4 0 11-8 0z"/>
                </svg>
                <time datetime="<%= post.published_at.iso8601 %>">
                  <%= post.published_at.strftime("%b %d, %Y") %>
                </time>
              </div>
            </div>

            <!-- Owner indicator -->
            <% if user_signed_in? && current_user == post.user %>
              <div class="mb-2">
                <span class="inline-flex items-center px-2 py-1 text-xs font-medium text-blue-700 dark:text-blue-300 bg-blue-100 dark:bg-blue-800 rounded-full">
                  <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  Your post
                </span>
              </div>
            <% end %>

            <!-- Title -->
            <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-3 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
              <%= link_to post.title, public_blog_post_path(post), class: "block" %>
            </h2>

            <!-- Excerpt -->
            <% if post.excerpt.present? %>
              <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed mb-4 line-clamp-3">
                <%= post.excerpt %>
              </p>
            <% end %>

            <!-- Meta info bottom -->
            <div class="flex items-center justify-between text-xs text-gray-500 dark:text-gray-400">
              <div class="flex items-center space-x-4">
                <span class="flex items-center">
                  <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  <%= post.reading_time %> min read
                </span>
                
                <span class="flex items-center">
                  <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                  </svg>
                  <%= pluralize(post.word_count, 'word') %>
                </span>
              </div>

              <div class="flex items-center space-x-2">
                <!-- Owner action links -->
                <% if user_signed_in? && current_user == post.user %>
                  <%= link_to edit_blog_post_path(post), 
                      class: "p-1 text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors" do %>
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                  <% end %>
                <% end %>
                
                <%= link_to public_blog_post_path(post), 
                    class: "text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-medium transition-colors" do %>
                  Read more →
                <% end %>
              </div>
            </div>
          </div>
        </article>
      <% end %>
    </div>

    <!-- Pagination -->
    <div class="flex justify-center">
      <nav class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-4">
        <%== pagy_nav(@pagy, id: 'blog-pagination', 
                      item_name: 'post', 
                      anchor_string: 'data-turbo-action="advance"',
                      size: 9) %>
      </nav>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="text-center py-16">
      <svg class="mx-auto h-16 w-16 text-gray-400 dark:text-gray-500 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      <h3 class="text-xl font-medium text-gray-900 dark:text-white mb-2">
        <% if params[:search].present? %>
          No articles found
        <% else %>
          No blog posts yet
        <% end %>
      </h3>
      <p class="text-gray-500 dark:text-gray-400 mb-6 max-w-sm mx-auto">
        <% if params[:search].present? %>
          Try adjusting your search terms or browse all articles.
        <% else %>
          Check back soon for new content, or explore other sections of the site.
        <% end %>
      </p>
      
      <% if params[:search].present? %>
        <%= link_to public_blog_index_path, 
            class: "inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors" do %>
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          View All Articles
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>

<% content_for :head do %>
  <style>
    /* Pagination styling */
    #blog-pagination .page {
      @apply inline-flex items-center px-3 py-2 text-sm leading-tight text-gray-500 bg-white border border-gray-300 hover:bg-gray-100 hover:text-gray-700 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-white transition-colors;
    }

    #blog-pagination .page.current {
      @apply z-10 px-3 py-2 text-sm leading-tight text-blue-600 bg-blue-50 border border-blue-300 hover:bg-blue-100 hover:text-blue-700 dark:border-gray-700 dark:bg-gray-700 dark:text-white;
    }

    #blog-pagination .page:first-child {
      @apply rounded-l-lg;
    }

    #blog-pagination .page:last-child {
      @apply rounded-r-lg;
    }

    #blog-pagination .page.gap {
      @apply px-3 py-2 text-sm leading-tight text-gray-500 bg-white border border-gray-300 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-400;
    }

    /* Line clamp utility for blog excerpts */
    .line-clamp-3 {
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  </style>
<% end %>