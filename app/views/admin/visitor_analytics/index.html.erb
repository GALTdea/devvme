<% content_for :title, "Visitor Analytics" %>

<div class="min-h-screen bg-secondary-50 dark:bg-secondary-900" 
     data-controller="visitor-analytics"
     data-visitor-analytics-update-url-value="<%= admin_visitor_analytics_index_path %>"
     data-visitor-analytics-time-range-value="<%= @time_range %>"
     data-visitor-analytics-update-interval-value="60000">
  <!-- Header -->
  <div class="bg-white dark:bg-secondary-800 shadow">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="py-6">
        <div class="flex items-center justify-between">
<div>
            <h1 class="text-2xl font-bold text-secondary-900 dark:text-white">Visitor Analytics</h1>
            <p class="mt-1 text-sm text-secondary-600 dark:text-secondary-400">
              Track visitor behavior and conversion patterns before user registration
            </p>
          </div>
          <div class="flex items-center space-x-4">
            <!-- Time Range Selector -->
            <div class="flex items-center space-x-2">
              <label for="time-range" class="text-sm font-medium text-secondary-700 dark:text-secondary-300">Time Range:</label>
              <%= form_with url: admin_visitor_analytics_index_path, method: :get, local: true, class: "inline-flex" do |form| %>
                <%= form.select :time_range, 
                    options_for_select([
                      ['Last 7 days', '7_days'],
                      ['Last 30 days', '30_days'],
                      ['Last 90 days', '90_days'],
                      ['Last year', '1_year']
                    ], @time_range),
                    { include_blank: false },
                    { 
                      id: "time-range",
                      class: "block w-full rounded-md border-secondary-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm dark:bg-secondary-700 dark:border-secondary-600 dark:text-white",
                      data: { action: "change->visitor-analytics#timeRangeChanged" }
                    } %>
              <% end %>
            </div>

            <!-- Real-time Indicator -->
            <div class="flex items-center space-x-4">
              <div class="flex items-center space-x-2 live-indicator">
                <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
                <span class="text-sm text-secondary-600 dark:text-secondary-400">Live</span>
              </div>
              
              <!-- Manual Refresh Button -->
              <button type="button"
                      class="inline-flex items-center px-3 py-1 border border-secondary-300 shadow-sm text-xs font-medium rounded text-secondary-700 bg-white hover:bg-secondary-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 dark:bg-secondary-700 dark:border-secondary-600 dark:text-secondary-300 dark:hover:bg-secondary-600"
                      data-action="click->visitor-analytics#refresh">
                <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                </svg>
                Refresh
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Navigation -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <nav class="flex space-x-4" aria-label="Admin Navigation">
      <%= link_to admin_root_path, 
          class: "text-secondary-600 hover:text-secondary-900 dark:text-secondary-300 dark:hover:text-white px-3 py-2 rounded-md text-sm font-medium hover:bg-secondary-100 dark:hover:bg-secondary-700" do %>
        Dashboard
      <% end %>
      <%= link_to admin_analytics_index_path, 
          class: "text-secondary-600 hover:text-secondary-900 dark:text-secondary-300 dark:hover:text-white px-3 py-2 rounded-md text-sm font-medium hover:bg-secondary-100 dark:hover:bg-secondary-700" do %>
        User Analytics
      <% end %>
      <%= link_to admin_visitor_analytics_index_path, 
          class: "bg-primary-100 text-primary-700 dark:bg-primary-900 dark:text-primary-200 px-3 py-2 rounded-md text-sm font-medium" do %>
        Visitor Analytics
      <% end %>
    </nav>
  </div>

  <!-- Key Metrics Cards -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-6 mb-8">
      <!-- Total Visitors -->
      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <div class="ml-3 w-0 flex-1">
              <dl>
                <dt class="text-xs font-medium text-secondary-500 dark:text-secondary-400 truncate">Total Visitors</dt>
                <dd class="text-lg font-medium text-secondary-900 dark:text-white" 
                    data-visitor-analytics-target="totalVisitors"><%= @visitor_stats[:total_visitors] %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <!-- Unique Visitors -->
      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" />
              </svg>
            </div>
            <div class="ml-3 w-0 flex-1">
              <dl>
                <dt class="text-xs font-medium text-secondary-500 dark:text-secondary-400 truncate">Unique Visitors</dt>
                <dd class="text-lg font-medium text-secondary-900 dark:text-white" 
                    data-visitor-analytics-target="uniqueVisitors"><%= @visitor_stats[:unique_visitors] %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <!-- Returning Visitors -->
      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
            </div>
            <div class="ml-3 w-0 flex-1">
              <dl>
                <dt class="text-xs font-medium text-secondary-500 dark:text-secondary-400 truncate">Returning</dt>
                <dd class="text-lg font-medium text-secondary-900 dark:text-white" 
                    data-visitor-analytics-target="returningVisitors"><%= @visitor_stats[:returning_visitors] %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <!-- Conversion Rate -->
      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
            </div>
            <div class="ml-3 w-0 flex-1">
              <dl>
                <dt class="text-xs font-medium text-secondary-500 dark:text-secondary-400 truncate">Conversion</dt>
                <dd class="text-lg font-medium text-secondary-900 dark:text-white" 
                    data-visitor-analytics-target="conversionRate"><%= @visitor_stats[:conversion_rate] %>%</dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <!-- Avg Time on Site -->
      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-3 w-0 flex-1">
              <dl>
                <dt class="text-xs font-medium text-secondary-500 dark:text-secondary-400 truncate">Avg Time</dt>
                <dd class="text-lg font-medium text-secondary-900 dark:text-white"><%= @visitor_stats[:average_time_on_site] %>m</dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <!-- Avg Page Views -->
      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            </div>
            <div class="ml-3 w-0 flex-1">
              <dl>
                <dt class="text-xs font-medium text-secondary-500 dark:text-secondary-400 truncate">Pages/Visit</dt>
                <dd class="text-lg font-medium text-secondary-900 dark:text-white"><%= @visitor_stats[:average_page_views] %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Charts Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
      <!-- Visitors Trend Chart -->
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-secondary-900 dark:text-white mb-4">Visitor Trends</h3>
          <div class="h-64">
            <canvas id="visitorsChart"></canvas>
          </div>
        </div>
      </div>

      <!-- Page Views Chart -->
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-secondary-900 dark:text-white mb-4">Page View Trends</h3>
          <div class="h-64">
            <canvas id="pageViewsChart"></canvas>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  // Chart data from Rails
  const visitorsData = <%= raw @chart_data[:visitors_by_date].to_json %>;
  const pageViewsData = <%= raw @chart_data[:page_views_by_date].to_json %>;

  // Chart.js configuration
  const chartOptions = {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      legend: {
        labels: {
          color: document.documentElement.classList.contains('dark') ? '#e5e7eb' : '#374151'
        }
      }
    },
    scales: {
      x: {
        ticks: {
          color: document.documentElement.classList.contains('dark') ? '#9ca3af' : '#6b7280'
        },
        grid: {
          color: document.documentElement.classList.contains('dark') ? '#374151' : '#e5e7eb'
        }
      },
      y: {
        ticks: {
          color: document.documentElement.classList.contains('dark') ? '#9ca3af' : '#6b7280'
        },
        grid: {
          color: document.documentElement.classList.contains('dark') ? '#374151' : '#e5e7eb'
        }
      }
    }
  };

  // Visitors Chart
  const visitorsCtx = document.getElementById('visitorsChart').getContext('2d');
  new Chart(visitorsCtx, {
    type: 'line',
    data: {
      labels: Object.keys(visitorsData).map(date => new Date(date).toLocaleDateString()),
      datasets: [{
        label: 'Unique Visitors',
        data: Object.values(visitorsData),
        borderColor: 'rgb(59, 130, 246)',
        backgroundColor: 'rgba(59, 130, 246, 0.1)',
        tension: 0.4,
        fill: true
      }]
    },
    options: chartOptions
  });

  // Page Views Chart
  const pageViewsCtx = document.getElementById('pageViewsChart').getContext('2d');
  new Chart(pageViewsCtx, {
    type: 'bar',
    data: {
      labels: Object.keys(pageViewsData).map(date => new Date(date).toLocaleDateString()),
      datasets: [{
        label: 'Page Views',
        data: Object.values(pageViewsData),
        backgroundColor: 'rgba(16, 185, 129, 0.8)',
        borderColor: 'rgb(16, 185, 129)',
        borderWidth: 1
      }]
    },
    options: chartOptions
  });
</script>