<% content_for :title, "Invitation Management - Admin" %>

<div class="min-h-screen bg-secondary-50 dark:bg-secondary-900">
  <!-- Header -->
  <%= admin_page_header("Invitation Management", "Manage user invitations, track conversion rates, and analyze invitation performance") do %>
    <div class="flex items-center space-x-3">
      <%= link_to analytics_admin_invitations_path, class: "inline-flex items-center px-4 py-2 border border-secondary-300 shadow-sm text-sm font-medium rounded-md text-secondary-700 bg-white hover:bg-secondary-50 dark:bg-secondary-700 dark:border-secondary-600 dark:text-secondary-200 dark:hover:bg-secondary-600" do %>
        <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
        </svg>
        Analytics
      <% end %>
      <% if can_create_users? %>
        <%= link_to bulk_create_admin_invitations_path, class: "inline-flex items-center px-4 py-2 border border-secondary-300 shadow-sm text-sm font-medium rounded-md text-secondary-700 bg-white hover:bg-secondary-50 dark:bg-secondary-700 dark:border-secondary-600 dark:text-secondary-200 dark:hover:bg-secondary-600" do %>
          <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10" />
          </svg>
          Bulk Import
        <% end %>
        <%= link_to new_admin_user_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500" do %>
          <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
          </svg>
          Create Invitation
        <% end %>
      <% end %>
    </div>
  <% end %>

  <!-- Breadcrumbs -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <%= admin_breadcrumbs(
      { text: "Admin Dashboard", path: admin_root_path },
      { text: "Invitation Management", path: admin_invitations_path }
    ) %>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-5 gap-6 mb-8">
      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Total Invitations</p>
              <p class="text-lg font-semibold text-secondary-900 dark:text-white"><%= @stats[:total_invitations] %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-amber-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Pending</p>
              <p class="text-lg font-semibold text-secondary-900 dark:text-white"><%= @stats[:pending_invitations] %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-red-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Expired</p>
              <p class="text-lg font-semibold text-secondary-900 dark:text-white"><%= @stats[:expired_invitations] %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-green-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Recent (7 days)</p>
              <p class="text-lg font-semibold text-secondary-900 dark:text-white"><%= @stats[:recent_invitations] %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-purple-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Conversion Rate</p>
              <p class="text-lg font-semibold text-secondary-900 dark:text-white"><%= @stats[:conversion_rate] %>%</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Filters and Actions -->
    <div class="bg-white dark:bg-secondary-800 shadow rounded-lg mb-6">
      <div class="p-6">
        <div class="flex flex-wrap items-center justify-between gap-4">
          <!-- Search and Filters -->
          <%= form_with url: admin_invitations_path, method: :get, class: "flex flex-wrap gap-4 flex-1", local: true do |form| %>
            <div class="flex-1 min-w-64">
              <%= form.text_field :search, placeholder: "Search by username, name, or email...", 
                  value: params[:search], 
                  class: "block w-full px-3 py-2 border border-secondary-300 rounded-md shadow-sm focus:outline-none focus:ring-primary-500 focus:border-primary-500 dark:bg-secondary-700 dark:border-secondary-600 dark:text-white" %>
            </div>
            <div>
              <%= form.select :status, options_for_select([
                ['All Invitations', ''], 
                ['Pending', 'pending'], 
                ['Expired', 'expired'],
                ['Recent (7 days)', 'recent']
              ], params[:status]), 
                  {}, { class: "block px-3 py-2 border border-secondary-300 rounded-md shadow-sm focus:outline-none focus:ring-primary-500 focus:border-primary-500 dark:bg-secondary-700 dark:border-secondary-600 dark:text-white" } %>
            </div>
            <div>
              <%= form.submit "Filter", class: "px-4 py-2 bg-primary-600 border border-transparent rounded-md font-medium text-white hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500" %>
            </div>
            <% if params[:search].present? || params[:status].present? %>
              <div>
                <%= link_to "Clear", admin_invitations_path, class: "px-4 py-2 bg-secondary-600 border border-transparent rounded-md font-medium text-white hover:bg-secondary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-secondary-500" %>
              </div>
            <% end %>
          <% end %>

          <!-- Bulk Actions -->
          <% if can_manage_users? %>
            <div class="flex items-center space-x-2">
              <button type="button" onclick="toggleBulkActions()" class="px-4 py-2 bg-secondary-600 border border-transparent rounded-md font-medium text-white hover:bg-secondary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-secondary-500">
                Bulk Actions
              </button>
            </div>
          <% end %>
        </div>

        <!-- Bulk Actions Panel (Hidden by default) -->
        <div id="bulk-actions-panel" class="hidden mt-4 p-4 bg-secondary-50 dark:bg-secondary-700 rounded-lg">
          <div class="flex items-center justify-between">
            <div class="flex items-center space-x-4">
              <span class="text-sm font-medium text-secondary-700 dark:text-secondary-300">
                Selected: <span id="selected-count">0</span> invitations
              </span>
            </div>
            <div class="flex items-center space-x-2">
              <%= button_to "Resend Selected", bulk_resend_admin_invitations_path, 
                  method: :post,
                  params: { user_ids: [] },
                  class: "px-3 py-2 bg-amber-600 text-white text-sm rounded-md hover:bg-amber-700 focus:outline-none focus:ring-2 focus:ring-amber-500",
                  id: "bulk-resend-btn",
                  data: { confirm: "Are you sure you want to resend invitations to selected users?" } %>
              <%= button_to "Expire Selected", bulk_expire_admin_invitations_path, 
                  method: :post,
                  params: { user_ids: [] },
                  class: "px-3 py-2 bg-red-600 text-white text-sm rounded-md hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500",
                  id: "bulk-expire-btn",
                  data: { confirm: "Are you sure you want to expire selected invitations?" } %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Invitations Table -->
    <div class="bg-white dark:bg-secondary-800 shadow rounded-lg overflow-hidden">
      <div class="px-6 py-4 border-b border-secondary-200 dark:border-secondary-700">
        <h3 class="text-lg font-medium text-secondary-900 dark:text-white">Active Invitations</h3>
      </div>
      
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-secondary-200 dark:divide-secondary-700">
          <thead class="bg-secondary-50 dark:bg-secondary-700">
            <tr>
              <% if can_manage_users? %>
                <th class="px-6 py-3 text-left">
                  <input type="checkbox" id="select-all" class="rounded border-secondary-300 text-primary-600 focus:ring-primary-500">
                </th>
              <% end %>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 dark:text-secondary-300 uppercase tracking-wider">User</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 dark:text-secondary-300 uppercase tracking-wider">Status</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 dark:text-secondary-300 uppercase tracking-wider">Sent</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 dark:text-secondary-300 uppercase tracking-wider">Expires</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-secondary-500 dark:text-secondary-300 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white dark:bg-secondary-800 divide-y divide-secondary-200 dark:divide-secondary-700">
            <% @invitations.each do |invitation| %>
              <tr class="hover:bg-secondary-50 dark:hover:bg-secondary-700">
                <% if can_manage_users? %>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <input type="checkbox" class="invitation-checkbox rounded border-secondary-300 text-primary-600 focus:ring-primary-500" value="<%= invitation.id %>">
                  </td>
                <% end %>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <div class="flex-shrink-0 h-10 w-10">
                      <div class="h-10 w-10 bg-primary-600 rounded-full flex items-center justify-center">
                        <span class="text-white font-medium"><%= invitation.username.first.upcase %></span>
                      </div>
                    </div>
                    <div class="ml-4">
                      <div class="text-sm font-medium text-secondary-900 dark:text-white">
                        <%= link_to invitation.display_name, admin_user_path(invitation), class: "hover:text-primary-600" %>
                      </div>
                      <div class="text-sm text-secondary-500 dark:text-secondary-400">@<%= invitation.username %></div>
                      <div class="text-xs text-secondary-400 dark:text-secondary-500"><%= invitation.email %></div>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <% if invitation.invitation_expired? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200">
                      Expired
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-200">
                      Pending
                    </span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-secondary-500 dark:text-secondary-400">
                  <%= invitation.invitation_sent_at&.strftime("%b %d, %Y") || "Not sent" %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-secondary-500 dark:text-secondary-400">
                  <% if invitation.invitation_sent_at %>
                    <% expires_at = invitation.invitation_sent_at + 30.days %>
                    <% if expires_at < Time.current %>
                      <span class="text-red-600 dark:text-red-400">Expired</span>
                    <% else %>
                      <% days_remaining = ((expires_at - Time.current) / 1.day).to_i %>
                      <span class="<%= days_remaining <= 3 ? 'text-red-600 dark:text-red-400' : 'text-secondary-500 dark:text-secondary-400' %>">
                        <%= pluralize(days_remaining, 'day') %> left
                      </span>
                    <% end %>
                  <% else %>
                    <span class="text-secondary-400">-</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <div class="flex justify-end space-x-2">
                    <%= link_to "View", admin_user_path(invitation), 
                        class: "text-primary-600 hover:text-primary-900 dark:text-primary-400 dark:hover:text-primary-300" %>
                    <% if can_manage_users? && invitation.invitation_pending? %>
                      <%= button_to "Resend", resend_invitation_admin_user_path(invitation), 
                          method: :patch,
                          data: { confirm: "Are you sure you want to resend the invitation?" },
                          class: "text-amber-600 hover:text-amber-900 dark:text-amber-400 dark:hover:text-amber-300 bg-transparent border-0 p-0 cursor-pointer underline" %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if @pagy.pages > 1 %>
        <div class="px-6 py-4 border-t border-secondary-200 dark:border-secondary-700">
          <%== pagy_nav(@pagy) %>
        </div>
      <% end %>
    </div>

    <!-- Cleanup Actions -->
    <% if can_manage_users? && @stats[:expired_invitations] > 0 %>
      <div class="mt-8 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-6">
        <div class="flex items-start">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3 flex-1">
            <h3 class="text-sm font-medium text-red-800 dark:text-red-200">
              <%= pluralize(@stats[:expired_invitations], 'expired invitation') %> found
            </h3>
            <div class="mt-2 text-sm text-red-700 dark:text-red-300">
              <p>You have expired invitations that may need cleanup. Choose an action:</p>
            </div>
            <div class="mt-4 flex space-x-3">
              <%= button_to "Send Expiration Notices", cleanup_expired_admin_invitations_path, 
                  method: :post,
                  params: { action_type: 'notify' },
                  class: "inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-red-700 bg-red-100 hover:bg-red-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 dark:bg-red-800 dark:text-red-200 dark:hover:bg-red-700",
                  data: { confirm: "Send expiration notices to #{@stats[:expired_invitations]} users?" } %>
              <%= button_to "Convert to Deactivated", cleanup_expired_admin_invitations_path, 
                  method: :post,
                  params: { action_type: 'deactivate' },
                  class: "inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-red-700 bg-red-100 hover:bg-red-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 dark:bg-red-800 dark:text-red-200 dark:hover:bg-red-700",
                  data: { confirm: "Convert #{@stats[:expired_invitations]} expired invitations to deactivated status?" } %>
              <%= button_to "Delete Expired", cleanup_expired_admin_invitations_path, 
                  method: :post,
                  params: { action_type: 'delete' },
                  class: "inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500",
                  data: { confirm: "Permanently delete #{@stats[:expired_invitations]} expired invitations? This cannot be undone." } %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<script>
function toggleBulkActions() {
  const panel = document.getElementById('bulk-actions-panel');
  panel.classList.toggle('hidden');
}

// Handle select all checkbox
document.getElementById('select-all')?.addEventListener('change', function() {
  const checkboxes = document.querySelectorAll('.invitation-checkbox');
  checkboxes.forEach(cb => cb.checked = this.checked);
  updateSelectedCount();
});

// Handle individual checkboxes
document.querySelectorAll('.invitation-checkbox').forEach(cb => {
  cb.addEventListener('change', updateSelectedCount);
});

function updateSelectedCount() {
  const selected = document.querySelectorAll('.invitation-checkbox:checked');
  document.getElementById('selected-count').textContent = selected.length;
  
  // Update bulk action forms
  const userIds = Array.from(selected).map(cb => cb.value);
  document.getElementById('bulk-resend-btn').form.querySelector('input[name="user_ids[]"]').value = userIds.join(',');
  document.getElementById('bulk-expire-btn').form.querySelector('input[name="user_ids[]"]').value = userIds.join(',');
}
</script>
