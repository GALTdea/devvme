<% content_for :title, "Bulk Create Invitations - Admin" %>

<div class="min-h-screen bg-secondary-50 dark:bg-secondary-900">
  <!-- Header -->
  <%= admin_page_header("Bulk Create Invitations", "Import multiple users from CSV or create invitations manually") do %>
    <%= link_to admin_invitations_path, class: "inline-flex items-center px-4 py-2 border border-secondary-300 shadow-sm text-sm font-medium rounded-md text-secondary-700 bg-white hover:bg-secondary-50 dark:bg-secondary-700 dark:border-secondary-600 dark:text-secondary-200 dark:hover:bg-secondary-600" do %>
      ← Back to Invitations
    <% end %>
  <% end %>

  <!-- Breadcrumbs -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <%= admin_breadcrumbs(
      { text: "Admin Dashboard", path: admin_root_path },
      { text: "Invitation Management", path: admin_invitations_path },
      { text: "Bulk Create", path: bulk_create_admin_invitations_path }
    ) %>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      
      <!-- Main Form -->
      <div class="lg:col-span-2">
        <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
          <div class="px-6 py-4 border-b border-secondary-200 dark:border-secondary-700">
            <h3 class="text-lg font-medium text-secondary-900 dark:text-white">Import Methods</h3>
            <p class="mt-1 text-sm text-secondary-600 dark:text-secondary-400">
              Choose how you'd like to create multiple invitations
            </p>
          </div>

          <div class="p-6">
            <!-- Tab Navigation -->
            <div class="border-b border-secondary-200 dark:border-secondary-700 mb-6">
              <nav class="-mb-px flex space-x-8">
                <button type="button" onclick="showTab('csv')" id="csv-tab" class="tab-button active border-transparent text-secondary-600 hover:text-secondary-800 hover:border-secondary-300 whitespace-nowrap py-2 px-1 border-b-2 font-medium text-sm">
                  CSV Upload
                </button>
                <button type="button" onclick="showTab('manual')" id="manual-tab" class="tab-button border-transparent text-secondary-600 hover:text-secondary-800 hover:border-secondary-300 whitespace-nowrap py-2 px-1 border-b-2 font-medium text-sm">
                  Manual Entry
                </button>
              </nav>
            </div>

            <!-- CSV Upload Tab -->
            <div id="csv-content" class="tab-content">
              <%= form_with url: bulk_create_admin_invitations_path, method: :post, multipart: true, local: true, class: "space-y-6" do |form| %>
                <div>
                  <label class="block text-sm font-medium text-secondary-700 dark:text-secondary-300 mb-2">
                    Upload CSV File
                  </label>
                  <%= form.file_field :csv_file, 
                      accept: ".csv",
                      class: "block w-full text-sm text-secondary-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-primary-50 file:text-primary-700 hover:file:bg-primary-100 dark:file:bg-primary-900 dark:file:text-primary-200" %>
                  <p class="mt-2 text-xs text-secondary-500 dark:text-secondary-400">
                    Upload a CSV file with user information. Maximum file size: 10MB
                  </p>
                </div>

                <div class="flex items-center justify-end space-x-4">
                  <%= link_to "Download Template", "#", class: "inline-flex items-center px-4 py-2 border border-secondary-300 shadow-sm text-sm font-medium rounded-md text-secondary-700 bg-white hover:bg-secondary-50 dark:bg-secondary-700 dark:border-secondary-600 dark:text-secondary-200 dark:hover:bg-secondary-600" do %>
                    <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    CSV Template
                  <% end %>
                  <%= form.submit "Upload & Create Invitations", 
                      class: "inline-flex items-center px-6 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500",
                      data: { disable_with: "Processing..." } %>
                </div>
              <% end %>
            </div>

            <!-- Manual Entry Tab -->
            <div id="manual-content" class="tab-content hidden">
              <%= form_with url: bulk_create_admin_invitations_path, method: :post, local: true, class: "space-y-6" do |form| %>
                <div>
                  <label class="block text-sm font-medium text-secondary-700 dark:text-secondary-300 mb-2">
                    User Entries
                  </label>
                  <%= form.text_area :manual_entries, 
                      rows: 10,
                      placeholder: "Enter user information, one per line. Supported formats:\n\nemail@example.com\n\"John Doe\" <john@example.com>\nemail@example.com,Full Name,Job Title\n\nExample:\njohn@example.com\n\"Jane Smith\" <jane@company.com>\nbob@startup.com,Bob Johnson,CTO",
                      class: "block w-full rounded-md border-secondary-300 dark:border-secondary-600 dark:bg-secondary-700 dark:text-white shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm font-mono" %>
                  <p class="mt-2 text-xs text-secondary-500 dark:text-secondary-400">
                    Enter one user per line. Supports email only, "Name" &lt;email&gt;, or comma-separated values.
                  </p>
                </div>

                <div class="flex items-center justify-end">
                  <%= form.submit "Create Invitations", 
                      class: "inline-flex items-center px-6 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500",
                      data: { disable_with: "Creating..." } %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Instructions Sidebar -->
      <div class="lg:col-span-1">
        <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
          <div class="px-6 py-4 border-b border-secondary-200 dark:border-secondary-700">
            <h3 class="text-lg font-medium text-secondary-900 dark:text-white">📋 Instructions</h3>
          </div>
          
          <div class="px-6 py-4">
            <div class="space-y-4 text-sm text-secondary-600 dark:text-secondary-400">
              <div>
                <h4 class="font-medium text-secondary-900 dark:text-white mb-2">CSV Format</h4>
                <p>Your CSV should include these columns:</p>
                <ul class="mt-2 space-y-1 text-xs">
                  <li>• <strong>email</strong> (required)</li>
                  <li>• full_name</li>
                  <li>• job_title</li>
                  <li>• location</li>
                  <li>• bio</li>
                  <li>• headline</li>
                  <li>• skills (comma-separated)</li>
                  <li>• github_url</li>
                  <li>• linkedin_url</li>
                  <li>• website_url</li>
                  <li>• twitter_url</li>
                  <li>• contact_email</li>
                  <li>• phone</li>
                  <li>• role (user/admin)</li>
                </ul>
              </div>

              <div>
                <h4 class="font-medium text-secondary-900 dark:text-white mb-2">Manual Entry</h4>
                <p>Supported formats:</p>
                <ul class="mt-2 space-y-1 text-xs font-mono">
                  <li>• email@example.com</li>
                  <li>• "Name" &lt;email@example.com&gt;</li>
                  <li>• email,Name,Job Title</li>
                </ul>
              </div>

              <div>
                <h4 class="font-medium text-secondary-900 dark:text-white mb-2">What Happens</h4>
                <ul class="mt-2 space-y-1 text-xs">
                  <li>• Users are created with "invited" status</li>
                  <li>• Usernames are auto-generated from emails</li>
                  <li>• Invitation emails are sent automatically</li>
                  <li>• Duplicates are skipped</li>
                  <li>• All actions are logged</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <!-- Tips Card -->
        <div class="bg-blue-50 dark:bg-blue-900/20 shadow rounded-lg mt-6">
          <div class="px-6 py-4 border-b border-blue-200 dark:border-blue-800">
            <h3 class="text-lg font-medium text-blue-900 dark:text-blue-100">💡 Best Practices</h3>
          </div>
          <div class="px-6 py-4">
            <ul class="space-y-2 text-sm text-blue-800 dark:text-blue-200">
              <li class="flex items-start">
                <span class="text-blue-500 mr-2">•</span>
                <span>Test with a small batch first</span>
              </li>
              <li class="flex items-start">
                <span class="text-blue-500 mr-2">•</span>
                <span>Include as much profile info as possible</span>
              </li>
              <li class="flex items-start">
                <span class="text-blue-500 mr-2">•</span>
                <span>Verify email addresses are valid</span>
              </li>
              <li class="flex items-start">
                <span class="text-blue-500 mr-2">•</span>
                <span>Check for duplicates before importing</span>
              </li>
              <li class="flex items-start">
                <span class="text-blue-500 mr-2">•</span>
                <span>Monitor the invitation analytics</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function showTab(tabName) {
  // Hide all tab contents
  document.querySelectorAll('.tab-content').forEach(content => {
    content.classList.add('hidden');
  });
  
  // Remove active class from all tabs
  document.querySelectorAll('.tab-button').forEach(button => {
    button.classList.remove('active', 'border-primary-500', 'text-primary-600');
    button.classList.add('border-transparent', 'text-secondary-600');
  });
  
  // Show selected tab content
  document.getElementById(tabName + '-content').classList.remove('hidden');
  
  // Add active class to selected tab
  const activeTab = document.getElementById(tabName + '-tab');
  activeTab.classList.add('active', 'border-primary-500', 'text-primary-600');
  activeTab.classList.remove('border-transparent', 'text-secondary-600');
}
</script>

<style>
.tab-button.active {
  border-color: rgb(59 130 246);
  color: rgb(59 130 246);
}
</style>
