<% content_for :title, "Invitation Analytics - Admin" %>

<div class="min-h-screen bg-secondary-50 dark:bg-secondary-900">
  <!-- Header -->
  <%= admin_page_header("Invitation Analytics", "Track invitation performance, conversion rates, and user engagement metrics") do %>
    <div class="flex items-center space-x-3">
      <!-- Time Range Selector -->
      <div class="flex items-center space-x-2">
        <label for="time-range" class="text-sm font-medium text-secondary-700 dark:text-secondary-300">Time Range:</label>
        <%= form_with url: analytics_admin_invitations_path, method: :get, local: true, class: "inline-flex" do |form| %>
          <%= form.select :time_range, 
              options_for_select([
                ['Last 7 days', '7_days'],
                ['Last 30 days', '30_days'],
                ['Last 90 days', '90_days'],
                ['Last year', '1_year']
              ], @time_range),
              { include_blank: false },
              { 
                id: "time-range",
                class: "block w-full rounded-md border-secondary-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm dark:bg-secondary-700 dark:border-secondary-600 dark:text-white",
                onchange: "this.form.submit()"
              } %>
        <% end %>
      </div>
      <%= link_to admin_invitations_path, class: "inline-flex items-center px-4 py-2 border border-secondary-300 shadow-sm text-sm font-medium rounded-md text-secondary-700 bg-white hover:bg-secondary-50 dark:bg-secondary-700 dark:border-secondary-600 dark:text-secondary-200 dark:hover:bg-secondary-600" do %>
        ← Back to Invitations
      <% end %>
    </div>
  <% end %>

  <!-- Breadcrumbs -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <%= admin_breadcrumbs(
      { text: "Admin Dashboard", path: admin_root_path },
      { text: "Invitation Management", path: admin_invitations_path },
      { text: "Analytics", path: analytics_admin_invitations_path }
    ) %>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <!-- Overview Metrics -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Total Invitations</p>
              <p class="text-2xl font-semibold text-secondary-900 dark:text-white"><%= @analytics_data[:overview][:total_invitations] %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-green-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Claimed</p>
              <p class="text-2xl font-semibold text-secondary-900 dark:text-white"><%= @analytics_data[:overview][:claimed_invitations] %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-purple-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Conversion Rate</p>
              <p class="text-2xl font-semibold text-secondary-900 dark:text-white">
                <%= @analytics_data[:overview][:conversion_rate] %>%
                <% if @analytics_data[:conversion][:benchmark] %>
                  <span class="text-sm font-normal <%= @analytics_data[:overview][:conversion_rate] >= @analytics_data[:conversion][:benchmark] ? 'text-green-600' : 'text-red-600' %>">
                    (<%= @analytics_data[:overview][:conversion_rate] >= @analytics_data[:conversion][:benchmark] ? '+' : '' %><%= (@analytics_data[:overview][:conversion_rate] - @analytics_data[:conversion][:benchmark]).round(1) %>%)
                  </span>
                <% end %>
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-amber-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Avg. Claim Time</p>
              <p class="text-2xl font-semibold text-secondary-900 dark:text-white">
                <%= @analytics_data[:overview][:average_claim_time].round(1) %>h
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
      <!-- Invitation Trends Chart -->
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-6 py-4 border-b border-secondary-200 dark:border-secondary-700">
          <h3 class="text-lg font-medium text-secondary-900 dark:text-white">Invitation Trends</h3>
          <p class="mt-1 text-sm text-secondary-600 dark:text-secondary-400">
            Invitations sent vs claimed over time
          </p>
        </div>
        <div class="p-6">
          <div class="space-y-4">
            <% @analytics_data[:trends][:sent].each do |date, count| %>
              <% claimed_count = @analytics_data[:trends][:claimed][date] || 0 %>
              <% conversion_rate = count > 0 ? (claimed_count.to_f / count * 100).round(1) : 0 %>
              <div class="flex items-center justify-between">
                <div class="text-sm font-medium text-secondary-900 dark:text-white">
                  <%= date.strftime("%b %d") if date.respond_to?(:strftime) %>
                </div>
                <div class="flex items-center space-x-4">
                  <div class="text-sm text-secondary-600 dark:text-secondary-400">
                    <span class="text-blue-600">Sent: <%= count %></span>
                    <span class="text-green-600 ml-2">Claimed: <%= claimed_count %></span>
                    <span class="text-purple-600 ml-2">(<%= conversion_rate %>%)</span>
                  </div>
                </div>
              </div>
              <div class="w-full bg-secondary-200 dark:bg-secondary-600 rounded-full h-2">
                <div class="bg-blue-600 h-2 rounded-full" style="width: <%= count > 0 ? [100, (count.to_f / @analytics_data[:trends][:sent].values.max * 100)].min : 0 %>%"></div>
                <div class="bg-green-600 h-2 rounded-full -mt-2" style="width: <%= claimed_count > 0 ? [100, (claimed_count.to_f / @analytics_data[:trends][:sent].values.max * 100)].min : 0 %>%"></div>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Status Breakdown -->
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-6 py-4 border-b border-secondary-200 dark:border-secondary-700">
          <h3 class="text-lg font-medium text-secondary-900 dark:text-white">Current Status</h3>
          <p class="mt-1 text-sm text-secondary-600 dark:text-secondary-400">
            Breakdown of invitation statuses
          </p>
        </div>
        <div class="p-6">
          <div class="space-y-4">
            <div class="flex items-center justify-between">
              <div class="flex items-center">
                <div class="w-3 h-3 bg-amber-500 rounded-full mr-3"></div>
                <span class="text-sm font-medium text-secondary-900 dark:text-white">Pending</span>
              </div>
              <span class="text-sm text-secondary-600 dark:text-secondary-400"><%= @analytics_data[:status_breakdown][:pending] %></span>
            </div>
            <div class="flex items-center justify-between">
              <div class="flex items-center">
                <div class="w-3 h-3 bg-red-500 rounded-full mr-3"></div>
                <span class="text-sm font-medium text-secondary-900 dark:text-white">Expired</span>
              </div>
              <span class="text-sm text-secondary-600 dark:text-secondary-400"><%= @analytics_data[:status_breakdown][:expired] %></span>
            </div>
            <div class="flex items-center justify-between">
              <div class="flex items-center">
                <div class="w-3 h-3 bg-green-500 rounded-full mr-3"></div>
                <span class="text-sm font-medium text-secondary-900 dark:text-white">Recent (7 days)</span>
              </div>
              <span class="text-sm text-secondary-600 dark:text-secondary-400"><%= @analytics_data[:status_breakdown][:recent] %></span>
            </div>
            <div class="flex items-center justify-between">
              <div class="flex items-center">
                <div class="w-3 h-3 bg-gray-500 rounded-full mr-3"></div>
                <span class="text-sm font-medium text-secondary-900 dark:text-white">Old (>30 days)</span>
              </div>
              <span class="text-sm text-secondary-600 dark:text-secondary-400"><%= @analytics_data[:status_breakdown][:old] %></span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Performance Metrics -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-6 py-4 border-b border-secondary-200 dark:border-secondary-700">
          <h3 class="text-lg font-medium text-secondary-900 dark:text-white">Email Delivery Performance</h3>
          <p class="mt-1 text-sm text-secondary-600 dark:text-secondary-400">
            Email delivery success rates and metrics
          </p>
        </div>
        <div class="p-6">
          <div class="space-y-4">
            <div class="flex items-center justify-between">
              <span class="text-sm font-medium text-secondary-900 dark:text-white">Delivery Rate</span>
              <span class="text-sm text-secondary-600 dark:text-secondary-400">
                <%= @analytics_data[:performance][:delivery_rate] %>%
                (<%= @analytics_data[:performance][:successful_deliveries] %>/<%= @analytics_data[:performance][:total_attempts] %>)
              </span>
            </div>
            <div class="w-full bg-secondary-200 dark:bg-secondary-600 rounded-full h-2">
              <div class="bg-green-600 h-2 rounded-full" style="width: <%= @analytics_data[:performance][:delivery_rate] %>%"></div>
            </div>
            
            <div class="mt-6">
              <h4 class="text-sm font-medium text-secondary-900 dark:text-white mb-3">Common Issues</h4>
              <div class="space-y-2">
                <% @analytics_data[:performance][:failure_reasons].each do |reason, count| %>
                  <div class="flex items-center justify-between text-sm">
                    <span class="text-secondary-600 dark:text-secondary-400"><%= reason %></span>
                    <span class="text-secondary-900 dark:text-white font-medium"><%= count %></span>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Conversion by Time Period -->
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-6 py-4 border-b border-secondary-200 dark:border-secondary-700">
          <h3 class="text-lg font-medium text-secondary-900 dark:text-white">Conversion by Time Period</h3>
          <p class="mt-1 text-sm text-secondary-600 dark:text-secondary-400">
            How quickly users claim their invitations
          </p>
        </div>
        <div class="p-6">
          <div class="space-y-4">
            <% @analytics_data[:conversion][:by_period].each do |period_data| %>
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium text-secondary-900 dark:text-white">
                  <%= period_data[:period].humanize %>
                </span>
                <div class="text-right">
                  <div class="text-sm text-secondary-900 dark:text-white font-medium">
                    <%= period_data[:rate] %>%
                  </div>
                  <div class="text-xs text-secondary-500 dark:text-secondary-400">
                    <%= period_data[:claimed] %>/<%= period_data[:sent] %>
                  </div>
                </div>
              </div>
              <div class="w-full bg-secondary-200 dark:bg-secondary-600 rounded-full h-2">
                <div class="bg-purple-600 h-2 rounded-full" style="width: <%= [100, period_data[:rate]].min %>%"></div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Recent Activity -->
    <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
      <div class="px-6 py-4 border-b border-secondary-200 dark:border-secondary-700">
        <h3 class="text-lg font-medium text-secondary-900 dark:text-white">Recent Activity</h3>
        <p class="mt-1 text-sm text-secondary-600 dark:text-secondary-400">
          Latest invitation-related actions
        </p>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-secondary-200 dark:divide-secondary-700">
          <thead class="bg-secondary-50 dark:bg-secondary-700">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 dark:text-secondary-300 uppercase tracking-wider">Action</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 dark:text-secondary-300 uppercase tracking-wider">Admin</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 dark:text-secondary-300 uppercase tracking-wider">Target</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 dark:text-secondary-300 uppercase tracking-wider">Date</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 dark:text-secondary-300 uppercase tracking-wider">Details</th>
            </tr>
          </thead>
          <tbody class="bg-white dark:bg-secondary-800 divide-y divide-secondary-200 dark:divide-secondary-700">
            <% @analytics_data[:recent_activity].each do |activity| %>
              <tr class="hover:bg-secondary-50 dark:hover:bg-secondary-700">
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                         <%= case activity[:action]
                             when 'create_invited_user'
                               'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200'
                             when 'resend_invitation'
                               'bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-200'
                             when 'bulk_create_invitations_csv', 'bulk_create_invitations_manual'
                               'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200'
                             else
                               'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200'
                             end %>">
                    <%= activity[:action].humanize %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-secondary-900 dark:text-white">
                  <%= activity[:admin_name] %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-secondary-900 dark:text-white">
                  <%= activity[:target_name] || '-' %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-secondary-500 dark:text-secondary-400">
                  <%= activity[:created_at].strftime("%b %d, %Y %I:%M %p") %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-secondary-500 dark:text-secondary-400">
                  <% if activity[:details]['resent_count'] %>
                    Resent: <%= activity[:details]['resent_count'] %>
                  <% elsif activity[:details]['successful'] %>
                    Success: <%= activity[:details]['successful'] %>
                  <% elsif activity[:details]['invitation_sent'] %>
                    Email sent: <%= activity[:details]['invitation_sent'] %>
                  <% else %>
                    -
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
