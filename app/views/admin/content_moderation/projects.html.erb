<% content_for :title, "All Projects - Admin" %>

<div class="min-h-screen bg-secondary-50 dark:bg-secondary-900">
  <!-- Header -->
  <div class="bg-white dark:bg-secondary-800 shadow">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="py-6">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-2xl font-bold text-secondary-900 dark:text-white">All Projects</h1>
            <p class="mt-1 text-sm text-secondary-600 dark:text-secondary-400">
              Manage and moderate all projects
            </p>
          </div>
          <div class="flex items-center space-x-4">
            <%= link_to admin_root_path, class: "inline-flex items-center px-4 py-2 border border-secondary-300 shadow-sm text-sm font-medium rounded-md text-secondary-700 bg-white hover:bg-secondary-50 dark:bg-secondary-700 dark:border-secondary-600 dark:text-secondary-200 dark:hover:bg-secondary-600" do %>
              ← Back to Dashboard
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Total Projects</p>
              <p class="text-lg font-semibold text-secondary-900 dark:text-white"><%= @pagy.count %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-green-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Published</p>
              <p class="text-lg font-semibold text-secondary-900 dark:text-white"><%= Project.where(status: 'published').count %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-yellow-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Drafts</p>
              <p class="text-lg font-semibold text-secondary-900 dark:text-white"><%= Project.where(status: 'draft').count %></p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Filters and Search -->
    <div class="bg-white dark:bg-secondary-800 shadow rounded-lg mb-6">
      <div class="p-6">
        <%= form_with url: admin_content_moderation_projects_path, method: :get, class: "flex flex-wrap gap-4", local: true do |form| %>
          <div class="flex-1 min-w-64">
            <%= form.text_field :search, placeholder: "Search by title or description...", 
                value: params[:search], 
                class: "block w-full px-3 py-2 border border-secondary-300 rounded-md shadow-sm focus:outline-none focus:ring-primary-500 focus:border-primary-500 dark:bg-secondary-700 dark:border-secondary-600 dark:text-white" %>
          </div>
          <div>
            <%= form.select :status, options_for_select([
              ['All Status', ''], 
              ['Published', 'published'], 
              ['Draft', 'draft']
            ], params[:status]), 
                {}, { class: "block px-3 py-2 border border-secondary-300 rounded-md shadow-sm focus:outline-none focus:ring-primary-500 focus:border-primary-500 dark:bg-secondary-700 dark:border-secondary-600 dark:text-white" } %>
          </div>
          <div>
            <%= form.select :sort, options_for_select([
              ['Newest First', 'created_at DESC'], 
              ['Oldest First', 'created_at ASC'], 
              ['Title A-Z', 'title ASC'],
              ['Title Z-A', 'title DESC']
            ], params[:sort] || 'created_at DESC'), 
                {}, { class: "block px-3 py-2 border border-secondary-300 rounded-md shadow-sm focus:outline-none focus:ring-primary-500 focus:border-primary-500 dark:bg-secondary-700 dark:border-secondary-600 dark:text-white" } %>
          </div>
          <div>
            <%= form.submit "Filter", class: "px-4 py-2 bg-primary-600 border border-transparent rounded-md font-medium text-white hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500" %>
          </div>
          <% if params[:search].present? || params[:status].present? || params[:sort] != 'created_at DESC' %>
            <div>
              <%= link_to "Clear", admin_content_moderation_projects_path, class: "px-4 py-2 bg-secondary-600 border border-transparent rounded-md font-medium text-white hover:bg-secondary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-secondary-500" %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Projects Table -->
    <div class="bg-white dark:bg-secondary-800 shadow rounded-lg overflow-hidden">
      <div class="px-6 py-4 border-b border-secondary-200 dark:border-secondary-700">
        <h3 class="text-lg font-medium text-secondary-900 dark:text-white">Projects</h3>
      </div>
      
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-secondary-200 dark:divide-secondary-700">
          <thead class="bg-secondary-50 dark:bg-secondary-700">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 dark:text-secondary-300 uppercase tracking-wider">Project</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 dark:text-secondary-300 uppercase tracking-wider">Author</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 dark:text-secondary-300 uppercase tracking-wider">Status</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 dark:text-secondary-300 uppercase tracking-wider">Created</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 dark:text-secondary-300 uppercase tracking-wider">Tech Stack</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-secondary-500 dark:text-secondary-300 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white dark:bg-secondary-800 divide-y divide-secondary-200 dark:divide-secondary-700">
            <% @projects.each do |project| %>
              <tr class="hover:bg-secondary-50 dark:hover:bg-secondary-700">
                <td class="px-6 py-4">
                  <div class="flex items-start">
                    <div class="flex-1 min-w-0">
                      <div class="text-sm font-medium text-secondary-900 dark:text-white truncate">
                        <%= link_to project.title, admin_content_moderation_moderate_project_path(project), class: "hover:text-primary-600" %>
                      </div>
                      <div class="text-sm text-secondary-500 dark:text-secondary-400 mt-1 line-clamp-2">
                        <%= truncate(project.description, length: 100) %>
                      </div>
                      <% if project.github_url.present? %>
                        <div class="mt-2">
                          <a href="<%= project.github_url %>" target="_blank" class="inline-flex items-center text-xs text-primary-600 hover:text-primary-800 dark:text-primary-400 dark:hover:text-primary-300">
                            <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                              <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd" />
                            </svg>
                            View on GitHub
                          </a>
                        </div>
                      <% end %>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <div class="flex-shrink-0 h-8 w-8">
                      <% if project.user.avatar.attached? %>
                        <%= image_tag project.user.avatar_thumbnail, class: "h-8 w-8 rounded-full" %>
                      <% else %>
                        <div class="h-8 w-8 bg-primary-600 rounded-full flex items-center justify-center">
                          <span class="text-white text-sm font-medium"><%= project.user.username.first.upcase %></span>
                        </div>
                      <% end %>
                    </div>
                    <div class="ml-3">
                      <div class="text-sm font-medium text-secondary-900 dark:text-white">
                        <%= project.user.display_name %>
                      </div>
                      <div class="text-sm text-secondary-500 dark:text-secondary-400">@<%= project.user.username %></div>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                         <%= if project.status == 'published'
                               'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200'
                             else
                               'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200'
                             end %>">
                    <%= project.status.humanize %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-secondary-500 dark:text-secondary-400">
                  <%= project.created_at.strftime("%b %d, %Y") %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-secondary-500 dark:text-secondary-400">
                  <% if project.technologies_used.any? %>
                    <div class="flex flex-wrap gap-1">
                      <% project.technologies_used.first(3).each do |tech| %>
                        <span class="inline-flex items-center px-2 py-1 rounded text-xs bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">
                          <%= tech %>
                        </span>
                      <% end %>
                      <% if project.technologies_used.size > 3 %>
                        <span class="text-xs text-secondary-400 dark:text-secondary-500">
                          +<%= project.technologies_used.size - 3 %> more
                        </span>
                      <% end %>
                    </div>
                  <% else %>
                    <span class="text-xs text-secondary-400 dark:text-secondary-500">No technologies</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <div class="flex justify-end space-x-2">
                    <%= link_to "View", admin_content_moderation_moderate_project_path(project), 
                        class: "text-primary-600 hover:text-primary-900 dark:text-primary-400 dark:hover:text-primary-300" %>
                    <% if project.status == 'published' %>
                      <%= link_to "Unpublish", admin_content_moderation_moderate_project_path(project, moderation_action: 'unpublish'), 
                          method: :patch,
                          data: { confirm: "Are you sure you want to unpublish this project?" },
                          class: "text-orange-600 hover:text-orange-900 dark:text-orange-400 dark:hover:text-orange-300" %>
                    <% else %>
                      <%= link_to "Publish", admin_content_moderation_moderate_project_path(project, moderation_action: 'publish'), 
                          method: :patch,
                          data: { confirm: "Are you sure you want to publish this project?" },
                          class: "text-green-600 hover:text-green-900 dark:text-green-400 dark:hover:text-green-300" %>
                    <% end %>
                    <%= link_to "Delete", admin_content_moderation_moderate_project_path(project, moderation_action: 'delete'), 
                        method: :patch,
                        data: { confirm: "Are you sure you want to delete this project? This action cannot be undone." },
                        class: "text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if @pagy.pages > 1 %>
        <div class="px-6 py-4 border-t border-secondary-200 dark:border-secondary-700">
          <%== pagy_nav(@pagy) %>
        </div>
      <% end %>
    </div>
  </div>
</div>