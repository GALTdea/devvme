<% content_for :title, "Admin Dashboard" %>

<div class="min-h-screen bg-secondary-50 dark:bg-secondary-900">
  <!-- Admin Header -->
  <div class="bg-white dark:bg-secondary-800 shadow">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="py-6">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-2xl font-bold text-secondary-900 dark:text-white">Admin Dashboard</h1>
            <p class="mt-1 text-sm text-secondary-600 dark:text-secondary-400">
              Manage users, content, and monitor platform activity
            </p>
          </div>
          <div class="flex items-center space-x-4">
            <!-- Time Range Selector -->
            <div class="flex items-center space-x-2">
              <label for="time-range" class="text-sm font-medium text-secondary-700 dark:text-secondary-300">Time Range:</label>
              <%= form_with url: admin_root_path, method: :get, local: true, class: "inline-flex" do |form| %>
                <%= form.select :time_range, 
                    options_for_select([
                      ['Last 24 hours', '24_hours'],
                      ['Last 7 days', '7_days'],
                      ['Last 30 days', '30_days'],
                      ['Last 90 days', '90_days'],
                      ['Last year', '1_year']
                    ], @time_range),
                    { include_blank: false },
                    { 
                      id: "time-range",
                      class: "block w-full rounded-md border-secondary-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm dark:bg-secondary-700 dark:border-secondary-600 dark:text-white",
                      onchange: "this.form.submit()"
                    } %>
              <% end %>
            </div>
            
            <!-- Export Button -->
            <div class="flex items-center space-x-2">
              <%= link_to admin_dashboard_export_path(format: :csv, time_range: @time_range), 
                  class: "inline-flex items-center px-3 py-2 border border-secondary-300 shadow-sm text-sm leading-4 font-medium rounded-md text-secondary-700 bg-white hover:bg-secondary-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 dark:bg-secondary-700 dark:border-secondary-600 dark:text-secondary-200 dark:hover:bg-secondary-600" do %>
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                Export CSV
              <% end %>
            </div>
            
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200">
              <%= current_user.role.humanize %> Access
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Admin Navigation -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <nav class="flex space-x-4" aria-label="Admin Navigation">
      <%= link_to admin_root_path, 
          class: "bg-primary-100 text-primary-700 dark:bg-primary-900 dark:text-primary-200 px-3 py-2 rounded-md text-sm font-medium" do %>
        Dashboard
      <% end %>
      <%= link_to admin_users_path, 
          class: "text-secondary-600 hover:text-secondary-900 dark:text-secondary-300 dark:hover:text-white px-3 py-2 rounded-md text-sm font-medium hover:bg-secondary-100 dark:hover:bg-secondary-700" do %>
        Users
      <% end %>
      <%= link_to admin_content_moderation_index_path, 
          class: "text-secondary-600 hover:text-secondary-900 dark:text-secondary-300 dark:hover:text-white px-3 py-2 rounded-md text-sm font-medium hover:bg-secondary-100 dark:hover:bg-secondary-700" do %>
        Content Moderation
      <% end %>
      <%= link_to admin_content_moderation_blog_posts_path, 
          class: "text-secondary-600 hover:text-secondary-900 dark:text-secondary-300 dark:hover:text-white px-3 py-2 rounded-md text-sm font-medium hover:bg-secondary-100 dark:hover:bg-secondary-700" do %>
        All Blogs
      <% end %>
      <%= link_to admin_content_moderation_projects_path, 
          class: "text-secondary-600 hover:text-secondary-900 dark:text-secondary-300 dark:hover:text-white px-3 py-2 rounded-md text-sm font-medium hover:bg-secondary-100 dark:hover:bg-secondary-700" do %>
        All Projects
      <% end %>
      <%= link_to admin_activities_path, 
          class: "text-secondary-600 hover:text-secondary-900 dark:text-secondary-300 dark:hover:text-white px-3 py-2 rounded-md text-sm font-medium hover:bg-secondary-100 dark:hover:bg-secondary-700" do %>
        Activity Log
      <% end %>
      <%= link_to admin_analytics_index_path, 
          class: "text-secondary-600 hover:text-secondary-900 dark:text-secondary-300 dark:hover:text-white px-3 py-2 rounded-md text-sm font-medium hover:bg-secondary-100 dark:hover:bg-secondary-700" do %>
        User Analytics
      <% end %>
      <%= link_to admin_visitor_analytics_index_path, 
          class: "text-secondary-600 hover:text-secondary-900 dark:text-secondary-300 dark:hover:text-white px-3 py-2 rounded-md text-sm font-medium hover:bg-secondary-100 dark:hover:bg-secondary-700" do %>
        Visitor Analytics
      <% end %>
      <%= link_to admin_blog_analytics_index_path, 
          class: "text-secondary-600 hover:text-secondary-900 dark:text-secondary-300 dark:hover:text-white px-3 py-2 rounded-md text-sm font-medium hover:bg-secondary-100 dark:hover:bg-secondary-700" do %>
        Blog Analytics
      <% end %>
    </nav>
  </div>

  <!-- Stats Overview -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6 mb-8">
      <!-- Total Users -->
      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400 truncate">Total Users</dt>
                <dd class="text-lg font-medium text-secondary-900 dark:text-white"><%= @user_stats[:total_users] %></dd>
              </dl>
            </div>
          </div>
          <div class="mt-3 text-sm text-secondary-600 dark:text-secondary-400">
            <span class="text-green-600"><%= @user_stats[:active_users] %></span> active in <%= @days == 1 ? '24 hours' : "#{@days} days" %>
          </div>
        </div>
      </div>

      <!-- Online Users (Real-time) -->
      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400 truncate">Online Now</dt>
                <dd class="text-lg font-medium text-secondary-900 dark:text-white" id="online-users"><%= @user_stats[:online_users] %></dd>
              </dl>
            </div>
          </div>
          <div class="mt-3 text-sm text-secondary-600 dark:text-secondary-400">
            <span class="text-blue-600"><%= @user_stats[:active_users_today] %></span> active today
          </div>
        </div>
      </div>

      <!-- New Users in Period -->
      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400 truncate">New Users</dt>
                <dd class="text-lg font-medium text-secondary-900 dark:text-white"><%= @user_stats[:new_users_in_period] %></dd>
              </dl>
            </div>
          </div>
          <div class="mt-3 text-sm text-secondary-600 dark:text-secondary-400">
            in last <%= @days == 1 ? '24 hours' : "#{@days} days" %>
          </div>
        </div>
      </div>

      <!-- Content Stats -->
      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400 truncate">Total Views</dt>
                <dd class="text-lg font-medium text-secondary-900 dark:text-white"><%= @content_stats[:total_views_in_period] %></dd>
              </dl>
            </div>
          </div>
          <div class="mt-3 text-sm text-secondary-600 dark:text-secondary-400">
            in last <%= @days == 1 ? '24 hours' : "#{@days} days" %>
          </div>
        </div>
      </div>

      <!-- Suspended Users -->
      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400 truncate">Suspended</dt>
                <dd class="text-lg font-medium text-secondary-900 dark:text-white"><%= @user_stats[:suspended_users] %></dd>
              </dl>
            </div>
          </div>
          <div class="mt-3 text-sm text-secondary-600 dark:text-secondary-400">
            <span class="text-red-600">Requires attention</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Charts Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
      <!-- Registration Chart -->
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-secondary-900 dark:text-white mb-4">User Registrations</h3>
          <div class="h-64">
            <canvas id="registrationChart"></canvas>
          </div>
        </div>
      </div>

      <!-- Activity Chart -->
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-secondary-900 dark:text-white mb-4">Admin Activity</h3>
          <div class="h-64">
            <canvas id="activityChart"></canvas>
          </div>
        </div>
      </div>
    </div>

    <!-- Content Creation Chart -->
    <div class="mb-8">
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-secondary-900 dark:text-white mb-4">Content Creation</h3>
          <div class="h-64">
            <canvas id="contentChart"></canvas>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Recent Users -->
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-secondary-900 dark:text-white">Recent Users</h3>
          <div class="mt-5">
            <div class="flow-root">
              <ul class="-my-5 divide-y divide-secondary-200 dark:divide-secondary-700">
                <% @recent_users.each do |user| %>
                  <li class="py-4">
                    <div class="flex items-center space-x-4">
                      <div class="flex-shrink-0">
                        <% if user.avatar.attached? %>
                          <%= image_tag user.avatar_thumbnail, class: "h-8 w-8 rounded-full" %>
                        <% else %>
                          <div class="h-8 w-8 bg-primary-600 rounded-full flex items-center justify-center">
                            <span class="text-white text-sm font-medium"><%= user.username.first.upcase %></span>
                          </div>
                        <% end %>
                      </div>
                      <div class="flex-1 min-w-0">
                        <p class="text-sm font-medium text-secondary-900 dark:text-white truncate">
                          <%= link_to user.display_name, admin_user_path(user), class: "hover:text-primary-600" %>
                        </p>
                        <p class="text-sm text-secondary-500 dark:text-secondary-400 truncate">@<%= user.username %></p>
                      </div>
                      <div class="flex-shrink-0">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium 
                               <%= user.suspended? ? 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200' : 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200' %>">
                          <%= user.suspended? ? 'Suspended' : 'Active' %>
                        </span>
                      </div>
                    </div>
                  </li>
                <% end %>
              </ul>
            </div>
            <div class="mt-6">
              <%= link_to admin_users_path, class: "w-full flex justify-center items-center px-4 py-2 border border-secondary-300 shadow-sm text-sm font-medium rounded-md text-secondary-700 bg-white hover:bg-secondary-50 dark:bg-secondary-700 dark:border-secondary-600 dark:text-secondary-200 dark:hover:bg-secondary-600" do %>
                View all users
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Recent Admin Activities -->
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-secondary-900 dark:text-white">Recent Admin Activities</h3>
          <div class="mt-5">
            <div class="flow-root">
              <ul class="-my-5 divide-y divide-secondary-200 dark:divide-secondary-700">
                <% @recent_activities.each do |activity| %>
                  <li class="py-4">
                    <div class="flex space-x-3">
                      <div class="flex-shrink-0">
                        <div class="h-8 w-8 bg-primary-600 rounded-full flex items-center justify-center">
                          <span class="text-white text-sm font-medium"><%= activity.admin.username.first.upcase %></span>
                        </div>
                      </div>
                      <div class="flex-1 min-w-0">
                        <p class="text-sm font-medium text-secondary-900 dark:text-white">
                          <%= activity.admin.username %>
                        </p>
                        <p class="text-sm text-secondary-500 dark:text-secondary-400">
                          <%= activity.action_description %> • <%= activity.target_description %>
                        </p>
                        <p class="text-xs text-secondary-400 dark:text-secondary-500">
                          <%= time_ago_in_words(activity.created_at) %> ago
                        </p>
                      </div>
                    </div>
                  </li>
                <% end %>
              </ul>
            </div>
            <div class="mt-6">
              <%= link_to admin_activities_path, class: "w-full flex justify-center items-center px-4 py-2 border border-secondary-300 shadow-sm text-sm font-medium rounded-md text-secondary-700 bg-white hover:bg-secondary-50 dark:bg-secondary-700 dark:border-secondary-600 dark:text-secondary-200 dark:hover:bg-secondary-600" do %>
                View all activities
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Role Distribution -->
    <div class="mt-8">
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-secondary-900 dark:text-white mb-4">User Role Distribution</h3>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <% @user_stats[:users_by_role].each do |role, count| %>
              <div class="text-center">
                <div class="text-2xl font-bold text-secondary-900 dark:text-white"><%= count %></div>
                <div class="text-sm text-secondary-500 dark:text-secondary-400"><%= role.humanize.pluralize %></div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Chart.js and Real-time Updates -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  // Chart data from Rails
  const registrationData = <%= raw @registration_chart_data.to_json %>;
  const activityData = <%= raw @activity_chart_data.to_json %>;
  const contentData = <%= raw @content_creation_chart_data.to_json %>;

  // Chart.js configuration
  const chartOptions = {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      legend: {
        labels: {
          color: document.documentElement.classList.contains('dark') ? '#e5e7eb' : '#374151'
        }
      }
    },
    scales: {
      x: {
        ticks: {
          color: document.documentElement.classList.contains('dark') ? '#9ca3af' : '#6b7280'
        },
        grid: {
          color: document.documentElement.classList.contains('dark') ? '#374151' : '#e5e7eb'
        }
      },
      y: {
        ticks: {
          color: document.documentElement.classList.contains('dark') ? '#9ca3af' : '#6b7280'
        },
        grid: {
          color: document.documentElement.classList.contains('dark') ? '#374151' : '#e5e7eb'
        }
      }
    }
  };

  // Registration Chart
  const registrationCtx = document.getElementById('registrationChart').getContext('2d');
  new Chart(registrationCtx, {
    type: 'line',
    data: {
      labels: Object.keys(registrationData).map(date => new Date(date).toLocaleDateString()),
      datasets: [{
        label: 'New Registrations',
        data: Object.values(registrationData),
        borderColor: 'rgb(59, 130, 246)',
        backgroundColor: 'rgba(59, 130, 246, 0.1)',
        tension: 0.4
      }]
    },
    options: chartOptions
  });

  // Activity Chart
  const activityCtx = document.getElementById('activityChart').getContext('2d');
  new Chart(activityCtx, {
    type: 'bar',
    data: {
      labels: Object.keys(activityData).map(date => new Date(date).toLocaleDateString()),
      datasets: [{
        label: 'Admin Actions',
        data: Object.values(activityData),
        backgroundColor: 'rgba(16, 185, 129, 0.8)',
        borderColor: 'rgb(16, 185, 129)',
        borderWidth: 1
      }]
    },
    options: chartOptions
  });

  // Content Creation Chart
  const contentCtx = document.getElementById('contentChart').getContext('2d');
  new Chart(contentCtx, {
    type: 'bar',
    data: {
      labels: contentData.map(item => new Date(item.date).toLocaleDateString()),
      datasets: [
        {
          label: 'Blog Posts',
          data: contentData.map(item => item.blog_posts),
          backgroundColor: 'rgba(99, 102, 241, 0.8)',
          borderColor: 'rgb(99, 102, 241)',
          borderWidth: 1
        },
        {
          label: 'Projects',
          data: contentData.map(item => item.projects),
          backgroundColor: 'rgba(168, 85, 247, 0.8)',
          borderColor: 'rgb(168, 85, 247)',
          borderWidth: 1
        }
      ]
    },
    options: chartOptions
  });

  // Real-time updates for online users
  function updateOnlineUsers() {
    fetch('/admin/dashboard/online_users', {
      method: 'GET',
      headers: {
        'Accept': 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      }
    })
    .then(response => response.json())
    .then(data => {
      document.getElementById('online-users').textContent = data.count;
    })
    .catch(error => console.log('Error updating online users:', error));
  }

  // Update online users every 30 seconds
  setInterval(updateOnlineUsers, 30000);

  // Initial update
  updateOnlineUsers();
</script>
