<% content_for :title, "Blog Analytics" %>

<div class="min-h-screen bg-secondary-50 dark:bg-secondary-900" 
     data-controller="visitor-analytics"
     data-visitor-analytics-update-url-value="<%= admin_blog_analytics_index_path %>"
     data-visitor-analytics-time-range-value="<%= @time_range %>"
     data-visitor-analytics-update-interval-value="60000">
  
  <!-- Header -->
  <div class="bg-white dark:bg-secondary-800 shadow">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="py-6">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-2xl font-bold text-secondary-900 dark:text-white">Blog Analytics</h1>
            <p class="mt-1 text-sm text-secondary-600 dark:text-secondary-400">
              Track blog engagement, reading patterns, and conversion metrics
            </p>
          </div>
          <div class="flex items-center space-x-4">
            <!-- Time Range Selector -->
            <div class="flex items-center space-x-2">
              <label for="time-range" class="text-sm font-medium text-secondary-700 dark:text-secondary-300">Time Range:</label>
              <%= form_with url: admin_blog_analytics_index_path, method: :get, local: true, class: "inline-flex" do |form| %>
                <%= form.select :time_range, 
                    options_for_select([
                      ['Last 7 days', '7_days'],
                      ['Last 30 days', '30_days'],
                      ['Last 90 days', '90_days'],
                      ['Last year', '1_year']
                    ], @time_range),
                    { include_blank: false },
                    { 
                      id: "time-range",
                      class: "block w-full rounded-md border-secondary-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm dark:bg-secondary-700 dark:border-secondary-600 dark:text-white",
                      data: { action: "change->visitor-analytics#timeRangeChanged" }
                    } %>
              <% end %>
            </div>

            <!-- Real-time Indicator -->
            <div class="flex items-center space-x-4">
              <div class="flex items-center space-x-2 live-indicator">
                <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
                <span class="text-sm text-secondary-600 dark:text-secondary-400">Live</span>
              </div>
              
              <button type="button"
                      class="inline-flex items-center px-3 py-1 border border-secondary-300 shadow-sm text-xs font-medium rounded text-secondary-700 bg-white hover:bg-secondary-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 dark:bg-secondary-700 dark:border-secondary-600 dark:text-secondary-300 dark:hover:bg-secondary-600"
                      data-action="click->visitor-analytics#refresh">
                <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                </svg>
                Refresh
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Navigation -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <nav class="flex space-x-4" aria-label="Admin Navigation">
      <%= link_to admin_root_path, 
          class: "text-secondary-600 hover:text-secondary-900 dark:text-secondary-300 dark:hover:text-white px-3 py-2 rounded-md text-sm font-medium hover:bg-secondary-100 dark:hover:bg-secondary-700" do %>
        Dashboard
      <% end %>
      <%= link_to admin_analytics_index_path, 
          class: "text-secondary-600 hover:text-secondary-900 dark:text-secondary-300 dark:hover:text-white px-3 py-2 rounded-md text-sm font-medium hover:bg-secondary-100 dark:hover:bg-secondary-700" do %>
        User Analytics
      <% end %>
      <%= link_to admin_visitor_analytics_index_path, 
          class: "text-secondary-600 hover:text-secondary-900 dark:text-secondary-300 dark:hover:text-white px-3 py-2 rounded-md text-sm font-medium hover:bg-secondary-100 dark:hover:bg-secondary-700" do %>
        Visitor Analytics
      <% end %>
      <%= link_to admin_blog_analytics_index_path, 
          class: "bg-primary-100 text-primary-700 dark:bg-primary-900 dark:text-primary-200 px-3 py-2 rounded-md text-sm font-medium" do %>
        Blog Analytics
      <% end %>
    </nav>
  </div>

  <!-- Key Blog Metrics Cards -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <!-- Blog Visitors -->
      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
            </div>
            <div class="ml-3 w-0 flex-1">
              <dl>
                <dt class="text-xs font-medium text-secondary-500 dark:text-secondary-400 truncate">Blog Visitors</dt>
                <dd class="text-lg font-medium text-secondary-900 dark:text-white" 
                    data-visitor-analytics-target="uniqueVisitors"><%= @blog_stats[:blog_visitors] %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <!-- Blog Page Views -->
      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            </div>
            <div class="ml-3 w-0 flex-1">
              <dl>
                <dt class="text-xs font-medium text-secondary-500 dark:text-secondary-400 truncate">Blog Views</dt>
                <dd class="text-lg font-medium text-secondary-900 dark:text-white" 
                    data-visitor-analytics-target="totalVisitors"><%= @blog_stats[:blog_page_views] %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <!-- Blog Bounce Rate -->
      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6" />
              </svg>
            </div>
            <div class="ml-3 w-0 flex-1">
              <dl>
                <dt class="text-xs font-medium text-secondary-500 dark:text-secondary-400 truncate">Bounce Rate</dt>
                <dd class="text-lg font-medium text-secondary-900 dark:text-white" 
                    data-visitor-analytics-target="returningVisitors"><%= @blog_stats[:blog_bounce_rate] %>%</dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <!-- Blog Conversion Rate -->
      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <div class="ml-3 w-0 flex-1">
              <dl>
                <dt class="text-xs font-medium text-secondary-500 dark:text-secondary-400 truncate">Blog Conversion</dt>
                <dd class="text-lg font-medium text-secondary-900 dark:text-white" 
                    data-visitor-analytics-target="conversionRate"><%= @blog_stats[:blog_conversion_rate] %>%</dd>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Blog Engagement Funnel -->
    <div class="mb-8">
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-secondary-900 dark:text-white mb-4">Blog to Signup Conversion Funnel</h3>
          <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div class="text-center">
              <div class="text-2xl font-bold text-blue-600"><%= @conversion_funnel[:blog_viewers] %></div>
              <div class="text-sm text-secondary-600 dark:text-secondary-400">Blog Viewers</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-green-600"><%= @conversion_funnel[:blog_to_other_pages] %></div>
              <div class="text-sm text-secondary-600 dark:text-secondary-400">Explored Other Pages</div>
              <div class="text-xs text-secondary-500">(<%= @conversion_funnel[:blog_engagement_rate] %>% engagement)</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-purple-600"><%= @conversion_funnel[:blog_to_conversion] %></div>
              <div class="text-sm text-secondary-600 dark:text-secondary-400">Signed Up</div>
              <div class="text-xs text-secondary-500">(<%= @conversion_funnel[:blog_conversion_rate] %>% conversion)</div>
            </div>
            <div class="text-center">
              <div class="text-lg font-semibold text-secondary-900 dark:text-white">
                <%= (@conversion_funnel[:blog_viewers] > 0 ? (@conversion_funnel[:blog_to_conversion].to_f / @conversion_funnel[:blog_viewers] * 100).round(1) : 0) %>%
              </div>
              <div class="text-sm text-secondary-600 dark:text-secondary-400">Overall Blog ROI</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Charts Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
      <!-- Blog Views Trend -->
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-secondary-900 dark:text-white mb-4">Blog Views Trend</h3>
          <div class="h-64">
            <canvas 
              data-controller="chart"
              data-chart-data-value="<%= raw @chart_data[:blog_views_by_date].to_json %>"
              data-chart-type-value="line"
              data-chart-target="canvas"></canvas>
          </div>
        </div>
      </div>

      <!-- Blog vs Other Content -->
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-secondary-900 dark:text-white mb-4">Content Distribution</h3>
          <div class="h-64">
            <canvas 
              data-controller="chart"
              data-chart-data-value="<%= raw @chart_data[:blog_vs_other_pages].to_json %>"
              data-chart-type-value="doughnut"
              data-chart-target="canvas"></canvas>
          </div>
        </div>
      </div>
    </div>

    <!-- Reading Patterns -->
    <div class="mb-8">
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-secondary-900 dark:text-white mb-4">Reading Patterns</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <h4 class="text-sm font-medium text-secondary-700 dark:text-secondary-300 mb-3">Reading Depth Distribution</h4>
              <div class="space-y-2">
                <% @blog_reading_patterns[:reading_depth].each do |depth, count| %>
                  <div class="flex justify-between items-center">
                    <span class="text-sm text-secondary-600 dark:text-secondary-400"><%= depth %></span>
                    <span class="text-sm font-medium text-secondary-900 dark:text-white"><%= count %></span>
                  </div>
                <% end %>
              </div>
            </div>
            <div>
              <h4 class="text-sm font-medium text-secondary-700 dark:text-secondary-300 mb-3">Reading Statistics</h4>
              <div class="space-y-2">
                <div class="flex justify-between items-center">
                  <span class="text-sm text-secondary-600 dark:text-secondary-400">Average Reading Time</span>
                  <span class="text-sm font-medium text-secondary-900 dark:text-white"><%= (@blog_reading_patterns[:average_reading_time] / 60).round(1) %>m</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-sm text-secondary-600 dark:text-secondary-400">Total Reading Time</span>
                  <span class="text-sm font-medium text-secondary-900 dark:text-white"><%= @blog_reading_patterns[:total_reading_time].round(1) %>m</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-sm text-secondary-600 dark:text-secondary-400">Index to Posts Ratio</span>
                  <span class="text-sm font-medium text-secondary-900 dark:text-white">1:<%= @blog_content_stats[:index_to_post_ratio] %></span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Top Content & Traffic Analysis -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Most Popular Posts -->
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-secondary-900 dark:text-white mb-4">Most Popular Posts</h3>
          <div class="space-y-3">
            <% @most_popular_posts.each_with_index do |(post_path, views), index| %>
              <div class="flex items-center justify-between">
                <div class="flex items-center">
                  <span class="flex-shrink-0 w-6 h-6 bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 rounded-full text-xs font-medium flex items-center justify-center">
                    <%= index + 1 %>
                  </span>
                  <span class="ml-3 text-sm text-secondary-900 dark:text-white truncate" title="<%= post_path %>">
                    <%= post_path.length > 25 ? "#{post_path[0..25]}..." : post_path %>
                  </span>
                </div>
                <span class="text-sm font-medium text-secondary-500 dark:text-secondary-400"><%= views %></span>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Blog Referrers -->
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-secondary-900 dark:text-white mb-4">Blog Traffic Sources</h3>
          <div class="space-y-3">
            <% if @blog_referrer_analysis[:external_referrers].any? %>
              <% @blog_referrer_analysis[:external_referrers].each_with_index do |(referrer, count), index| %>
                <div class="flex items-center justify-between">
                  <div class="flex items-center">
                    <span class="flex-shrink-0 w-6 h-6 bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200 rounded-full text-xs font-medium flex items-center justify-center">
                      <%= index + 1 %>
                    </span>
                    <span class="ml-3 text-sm text-secondary-900 dark:text-white truncate" title="<%= referrer %>">
                      <%= referrer.length > 20 ? "#{referrer[0..20]}..." : referrer %>
                    </span>
                  </div>
                  <span class="text-sm font-medium text-secondary-500 dark:text-secondary-400"><%= count %></span>
                </div>
              <% end %>
            <% else %>
              <p class="text-sm text-secondary-500 dark:text-secondary-400">No external referrer data</p>
            <% end %>
            <div class="border-t pt-3">
              <div class="flex justify-between items-center">
                <span class="text-sm text-secondary-600 dark:text-secondary-400">Internal Navigation</span>
                <span class="text-sm font-medium text-secondary-900 dark:text-white"><%= @blog_referrer_analysis[:internal_navigation] %></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Blog Exit Analysis -->
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-secondary-900 dark:text-white mb-4">Exit Analysis</h3>
          <div class="space-y-3">
            <div class="bg-yellow-50 dark:bg-yellow-900/20 p-3 rounded-md">
              <div class="text-sm font-medium text-yellow-800 dark:text-yellow-200">Blog Exit Rate</div>
              <div class="text-lg font-bold text-yellow-900 dark:text-yellow-100"><%= @blog_exit_analysis[:blog_exit_rate] %>%</div>
            </div>
            <div>
              <h4 class="text-sm font-medium text-secondary-700 dark:text-secondary-300 mb-2">Top Exit Pages</h4>
              <% @blog_exit_analysis[:exit_pages].first(5).each_with_index do |(page, exits), index| %>
                <div class="flex items-center justify-between py-1">
                  <span class="text-xs text-secondary-600 dark:text-secondary-400 truncate">
                    <%= page.length > 20 ? "#{page[0..20]}..." : page %>
                  </span>
                  <span class="text-xs font-medium text-secondary-900 dark:text-white"><%= exits %></span>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

