<% content_for :title, "User Engagement" %>

<div class="min-h-screen bg-secondary-50 dark:bg-secondary-900">
  <!-- Header -->
  <div class="bg-white dark:bg-secondary-800 shadow">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="py-6">
        <div class="flex items-center justify-between">
<div>
            <h1 class="text-2xl font-bold text-secondary-900 dark:text-white">User Engagement</h1>
            <p class="mt-1 text-sm text-secondary-600 dark:text-secondary-400">
              Track user activity, session duration, and feature usage patterns
            </p>
          </div>
          <div class="flex items-center space-x-4">
            <!-- Time Range Selector -->
            <div class="flex items-center space-x-2">
              <label for="time-range" class="text-sm font-medium text-secondary-700 dark:text-secondary-300">Time Range:</label>
              <%= form_with url: admin_analytics_user_engagement_path, method: :get, local: true, class: "inline-flex" do |form| %>
                <%= form.select :time_range, 
                    options_for_select([
                      ['Last 7 days', '7_days'],
                      ['Last 30 days', '30_days'],
                      ['Last 90 days', '90_days'],
                      ['Last year', '1_year']
                    ], @time_range),
                    { include_blank: false },
                    { 
                      id: "time-range",
                      class: "block w-full rounded-md border-secondary-300 shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm dark:bg-secondary-700 dark:border-secondary-600 dark:text-white",
                      onchange: "this.form.submit()"
                    } %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Navigation -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <nav class="flex space-x-4" aria-label="Analytics Navigation">
      <%= link_to admin_analytics_index_path, 
          class: "text-secondary-600 hover:text-secondary-900 dark:text-secondary-300 dark:hover:text-white px-3 py-2 rounded-md text-sm font-medium hover:bg-secondary-100 dark:hover:bg-secondary-700" do %>
        Overview
      <% end %>
      <%= link_to admin_analytics_registration_trends_path, 
          class: "text-secondary-600 hover:text-secondary-900 dark:text-secondary-300 dark:hover:text-white px-3 py-2 rounded-md text-sm font-medium hover:bg-secondary-100 dark:hover:bg-secondary-700" do %>
        Registration Trends
      <% end %>
      <%= link_to admin_analytics_user_engagement_path, 
          class: "bg-primary-100 text-primary-700 dark:bg-primary-900 dark:text-primary-200 px-3 py-2 rounded-md text-sm font-medium" do %>
        User Engagement
      <% end %>
    </nav>
  </div>

  <!-- Engagement Metrics Cards -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <!-- Active Users -->
      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400 truncate">Active Users</dt>
                <dd class="text-lg font-medium text-secondary-900 dark:text-white"><%= @engagement_metrics[:active_users] %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <!-- Session Duration -->
      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400 truncate">Avg Session</dt>
                <dd class="text-lg font-medium text-secondary-900 dark:text-white"><%= @engagement_metrics[:session_duration] %> min</dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <!-- Feature Usage -->
      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400 truncate">Content Created</dt>
                <dd class="text-lg font-medium text-secondary-900 dark:text-white">
                  <%= @engagement_metrics[:feature_usage][:blog_posts_created] + @engagement_metrics[:feature_usage][:projects_created] %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <!-- Profile Views -->
      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400 truncate">Profile Views</dt>
                <dd class="text-lg font-medium text-secondary-900 dark:text-white"><%= @engagement_metrics[:feature_usage][:profile_views] %></dd>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Feature Usage Breakdown -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
      <!-- Feature Usage Chart -->
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-secondary-900 dark:text-white mb-4">Feature Usage</h3>
          <div class="h-64">
            <canvas id="featureUsageChart"></canvas>
          </div>
        </div>
      </div>

      <!-- Engagement by Role -->
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-secondary-900 dark:text-white mb-4">Engagement by Role</h3>
          <div class="space-y-4">
            <% @engagement_metrics[:engagement_by_role].each do |role_data| %>
              <div class="flex items-center justify-between">
                <div class="flex items-center">
                  <div class="flex-shrink-0">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium 
                           <%= case role_data[:role]
                               when 'admin', 'super_admin' then 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200'
                               else 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200'
                               end %>">
                      <%= role_data[:role].humanize %>
                    </span>
                  </div>
                  <div class="ml-3">
                    <p class="text-sm font-medium text-secondary-900 dark:text-white">
                      <%= role_data[:active_count] %> / <%= role_data[:count] %> active
                    </p>
                  </div>
                </div>
                <div class="text-right">
                  <p class="text-sm font-medium text-secondary-900 dark:text-white">
                    <%= role_data[:engagement_rate] %>%
                  </p>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Retention Rates -->
    <div class="mb-8">
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-secondary-900 dark:text-white mb-4">User Retention Rates</h3>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="text-center">
              <div class="text-3xl font-bold text-secondary-900 dark:text-white"><%= @engagement_metrics[:retention_rates][:day_1] %>%</div>
              <div class="text-sm text-secondary-500 dark:text-secondary-400">Day 1 Retention</div>
            </div>
            <div class="text-center">
              <div class="text-3xl font-bold text-secondary-900 dark:text-white"><%= @engagement_metrics[:retention_rates][:day_7] %>%</div>
              <div class="text-sm text-secondary-500 dark:text-secondary-400">Day 7 Retention</div>
            </div>
            <div class="text-center">
              <div class="text-3xl font-bold text-secondary-900 dark:text-white"><%= @engagement_metrics[:retention_rates][:day_30] %>%</div>
              <div class="text-sm text-secondary-500 dark:text-secondary-400">Day 30 Retention</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Charts Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Daily Engagement Chart -->
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-secondary-900 dark:text-white mb-4">Daily Engagement</h3>
          <div class="h-64">
            <canvas id="dailyEngagementChart"></canvas>
          </div>
        </div>
      </div>

      <!-- Feature Adoption Chart -->
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-secondary-900 dark:text-white mb-4">Feature Adoption</h3>
          <div class="h-64">
            <canvas id="featureAdoptionChart"></canvas>
          </div>
        </div>
      </div>
    </div>

    <!-- Activity Patterns -->
    <div class="mt-8">
      <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
        <div class="px-4 py-5 sm:p-6">
          <h3 class="text-lg leading-6 font-medium text-secondary-900 dark:text-white mb-4">User Activity Patterns</h3>
          <div class="h-64">
            <canvas id="activityPatternsChart"></canvas>
          </div>
          <% if @engagement_trends[:user_activity_patterns][:peak_hour] %>
            <div class="mt-4 text-center">
              <p class="text-sm text-secondary-600 dark:text-secondary-400">
                Peak activity hour: <%= @engagement_trends[:user_activity_patterns][:peak_hour] %>:00
              </p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  // Chart data from Rails
  const featureUsageData = <%= raw @engagement_metrics[:feature_usage].to_json %>;
  const dailyEngagementData = <%= raw @engagement_trends[:daily_engagement].to_json %>;
  const featureAdoptionData = <%= raw @engagement_trends[:feature_adoption].to_json %>;
  const activityPatternsData = <%= raw @engagement_trends[:user_activity_patterns][:hourly_distribution].to_json %>;

  // Chart.js configuration
  const chartOptions = {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      legend: {
        labels: {
          color: document.documentElement.classList.contains('dark') ? '#e5e7eb' : '#374151'
        }
      }
    },
    scales: {
      x: {
        ticks: {
          color: document.documentElement.classList.contains('dark') ? '#9ca3af' : '#6b7280'
        },
        grid: {
          color: document.documentElement.classList.contains('dark') ? '#374151' : '#e5e7eb'
        }
      },
      y: {
        ticks: {
          color: document.documentElement.classList.contains('dark') ? '#9ca3af' : '#6b7280'
        },
        grid: {
          color: document.documentElement.classList.contains('dark') ? '#374151' : '#e5e7eb'
        }
      }
    }
  };

  // Feature Usage Chart
  const featureUsageCtx = document.getElementById('featureUsageChart').getContext('2d');
  new Chart(featureUsageCtx, {
    type: 'doughnut',
    data: {
      labels: ['Blog Posts', 'Projects', 'Profile Views'],
      datasets: [{
        data: [
          featureUsageData.blog_posts_created,
          featureUsageData.projects_created,
          featureUsageData.profile_views
        ],
        backgroundColor: [
          'rgba(59, 130, 246, 0.8)',
          'rgba(168, 85, 247, 0.8)',
          'rgba(16, 185, 129, 0.8)'
        ],
        borderColor: [
          'rgb(59, 130, 246)',
          'rgb(168, 85, 247)',
          'rgb(16, 185, 129)'
        ],
        borderWidth: 1
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          labels: {
            color: document.documentElement.classList.contains('dark') ? '#e5e7eb' : '#374151'
          }
        }
      }
    }
  });

  // Daily Engagement Chart
  const dailyEngagementCtx = document.getElementById('dailyEngagementChart').getContext('2d');
  new Chart(dailyEngagementCtx, {
    type: 'line',
    data: {
      labels: Object.keys(dailyEngagementData).map(date => new Date(date).toLocaleDateString()),
      datasets: [{
        label: 'Daily Active Users',
        data: Object.values(dailyEngagementData),
        borderColor: 'rgb(16, 185, 129)',
        backgroundColor: 'rgba(16, 185, 129, 0.1)',
        tension: 0.4,
        fill: true
      }]
    },
    options: chartOptions
  });

  // Feature Adoption Chart
  const featureAdoptionCtx = document.getElementById('featureAdoptionChart').getContext('2d');
  new Chart(featureAdoptionCtx, {
    type: 'bar',
    data: {
      labels: ['Blog Adoption', 'Project Adoption', 'Profile Completion'],
      datasets: [{
        label: 'Adoption Rate (%)',
        data: [
          featureAdoptionData.blog_adoption,
          featureAdoptionData.project_adoption,
          featureAdoptionData.profile_completion
        ],
        backgroundColor: [
          'rgba(59, 130, 246, 0.8)',
          'rgba(168, 85, 247, 0.8)',
          'rgba(16, 185, 129, 0.8)'
        ],
        borderColor: [
          'rgb(59, 130, 246)',
          'rgb(168, 85, 247)',
          'rgb(16, 185, 129)'
        ],
        borderWidth: 1
      }]
    },
    options: chartOptions
  });

  // Activity Patterns Chart
  const activityPatternsCtx = document.getElementById('activityPatternsChart').getContext('2d');
  new Chart(activityPatternsCtx, {
    type: 'line',
    data: {
      labels: Array.from({length: 24}, (_, i) => i + ':00'),
      datasets: [{
        label: 'Activity Level',
        data: Array.from({length: 24}, (_, i) => activityPatternsData[i] || 0),
        borderColor: 'rgb(168, 85, 247)',
        backgroundColor: 'rgba(168, 85, 247, 0.1)',
        tension: 0.4,
        fill: true
      }]
    },
    options: chartOptions
  });
</script>