<% content_for :title, "#{@user.display_name} - Admin" %>

<div class="min-h-screen bg-secondary-50 dark:bg-secondary-900">
  <!-- Header -->
  <div class="bg-white dark:bg-secondary-800 shadow">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="py-6">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-4">
            <div class="flex-shrink-0 h-16 w-16">
              <% if @user.avatar.attached? %>
                <%= image_tag @user.avatar_medium, class: "h-16 w-16 rounded-full" %>
              <% else %>
                <div class="h-16 w-16 bg-primary-600 rounded-full flex items-center justify-center">
                  <span class="text-white text-xl font-medium"><%= @user.username.first.upcase %></span>
                </div>
              <% end %>
            </div>
            <div>
              <h1 class="text-2xl font-bold text-secondary-900 dark:text-white"><%= @user.display_name %></h1>
              <p class="text-sm text-secondary-600 dark:text-secondary-400">@<%= @user.username %></p>
              <div class="flex items-center space-x-4 mt-2">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                       <%= case @user.role
                           when 'super_admin'
                             'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200'
                           when 'admin' 
                             'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200'
                           else
                             'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200'
                           end %>">
                  <%= @user.role.humanize %>
                </span>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                       <%= case @user.account_status
                           when 'pending_activation'
                             'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200'
                           when 'active'
                             'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200'
                           when 'suspended'
                             'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200'
                           when 'deactivated'
                             'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200'
                           end %>">
                  <%= @user.account_status.humanize %>
                </span>
              </div>
            </div>
          </div>
          <div class="flex items-center space-x-4">
            <%= link_to admin_users_path, class: "inline-flex items-center px-4 py-2 border border-secondary-300 shadow-sm text-sm font-medium rounded-md text-secondary-700 bg-white hover:bg-secondary-50 dark:bg-secondary-700 dark:border-secondary-600 dark:text-secondary-200 dark:hover:bg-secondary-600" do %>
              ← Back to Users
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- User Details -->
      <div class="lg:col-span-2">
        <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
          <div class="px-6 py-4 border-b border-secondary-200 dark:border-secondary-700">
            <h3 class="text-lg font-medium text-secondary-900 dark:text-white">User Details</h3>
          </div>
          <div class="px-6 py-4">
            <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
              <div>
                <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Email</dt>
                <dd class="mt-1 text-sm text-secondary-900 dark:text-white"><%= @user.email %></dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Full Name</dt>
                <dd class="mt-1 text-sm text-secondary-900 dark:text-white"><%= @user.full_name.present? ? @user.full_name : 'Not provided' %></dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Job Title</dt>
                <dd class="mt-1 text-sm text-secondary-900 dark:text-white"><%= @user.job_title.present? ? @user.job_title : 'Not provided' %></dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Location</dt>
                <dd class="mt-1 text-sm text-secondary-900 dark:text-white"><%= @user.location.present? ? @user.location : 'Not provided' %></dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Joined</dt>
                <dd class="mt-1 text-sm text-secondary-900 dark:text-white"><%= @user.created_at.strftime("%B %d, %Y at %I:%M %p") %></dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Last Login</dt>
                <dd class="mt-1 text-sm text-secondary-900 dark:text-white">
                  <%= @user.last_login_at.present? ? @user.last_login_at.strftime("%B %d, %Y at %I:%M %p") : 'Never' %>
                </dd>
              </div>
              <% if @user.suspended? %>
                <div class="sm:col-span-2">
                  <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Suspension Details</dt>
                  <dd class="mt-1 text-sm text-secondary-900 dark:text-white">
                    <p><strong>Suspended:</strong> <%= @user.suspended_at.strftime("%B %d, %Y at %I:%M %p") %></p>
                    <% if @user.suspension_reason.present? %>
                      <p><strong>Reason:</strong> <%= @user.suspension_reason %></p>
                    <% end %>
                  </dd>
                </div>
              <% end %>
              <% if @user.bio.present? %>
                <div class="sm:col-span-2">
                  <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Bio</dt>
                  <dd class="mt-1 text-sm text-secondary-900 dark:text-white"><%= @user.bio %></dd>
                </div>
              <% end %>
            </dl>
          </div>
        </div>
      </div>

      <!-- Actions Sidebar -->
      <div class="lg:col-span-1">
        <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
          <div class="px-6 py-4 border-b border-secondary-200 dark:border-secondary-700">
            <h3 class="text-lg font-medium text-secondary-900 dark:text-white">Actions</h3>
          </div>
          <div class="px-6 py-4 space-y-4">
            <% if current_user.can_manage_users? && @user != current_user %>
              <!-- Account Status Actions -->
              <% if @user.pending_activation? %>
                <%= button_to "Activate Account", activate_admin_user_path(@user), 
                    method: :patch,
                    data: { confirm: "Are you sure you want to activate this user's account?" },
                    class: "w-full inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
              <% elsif @user.active? %>
                <%= button_to "Deactivate Account", deactivate_admin_user_path(@user), 
                    method: :patch,
                    data: { confirm: "Are you sure you want to deactivate this user's account?" },
                    class: "w-full inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-orange-600 hover:bg-orange-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500" %>
              <% elsif @user.deactivated? %>
                <%= button_to "Reactivate Account", activate_admin_user_path(@user), 
                    method: :patch,
                    data: { confirm: "Are you sure you want to reactivate this user's account?" },
                    class: "w-full inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
              <% end %>

              <!-- Suspension Actions -->
              <% if @user.suspended? %>
                <%= button_to "Unsuspend User", unsuspend_admin_user_path(@user), 
                    method: :patch,
                    data: { confirm: "Are you sure you want to unsuspend this user?" },
                    class: "w-full inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
              <% elsif @user.active? %>
                <%= button_to "Suspend User", suspend_admin_user_path(@user), 
                    method: :patch,
                    data: { confirm: "Are you sure you want to suspend this user?" },
                    class: "w-full inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
              <% end %>
            <% end %>

            <!-- View Public Profile -->
            <%= link_to "View Public Profile", "/#{@user.friendly_id}", target: "_blank",
                class: "w-full inline-flex justify-center items-center px-4 py-2 border border-secondary-300 text-sm font-medium rounded-md text-secondary-700 bg-white hover:bg-secondary-50 dark:bg-secondary-700 dark:border-secondary-600 dark:text-secondary-200 dark:hover:bg-secondary-600" %>
          </div>
        </div>

        <!-- User Stats -->
        <div class="bg-white dark:bg-secondary-800 shadow rounded-lg mt-6">
          <div class="px-6 py-4 border-b border-secondary-200 dark:border-secondary-700">
            <h3 class="text-lg font-medium text-secondary-900 dark:text-white">Statistics</h3>
          </div>
          <div class="px-6 py-4">
            <dl class="space-y-3">
              <div class="flex justify-between">
                <dt class="text-sm text-secondary-500 dark:text-secondary-400">Projects</dt>
                <dd class="text-sm font-medium text-secondary-900 dark:text-white"><%= @user.projects.count %></dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-sm text-secondary-500 dark:text-secondary-400">Blog Posts</dt>
                <dd class="text-sm font-medium text-secondary-900 dark:text-white"><%= @user.blog_posts.count %></dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-sm text-secondary-500 dark:text-secondary-400">Profile Views</dt>
                <dd class="text-sm font-medium text-secondary-900 dark:text-white"><%= @user.total_profile_views %></dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-sm text-secondary-500 dark:text-secondary-400">Profile Completion</dt>
                <dd class="text-sm font-medium text-secondary-900 dark:text-white"><%= @user.profile_completion_percentage %>%</dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
