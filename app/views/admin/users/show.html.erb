<% content_for :title, "#{@user.display_name} - Admin" %>

<div class="min-h-screen bg-secondary-50 dark:bg-secondary-900">
  <!-- Header -->
  <div class="bg-white dark:bg-secondary-800 shadow">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="py-6">
        <div class="flex items-center justify-between">
          <div class="flex items-center space-x-4">
            <div class="flex-shrink-0 h-16 w-16">
              <% if @user.avatar.attached? %>
                <%= image_tag @user.avatar_medium, class: "h-16 w-16 rounded-full" %>
              <% else %>
                <div class="h-16 w-16 bg-primary-600 rounded-full flex items-center justify-center">
                  <span class="text-white text-xl font-medium"><%= @user.username.first.upcase %></span>
                </div>
              <% end %>
            </div>
            <div>
              <h1 class="text-2xl font-bold text-secondary-900 dark:text-white"><%= @user.display_name %></h1>
              <p class="text-sm text-secondary-600 dark:text-secondary-400">@<%= @user.username %></p>
              <div class="flex items-center space-x-4 mt-2">
                <%= user_role_badge(@user) %>
                <%= user_status_badge(@user) %>
              </div>
            </div>
          </div>
          <div class="flex items-center space-x-4">
            <%= link_to admin_users_path, class: "inline-flex items-center px-4 py-2 border border-secondary-300 shadow-sm text-sm font-medium rounded-md text-secondary-700 bg-white hover:bg-secondary-50 dark:bg-secondary-700 dark:border-secondary-600 dark:text-secondary-200 dark:hover:bg-secondary-600" do %>
              ← Back to Users
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Breadcrumbs -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <%= admin_breadcrumbs(
      { text: "Admin Dashboard", path: admin_root_path },
      { text: "User Management", path: admin_users_path },
      { text: @user.display_name, path: admin_user_path(@user) }
    ) %>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- User Details -->
      <div class="lg:col-span-2">
        <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
          <div class="px-6 py-4 border-b border-secondary-200 dark:border-secondary-700">
            <h3 class="text-lg font-medium text-secondary-900 dark:text-white">User Details</h3>
          </div>
          <div class="px-6 py-4">
            <dl class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">
              <div>
                <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Email</dt>
                <dd class="mt-1 text-sm text-secondary-900 dark:text-white"><%= @user.email %></dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Full Name</dt>
                <dd class="mt-1 text-sm text-secondary-900 dark:text-white"><%= @user.full_name.present? ? @user.full_name : 'Not provided' %></dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Job Title</dt>
                <dd class="mt-1 text-sm text-secondary-900 dark:text-white"><%= @user.job_title.present? ? @user.job_title : 'Not provided' %></dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Location</dt>
                <dd class="mt-1 text-sm text-secondary-900 dark:text-white"><%= @user.location.present? ? @user.location : 'Not provided' %></dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Joined</dt>
                <dd class="mt-1 text-sm text-secondary-900 dark:text-white"><%= @user.created_at.strftime("%B %d, %Y at %I:%M %p") %></dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Last Login</dt>
                <dd class="mt-1 text-sm text-secondary-900 dark:text-white">
                  <%= @user.last_login_at.present? ? @user.last_login_at.strftime("%B %d, %Y at %I:%M %p") : 'Never' %>
                </dd>
              </div>
              <% if @user.suspended? %>
                <div class="sm:col-span-2">
                  <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Suspension Details</dt>
                  <dd class="mt-1 text-sm text-secondary-900 dark:text-white">
                    <p><strong>Suspended:</strong> <%= @user.suspended_at.strftime("%B %d, %Y at %I:%M %p") %></p>
                    <% if @user.suspension_reason.present? %>
                      <p><strong>Reason:</strong> <%= @user.suspension_reason %></p>
                    <% end %>
                  </dd>
                </div>
              <% end %>
              <% if @user.invited? %>
                <div class="sm:col-span-2">
                  <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Invitation Details</dt>
                  <dd class="mt-1 text-sm text-secondary-900 dark:text-white">
                    <% if @user.invitation_token.present? %>
                      <% if @user.invitation_sent_at.present? %>
                        <p><strong>Invitation Sent:</strong> <%= @user.invitation_sent_at.strftime("%B %d, %Y at %I:%M %p") %></p>
                      <% else %>
                        <p><strong>Invitation Created:</strong> <%= @user.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
                      <% end %>
                      <p><strong>Status:</strong> 
                        <% if @user.invitation_expired? %>
                          <span class="text-red-600 dark:text-red-400">Expired</span>
                        <% else %>
                          <span class="text-amber-600 dark:text-amber-400">Pending (expires in <%= pluralize((@user.invitation_sent_at + 30.days - Time.current).to_i / 1.day, 'day') %>)</span>
                        <% end %>
                      </p>
                      <div class="mt-3">
                        <p><strong>🔐 Secure Access Code:</strong></p>
                        <div class="mt-2 p-4 bg-green-50 dark:bg-green-900/20 rounded-md border-2 border-green-500 dark:border-green-600">
                          <div class="flex items-center justify-between">
                            <div class="flex-1">
                              <code class="text-3xl font-bold text-green-700 dark:text-green-400 tracking-widest font-mono" id="access-code">
                                <%= @user.invitation_access_code %>
                              </code>
                              <p class="mt-2 text-xs text-green-600 dark:text-green-400">
                                <strong>Required for claiming profile</strong> - User must enter this code to verify their identity
                              </p>
                            </div>
                            <button type="button" 
                                    onclick="navigator.clipboard.writeText(document.getElementById('access-code').textContent.trim()); this.textContent='✓ Copied!'; setTimeout(() => this.textContent='Copy Code', 2000)"
                                    class="ml-4 inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500">
                              Copy Code
                            </button>
                          </div>
                        </div>
                      </div>
                      
                      <div class="mt-4">
                        <p><strong>Invitation Link:</strong></p>
                        <div class="mt-2 p-3 bg-secondary-50 dark:bg-secondary-700 rounded-md border">
                          <div class="flex items-center justify-between">
                            <code class="text-sm text-secondary-700 dark:text-secondary-300 break-all" id="invitation-link">
                              <%= "#{request.base_url}/invitations/#{@user.invitation_token}/verify" %>
                            </code>
                            <button type="button" 
                                    onclick="navigator.clipboard.writeText(document.getElementById('invitation-link').textContent); this.textContent='Copied!'; setTimeout(() => this.textContent='Copy', 2000)"
                                    class="ml-3 inline-flex items-center px-3 py-1 border border-transparent text-xs font-medium rounded text-primary-700 bg-primary-100 hover:bg-primary-200 dark:bg-primary-900 dark:text-primary-300 dark:hover:bg-primary-800">
                              Copy
                            </button>
                          </div>
                        </div>
                        <p class="mt-1 text-xs text-secondary-500 dark:text-secondary-400">
                          Share this link and the access code above with the user to claim their profile
                        </p>
                      </div>
                      <p class="mt-2"><strong>Public Profile:</strong> 
                        <%= link_to "View Profile", "/#{@user.username}", target: "_blank", class: "text-primary-600 hover:text-primary-900 dark:text-primary-400 dark:hover:text-primary-300" %>
                      </p>
                    <% else %>
                      <p class="text-amber-600 dark:text-amber-400">Invitation not yet created</p>
                    <% end %>
                  </dd>
                </div>
              <% end %>
              <% if @user.bio.present? %>
                <div class="sm:col-span-2">
                  <dt class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Bio</dt>
                  <dd class="mt-1 text-sm text-secondary-900 dark:text-white"><%= @user.bio %></dd>
                </div>
              <% end %>
            </dl>
          </div>
        </div>
      </div>

      <!-- Actions Sidebar -->
      <div class="lg:col-span-1">
        <div class="bg-white dark:bg-secondary-800 shadow rounded-lg">
          <div class="px-6 py-4 border-b border-secondary-200 dark:border-secondary-700">
            <h3 class="text-lg font-medium text-secondary-900 dark:text-white">Actions</h3>
          </div>
          <div class="px-6 py-4 space-y-4">
            <% if current_user.can_manage_users? && @user != current_user %>
              <!-- Account Status Actions -->
              <% if @user.pending_activation? %>
                <%= button_to "Activate Account", activate_admin_user_path(@user), 
                    method: :patch,
                    data: { confirm: "Are you sure you want to activate this user's account?" },
                    class: "w-full inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
              <% elsif @user.invited? %>
                <%= button_to "Resend Invitation", resend_invitation_admin_user_path(@user), 
                    method: :patch,
                    data: { confirm: "Are you sure you want to resend the invitation email?" },
                    class: "w-full inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-amber-600 hover:bg-amber-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-amber-500 mb-2" %>
                <%= button_to "Generate Link Only", generate_invitation_link_admin_user_path(@user), 
                    method: :patch,
                    class: "w-full inline-flex justify-center items-center px-4 py-2 border border-secondary-300 text-sm font-medium rounded-md text-secondary-700 bg-white hover:bg-secondary-50 dark:bg-secondary-700 dark:border-secondary-600 dark:text-secondary-200 dark:hover:bg-secondary-600" %>
                <p class="mt-1 text-xs text-secondary-500 dark:text-secondary-400 text-center">
                  Generate link without sending email
                </p>
              <% elsif @user.active? %>
                <%= button_to "Deactivate Account", deactivate_admin_user_path(@user), 
                    method: :patch,
                    data: { confirm: "Are you sure you want to deactivate this user's account?" },
                    class: "w-full inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-orange-600 hover:bg-orange-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500" %>
              <% elsif @user.deactivated? %>
                <%= button_to "Reactivate Account", activate_admin_user_path(@user), 
                    method: :patch,
                    data: { confirm: "Are you sure you want to reactivate this user's account?" },
                    class: "w-full inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
              <% end %>

              <!-- Suspension Actions -->
              <% if @user.suspended? %>
                <%= button_to "Unsuspend User", unsuspend_admin_user_path(@user), 
                    method: :patch,
                    data: { confirm: "Are you sure you want to unsuspend this user?" },
                    class: "w-full inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
              <% elsif @user.active? %>
                <%= button_to "Suspend User", suspend_admin_user_path(@user), 
                    method: :patch,
                    data: { confirm: "Are you sure you want to suspend this user?" },
                    class: "w-full inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
              <% end %>
            <% end %>

            <!-- Featured Profile Toggle (Super Admin Only) -->
            <% if current_user.super_admin? %>
              <div class="pt-4 border-t border-secondary-200 dark:border-secondary-700">
                <% if @user.featured? %>
                  <%= button_to "⭐ Unfeature User", toggle_featured_admin_user_path(@user), 
                      method: :patch,
                      data: { confirm: "Are you sure you want to remove this user from featured profiles?" },
                      class: "w-full inline-flex justify-center items-center px-4 py-2 border border-amber-300 text-sm font-medium rounded-md text-amber-700 bg-amber-50 hover:bg-amber-100 dark:bg-amber-900/20 dark:border-amber-600 dark:text-amber-400 dark:hover:bg-amber-900/30" %>
                  <p class="mt-2 text-xs text-center text-secondary-500 dark:text-secondary-400">
                    Featured since <%= @user.featured_at.strftime("%b %d, %Y") %>
                  </p>
                <% else %>
                  <%= button_to "⭐ Feature User", toggle_featured_admin_user_path(@user), 
                      method: :patch,
                      data: { confirm: "Are you sure you want to feature this user on the homepage?" },
                      class: "w-full inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-amber-600 hover:bg-amber-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-amber-500" %>
                  <p class="mt-2 text-xs text-center text-secondary-500 dark:text-secondary-400">
                    Feature this user on homepage
                  </p>
                <% end %>
              </div>
            <% end %>

            <!-- Destroy User (Super Admin Only) -->
            <% if current_user.super_admin? && @user != current_user %>
              <div class="pt-4 border-t border-red-200 dark:border-red-900">
                <%= button_to "Delete User", admin_user_path(@user), 
                    method: :delete,
                    data: { 
                      confirm: "Are you sure you want to permanently delete this user? This action cannot be undone and will delete all their content (projects, blog posts, etc.).",
                      turbo_confirm: "Are you sure you want to permanently delete this user? This action cannot be undone and will delete all their content (projects, blog posts, etc.)."
                    },
                    class: "w-full inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
                <p class="mt-2 text-xs text-center text-red-600 dark:text-red-400">
                  ⚠️ This action cannot be undone
                </p>
              </div>
            <% end %>

            <!-- View Public Profile -->
            <%= link_to "View Public Profile", "/#{@user.friendly_id}", target: "_blank",
                class: "w-full inline-flex justify-center items-center px-4 py-2 border border-secondary-300 text-sm font-medium rounded-md text-secondary-700 bg-white hover:bg-secondary-50 dark:bg-secondary-700 dark:border-secondary-600 dark:text-secondary-200 dark:hover:bg-secondary-600" %>
          </div>
        </div>

        <!-- User Stats -->
        <div class="bg-white dark:bg-secondary-800 shadow rounded-lg mt-6">
          <div class="px-6 py-4 border-b border-secondary-200 dark:border-secondary-700">
            <h3 class="text-lg font-medium text-secondary-900 dark:text-white">Statistics</h3>
          </div>
          <div class="px-6 py-4">
            <dl class="space-y-3">
              <div class="flex justify-between">
                <dt class="text-sm text-secondary-500 dark:text-secondary-400">Projects</dt>
                <dd class="text-sm font-medium text-secondary-900 dark:text-white"><%= @user.projects.count %></dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-sm text-secondary-500 dark:text-secondary-400">Blog Posts</dt>
                <dd class="text-sm font-medium text-secondary-900 dark:text-white"><%= @user.blog_posts.count %></dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-sm text-secondary-500 dark:text-secondary-400">Profile Views</dt>
                <dd class="text-sm font-medium text-secondary-900 dark:text-white"><%= @user.total_profile_views %></dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-sm text-secondary-500 dark:text-secondary-400">Profile Completion</dt>
                <dd class="text-sm font-medium text-secondary-900 dark:text-white"><%= @user.profile_completion_percentage %>%</dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
