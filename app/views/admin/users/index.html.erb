<% content_for :title, "User Management - Admin" %>

<div class="min-h-screen bg-secondary-50 dark:bg-secondary-900">
  <!-- Header -->
  <%= admin_page_header("User Management", "Manage user accounts, roles, and permissions") do %>
    <% if can_create_users? %>
      <%= link_to new_admin_user_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500" do %>
        <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
        </svg>
        Create User Profile
      <% end %>
    <% end %>
    <%= link_to admin_root_path, class: "inline-flex items-center px-4 py-2 border border-secondary-300 shadow-sm text-sm font-medium rounded-md text-secondary-700 bg-white hover:bg-secondary-50 dark:bg-secondary-700 dark:border-secondary-600 dark:text-secondary-200 dark:hover:bg-secondary-600" do %>
      ← Back to Dashboard
    <% end %>
  <% end %>

  <!-- Breadcrumbs -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <%= admin_breadcrumbs(
      { text: "Admin Dashboard", path: admin_root_path },
      { text: "User Management", path: admin_users_path }
    ) %>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-6 gap-6 mb-8">
      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Total Users</p>
              <p class="text-lg font-semibold text-secondary-900 dark:text-white"><%= @total_users %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-green-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Active</p>
              <p class="text-lg font-semibold text-secondary-900 dark:text-white"><%= @active_users %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-yellow-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Pending</p>
              <p class="text-lg font-semibold text-secondary-900 dark:text-white"><%= @pending_activation_users %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-red-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728L5.636 5.636m12.728 12.728L5.636 5.636" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Suspended</p>
              <p class="text-lg font-semibold text-secondary-900 dark:text-white"><%= @suspended_users %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-purple-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Admins</p>
              <p class="text-lg font-semibold text-secondary-900 dark:text-white"><%= @admin_users %></p>
            </div>
          </div>
        </div>
      </div>

      <% if current_user.super_admin? %>
        <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
          <div class="p-5">
            <div class="flex items-center">
              <div class="w-8 h-8 bg-amber-600 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              </div>
              <div class="ml-4">
                <p class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Featured</p>
                <p class="text-lg font-semibold text-secondary-900 dark:text-white"><%= @featured_users_count %></p>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Filters and Search -->
    <div class="bg-white dark:bg-secondary-800 shadow rounded-lg mb-6">
      <div class="p-6">
        <%= form_with url: admin_users_path, method: :get, class: "flex flex-wrap gap-4", local: true do |form| %>
          <div class="flex-1 min-w-64">
            <%= form.text_field :search, placeholder: "Search by username, name, or email...", 
                value: params[:search], 
                class: "block w-full px-3 py-2 border border-secondary-300 rounded-md shadow-sm focus:outline-none focus:ring-primary-500 focus:border-primary-500 dark:bg-secondary-700 dark:border-secondary-600 dark:text-white" %>
          </div>
          <div>
            <%= form.select :role, options_for_select([['All Roles', ''], ['User', 'user'], ['Admin', 'admin'], ['Super Admin', 'super_admin']], params[:role]), 
                {}, { class: "block px-3 py-2 border border-secondary-300 rounded-md shadow-sm focus:outline-none focus:ring-primary-500 focus:border-primary-500 dark:bg-secondary-700 dark:border-secondary-600 dark:text-white" } %>
          </div>
          <div>
            <%= form.select :status, options_for_select([
              ['All Status', ''], 
              ['Active', 'active'], 
              ['Pending Activation', 'pending_activation'],
              ['Invited', 'invited'],
              ['Suspended', 'suspended'],
              ['Deactivated', 'deactivated']
            ], params[:status]), 
                {}, { class: "block px-3 py-2 border border-secondary-300 rounded-md shadow-sm focus:outline-none focus:ring-primary-500 focus:border-primary-500 dark:bg-secondary-700 dark:border-secondary-600 dark:text-white" } %>
          </div>
          <% if current_user.super_admin? %>
            <div>
              <%= form.select :featured, options_for_select([
                ['All Users', ''], 
                ['Featured Only', 'true']
              ], params[:featured]), 
                  {}, { class: "block px-3 py-2 border border-secondary-300 rounded-md shadow-sm focus:outline-none focus:ring-primary-500 focus:border-primary-500 dark:bg-secondary-700 dark:border-secondary-600 dark:text-white" } %>
            </div>
          <% end %>
          <div>
            <%= form.submit "Filter", class: "px-4 py-2 bg-primary-600 border border-transparent rounded-md font-medium text-white hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500" %>
          </div>
          <% if params[:search].present? || params[:role].present? || params[:status].present? || params[:featured].present? %>
            <div>
              <%= link_to "Clear", admin_users_path, class: "px-4 py-2 bg-secondary-600 border border-transparent rounded-md font-medium text-white hover:bg-secondary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-secondary-500" %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Users Table -->
    <div class="bg-white dark:bg-secondary-800 shadow rounded-lg overflow-hidden">
      <div class="px-6 py-4 border-b border-secondary-200 dark:border-secondary-700">
        <h3 class="text-lg font-medium text-secondary-900 dark:text-white">Users</h3>
      </div>
      
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-secondary-200 dark:divide-secondary-700">
          <thead class="bg-secondary-50 dark:bg-secondary-700">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 dark:text-secondary-300 uppercase tracking-wider">User</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 dark:text-secondary-300 uppercase tracking-wider">Role</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 dark:text-secondary-300 uppercase tracking-wider">Status</th>
              <% if current_user.super_admin? %>
                <th class="px-6 py-3 text-center text-xs font-medium text-secondary-500 dark:text-secondary-300 uppercase tracking-wider">Featured</th>
              <% end %>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 dark:text-secondary-300 uppercase tracking-wider">Joined</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 dark:text-secondary-300 uppercase tracking-wider">Content</th>
              <th class="px-6 py-3 text-right text-xs font-medium text-secondary-500 dark:text-secondary-300 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="bg-white dark:bg-secondary-800 divide-y divide-secondary-200 dark:divide-secondary-700">
            <% @users.each do |user| %>
              <tr class="hover:bg-secondary-50 dark:hover:bg-secondary-700">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <div class="flex-shrink-0 h-10 w-10">
                      <% if user.avatar.attached? %>
                        <%= image_tag user.avatar_thumbnail, class: "h-10 w-10 rounded-full" %>
                      <% else %>
                        <div class="h-10 w-10 bg-primary-600 rounded-full flex items-center justify-center">
                          <span class="text-white font-medium"><%= user.username.first.upcase %></span>
                        </div>
                      <% end %>
                    </div>
                    <div class="ml-4">
                      <div class="text-sm font-medium text-secondary-900 dark:text-white">
                        <%= link_to user.display_name, admin_user_path(user), class: "hover:text-primary-600" %>
                      </div>
                      <div class="text-sm text-secondary-500 dark:text-secondary-400">@<%= user.username %></div>
                      <div class="text-xs text-secondary-400 dark:text-secondary-500"><%= user.email %></div>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                         <%= case user.role
                             when 'super_admin'
                               'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200'
                             when 'admin' 
                               'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200'
                             else
                               'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200'
                             end %>">
                    <%= user.role.humanize %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                         <%= case user.account_status
                             when 'pending_activation'
                               'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200'
                             when 'invited'
                               'bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-200'
                             when 'active'
                               'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200'
                             when 'suspended'
                               'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200'
                             when 'deactivated'
                               'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200'
                             end %>">
                    <%= user.account_status.humanize %>
                  </span>
                </td>
                <% if current_user.super_admin? %>
                  <td class="px-6 py-4 whitespace-nowrap text-center">
                    <% if user.featured? %>
                      <%= button_to toggle_featured_admin_user_path(user), 
                          method: :patch,
                          class: "inline-flex items-center justify-center bg-transparent border-0 p-0 cursor-pointer",
                          title: "Featured (click to unfeature)",
                          data: { turbo_confirm: "Remove from featured profiles?" } do %>
                        <svg class="w-6 h-6 text-amber-500" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                      <% end %>
                    <% else %>
                      <%= button_to toggle_featured_admin_user_path(user), 
                          method: :patch,
                          class: "inline-flex items-center justify-center bg-transparent border-0 p-0 cursor-pointer",
                          title: "Not featured (click to feature)",
                          data: { turbo_confirm: "Add to featured profiles on homepage?" } do %>
                        <svg class="w-6 h-6 text-secondary-300 dark:text-secondary-600 hover:text-amber-500" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                      <% end %>
                    <% end %>
                  </td>
                <% end %>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-secondary-500 dark:text-secondary-400">
                  <%= user.created_at.strftime("%b %d, %Y") %>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-secondary-500 dark:text-secondary-400">
                  <div class="flex space-x-2">
                    <span class="inline-flex items-center px-2 py-1 rounded text-xs bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">
                      <%= user.projects.count %> projects
                    </span>
                    <span class="inline-flex items-center px-2 py-1 rounded text-xs bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                      <%= user.blog_posts.count %> posts
                    </span>
                  </div>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                  <div class="flex justify-end space-x-2">
                    <%= link_to "View", admin_user_path(user), 
                        class: "text-primary-600 hover:text-primary-900 dark:text-primary-400 dark:hover:text-primary-300" %>
                    <% if current_user.can_manage_users? && user != current_user %>
                      <!-- Account Status Actions -->
                      <% if user.pending_activation? %>
                        <%= button_to "Activate", activate_admin_user_path(user), 
                            method: :patch,
                            data: { confirm: "Are you sure you want to activate this user's account?" },
                            class: "text-green-600 hover:text-green-900 dark:text-green-400 dark:hover:text-green-300 bg-transparent border-0 p-0 cursor-pointer underline" %>
                      <% elsif user.invited? %>
                        <%= button_to "Resend Invitation", resend_invitation_admin_user_path(user), 
                            method: :patch,
                            data: { confirm: "Are you sure you want to resend the invitation email?" },
                            class: "text-amber-600 hover:text-amber-900 dark:text-amber-400 dark:hover:text-amber-300 bg-transparent border-0 p-0 cursor-pointer underline" %>
                      <% elsif user.active? %>
                        <%= button_to "Deactivate", deactivate_admin_user_path(user), 
                            method: :patch,
                            data: { confirm: "Are you sure you want to deactivate this user's account?" },
                            class: "text-orange-600 hover:text-orange-900 dark:text-orange-400 dark:hover:text-orange-300 bg-transparent border-0 p-0 cursor-pointer underline" %>
                      <% elsif user.deactivated? %>
                        <%= button_to "Activate", activate_admin_user_path(user), 
                            method: :patch,
                            data: { confirm: "Are you sure you want to reactivate this user's account?" },
                            class: "text-green-600 hover:text-green-900 dark:text-green-400 dark:hover:text-green-300 bg-transparent border-0 p-0 cursor-pointer underline" %>
                      <% end %>
                      
                      <!-- Suspension Actions -->
                      <% if user.suspended? %>
                        <%= button_to "Unsuspend", unsuspend_admin_user_path(user), 
                            method: :patch,
                            data: { confirm: "Are you sure you want to unsuspend this user?" },
                            class: "text-green-600 hover:text-green-900 dark:text-green-400 dark:hover:text-green-300 bg-transparent border-0 p-0 cursor-pointer underline" %>
                      <% elsif user.active? %>
                        <%= button_to "Suspend", suspend_admin_user_path(user), 
                            method: :patch,
                            data: { confirm: "Are you sure you want to suspend this user?" },
                            class: "text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300 bg-transparent border-0 p-0 cursor-pointer underline" %>
                      <% end %>
                      
                      <!-- Destroy Action - Only for super_admin -->
                      <% if current_user.super_admin? %>
                        <%= button_to "Delete", admin_user_path(user), 
                            method: :delete,
                            data: { 
                              confirm: "Are you sure you want to permanently delete this user? This action cannot be undone and will delete all their content (projects, blog posts, etc.).",
                              turbo_confirm: "Are you sure you want to permanently delete this user? This action cannot be undone and will delete all their content (projects, blog posts, etc.)."
                            },
                            class: "text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300 bg-transparent border-0 p-0 cursor-pointer underline font-medium" %>
                      <% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if @pagy.pages > 1 %>
        <div class="px-6 py-4 border-t border-secondary-200 dark:border-secondary-700">
          <%== pagy_nav(@pagy) %>
        </div>
      <% end %>
    </div>
  </div>
</div>
