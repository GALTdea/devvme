<% content_for :title, "Waiting List Management - Admin" %>

<div class="min-h-screen bg-secondary-50 dark:bg-secondary-900">
  <!-- Header -->
  <%= admin_page_header("Waiting List Management", "Manage waiting list entries, approve signups, and track conversion rates") do %>
    <div class="flex items-center space-x-3">
      <%= link_to waiting_list_path, class: "inline-flex items-center px-4 py-2 border border-secondary-300 shadow-sm text-sm font-medium rounded-md text-secondary-700 bg-white hover:bg-secondary-50 dark:bg-secondary-700 dark:border-secondary-600 dark:text-secondary-200 dark:hover:bg-secondary-600", target: "_blank" do %>
        <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
        View Signup Page
      <% end %>
    </div>
  <% end %>

  <!-- Breadcrumbs -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <%= admin_breadcrumbs(
      { text: "Admin Dashboard", path: admin_root_path },
      { text: "Waiting List", path: admin_waiting_list_index_path }
    ) %>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-5 gap-6 mb-8">
      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Total Signups</p>
              <p class="text-lg font-semibold text-secondary-900 dark:text-white"><%= @stats[:total] %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-amber-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Pending</p>
              <p class="text-lg font-semibold text-secondary-900 dark:text-white"><%= @stats[:pending] %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-purple-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Invited</p>
              <p class="text-lg font-semibold text-secondary-900 dark:text-white"><%= @stats[:invited] %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-green-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Converted</p>
              <p class="text-lg font-semibold text-secondary-900 dark:text-white"><%= @stats[:converted] %></p>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white dark:bg-secondary-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
          <div class="flex items-center">
            <div class="w-8 h-8 bg-red-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-medium text-secondary-500 dark:text-secondary-400">Declined</p>
              <p class="text-lg font-semibold text-secondary-900 dark:text-white"><%= @stats[:declined] %></p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Filters and Search -->
    <div class="bg-white dark:bg-secondary-800 shadow rounded-lg p-6 mb-6">
      <%= form_with url: admin_waiting_list_index_path, method: :get, class: "space-y-4 sm:space-y-0 sm:flex sm:items-end sm:space-x-4" do |f| %>
        <!-- Search -->
        <div class="flex-1">
          <%= f.label :search, "Search", class: "block text-sm font-medium text-secondary-700 dark:text-secondary-200 mb-1" %>
          <%= f.text_field :search, 
              value: params[:search], 
              placeholder: "Search by email or name...",
              class: "w-full rounded-md border-secondary-300 dark:border-secondary-600 dark:bg-secondary-700 dark:text-white shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm" %>
        </div>

        <!-- Status Filter -->
        <div class="w-full sm:w-48">
          <%= f.label :status, "Status", class: "block text-sm font-medium text-secondary-700 dark:text-secondary-200 mb-1" %>
          <%= f.select :status, 
              options_for_select([
                ['All Statuses', ''],
                ['Pending', 'pending'],
                ['Invited', 'invited'],
                ['Converted', 'converted'],
                ['Declined', 'declined']
              ], params[:status]),
              {}, 
              class: "w-full rounded-md border-secondary-300 dark:border-secondary-600 dark:bg-secondary-700 dark:text-white shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm" %>
        </div>

        <!-- Sort -->
        <div class="w-full sm:w-48">
          <%= f.label :sort, "Sort By", class: "block text-sm font-medium text-secondary-700 dark:text-secondary-200 mb-1" %>
          <%= f.select :sort,
              options_for_select([
                ['Newest First', 'created_at DESC'],
                ['Oldest First', 'created_at ASC'],
                ['Email A-Z', 'email ASC'],
                ['Email Z-A', 'email DESC']
              ], params[:sort]),
              {},
              class: "w-full rounded-md border-secondary-300 dark:border-secondary-600 dark:bg-secondary-700 dark:text-white shadow-sm focus:border-primary-500 focus:ring-primary-500 sm:text-sm" %>
        </div>

        <!-- Buttons -->
        <div class="flex space-x-2">
          <%= f.submit "Filter", class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500" %>
          <%= link_to "Clear", admin_waiting_list_index_path, class: "inline-flex items-center px-4 py-2 border border-secondary-300 shadow-sm text-sm font-medium rounded-md text-secondary-700 bg-white hover:bg-secondary-50 dark:bg-secondary-700 dark:border-secondary-600 dark:text-secondary-200 dark:hover:bg-secondary-600" %>
        </div>
      <% end %>
    </div>

    <!-- Entries Table -->
    <div class="bg-white dark:bg-secondary-800 shadow rounded-lg overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-secondary-200 dark:divide-secondary-700">
          <thead class="bg-secondary-50 dark:bg-secondary-900">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-secondary-500 dark:text-secondary-400 uppercase tracking-wider">
                Position
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-secondary-500 dark:text-secondary-400 uppercase tracking-wider">
                Email / Name
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-secondary-500 dark:text-secondary-400 uppercase tracking-wider">
                Status
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-secondary-500 dark:text-secondary-400 uppercase tracking-wider">
                Source
              </th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-secondary-500 dark:text-secondary-400 uppercase tracking-wider">
                Signed Up
              </th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-secondary-500 dark:text-secondary-400 uppercase tracking-wider">
                Actions
              </th>
            </tr>
          </thead>
          <tbody class="bg-white dark:bg-secondary-800 divide-y divide-secondary-200 dark:divide-secondary-700">
            <% if @waiting_list_entries.any? %>
              <% @waiting_list_entries.each do |entry| %>
                <tr class="hover:bg-secondary-50 dark:hover:bg-secondary-700 transition-colors">
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-secondary-900 dark:text-secondary-100">
                    <span class="font-mono text-xs bg-secondary-100 dark:bg-secondary-700 px-2 py-1 rounded">
                      #<%= entry.position || 'N/A' %>
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm font-medium text-secondary-900 dark:text-white"><%= entry.email %></div>
                    <% if entry.full_name.present? %>
                      <div class="text-sm text-secondary-500 dark:text-secondary-400"><%= entry.full_name %></div>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <% case entry.status %>
                    <% when 'pending' %>
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400">
                        Pending
                      </span>
                    <% when 'invited' %>
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-400">
                        Invited
                      </span>
                    <% when 'converted' %>
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400">
                        Converted
                      </span>
                    <% when 'declined' %>
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400">
                        Declined
                      </span>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-secondary-500 dark:text-secondary-400">
                    <%= entry.source || 'direct' %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-secondary-500 dark:text-secondary-400">
                    <%= time_ago_in_words(entry.created_at) %> ago
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                    <div class="flex items-center justify-end space-x-2">
                      <%= link_to admin_waiting_list_path(entry), class: "text-primary-600 hover:text-primary-900 dark:text-primary-400 dark:hover:text-primary-300" do %>
                        View
                      <% end %>
                      <% if entry.pending? %>
                        <%= button_to "Approve", approve_admin_waiting_list_path(entry), 
                            method: :patch,
                            data: { turbo_confirm: "Approve and invite #{entry.email}?" },
                            class: "text-green-600 hover:text-green-900 dark:text-green-400 dark:hover:text-green-300" %>
                        <%= button_to "Decline", decline_admin_waiting_list_path(entry),
                            method: :patch,
                            data: { turbo_confirm: "Decline #{entry.email}?" },
                            class: "text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300" %>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="6" class="px-6 py-12 text-center">
                  <div class="flex flex-col items-center justify-center">
                    <svg class="w-12 h-12 text-secondary-400 dark:text-secondary-600 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
                    </svg>
                    <p class="text-secondary-500 dark:text-secondary-400 text-lg font-medium">No waiting list entries found</p>
                    <p class="text-secondary-400 dark:text-secondary-500 text-sm mt-1">
                      <% if params[:search].present? || params[:status].present? %>
                        Try adjusting your filters
                      <% else %>
                        Entries will appear here when users sign up for the waiting list
                      <% end %>
                    </p>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if @waiting_list_entries.any? %>
        <div class="bg-white dark:bg-secondary-800 px-4 py-3 border-t border-secondary-200 dark:border-secondary-700 sm:px-6">
          <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
        </div>
      <% end %>
    </div>
  </div>
</div>
