<% if user_signed_in? %>
  <!-- Authenticated User Dashboard -->
  <div class="max-w-screen-xl mx-auto px-4 py-8">
    <div class="bg-white dark:bg-secondary-800 shadow-lg rounded-lg p-8 mb-8">
      <div class="flex items-center space-x-6 mb-6">
        <div class="w-16 h-16 bg-primary-600 rounded-full flex items-center justify-center">
          <span class="text-white text-2xl font-bold"><%= current_user.username.first.upcase %></span>
        </div>
        <div>
          <h1 class="text-3xl font-bold text-secondary-900 dark:text-white">Welcome back, <%= current_user.username %>!</h1>
          <p class="text-secondary-600 dark:text-secondary-400">Ready to work on your portfolio?</p>
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-primary-50 dark:bg-primary-900/20 rounded-lg p-6 text-center">
          <div class="w-12 h-12 bg-primary-600 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-primary-900 dark:text-primary-100 mb-2">Projects</h3>
          <p class="text-primary-700 dark:text-primary-300 text-sm">0 projects</p>
          <%= link_to "#", class: "inline-block mt-4 text-primary-600 hover:text-primary-800 dark:text-primary-400 dark:hover:text-primary-200 font-medium" do %>
            Create First Project →
          <% end %>
        </div>
        
        <div class="bg-accent-50 dark:bg-accent-900/20 rounded-lg p-6 text-center">
          <div class="w-12 h-12 bg-accent-600 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-accent-900 dark:text-accent-100 mb-2">Profile</h3>
          <p class="text-accent-700 dark:text-accent-300 text-sm">Complete your profile</p>
          <%= link_to edit_user_registration_path, class: "inline-block mt-4 text-accent-600 hover:text-accent-800 dark:text-accent-400 dark:hover:text-accent-200 font-medium" do %>
            Edit Profile →
          <% end %>
        </div>
        
        <div class="bg-warning-50 dark:bg-warning-900/20 rounded-lg p-6 text-center">
          <div class="w-12 h-12 bg-warning-600 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-warning-900 dark:text-warning-100 mb-2">Analytics</h3>
          <p class="text-warning-700 dark:text-warning-300 text-sm">0 views this month</p>
          <%= link_to "#", class: "inline-block mt-4 text-warning-600 hover:text-warning-800 dark:text-warning-400 dark:hover:text-warning-200 font-medium" do %>
            View Details →
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% else %>
  <!-- Landing Page for Non-Authenticated Users -->
  
  <!-- Hero Section -->
  <section class="bg-white dark:bg-secondary-900">
    <div class="py-8 px-4 mx-auto max-w-screen-xl text-center lg:py-16 lg:px-12">
      <h1 class="mb-4 text-4xl font-extrabold tracking-tight leading-none text-secondary-900 md:text-5xl lg:text-6xl dark:text-white">
        Build Your Developer Portfolio
      </h1>
      <p class="mb-8 text-lg font-normal text-secondary-500 lg:text-xl sm:px-16 xl:px-48 dark:text-secondary-400">
        Showcase your projects, skills, and experience with a professional portfolio that stands out. Perfect for developers looking to make their mark.
      </p>
      <div class="flex flex-col mb-8 lg:mb-16 space-y-4 sm:flex-row sm:justify-center sm:space-y-0 sm:space-x-4">
        <%= link_to new_user_registration_path, class: "inline-flex justify-center items-center py-3 px-5 text-base font-medium text-center text-white rounded-lg bg-primary-700 hover:bg-primary-800 focus:ring-4 focus:ring-primary-300 dark:focus:ring-primary-900" do %>
          Get Started Free
          <svg class="ml-2 -mr-1 w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
          </svg>
        <% end %>
        <%= link_to new_user_session_path, class: "inline-flex justify-center items-center py-3 px-5 text-base font-medium text-center text-secondary-900 rounded-lg border border-secondary-300 hover:bg-secondary-100 focus:ring-4 focus:ring-secondary-100 dark:text-white dark:border-secondary-700 dark:hover:bg-secondary-700 dark:focus:ring-secondary-800" do %>
          Sign In
        <% end %>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="bg-secondary-50 dark:bg-secondary-800">
    <div class="py-8 px-4 mx-auto max-w-screen-xl sm:py-16 lg:px-6">
      <div class="max-w-screen-md mb-8 lg:mb-16 mx-auto text-center">
        <h2 class="mb-4 text-4xl tracking-tight font-extrabold text-secondary-900 dark:text-white">
          Everything you need to showcase your work
        </h2>
        <p class="text-secondary-500 sm:text-xl dark:text-secondary-400">
          Professional portfolio features designed specifically for developers and creative professionals.
        </p>
      </div>
      <div class="space-y-8 md:grid md:grid-cols-2 lg:grid-cols-3 md:gap-12 md:space-y-0">
        <div class="text-center">
          <div class="flex justify-center items-center mb-4 w-10 h-10 rounded-full bg-primary-100 lg:h-12 lg:w-12 dark:bg-primary-900">
            <svg class="w-5 h-5 text-primary-600 lg:w-6 lg:h-6 dark:text-primary-300" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z" clip-rule="evenodd"></path>
            </svg>
          </div>
          <h3 class="mb-2 text-xl font-bold dark:text-white">Project Showcase</h3>
          <p class="text-secondary-500 dark:text-secondary-400">Display your best work with detailed project descriptions, technologies used, and live demos.</p>
        </div>
        <div class="text-center">
          <div class="flex justify-center items-center mb-4 w-10 h-10 rounded-full bg-primary-100 lg:h-12 lg:w-12 dark:bg-primary-900">
            <svg class="w-5 h-5 text-primary-600 lg:w-6 lg:h-6 dark:text-primary-300" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="mb-2 text-xl font-bold dark:text-white">Skills & Experience</h3>
          <p class="text-secondary-500 dark:text-secondary-400">Highlight your technical skills, certifications, and professional experience in a clean format.</p>
        </div>
        <div class="text-center">
          <div class="flex justify-center items-center mb-4 w-10 h-10 rounded-full bg-primary-100 lg:h-12 lg:w-12 dark:bg-primary-900">
            <svg class="w-5 h-5 text-primary-600 lg:w-6 lg:h-6 dark:text-primary-300" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M6 6V5a3 3 0 013-3h2a3 3 0 013 3v1h2a2 2 0 012 2v3.57A22.952 22.952 0 0110 13a22.95 22.95 0 01-8-1.43V8a2 2 0 012-2h2zm2-1a1 1 0 011-1h2a1 1 0 011 1v1H8V5zm1 5a1 1 0 011-1h.01a1 1 0 110 2H10a1 1 0 01-1-1z" clip-rule="evenodd"></path>
            </svg>
          </div>
          <h3 class="mb-2 text-xl font-bold dark:text-white">Professional Design</h3>
          <p class="text-secondary-500 dark:text-secondary-400">Modern, responsive templates that look great on all devices and impress potential employers.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-white dark:bg-secondary-900">
    <div class="py-8 px-4 mx-auto max-w-screen-xl sm:py-16 lg:px-6">
      <div class="mx-auto max-w-screen-sm text-center">
        <h2 class="mb-4 text-4xl tracking-tight font-extrabold leading-tight text-secondary-900 dark:text-white">
          Start building today
        </h2>
        <p class="mb-6 font-light text-secondary-500 dark:text-secondary-400 md:text-lg">
          Join thousands of developers who've already created stunning portfolios with DevvMe.
        </p>
        <%= link_to new_user_registration_path, class: "text-white bg-primary-700 hover:bg-primary-800 focus:ring-4 focus:ring-primary-300 font-medium rounded-lg text-sm px-5 py-2.5 mr-2 mb-2 dark:bg-primary-600 dark:hover:bg-primary-700 focus:outline-none dark:focus:ring-primary-800" do %>
          Create Your Portfolio
        <% end %>
      </div>
    </div>
  </section>
<% end %>
