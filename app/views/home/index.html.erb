<div class="text-center">
  <h1 class="font-bold text-4xl mb-6">Welcome to DevvMe</h1>
  <p class="text-gray-600 mb-8">Connect with developers from around the world</p>
  
  <% if user_signed_in? %>
    <div class="bg-white shadow-md rounded px-8 py-6">
      <h2 class="text-2xl font-bold mb-4">Welcome back, <%= current_user.username %>!</h2>
      <% if current_user.avatar.attached? %>
        <%= image_tag current_user.avatar, class: "w-20 h-20 rounded-full object-cover mx-auto mb-4" %>
      <% end %>
      <% if current_user.bio.present? %>
        <p class="text-gray-700 mb-4"><%= current_user.bio %></p>
      <% end %>
      <div class="flex justify-center space-x-4">
        <% if current_user.github_url.present? %>
          <%= link_to "GitHub", current_user.github_url, target: "_blank", class: "text-blue-500 hover:text-blue-700" %>
        <% end %>
        <% if current_user.linkedin_url.present? %>
          <%= link_to "LinkedIn", current_user.linkedin_url, target: "_blank", class: "text-blue-500 hover:text-blue-700" %>
        <% end %>
        <% if current_user.website_url.present? %>
          <%= link_to "Website", current_user.website_url, target: "_blank", class: "text-blue-500 hover:text-blue-700" %>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="bg-white shadow-md rounded px-8 py-6">
      <p class="text-gray-700 mb-6">Join our community of developers and showcase your skills</p>
      <div class="space-x-4">
        <%= link_to "Sign Up", new_user_registration_path, class: "bg-green-500 hover:bg-green-700 text-white font-bold py-2 px-6 rounded" %>
        <%= link_to "Log In", new_user_session_path, class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded" %>
      </div>
    </div>
  <% end %>
</div>
