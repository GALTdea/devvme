<%# SEO Meta Tags for Social Media %>
<% content_for :title, @seo_title %>
<% content_for :meta_description, @seo_description %>
<% content_for :canonical, tag.link(rel: "canonical", href: @seo_url) %>
<% content_for :social_meta, enhanced_open_graph_tags(
  title: @seo_title,
  description: @seo_description,
  image: @seo_image_url,
  url: @seo_url,
  type: "website",
  image_alt: "Devv.me - Developer Portfolio Platform",
  twitter_creator: "@devvme_app"
) %>

<% if user_signed_in? %>
  <!-- Authenticated User Dashboard -->
  <div class="max-w-screen-xl mx-auto px-4 py-8">
    <div class="bg-cream-50 dark:bg-charcoal-800 shadow-lg rounded-lg p-8 mb-8 border border-primary-200 dark:border-secondary-700">
      <div class="flex items-center space-x-6 mb-6">
        <div class="w-16 h-16 bg-gradient-to-br from-primary-500 to-secondary-600 rounded-full flex items-center justify-center shadow-lg">
          <span class="text-white text-2xl font-bold"><%= current_user.username.first.upcase %></span>
        </div>
        <div>
          <h1 class="text-3xl font-bold text-charcoal-900 dark:text-cream-50">Welcome back, <%= current_user.username %>!</h1>
          <p class="text-charcoal-600 dark:text-charcoal-400">Ready to build something amazing?</p>
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-gradient-to-br from-primary-50 to-primary-100 dark:bg-gradient-to-br dark:from-primary-900/20 dark:to-secondary-900/20 rounded-lg p-6 text-center border border-primary-200 dark:border-primary-800 hover:shadow-lg transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-primary-600 to-primary-700 rounded-lg flex items-center justify-center mx-auto mb-4 shadow-md">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-primary-900 dark:text-primary-100 mb-2">Projects</h3>
          <p class="text-primary-700 dark:text-primary-300 text-sm">0 projects</p>
          <%= link_to "#", class: "inline-block mt-4 text-primary-600 hover:text-primary-800 dark:text-primary-400 dark:hover:text-primary-200 font-medium transition-colors duration-200" do %>
            Create First Project →
          <% end %>
        </div>
        
        <div class="bg-gradient-to-br from-pink-50 to-pink-100 dark:bg-gradient-to-br dark:from-pink-900/20 dark:to-secondary-900/20 rounded-lg p-6 text-center border border-pink-200 dark:border-pink-800 hover:shadow-lg transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-pink-500 to-pink-600 rounded-lg flex items-center justify-center mx-auto mb-4 shadow-md">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-pink-900 dark:text-pink-100 mb-2">Profile</h3>
          <p class="text-pink-700 dark:text-pink-300 text-sm">Complete your profile</p>
          <%= link_to edit_user_registration_path, class: "inline-block mt-4 text-pink-600 hover:text-pink-800 dark:text-pink-400 dark:hover:text-pink-200 font-medium transition-colors duration-200" do %>
            Edit Profile →
          <% end %>
        </div>
        
        <div class="bg-gradient-to-br from-warning-50 to-warning-100 dark:bg-gradient-to-br dark:from-warning-900/20 dark:to-secondary-900/20 rounded-lg p-6 text-center border border-warning-200 dark:border-warning-800 hover:shadow-lg transition-all duration-300">
          <div class="w-12 h-12 bg-gradient-to-br from-warning-500 to-warning-600 rounded-lg flex items-center justify-center mx-auto mb-4 shadow-md">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-warning-900 dark:text-warning-100 mb-2">Analytics</h3>
          <p class="text-warning-700 dark:text-warning-300 text-sm">0 views this month</p>
          <%= link_to "#", class: "inline-block mt-4 text-warning-600 hover:text-warning-800 dark:text-warning-400 dark:hover:text-warning-200 font-medium transition-colors duration-200" do %>
            View Details →
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% else %>
  <!-- Landing Page for Non-Authenticated Users -->
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-cream-50 via-primary-50 to-secondary-50 dark:bg-gradient-to-br dark:from-charcoal-900 dark:via-secondary-900 dark:to-charcoal-800">
    <div class="py-8 px-4 mx-auto max-w-screen-xl text-center lg:py-16 lg:px-12">
      <h1 class="mb-4 text-4xl font-extrabold tracking-tight leading-none bg-gradient-to-r from-primary-600 via-secondary-600 to-pink-600 bg-clip-text text-transparent md:text-5xl lg:text-6xl">
        Showcase, Connect, and Grow as a Developer
      </h1>
      <p class="mb-8 text-lg font-normal text-charcoal-600 lg:text-xl sm:px-16 xl:px-48 dark:text-charcoal-300">
        Build your portfolio, share your projects, write blog posts, and connect with developers who share your passions.
      </p>
      <div class="flex flex-col mb-8 lg:mb-16 space-y-4 sm:flex-row sm:justify-center sm:space-y-0 sm:space-x-4">
        <% if registration_enabled? %>
          <%= link_to new_user_registration_path, class: "inline-flex justify-center items-center py-3 px-6 text-base font-medium text-center text-white rounded-lg bg-gradient-to-r from-primary-600 to-primary-700 hover:from-primary-700 hover:to-primary-800 focus:ring-4 focus:ring-primary-300 dark:focus:ring-primary-900 shadow-lg hover:shadow-xl transition-all duration-300" do %>
            Start Creating
            <svg class="ml-2 -mr-1 w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
            </svg>
          <% end %>
        <% else %>
          <%= link_to new_user_registration_path, class: "inline-flex justify-center items-center py-3 px-6 text-base font-medium text-center text-gray-500 rounded-lg bg-gray-200 cursor-not-allowed shadow-lg transition-all duration-300", title: "Registration temporarily disabled" do %>
            <svg class="mr-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Coming Soon
          <% end %>
        <% end %>
        <%= link_to new_user_session_path, class: "inline-flex justify-center items-center py-3 px-6 text-base font-medium text-center text-charcoal-700 rounded-lg border border-charcoal-300 hover:bg-charcoal-50 focus:ring-4 focus:ring-charcoal-100 dark:text-cream-100 dark:border-charcoal-600 dark:hover:bg-charcoal-800 dark:focus:ring-charcoal-700 transition-all duration-300" do %>
          Sign In
        <% end %>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="bg-gradient-to-br from-secondary-50 via-pink-50 to-warning-50 dark:bg-gradient-to-br dark:from-secondary-800 dark:via-charcoal-800 dark:to-secondary-900">
    <div class="py-8 px-4 mx-auto max-w-screen-xl sm:py-16 lg:px-6">
      <div class="max-w-screen-md mb-8 lg:mb-16 mx-auto text-center">
        <h2 class="mb-4 text-4xl tracking-tight font-extrabold bg-gradient-to-r from-secondary-700 via-primary-600 to-pink-600 bg-clip-text text-transparent">
          Everything you need to showcase your work — and grow your community
        </h2>
        <p class="text-charcoal-600 sm:text-xl dark:text-charcoal-300">
          Powerful tools to highlight your skills, projects, and insights through blogs—while helping you connect, share, and get discovered by other developers, clients, and potential employers.
        </p>
      </div>
      <div class="space-y-8 md:grid md:grid-cols-2 lg:grid-cols-4 md:gap-8 md:space-y-0">
        <div class="text-center p-6 bg-white/50 dark:bg-charcoal-800/50 rounded-lg border border-primary-200 dark:border-charcoal-700 hover:shadow-lg transition-all duration-300">
          <div class="flex justify-center items-center mb-4 w-12 h-12 rounded-full bg-gradient-to-br from-primary-500 to-primary-600 lg:h-14 lg:w-14 shadow-lg mx-auto">
            <svg class="w-6 h-6 text-white lg:w-7 lg:h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h8M8 11h4"></path>
            </svg>
          </div>
          <h3 class="mb-2 text-xl font-bold text-charcoal-900 dark:text-cream-50">Share Your Projects</h3>
          <p class="text-charcoal-600 dark:text-charcoal-300">Post your best work with detailed descriptions, live demos, and updates for followers.</p>
        </div>
        <div class="text-center p-6 bg-white/50 dark:bg-charcoal-800/50 rounded-lg border border-secondary-200 dark:border-charcoal-700 hover:shadow-lg transition-all duration-300">
          <div class="flex justify-center items-center mb-4 w-12 h-12 rounded-full bg-gradient-to-br from-secondary-500 to-secondary-600 lg:h-14 lg:w-14 shadow-lg mx-auto">
            <svg class="w-6 h-6 text-white lg:w-7 lg:h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
            </svg>
          </div>
          <h3 class="mb-2 text-xl font-bold text-charcoal-900 dark:text-cream-50">Blogging</h3>
          <p class="text-charcoal-600 dark:text-charcoal-300">Share your journey — from what you’re building to what you’re learning — through blog posts that help you grow and connect with others.</p>
        </div>
        <div class="text-center p-6 bg-white/50 dark:bg-charcoal-800/50 rounded-lg border border-accent-200 dark:border-charcoal-700 hover:shadow-lg transition-all duration-300">
          <div class="flex justify-center items-center mb-4 w-12 h-12 rounded-full bg-gradient-to-br from-accent-500 to-accent-600 lg:h-14 lg:w-14 shadow-lg mx-auto">
            <svg class="w-6 h-6 text-white lg:w-7 lg:h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="mb-2 text-xl font-bold text-charcoal-900 dark:text-cream-50">Skills & Experience</h3>
          <p class="text-charcoal-600 dark:text-charcoal-300">Highlight your technical skills, certifications, and professional experience in a clean format.</p>
        </div>
        <div class="text-center p-6 bg-white/50 dark:bg-charcoal-800/50 rounded-lg border border-warning-200 dark:border-charcoal-700 hover:shadow-lg transition-all duration-300">
          <div class="flex justify-center items-center mb-4 w-12 h-12 rounded-full bg-gradient-to-br from-warning-500 to-warning-600 lg:h-14 lg:w-14 shadow-lg mx-auto">
            <svg class="w-6 h-6 text-white lg:w-7 lg:h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </div>
          <h3 class="mb-2 text-xl font-bold text-charcoal-900 dark:text-cream-50">Beautiful Portfolio Templates</h3>
          <p class="text-charcoal-600 dark:text-charcoal-300">Responsive layouts that make your portfolio and community profile stand out.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Community Spotlight Section -->
  <section class="bg-white dark:bg-charcoal-900 border-t border-charcoal-100 dark:border-charcoal-800">
    <div class="py-8 px-4 mx-auto max-w-screen-xl sm:py-16 lg:px-6">
      <div class="mx-auto max-w-screen-md text-center mb-12">
        <h2 class="mb-4 text-4xl tracking-tight font-extrabold leading-tight text-charcoal-900 dark:text-cream-50">
          Meet the Builders
        </h2>
        <p class="mb-6 font-light text-charcoal-600 dark:text-charcoal-300 md:text-lg">
          Explore top developer creators sharing their projects, ideas, and progress. Follow the ones who inspire you to build more.
        </p>
      </div>
      
      <!-- Developer Cards Grid -->
      <% cache ['featured_users_section', @featured_users.maximum(:updated_at), @featured_users.count] do %>
        <% if @featured_users.any? %>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            <% @featured_users.each_with_index do |user, index| %>
            <% 
              # Generate varied gradient colors for each user
              gradient_colors = [
                { from: 'pink-500', to: 'pink-600' },
                { from: 'green-500', to: 'green-600' },
                { from: 'purple-500', to: 'purple-600' },
                { from: 'orange-500', to: 'orange-600' },
                { from: 'blue-500', to: 'blue-600' },
                { from: 'red-500', to: 'red-600' },
                { from: 'indigo-500', to: 'indigo-600' },
                { from: 'teal-500', to: 'teal-600' },
                { from: 'amber-500', to: 'amber-600' },
                { from: 'cyan-500', to: 'cyan-600' }
              ]
              color = gradient_colors[index % gradient_colors.length]
              
              # Generate initials
              initials = if user.full_name.present?
                user.full_name.split.map(&:first).join.upcase[0..1]
              else
                user.username[0..1].upcase
              end
            %>
            
            <%= link_to public_profile_path(user.username), class: "block bg-white dark:bg-charcoal-800 rounded-lg border border-charcoal-200 dark:border-charcoal-700 p-6 hover:shadow-lg transition-all duration-300 hover:border-primary-300 dark:hover:border-primary-600" do %>
              <div class="flex items-center space-x-3 mb-4">
                <% if user.avatar.attached? %>
                  <%= image_tag user.avatar_thumbnail, class: "w-12 h-12 rounded-full shadow-md object-cover" %>
                <% else %>
                  <div class="w-12 h-12 bg-gradient-to-br from-<%= color[:from] %> to-<%= color[:to] %> rounded-full flex items-center justify-center shadow-md">
                    <span class="text-white text-lg font-semibold"><%= initials %></span>
                  </div>
                <% end %>
                <div class="flex-1 min-w-0">
                  <h3 class="text-lg font-semibold text-charcoal-900 dark:text-cream-50 truncate"><%= user.display_name %></h3>
                  <p class="text-sm text-charcoal-600 dark:text-charcoal-400 truncate">
                    <%= user.headline.present? ? user.headline : user.job_title.present? ? user.job_title : "@#{user.username}" %>
                  </p>
                </div>
              </div>
              
              <% if user.bio.present? %>
                <div class="mb-4">
                  <p class="text-sm text-charcoal-600 dark:text-charcoal-400 line-clamp-2">
                    <%= user.bio %>
                  </p>
                </div>
              <% end %>
              
              <div class="flex items-center justify-between pt-3 border-t border-charcoal-100 dark:border-charcoal-700">
                <div class="flex items-center space-x-1">
                  <span class="text-warning-500">⭐</span>
                  <span class="text-sm text-charcoal-600 dark:text-charcoal-400">
                    <%= pluralize(user.followers.count, 'follower') %>
                  </span>
                </div>
                <% if user.projects.published.any? %>
                  <div class="text-xs text-charcoal-500 dark:text-charcoal-500">
                    <%= pluralize(user.projects.published.count, 'project') %>
                  </div>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
        <% else %>
          <!-- Fallback message if no featured users -->
          <div class="text-center py-12">
            <p class="text-charcoal-600 dark:text-charcoal-400 text-lg">
              Featured developer profiles coming soon! Check back later to discover amazing creators.
            </p>
          </div>
        <% end %>
      <% end %>
    </div>
  </section>

<% end %>
