<% content_for :title, "Dashboard" %>

<div class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    
    <!-- Welcome Header -->
    <div class="mb-6">
      <div class="sm:flex sm:items-center sm:justify-between">
        <div>
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white">
            Welcome back, <%= @user.display_name %>!
          </h1>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
            Here's what's happening with your developer portfolio today.
          </p>
        </div>
        <div class="mt-4 sm:mt-0">
          <%= link_to complete_profile_path, class: "inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200 hover:bg-blue-200 dark:hover:bg-blue-800 transition-colors cursor-pointer" do %>
            Profile <%= @profile_completion %>% complete
          <% end %>
        </div>
      </div>
    </div>
    <!-- Compact Statistics Overview -->
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 mb-6">
      <div class="p-6">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Overview</h2>
        
        <!-- Main Stats Grid -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
          <!-- Projects -->
          <div class="text-center">
            <div class="flex items-center justify-center w-12 h-12 mx-auto mb-2 bg-blue-100 dark:bg-blue-900 rounded-lg">
              <svg class="h-6 w-6 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
            </div>
            <div class="text-2xl font-bold text-gray-900 dark:text-white"><%= @projects_count %></div>
            <div class="text-sm text-gray-500 dark:text-gray-400">Projects</div>
            <div class="text-xs text-green-600 dark:text-green-400 mt-1">
              <%= @published_projects_count %> published
            </div>
          </div>

          <!-- Blog Posts -->
          <div class="text-center">
            <div class="flex items-center justify-center w-12 h-12 mx-auto mb-2 bg-orange-100 dark:bg-orange-900 rounded-lg">
              <svg class="h-6 w-6 text-orange-600 dark:text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <div class="text-2xl font-bold text-gray-900 dark:text-white"><%= @blog_posts_count %></div>
            <div class="text-sm text-gray-500 dark:text-gray-400">Blog Posts</div>
            <div class="text-xs text-green-600 dark:text-green-400 mt-1">
              <%= @published_blog_posts_count %> published
            </div>
          </div>

          <!-- Total Views -->
          <div class="text-center">
            <div class="flex items-center justify-center w-12 h-12 mx-auto mb-2 bg-purple-100 dark:bg-purple-900 rounded-lg">
              <svg class="h-6 w-6 text-purple-600 dark:text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            </div>
            <div class="text-2xl font-bold text-gray-900 dark:text-white"><%= number_with_delimiter(@total_blog_views) %></div>
            <div class="text-sm text-gray-500 dark:text-gray-400">Total Views</div>
          </div>

          <!-- Profile Completion -->
          <%= link_to complete_profile_path, class: "block text-center hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors rounded-lg p-2 -m-2" do %>
            <div class="flex items-center justify-center w-12 h-12 mx-auto mb-2 bg-green-100 dark:bg-green-900 rounded-lg">
              <svg class="h-6 w-6 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <div class="text-2xl font-bold text-gray-900 dark:text-white"><%= @profile_completion %>%</div>
            <div class="text-sm text-gray-500 dark:text-gray-400">Profile Complete</div>
            <div class="w-full bg-gray-200 rounded-full h-1.5 mt-2 dark:bg-gray-700">
              <div class="bg-green-600 h-1.5 rounded-full" style="width: <%= @profile_completion %>%"></div>
            </div>
          <% end %>
        </div>

        <!-- Additional Stats Row -->
        <div class="flex justify-center space-x-8 text-sm text-gray-500 dark:text-gray-400">
          <div class="flex items-center">
            <div class="w-2 h-2 bg-yellow-400 rounded-full mr-2"></div>
            <%= @draft_blog_posts_count %> drafts
          </div>
          <div class="flex items-center">
            <div class="w-2 h-2 bg-blue-400 rounded-full mr-2"></div>
            <%= @projects_count - @published_projects_count %> unpublished
          </div>
        </div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="mb-6">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Quick Actions</h2>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
        
        <!-- Create New Project -->
        <%= link_to new_project_path, class: "group flex items-center p-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg hover:border-blue-300 dark:hover:border-blue-600 hover:shadow-sm transition-all duration-200" do %>
          <div class="flex-shrink-0">
            <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900 rounded-lg flex items-center justify-center group-hover:bg-blue-200 dark:group-hover:bg-blue-800 transition-colors">
              <svg class="h-5 w-5 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
              </svg>
            </div>
          </div>
          <div class="ml-3 min-w-0 flex-1">
            <p class="text-sm font-medium text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400">
              New Project
            </p>
            <p class="text-xs text-gray-500 dark:text-gray-400 truncate">
              Add project
            </p>
          </div>
        <% end %>

        <!-- Edit Profile -->
        <%= link_to edit_profile_path, class: "group flex items-center p-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg hover:border-green-300 dark:hover:border-green-600 hover:shadow-sm transition-all duration-200" do %>
          <div class="flex-shrink-0">
            <div class="w-10 h-10 bg-green-100 dark:bg-green-900 rounded-lg flex items-center justify-center group-hover:bg-green-200 dark:group-hover:bg-green-800 transition-colors">
              <svg class="h-5 w-5 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
              </svg>
            </div>
          </div>
          <div class="ml-3 min-w-0 flex-1">
            <p class="text-sm font-medium text-gray-900 dark:text-white group-hover:text-green-600 dark:group-hover:text-green-400">
              Edit Profile
            </p>
            <p class="text-xs text-gray-500 dark:text-gray-400 truncate">
              Update info
            </p>
          </div>
        <% end %>

        <!-- Create New Blog Post -->
        <%= link_to new_blog_post_path, class: "group flex items-center p-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg hover:border-orange-300 dark:hover:border-orange-600 hover:shadow-sm transition-all duration-200" do %>
          <div class="flex-shrink-0">
            <div class="w-10 h-10 bg-orange-100 dark:bg-orange-900 rounded-lg flex items-center justify-center group-hover:bg-orange-200 dark:group-hover:bg-orange-800 transition-colors">
              <svg class="h-5 w-5 text-orange-600 dark:text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
              </svg>
            </div>
          </div>
          <div class="ml-3 min-w-0 flex-1">
            <p class="text-sm font-medium text-gray-900 dark:text-white group-hover:text-orange-600 dark:group-hover:text-orange-400">
              Write Post
            </p>
            <p class="text-xs text-gray-500 dark:text-gray-400 truncate">
              New blog post
            </p>
          </div>
        <% end %>

        <!-- View Public Profile -->
        <%= link_to profile_path, class: "group flex items-center p-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg hover:border-purple-300 dark:hover:border-purple-600 hover:shadow-sm transition-all duration-200" do %>
          <div class="flex-shrink-0">
            <div class="w-10 h-10 bg-purple-100 dark:bg-purple-900 rounded-lg flex items-center justify-center group-hover:bg-purple-200 dark:group-hover:bg-purple-800 transition-colors">
              <svg class="h-5 w-5 text-purple-600 dark:text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            </div>
          </div>
          <div class="ml-3 min-w-0 flex-1">
            <p class="text-sm font-medium text-gray-900 dark:text-white group-hover:text-purple-600 dark:group-hover:text-purple-400">
              View Profile
            </p>
            <p class="text-xs text-gray-500 dark:text-gray-400 truncate">
              Public view
            </p>
          </div>
        <% end %>

      </div>
    </div>

    <!-- Recent Projects Section -->
    <div class="mb-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Recent Projects</h2>
        <% if @recent_projects.any? %>
          <%= link_to projects_path, class: "text-sm font-medium text-blue-600 hover:text-blue-500 dark:text-blue-400 dark:hover:text-blue-300 flex items-center" do %>
            View all
            <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          <% end %>
        <% end %>
      </div>

      <% if @recent_projects.any? %>
        <!-- Projects List -->
        <div class="bg-white dark:bg-gray-800 shadow rounded-lg divide-y divide-gray-200 dark:divide-gray-700">
          <% @recent_projects.each do |project| %>
            <div class="p-6">
              <div class="flex items-center justify-between">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center justify-between">
                    <h3 class="text-sm font-medium text-gray-900 dark:text-white truncate">
                      <%= link_to project.title, project_path(project), class: "hover:text-blue-600 dark:hover:text-blue-400" %>
                    </h3>
                    <div class="flex items-center space-x-2 ml-4">
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                        Published
                      </span>
                      <div class="flex space-x-1">
                        <% if project.github_url.present? %>
                          <%= link_to project.github_url, target: "_blank", class: "text-gray-400 hover:text-gray-500 dark:hover:text-gray-300", onclick: "event.stopPropagation()" do %>
                            <span class="sr-only">GitHub</span>
                            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                              <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd" />
                            </svg>
                          <% end %>
                        <% end %>
                        <% if project.demo_url.present? %>
                          <%= link_to project.demo_url, target: "_blank", class: "text-gray-400 hover:text-gray-500 dark:hover:text-gray-300", onclick: "event.stopPropagation()" do %>
                            <span class="sr-only">Live Demo</span>
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                            </svg>
                          <% end %>
                        <% end %>
                      </div>
                    </div>
                  </div>
                  <% if project.description.present? %>
                    <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
                      <%= truncate(project.description, length: 120) %>
                    </p>
                  <% end %>
                  <div class="mt-2 flex items-center text-xs text-gray-500 dark:text-gray-400">
                    <time>
                      Created <%= time_ago_in_words(project.created_at) %> ago
                    </time>
                    <% if project.technologies.present? %>
                      <span class="mx-2">•</span>
                      <span><%= project.technologies.join(', ') %></span>
                    <% end %>
                  </div>
                </div>
                <div class="ml-4 flex-shrink-0">
                  <%= link_to edit_project_path(project), class: "text-gray-400 hover:text-gray-600 dark:hover:text-gray-300" do %>
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <!-- Empty State -->
        <div class="text-center py-12 bg-white dark:bg-gray-800 rounded-lg">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No projects yet</h3>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
            Get started by creating your first project to showcase your development work.
          </p>
          <div class="mt-6">
            <%= link_to new_project_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
              <svg class="-ml-1 mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
              </svg>
              Create your first project
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Recent Blog Posts Section -->
    <div class="mb-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Recent Blog Posts</h2>
        <% if @recent_blog_posts.any? %>
          <%= link_to blog_posts_path, class: "text-sm font-medium text-blue-600 hover:text-blue-500 dark:text-blue-400 dark:hover:text-blue-300 flex items-center" do %>
            Manage all
            <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          <% end %>
        <% end %>
      </div>

      <% if @recent_blog_posts.any? %>
        <!-- Blog Posts List -->
        <div class="bg-white dark:bg-gray-800 shadow rounded-lg divide-y divide-gray-200 dark:divide-gray-700">
          <% @recent_blog_posts.each do |blog_post| %>
            <div class="p-6">
              <div class="flex items-center justify-between">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center justify-between">
                    <h3 class="text-sm font-medium text-gray-900 dark:text-white truncate">
                      <%= link_to blog_post.title, blog_post_path(blog_post), class: "hover:text-blue-600 dark:hover:text-blue-400" %>
                    </h3>
                    <div class="flex items-center space-x-2 ml-4">
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= blog_post.published? ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200' : 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200' %>">
                        <%= blog_post.published? ? 'Published' : 'Draft' %>
                      </span>
                      <% if blog_post.published? %>
                        <span class="inline-flex items-center text-xs text-gray-500 dark:text-gray-400">
                          <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                          </svg>
                          <%= blog_post.views_count %>
                        </span>
                      <% end %>
                    </div>
                  </div>
                  <% if blog_post.excerpt.present? %>
                    <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
                      <%= truncate(blog_post.excerpt, length: 100) %>
                    </p>
                  <% end %>
                  <div class="mt-2 flex items-center text-xs text-gray-500 dark:text-gray-400">
                    <time>
                      <%= blog_post.published? ? "Published #{time_ago_in_words(blog_post.published_at)} ago" : "Updated #{time_ago_in_words(blog_post.updated_at)} ago" %>
                    </time>
                    <span class="mx-2">•</span>
                    <span><%= pluralize(blog_post.word_count, 'word') %></span>
                    <span class="mx-2">•</span>
                    <span><%= blog_post.reading_time %> min read</span>
                  </div>
                </div>
                <div class="ml-4 flex-shrink-0">
                  <%= link_to edit_blog_post_path(blog_post), class: "text-gray-400 hover:text-gray-600 dark:hover:text-gray-300" do %>
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <!-- Empty State -->
        <div class="text-center py-12 bg-white dark:bg-gray-800 rounded-lg">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
          </svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No blog posts yet</h3>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
            Start sharing your knowledge and experiences through blog posts.
          </p>
          <div class="mt-6">
            <%= link_to new_blog_post_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
              <svg class="-ml-1 mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
              </svg>
              Write your first post
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Profile Completion Prompt -->
    <% if @profile_completion < 100 %>
      <div class="bg-blue-50 dark:bg-blue-900 border border-blue-200 dark:border-blue-700 rounded-md p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-blue-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3 flex-1 md:flex md:justify-between">
            <p class="text-sm text-blue-700 dark:text-blue-200">
              Complete your profile to improve your visibility and attract more opportunities.
            </p>
            <%= link_to edit_profile_path, class: "text-sm font-medium text-blue-700 dark:text-blue-200 hover:text-blue-600 dark:hover:text-blue-100 whitespace-nowrap md:ml-6" do %>
              Complete profile
              <span aria-hidden="true"> →</span>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

  </div>
</div>
