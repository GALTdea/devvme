<% if @project.published? && defined?(@seo_title) %>
  <% page_title(@seo_title) %>
  <% meta_description(@seo_description) %>
  <% canonical_url(@seo_project_url) %>
  <% enhanced_open_graph_tags(
    title: @seo_title,
    description: @seo_description,
    image: @seo_image_url,
    url: @seo_project_url,
    type: "article",
    image_alt: @seo_image_alt
  ) %>
<% end %>

<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>
<div class="min-h-screen bg-gray-50 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <nav class="flex items-center space-x-2 text-sm text-gray-500 mb-4">
        <%= link_to public_projects_path, class: "hover:text-gray-700" do %>
          Project Stories
        <% end %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-gray-900"><%= truncate(@project.title, length: 50) %></span>
      </nav>
      
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between">
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-2">
            <h1 class="text-3xl font-bold text-gray-900"><%= @project.title %></h1>
            
            <!-- Status Badge (owner/admin only for draft/archived) -->
            <% if can_edit_project?(@project) && !@project.published? %>
              <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium
                <%= case @project.status
                    when 'draft' then 'bg-yellow-100 text-yellow-800'
                    when 'archived' then 'bg-gray-100 text-gray-800'
                    else 'bg-gray-100 text-gray-800'
                    end %>">
                <%= @project.status.humanize %>
              </span>
            <% end %>
            
            <!-- Featured Badge -->
            <% if @project.featured? %>
              <span class="inline-flex items-center px-2 py-1 rounded-full text-sm font-medium bg-purple-100 text-purple-800">
                <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
                Featured
              </span>
            <% end %>
          </div>
          
          <!-- Developer Info -->
          <div class="flex items-center gap-3 mb-4">
            <% if @project.user.avatar.attached? %>
              <%= image_tag @project.user.avatar_medium, 
                  class: "w-12 h-12 rounded-full", 
                  alt: @project.user.display_name %>
            <% else %>
              <div class="w-12 h-12 bg-gray-300 rounded-full flex items-center justify-center">
                <span class="text-lg font-medium text-gray-600">
                  <%= @project.user.display_name.first.upcase %>
                </span>
              </div>
            <% end %>
            <div>
              <div class="text-sm text-gray-600">
                by <%= link_to @project.user.display_name, public_profile_path(@project.user.username), class: "hover:text-blue-600 transition-colors font-medium" %>
              </div>
              <div class="text-xs text-gray-500">
                <%= @project.published? ? "Published" : "Created" %> <%= @project.created_at.strftime("%B %d, %Y") %>
              </div>
            </div>
          </div>
          <% if can_edit_project?(@project) && !@project.published? %>
            <div class="mt-3 p-3 rounded-lg bg-amber-50 border border-amber-200 text-sm text-amber-800">
              This project is not visible to the public. <%= link_to "Edit project", edit_project_path(@project), class: "font-medium underline hover:text-amber-900" %> to publish it.
            </div>
          <% end %>
        </div>
        
        <!-- Action Buttons -->
        <div class="flex items-center gap-3 mt-4 lg:mt-0 flex-wrap">
          <% if @project.live_url.present? %>
            <%= link_to @project.live_url, target: "_blank", rel: "noopener noreferrer",
                class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
              Live Demo
            <% end %>
          <% end %>
          
          <% if @project.source_code_url.present? %>
            <%= link_to @project.source_code_url, target: "_blank", rel: "noopener noreferrer",
                class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
              <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.293a1 1 0 010 1.414L3.414 10l2.293 2.293a1 1 0 11-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0zm8.586 0a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 11-1.414-1.414L16.586 10l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
              </svg>
              Source Code
            <% end %>
          <% end %>

          <% if @project.published? %>
            <% share_label = can_edit_project?(@project) ? "Share your story" : "Share this project story" %>
            <div data-controller="share-button"
                 data-share-button-url-value="<%= public_project_url(@project) %>"
                 data-share-button-title-value="<%= @project.title %>"
                 data-share-button-copied-message-value="Project story link copied to clipboard!">
              <button type="button"
                      data-action="click->share-button#share"
                      class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"
                      aria-label="<%= share_label %>">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.367 2.684 3 3 0 00-5.367-2.684z"/>
                </svg>
                <%= share_label %>
              </button>
            </div>
          <% end %>
          
          <!-- Owner/Admin actions -->
          <% if can_edit_project?(@project) %>
            <%= link_to edit_project_path(@project), 
                class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
              Edit Project
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main Content -->
      <div class="lg:col-span-2 space-y-8">
        <!-- Project Images -->
        <% if @project.images.attached? || @project.thumbnail.attached? %>
          <div class="bg-white rounded-lg shadow-md overflow-hidden">
            <div class="p-6">
              <h2 class="text-xl font-semibold text-gray-900 mb-4">Project Gallery</h2>
              
              <!-- Main Image -->
              <% main_image = @project.thumbnail.attached? ? @project.thumbnail : @project.images.first %>
              <% if main_image %>
                <div class="mb-6">
                  <%= image_tag main_image, 
                      class: "w-full h-64 md:h-80 object-cover rounded-lg shadow-sm",
                      alt: @project.title %>
                </div>
              <% end %>
              
              <!-- Additional Images -->
              <% if @project.images.attached? && @project.images.count > 1 %>
                <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                  <% @project.images.each_with_index do |image, index| %>
                    <% next if index == 0 && !@project.thumbnail.attached? %>
                    <%= image_tag image, 
                        class: "w-full h-24 object-cover rounded-md shadow-sm cursor-pointer hover:shadow-md transition-shadow",
                        alt: "#{@project.title} screenshot #{index + 1}" %>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Project Story -->
        <%= render "project_story", project: @project %>

        <!-- Related Projects -->
        <% if @related_projects.any? %>
          <div class="bg-white rounded-lg shadow-md p-6">
            <h2 class="text-xl font-semibold text-gray-900 mb-4">More Projects by <%= @project.user.display_name %></h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              <% @related_projects.each do |related_project| %>
                <div class="border border-gray-200 rounded-lg overflow-hidden hover:shadow-md transition-shadow">
                  <!-- Project Image -->
                  <div class="relative h-32 bg-gray-200">
                    <% if related_project.thumbnail.attached? %>
                      <%= image_tag related_project.thumbnail, 
                          class: "w-full h-full object-cover", 
                          alt: related_project.title %>
                    <% elsif related_project.images.attached? && related_project.images.first %>
                      <%= image_tag related_project.images.first, 
                          class: "w-full h-full object-cover", 
                          alt: related_project.title %>
                    <% else %>
                      <div class="w-full h-full flex items-center justify-center">
                        <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                        </svg>
                      </div>
                    <% end %>
                  </div>

                  <!-- Project Info -->
                  <div class="p-4">
                    <h3 class="font-semibold text-gray-900 mb-2">
                      <%= link_to related_project.title, public_project_path(related_project), class: "hover:text-blue-600 transition-colors" %>
                    </h3>
                    <p class="text-sm text-gray-600 line-clamp-2">
                      <%= truncate(related_project.public_story_overview, length: 80) %>
                    </p>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <%= render "github_enrichment", project: @project %>

        <% if @project.project_insight_enabled? %>
          <div class="bg-white rounded-lg shadow-md p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Project Insight</h3>
            <p class="text-sm text-gray-600 mb-4">
              Ask technical questions about this project. Answers are grounded in repository evidence.
            </p>

            <% if user_signed_in? %>
              <%= form_with url: ask_public_project_insight_path(@project), method: :post, local: true, class: "space-y-3", data: { turbo: false } do |form| %>
                <%= form.label :question, "Question", class: "block text-sm font-medium text-gray-700" %>
                <%= form.text_area :question,
                    rows: 3,
                    maxlength: 400,
                    value: @project_insight_result&.dig("question"),
                    placeholder: "What does this project demonstrate about the developer's architecture skills?",
                    class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
                <%= form.submit "Ask Project Insight",
                    class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" %>
              <% end %>

              <% if @project_insight_result.present? %>
                <div class="mt-4 p-4 rounded-md bg-blue-50 border border-blue-100">
                  <h4 class="text-sm font-semibold text-blue-900 mb-2">Answer</h4>
                  <p class="text-sm text-blue-900 leading-relaxed"><%= @project_insight_result["answer"] %></p>

                  <% if @project_insight_result["evidence"].present? %>
                    <h5 class="text-xs font-semibold uppercase tracking-wide text-blue-700 mt-3 mb-1">Evidence</h5>
                    <ul class="list-disc list-inside text-sm text-blue-900 space-y-1">
                      <% @project_insight_result["evidence"].each do |evidence_item| %>
                        <li><%= evidence_item %></li>
                      <% end %>
                    </ul>
                  <% end %>
                </div>
              <% end %>

              <p class="text-xs text-gray-500 mt-3">
                Project Insight can be wrong. Verify important details against the repository.
              </p>
            <% else %>
              <p class="text-sm text-gray-600">
                <%= link_to "Sign in", new_user_session_path, class: "text-blue-600 hover:text-blue-700 font-medium" %>
                to ask Project Insight questions.
              </p>
            <% end %>
          </div>
        <% end %>

        <!-- Technologies Used -->
        <div class="bg-white rounded-lg shadow-md p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Technologies Used</h3>
          <% if @project.technologies_used.any? %>
            <div class="flex flex-wrap gap-2">
              <% @project.technologies_used.each do |tech| %>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
                  <%= tech %>
                </span>
              <% end %>
            </div>
          <% else %>
            <p class="text-gray-500 text-sm">No technologies specified</p>
          <% end %>
        </div>

        <!-- Developer Profile -->
        <div class="bg-white rounded-lg shadow-md p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Developer</h3>
          <div class="flex items-center gap-3 mb-4">
            <% if @project.user.avatar.attached? %>
              <%= image_tag @project.user.avatar_medium, 
                  class: "w-16 h-16 rounded-full", 
                  alt: @project.user.display_name %>
            <% else %>
              <div class="w-16 h-16 bg-gray-300 rounded-full flex items-center justify-center">
                <span class="text-xl font-medium text-gray-600">
                  <%= @project.user.display_name.first.upcase %>
                </span>
              </div>
            <% end %>
            <div>
              <h4 class="font-semibold text-gray-900">
                <%= link_to @project.user.display_name, public_profile_path(@project.user.username), class: "hover:text-blue-600 transition-colors" %>
              </h4>
              <p class="text-sm text-gray-600">@<%= @project.user.username %></p>
            </div>
          </div>
          
          <% if @project.user.bio.present? %>
            <p class="text-sm text-gray-600 mb-4">
              <%= truncate(@project.user.bio, length: 120) %>
            </p>
          <% end %>

          <div class="flex items-center gap-4 text-sm text-gray-500">
            <div>
              <span class="font-medium"><%= @project.user.projects.published.count %></span>
              <span>projects</span>
            </div>
            <div>
              <span class="font-medium"><%= @project.user.blog_posts.published_posts.count %></span>
              <span>posts</span>
            </div>
          </div>

          <div class="mt-4">
            <%= link_to public_profile_path(@project.user.username), 
                class: "w-full inline-flex items-center justify-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
              View Full Profile
            <% end %>
          </div>
        </div>

        <!-- Owner Quick Actions -->
        <% if can_edit_project?(@project) %>
          <div class="bg-white rounded-lg shadow-md p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Quick Actions</h3>
            <div class="space-y-3">
              <% if user_signed_in? && FeatureFlags.github_project_enrichment_enabled_for?(current_user) %>
                <%= button_to refresh_github_insights_project_path(@project),
                    method: :post,
                    disabled: !@project.project_github_repo_url.present? || @project.github_insights_sync_status == "syncing",
                    class: "w-full inline-flex items-center justify-center px-4 py-2 border border-blue-300 text-sm font-medium rounded-md text-blue-700 bg-blue-50 hover:bg-blue-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-60 disabled:cursor-not-allowed" do %>
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m14.356-2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-14.357-2m14.357 2H15"/>
                  </svg>
                  Refresh GitHub Insights
                <% end %>
              <% end %>
              <%= link_to edit_project_path(@project), 
                  class: "w-full inline-flex items-center justify-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
                Edit Project
              <% end %>
              <% if can_delete_project?(@project) %>
                <%= button_to @project, 
                    method: :delete,
                    data: { 
                      confirm: "Are you sure you want to delete this project? This action cannot be undone.",
                      turbo_method: :delete
                    },
                    class: "w-full inline-flex items-center justify-center px-4 py-2 border border-red-300 text-sm font-medium rounded-md text-red-700 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" do %>
                  <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                  </svg>
                  Delete Project
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Admin Controls (only visible to admins viewing another user's project) -->
        <% if user_signed_in? && is_admin? && @project.user != current_user %>
          <div class="bg-orange-50 border border-orange-200 rounded-lg shadow-md p-6">
            <h3 class="text-lg font-semibold text-orange-900 mb-4">Admin Controls</h3>
            <div class="space-y-3">
              <%= link_to edit_project_path(@project), 
                  class: "w-full inline-flex items-center justify-center px-4 py-2 border border-orange-300 text-sm font-medium rounded-md text-orange-700 bg-white hover:bg-orange-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500" do %>
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
                Edit Project (Admin)
              <% end %>
              
              <%= link_to public_profile_path(@project.user.username), 
                  class: "w-full inline-flex items-center justify-center px-4 py-2 border border-blue-300 text-sm font-medium rounded-md text-blue-700 bg-white hover:bg-blue-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
                View Owner Profile
              <% end %>
              
              <%= link_to admin_content_moderation_projects_path, 
                  class: "w-full inline-flex items-center justify-center px-4 py-2 border border-red-300 text-sm font-medium rounded-md text-red-700 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" do %>
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                Content Moderation
              <% end %>
            </div>
            
            <div class="mt-4 pt-4 border-t border-orange-200">
              <div class="text-xs text-orange-700">
                <p><strong>Project Owner:</strong> <%= @project.user.display_name %> (@<%= @project.user.username %>)</p>
                <p><strong>Project Status:</strong> <%= @project.status.humanize %></p>
                <p><strong>Created:</strong> <%= @project.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Project Stats -->
        <div class="bg-white rounded-lg shadow-md p-6">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Project Details</h3>
          <dl class="space-y-3">
            <div>
              <dt class="text-sm font-medium text-gray-500">Status</dt>
              <dd class="mt-1 text-sm text-gray-900">
                <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium
                  <%= case @project.status
                      when 'published' then 'bg-green-100 text-green-800'
                      when 'draft' then 'bg-yellow-100 text-yellow-800'
                      when 'archived' then 'bg-gray-100 text-gray-800'
                      else 'bg-gray-100 text-gray-800'
                      end %>">
                  <%= @project.status.humanize %>
                </span>
              </dd>
            </div>
            
            <% if can_edit_project?(@project) %>
              <div>
                <dt class="text-sm font-medium text-gray-500">Display Order</dt>
                <dd class="mt-1 text-sm text-gray-900">#<%= @project.display_order %></dd>
              </div>
            <% end %>
            
            <div>
              <dt class="text-sm font-medium text-gray-500">Featured</dt>
              <dd class="mt-1 text-sm text-gray-900">
                <%= @project.featured? ? "Yes" : "No" %>
              </dd>
            </div>
            
            <div>
              <dt class="text-sm font-medium text-gray-500">Created</dt>
              <dd class="mt-1 text-sm text-gray-900">
                <%= @project.created_at.strftime("%B %d, %Y") %>
              </dd>
            </div>
            
            <div>
              <dt class="text-sm font-medium text-gray-500">Last Updated</dt>
              <dd class="mt-1 text-sm text-gray-900">
                <%= @project.updated_at.strftime("%B %d, %Y") %>
              </dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </div>
</div>
