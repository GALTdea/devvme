<% page_title("Project Stories") %>
<% meta_description("Discover proof-of-work project stories from developers on Devv.me. Explore real work, technical decisions, and what each project demonstrates.") %>
<% canonical_url(public_projects_url) %>

<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>
<div class="min-h-screen bg-gray-50 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header Section -->
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Project Stories</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Explore proof-of-work project stories from developers. See what they built, why it mattered, and what it demonstrates.
      </p>
      
      <!-- Admin indicator -->
      <% if user_signed_in? && is_admin? %>
        <div class="mt-4 inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-orange-100 text-orange-800">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          Admin View - You can edit any project
        </div>
      <% end %>
    </div>

    <!-- Stats Section -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white rounded-lg shadow-md p-6 text-center">
        <div class="text-3xl font-bold text-blue-600 mb-2"><%= @total_projects %></div>
        <div class="text-gray-600">Published Project Stories</div>
      </div>
      <div class="bg-white rounded-lg shadow-md p-6 text-center">
        <div class="text-3xl font-bold text-green-600 mb-2"><%= @total_users %></div>
        <div class="text-gray-600">Active Developers</div>
      </div>
      <div class="bg-white rounded-lg shadow-md p-6 text-center">
        <div class="text-3xl font-bold text-purple-600 mb-2">
          <%= Project.published.featured.count %>
        </div>
        <div class="text-gray-600">Highlighted Stories</div>
      </div>
    </div>

    <!-- Search and Filter Section -->
    <div class="bg-white rounded-lg shadow-md p-6 mb-8">
      <%= form_with url: public_projects_path, method: :get, local: true, class: "space-y-4" do |form| %>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <!-- Search -->
          <div>
            <%= form.label :search, "Search project stories", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_field :search, 
                value: params[:search],
                placeholder: "Search by title, story, or description...",
                class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
          </div>

          <!-- Technology Filter -->
          <div>
            <%= form.label :technology, "Filter by technology", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <% 
              # Get all unique technologies from published projects
              all_technologies = Project.published.pluck(:technologies_used).flatten.uniq.compact.sort
            %>
            <%= form.select :technology, 
                options_for_select([["All Technologies", ""]] + all_technologies.map { |tech| [tech, tech] }, params[:technology]),
                {},
                { class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" } %>
          </div>

          <!-- User Filter -->
          <div>
            <%= form.label :user, "Filter by developer", class: "block text-sm font-medium text-gray-700 mb-2" %>
            <%= form.text_field :user, 
                value: params[:user],
                placeholder: "Search by username...",
                class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
          </div>
        </div>

        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <%= form.submit "Search", class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
            
            <% if params[:search].present? || params[:technology].present? || params[:user].present? %>
              <%= link_to public_projects_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
                Clear Filters
              <% end %>
            <% end %>
          </div>

          <div class="text-sm text-gray-500">
            <%= pluralize(@projects.size, 'project story') %> found
          </div>
        </div>
      <% end %>
    </div>

    <% if @featured_stories&.any? %>
      <div class="mb-10">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-2xl font-bold text-gray-900">Highlighted Project Stories</h2>
          <p class="text-sm text-gray-500">Owner-highlighted proof-of-work stories</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <% @featured_stories.each do |project| %>
            <div class="bg-white rounded-lg shadow-md overflow-hidden border border-purple-100 hover:shadow-lg transition-shadow duration-300">
              <div class="p-6">
                <div class="flex items-center gap-2 mb-2">
                  <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                    Highlighted
                  </span>
                </div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">
                  <%= link_to project.title, public_project_path(project), class: "hover:text-blue-600 transition-colors" %>
                </h3>
                <p class="text-gray-600 text-sm mb-4 line-clamp-3">
                  <%= truncate(project.public_story_overview, length: 120) %>
                </p>
                <p class="text-sm text-gray-500 mb-4">
                  by <%= link_to project.user.display_name, public_profile_path(project.user.username), class: "hover:text-blue-600 transition-colors" %>
                </p>
                <%= link_to public_project_path(project),
                    class: "inline-flex items-center text-sm font-medium text-blue-600 hover:text-blue-800 transition-colors" do %>
                  Read project story
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @projects.any? %>
      <!-- Projects Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @projects.each do |project| %>
          <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow duration-300">
            <!-- Project Image -->
            <div class="relative h-48 bg-gray-200">
              <% if project.thumbnail.attached? %>
                <%= image_tag project.thumbnail, 
                    class: "w-full h-full object-cover", 
                    alt: project.title %>
              <% elsif project.images.attached? && project.images.first %>
                <%= image_tag project.images.first, 
                    class: "w-full h-full object-cover", 
                    alt: project.title %>
              <% else %>
                <div class="w-full h-full flex items-center justify-center">
                  <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                  </svg>
                </div>
              <% end %>
              
              <!-- Featured Badge -->
              <% if project.featured? %>
                <div class="absolute top-3 right-3">
                  <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                    Featured
                  </span>
                </div>
              <% end %>
            </div>

            <!-- Project Content -->
            <div class="p-6">
              <div class="flex items-center gap-2 mb-2">
                <h3 class="text-lg font-semibold text-gray-900 flex-1">
                  <%= link_to project.title, public_project_path(project), class: "hover:text-blue-600 transition-colors" %>
                </h3>
              </div>
              
              <p class="text-gray-600 text-sm mb-4 line-clamp-3">
                <%= truncate(project.public_story_overview, length: 120) %>
              </p>

              <!-- Developer Info -->
              <div class="flex items-center gap-2 mb-4">
                <% if project.user.avatar.attached? %>
                  <%= image_tag project.user.avatar_thumbnail, 
                      class: "w-6 h-6 rounded-full", 
                      alt: project.user.display_name %>
                <% else %>
                  <div class="w-6 h-6 bg-gray-300 rounded-full flex items-center justify-center">
                    <span class="text-xs font-medium text-gray-600">
                      <%= project.user.display_name.first.upcase %>
                    </span>
                  </div>
                <% end %>
                <span class="text-sm text-gray-600">
                  by <%= link_to project.user.display_name, public_profile_path(project.user.username), class: "hover:text-blue-600 transition-colors" %>
                </span>
              </div>

              <!-- Technology Tags -->
              <% if project.technologies_used.any? %>
                <div class="flex flex-wrap gap-1 mb-4">
                  <% project.technologies_used.first(3).each do |tech| %>
                    <span class="inline-flex items-center px-2 py-1 rounded-md text-xs font-medium bg-blue-100 text-blue-800">
                      <%= tech %>
                    </span>
                  <% end %>
                  <% if project.technologies_used.size > 3 %>
                    <span class="inline-flex items-center px-2 py-1 rounded-md text-xs font-medium bg-gray-100 text-gray-600">
                      +<%= project.technologies_used.size - 3 %> more
                    </span>
                  <% end %>
                </div>
              <% end %>

              <!-- Project Links -->
              <div class="flex items-center gap-3 mb-4">
                <% if project.live_url.present? %>
                  <%= link_to project.live_url, target: "_blank", rel: "noopener noreferrer",
                      class: "text-blue-600 hover:text-blue-800 transition-colors",
                      title: "Live Demo" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                    </svg>
                  <% end %>
                <% end %>
                
                <% if project.source_code_url.present? %>
                  <%= link_to project.source_code_url, target: "_blank", rel: "noopener noreferrer",
                      class: "text-gray-600 hover:text-gray-800 transition-colors",
                      title: "Source Code" do %>
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.293a1 1 0 010 1.414L3.414 10l2.293 2.293a1 1 0 11-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0zm8.586 0a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 11-1.414-1.414L16.586 10l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
                    </svg>
                  <% end %>
                <% end %>
              </div>

              <!-- View Details Button -->
              <div class="pt-4 border-t border-gray-100">
                <%= link_to public_project_path(project), 
                    class: "w-full inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors" do %>
                  Read project story
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Pagination -->
      <% if @pagy.pages > 1 %>
        <div class="mt-12 flex justify-center">
          <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
        </div>
      <% end %>
    <% else %>
      <!-- Empty State -->
      <div class="text-center py-12">
        <div class="mx-auto w-24 h-24 bg-gray-100 rounded-full flex items-center justify-center mb-6">
          <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
          </svg>
        </div>
        
        <h3 class="text-lg font-medium text-gray-900 mb-2">No project stories found</h3>
        <p class="text-gray-600 mb-6 max-w-md mx-auto">
          <% if params[:search].present? || params[:technology].present? || params[:user].present? %>
            Try adjusting your search criteria or clearing the filters to see more project stories.
          <% else %>
            No project stories have been published yet. Check back soon for proof-of-work stories from our community.
          <% end %>
        </p>
        
        <% if params[:search].present? || params[:technology].present? || params[:user].present? %>
          <%= link_to public_projects_path, 
              class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors" do %>
            View all project stories
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
