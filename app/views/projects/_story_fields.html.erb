<div class="form-section mb-8">
  <div class="mb-4">
    <h3 class="text-lg font-medium text-gray-900">Project Story</h3>
    <p class="mt-1 text-sm text-gray-500">
      Optional proof-of-work context. Add as much or as little as you want — all fields are optional.
    </p>
  </div>

  <div class="space-y-6">
    <%= form.fields_for :project_story, project.project_story do |story_form| %>
      <% Project::FORM_STORY_SECTIONS.each do |field, config| %>
        <div class="<%= config[:private] ? 'rounded-md border border-dashed border-gray-300 bg-gray-50 p-4' : '' %>">
          <%= story_form.label field, config[:label], class: "block text-sm font-medium text-gray-700 mb-1" %>
          <p class="text-sm text-gray-500 mb-2"><%= config[:prompt] %></p>
          <%= story_form.text_area field,
              rows: config[:rows],
              maxlength: Project::STORY_FIELD_MAX_LENGTH,
              class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500",
              placeholder: config[:prompt] %>
          <% if config[:private] %>
            <p class="mt-1 text-xs text-gray-500">Only visible to you while editing. Not shown on the public project page.</p>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
