<%= form_with model: project, local: true, multipart: true, 
    class: "max-w-4xl mx-auto bg-white rounded-lg shadow-md p-6",
    data: { 
      controller: "project-form loading notification", 
      project_form_target: "form",
      loading_target: "form",
      action: "submit->loading#showFormLoading"
    } do |form| %>
  
  <% if project.errors.any? %>
    <div class="mb-6 bg-red-50 border border-red-200 rounded-md p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(project.errors.count, "error") %> prohibited this project from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% project.errors.each do |error| %>
                <li><%= error.full_message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Basic Information Section -->
  <div class="form-section mb-8">
    <h3 class="text-lg font-medium text-gray-900 mb-4">Basic Information</h3>
    
    <div class="grid grid-cols-1 gap-6">
      <!-- Title -->
      <div>
        <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_field :title, 
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500",
            placeholder: "Enter project title" %>
      </div>

      <!-- Description -->
      <div>
        <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.text_area :description, 
            rows: 4,
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500",
            placeholder: "Short project summary for your portfolio..." %>
        <p class="mt-1 text-sm text-gray-500">Maximum 1000 characters. Used as a fallback on the public page when no story overview is provided.</p>
      </div>
    </div>
  </div>

  <%= render "story_fields", form: form, project: project %>

  <!-- Media Section -->
  <div class="form-section mb-8">
    <h3 class="text-lg font-medium text-gray-900 mb-4">Project Images</h3>
    
    <!-- Thumbnail Upload -->
    <div class="mb-6">
      <%= form.label :thumbnail, "Thumbnail Image", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-md hover:border-gray-400 transition-colors"
           data-project-form-target="thumbnailDropzone"
           data-action="dragover->project-form#handleDragOver dragleave->project-form#handleDragLeave drop->project-form#handleThumbnailDrop">
        <div class="space-y-1 text-center">
          <div data-project-form-target="thumbnailPreview" class="hidden">
            <img data-project-form-target="thumbnailImage" class="mx-auto h-32 w-auto rounded-md shadow-sm">
            <button type="button" 
                    data-action="click->project-form#removeThumbnail"
                    class="mt-2 text-sm text-red-600 hover:text-red-800">
              Remove
            </button>
          </div>
          <div data-project-form-target="thumbnailUploadArea">
            <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
              <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <div class="flex text-sm text-gray-600">
              <label for="project_thumbnail" class="relative cursor-pointer bg-white rounded-md font-medium text-blue-600 hover:text-blue-500 focus-within:outline-none focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-blue-500">
                <span>Upload thumbnail</span>
                <%= form.file_field :thumbnail, 
                    id: "project_thumbnail",
                    class: "sr-only",
                    accept: "image/*",
                    data: { action: "change->project-form#previewThumbnail" } %>
              </label>
              <p class="pl-1">or drag and drop</p>
            </div>
            <p class="text-xs text-gray-500">PNG, JPG, GIF up to 10MB</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Additional Images -->
    <div>
      <%= form.label :images, "Additional Images", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-md hover:border-gray-400 transition-colors"
           data-project-form-target="imagesDropzone"
           data-action="dragover->project-form#handleDragOver dragleave->project-form#handleDragLeave drop->project-form#handleImagesDrop">
        <div class="space-y-1 text-center">
          <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
            <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <div class="flex text-sm text-gray-600">
            <label for="project_images" class="relative cursor-pointer bg-white rounded-md font-medium text-blue-600 hover:text-blue-500 focus-within:outline-none focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-blue-500">
              <span>Upload additional images</span>
              <%= form.file_field :images, 
                  id: "project_images",
                  multiple: true,
                  class: "sr-only",
                  accept: "image/*",
                  data: { action: "change->project-form#previewImages" } %>
            </label>
            <p class="pl-1">or drag and drop</p>
          </div>
          <p class="text-xs text-gray-500">PNG, JPG, GIF up to 10MB each (multiple files)</p>
        </div>
      </div>
      
      <!-- Images Preview -->
      <div data-project-form-target="imagesPreview" class="mt-4 hidden">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4" data-project-form-target="imagesGrid">
          <!-- Preview images will be inserted here -->
        </div>
      </div>
    </div>
  </div>

  <!-- Technology Tags Section -->
  <div class="form-section mb-8">
    <h3 class="text-lg font-medium text-gray-900 mb-4">Technologies Used</h3>
    
    <div>
      <label for="project_technologies_input" class="block text-sm font-medium text-gray-700 mb-2">Technologies</label>
      <div class="relative"
           data-controller="technology-tags"
           data-technology-tags-technologies-value="<%= (project.technologies_used || []).to_json %>">
        
        <!-- Hidden field for form submission -->
        <%= form.hidden_field :technologies_display, 
            value: project.technologies_display,
            data: { technology_tags_target: "hiddenField" } %>
        
        <!-- Tag input area -->
        <div class="min-h-[42px] w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus-within:ring-blue-500 focus-within:border-blue-500 bg-white cursor-text"
             data-technology-tags-target="container"
             data-action="click->technology-tags#focusInput">
          
          <!-- Tags display -->
          <div class="flex flex-wrap gap-2 mb-2" data-technology-tags-target="tagsContainer">
            <!-- Existing tags will be rendered here -->
          </div>
          
          <!-- Input field (id for a11y/autofill; value submitted via hidden project_technologies_display) -->
          <input type="text"
                 id="project_technologies_input"
                 autocomplete="off"
                 placeholder="Type technology name and press Enter..."
                 class="border-0 outline-none flex-1 min-w-[200px] text-sm"
                 data-technology-tags-target="input"
                 data-action="keydown->technology-tags#handleKeydown blur->technology-tags#handleBlur"
                 aria-label="Technologies">
        </div>
        
        <p class="mt-1 text-sm text-gray-500">Press Enter to add a technology. Maximum 10 technologies.</p>
      </div>
    </div>
  </div>

  <!-- URLs Section -->
  <div class="form-section mb-8">
    <h3 class="text-lg font-medium text-gray-900 mb-4">Project Links</h3>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Live URL -->
      <div>
        <%= form.label :live_url, "Live Demo URL", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.url_field :live_url, 
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500",
            placeholder: "https://your-project.com" %>
      </div>

      <!-- Source Code URL -->
      <div>
        <%= form.label :source_code_url, "Source Code URL", class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.url_field :source_code_url, 
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500",
            placeholder: "https://github.com/username/repo" %>
      </div>
    </div>
  </div>

  <!-- Project Settings Section -->
  <div class="form-section mb-8">
    <h3 class="text-lg font-medium text-gray-900 mb-4">Project Settings</h3>
    
    <div class="grid grid-cols-1 md:grid-cols-5 gap-6">
      <!-- Status -->
      <div>
        <%= form.label :status, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.select :status, 
            options_from_collection_for_select(Project.statuses.map {|key, value| [key.humanize, key]}, :second, :first, project.status),
            {},
            { class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" } %>
      </div>

      <!-- Display Order -->
      <div>
        <%= form.label :display_order, class: "block text-sm font-medium text-gray-700 mb-2" %>
        <%= form.number_field :display_order, 
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500",
            min: 1 %>
        <p class="mt-1 text-xs text-gray-500">Lower numbers appear first</p>
      </div>

      <!-- Featured -->
      <div>
        <div class="flex items-center h-9">
          <%= form.check_box :featured, 
              class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
          <%= form.label :featured, "Featured Project", class: "ml-2 block text-sm text-gray-900" %>
        </div>
        <p class="mt-1 text-xs text-gray-500">Featured projects are highlighted</p>
      </div>

      <!-- Project Insight -->
      <div>
        <div class="flex items-center h-9">
          <%= form.check_box :project_insight_enabled,
              class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
          <%= form.label :project_insight_enabled, "Enable Project Insight", class: "ml-2 block text-sm text-gray-900" %>
        </div>
        <p class="mt-1 text-xs text-gray-500">Authenticated users can ask AI questions about this project's GitHub repository.</p>
      </div>

      <!-- GitHub Enrichment -->
      <% if FeatureFlags.github_project_enrichment_enabled_for?(current_user) %>
        <div>
          <div class="flex items-center h-9">
            <%= form.check_box :github_insights_enabled,
                class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
            <%= form.label :github_insights_enabled, "Enable GitHub Enrichment", class: "ml-2 block text-sm text-gray-900" %>
          </div>
          <p class="mt-1 text-xs text-gray-500">Collects recruiter-friendly activity, stack, and delivery signals from GitHub.</p>
        </div>
      <% end %>
    </div>

    <% if project.persisted? && FeatureFlags.github_project_enrichment_enabled_for?(current_user) %>
      <div class="mt-6 p-4 border border-gray-200 rounded-md bg-gray-50">
        <% unless current_user.github_oauth_connected? %>
          <div class="mb-3 rounded-md border border-amber-200 bg-amber-50 p-3">
            <p class="text-xs text-amber-900">
              Private repository support requires GitHub OAuth. 
              <%= link_to "Connect GitHub", user_github_omniauth_authorize_path, class: "font-semibold underline hover:no-underline" %>.
            </p>
          </div>
        <% end %>

        <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
          <div>
            <p class="text-sm font-medium text-gray-900">
              GitHub Enrichment Status:
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-white border border-gray-300 text-gray-700">
                <%= project.github_insights_sync_status.to_s.humanize.presence || "Never" %>
              </span>
            </p>
            <p class="mt-1 text-xs text-gray-500">
              Last synced:
              <%= project.github_insights_last_synced_at.present? ? l(project.github_insights_last_synced_at, format: :short) : "Never" %>
            </p>
            <% if project.github_insights_last_error.present? %>
              <p class="mt-1 text-xs text-red-600"><%= project.github_insights_last_error %></p>
            <% end %>
          </div>

          <div>
            <% refresh_disabled = !project.project_github_repo_url.present? || project.github_insights_sync_status == "syncing" %>
            <% if refresh_disabled %>
              <button type="button"
                      class="inline-flex items-center px-3 py-2 border border-blue-600 text-sm font-medium rounded-md text-blue-700 bg-white opacity-60 cursor-not-allowed"
                      disabled>
                Refresh GitHub Insights
              </button>
            <% else %>
              <%= link_to "Refresh GitHub Insights",
                  refresh_github_insights_project_path(project),
                  data: { turbo_method: :post },
                  class: "inline-flex items-center px-3 py-2 border border-blue-600 text-sm font-medium rounded-md text-blue-700 bg-white hover:bg-blue-50" %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Action Buttons (relative z-20 so button stays above overlays e.g. technology dropdown) -->
  <div class="relative z-20 flex items-center justify-between pt-6 border-t border-gray-200">
    <div>
      <%= link_to projects_path, 
          class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
        Cancel
      <% end %>
    </div>
    
    <div class="flex items-center gap-3">
      <% if project.persisted? %>
        <%= form.submit "Update Project", 
            class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200",
            data: { 
              project_form_target: "submitButton",
              loading_target: "button"
            } %>
      <% else %>
        <%= form.submit "Create Project", 
            class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200",
            data: { 
              project_form_target: "submitButton",
              loading_target: "button"
            } %>
      <% end %>
    </div>
  </div>
<% end %>
