<div class="min-h-screen bg-gray-50 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <nav class="flex items-center space-x-2 text-sm text-gray-500 mb-4">
        <%= link_to projects_path, class: "hover:text-gray-700" do %>
          Projects
        <% end %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-gray-900">New Project</span>
      </nav>
      
      <h1 class="text-3xl font-bold text-gray-900">Create New Project</h1>
      <p class="mt-2 text-gray-600">Add a new project to showcase your development work</p>
    </div>

    <!-- Project Form -->
    <%= render 'form', project: @project %>
  </div>
</div>
