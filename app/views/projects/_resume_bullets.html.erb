<%= turbo_frame_tag "project_resume_bullets" do %>
  <div id="resume-bullets" class="form-section mb-8 scroll-mt-24">
    <div class="rounded-lg border border-emerald-200 bg-emerald-50/60 p-6">
      <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-emerald-700">Resume Bullets</p>
          <h3 class="mt-1 text-lg font-medium text-gray-900">Turn this project story into reusable resume bullets</h3>
          <p class="mt-2 text-sm text-gray-600">
            Generate concise, project-specific bullets grounded in your story, project metadata, and available GitHub signals.
            Nothing is saved automatically — copy what you want and use it in your resume or profile.
          </p>
          <p class="mt-2 text-sm text-gray-700">
            Story completeness:
            <span class="font-semibold"><%= project.story_completion_count %>/<%= project.story_completion_total %></span>
            core sections filled.
          </p>
        </div>
      </div>

      <% if local_assigns[:resume_bullets_error].present? %>
        <div class="mt-4 rounded-md border border-red-200 bg-red-50 p-4 text-sm text-red-800">
          <%= resume_bullets_error %>
        </div>
      <% end %>

      <%= form_with url: generate_resume_bullets_project_path(project),
                    method: :post,
                    class: "mt-5",
                    data: { turbo_frame: "project_resume_bullets" } do |form| %>
        <div>
          <%= form.label :emphasis, "Anything specific you want these bullets to emphasize?", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <p class="text-sm text-gray-500 mb-2">
            Optional — e.g. backend work, architecture decisions, or a skill you want highlighted.
          </p>
          <%= form.text_area :emphasis,
              rows: 3,
              maxlength: ProjectResumeBullets::GenerationService::MAX_EMPHASIS_CHARS,
              value: local_assigns[:emphasis],
              class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-emerald-500 focus:border-emerald-500",
              placeholder: "Example: Emphasize API design, database migrations, and test coverage." %>
        </div>

        <div class="mt-4">
          <%= form.submit "Generate resume bullets",
              class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-emerald-600 hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500" %>
        </div>
      <% end %>

      <% if local_assigns[:resume_bullets].present? %>
        <%= render "resume_bullets_review",
                   project: project,
                   resume_bullets: resume_bullets %>
      <% end %>
    </div>
  </div>
<% end %>
