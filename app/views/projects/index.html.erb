<div class="min-h-screen bg-gray-50 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header Section -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-8">
<div>
        <h1 class="text-3xl font-bold text-gray-900">My Projects</h1>
        <p class="mt-2 text-gray-600">Showcase your development work and portfolio</p>
      </div>
      <%= link_to new_project_path, 
          class: "mt-4 sm:mt-0 inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
        </svg>
        New Project
      <% end %>
    </div>

    <% if @projects.any? %>
      <!-- Projects Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @projects.each do |project| %>
          <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow duration-300">
            <!-- Project Image -->
            <div class="relative h-48 bg-gray-200">
              <% if project.thumbnail.attached? %>
                <%= image_tag project.thumbnail, 
                    class: "w-full h-full object-cover", 
                    alt: project.title %>
              <% elsif project.images.attached? && project.images.first %>
                <%= image_tag project.images.first, 
                    class: "w-full h-full object-cover", 
                    alt: project.title %>
              <% else %>
                <div class="w-full h-full flex items-center justify-center">
                  <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                  </svg>
                </div>
              <% end %>
              
              <!-- Status Badge -->
              <div class="absolute top-3 left-3">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                  <%= case project.status
                      when 'published' then 'bg-green-100 text-green-800'
                      when 'draft' then 'bg-yellow-100 text-yellow-800'
                      when 'archived' then 'bg-gray-100 text-gray-800'
                      end %>">
                  <%= project.status.humanize %>
                </span>
              </div>

              <!-- Featured Badge -->
              <% if project.featured? %>
                <div class="absolute top-3 right-3">
                  <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                    Featured
                  </span>
                </div>
              <% end %>
            </div>

            <!-- Project Content -->
            <div class="p-6">
              <h3 class="text-lg font-semibold text-gray-900 mb-2">
                <%= link_to project.title, project, class: "hover:text-blue-600 transition-colors" %>
              </h3>
              
              <p class="text-gray-600 text-sm mb-4 line-clamp-3">
                <%= truncate(project.description, length: 120) %>
              </p>

              <!-- Technology Tags -->
              <% if project.technologies_used.any? %>
                <div class="flex flex-wrap gap-1 mb-4">
                  <% project.technologies_used.first(3).each do |tech| %>
                    <span class="inline-flex items-center px-2 py-1 rounded-md text-xs font-medium bg-blue-100 text-blue-800">
                      <%= tech %>
                    </span>
                  <% end %>
                  <% if project.technologies_used.size > 3 %>
                    <span class="inline-flex items-center px-2 py-1 rounded-md text-xs font-medium bg-gray-100 text-gray-600">
                      +<%= project.technologies_used.size - 3 %> more
                    </span>
                  <% end %>
                </div>
              <% end %>

              <!-- Project Links -->
              <div class="flex items-center gap-3 mb-4">
                <% if project.live_url.present? %>
                  <%= link_to project.live_url, target: "_blank", rel: "noopener noreferrer",
                      class: "text-blue-600 hover:text-blue-800 transition-colors" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                    </svg>
                  <% end %>
                <% end %>
                
                <% if project.source_code_url.present? %>
                  <%= link_to project.source_code_url, target: "_blank", rel: "noopener noreferrer",
                      class: "text-gray-600 hover:text-gray-800 transition-colors" do %>
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.293a1 1 0 010 1.414L3.414 10l2.293 2.293a1 1 0 11-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0zm8.586 0a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 11-1.414-1.414L16.586 10l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
                    </svg>
                  <% end %>
                <% end %>
              </div>

              <!-- Action Buttons -->
              <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                <div class="flex items-center gap-2">
                  <%= link_to project, 
                      class: "text-sm text-blue-600 hover:text-blue-800 font-medium transition-colors" do %>
                    View Details
                  <% end %>
                </div>
                
                <div class="flex items-center gap-2">
                  <%= link_to edit_project_path(project), 
                      class: "inline-flex items-center p-1.5 text-gray-400 hover:text-blue-600 transition-colors",
                      title: "Edit project" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                  <% end %>
                  
                  <%= link_to project, 
                      method: :delete,
                      data: { 
                        confirm: "Are you sure you want to delete this project?",
                        turbo_method: :delete
                      },
                      class: "inline-flex items-center p-1.5 text-gray-400 hover:text-red-600 transition-colors",
                      title: "Delete project" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <!-- Empty State -->
      <div class="text-center py-12">
        <div class="mx-auto w-24 h-24 bg-gray-100 rounded-full flex items-center justify-center mb-6">
          <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
          </svg>
        </div>
        
        <h3 class="text-lg font-medium text-gray-900 mb-2">No projects yet</h3>
        <p class="text-gray-600 mb-6 max-w-md mx-auto">
          Get started by creating your first project to showcase your development work and build your portfolio.
        </p>
        
        <%= link_to new_project_path, 
            class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors" do %>
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
          </svg>
          Create Your First Project
        <% end %>
      </div>
    <% end %>
  </div>
</div>
