<div class="max-w-4xl mx-auto mb-6"
     data-controller="github-project-import"
     data-github-project-import-repositories-url-value="<%= github_repositories_projects_path %>"
     data-github-project-import-prefill-url-value="<%= github_prefill_projects_path %>"
     data-github-project-import-connected-value="<%= current_user.github_oauth_connected? %>"
     data-github-project-import-form-selector-value="#project_form">
  <div class="bg-white rounded-lg shadow-md border border-gray-200 p-5">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="text-lg font-medium text-gray-900">Import from GitHub</h2>
        <p class="mt-1 text-sm text-gray-500">Prefill this draft from a repository. Nothing is saved until you create the project.</p>
      </div>
      <% unless current_user.github_oauth_connected? %>
        <%= link_to "Connect GitHub",
            user_github_omniauth_authorize_path,
            class: "inline-flex items-center justify-center px-3 py-2 text-sm font-medium text-white bg-gray-900 rounded-md hover:bg-gray-800" %>
      <% end %>
    </div>

    <div data-github-project-import-target="notice" class="hidden mt-4 rounded-md border p-3 text-sm"></div>
    <div data-github-project-import-target="error" class="hidden mt-4 rounded-md border border-red-200 bg-red-50 p-3 text-sm text-red-800"></div>

    <% if current_user.github_oauth_connected? %>
      <div class="mt-4">
        <button type="button"
                class="text-sm font-medium text-blue-600 hover:text-blue-800"
                data-action="click->github-project-import#togglePicker"
                data-github-project-import-target="pickerToggle">
          Choose from your repositories
        </button>

        <div data-github-project-import-target="pickerPanel" class="hidden mt-3 border border-gray-200 rounded-md p-3 bg-gray-50">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <input type="search"
                   placeholder="Search repositories..."
                   class="w-full sm:max-w-xs px-3 py-2 text-sm border border-gray-300 rounded-md"
                   data-github-project-import-target="searchInput"
                   data-action="input->github-project-import#filterRepositories">
            <label class="inline-flex items-center gap-2 text-sm text-gray-700">
              <input type="checkbox"
                     class="rounded border-gray-300 text-blue-600"
                     data-github-project-import-target="includeForks"
                     data-action="change->github-project-import#reloadRepositories">
              Include forks
            </label>
          </div>

          <p data-github-project-import-target="repoLoading" class="hidden mt-3 text-sm text-gray-500">Loading repositories…</p>
          <p data-github-project-import-target="repoEmpty" class="hidden mt-3 text-sm text-gray-500">No matching repositories.</p>

          <ul data-github-project-import-target="repoList" class="mt-3 max-h-64 overflow-y-auto divide-y divide-gray-200 bg-white rounded-md border border-gray-200"></ul>
        </div>
      </div>
    <% end %>

    <div class="mt-4 flex flex-col gap-2 sm:flex-row sm:items-end">
      <div class="flex-1">
        <label for="github_import_url" class="block text-sm font-medium text-gray-700 mb-1">GitHub repository URL</label>
        <input type="url"
               id="github_import_url"
               placeholder="https://github.com/owner/repo"
               class="w-full px-3 py-2 text-sm border border-gray-300 rounded-md"
               data-github-project-import-target="urlInput">
      </div>
      <button type="button"
              class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-md hover:bg-blue-700 disabled:opacity-60"
              data-github-project-import-target="importButton"
              data-action="click->github-project-import#importFromUrl">
        Apply prefill
      </button>
    </div>
  </div>
</div>
