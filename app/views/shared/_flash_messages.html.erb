<div class="flash-messages">
  <% if notice %>
    <div id="alert-success" class="flex items-center p-4 mb-4 text-accent-800 rounded-lg bg-accent-50 dark:bg-secondary-800 dark:text-accent-400 mx-4 mt-4" role="alert">
      <svg class="flex-shrink-0 w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
        <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z"/>
      </svg>
      <span class="sr-only">Success</span>
      <div class="ms-3 text-sm font-medium">
        <%= notice %>
      </div>
      <button type="button" class="ms-auto -mx-1.5 -my-1.5 bg-accent-50 text-accent-500 rounded-lg focus:ring-2 focus:ring-accent-400 p-1.5 hover:bg-accent-200 inline-flex items-center justify-center h-8 w-8 dark:bg-secondary-800 dark:text-accent-400 dark:hover:bg-secondary-700" data-dismiss-target="#alert-success" aria-label="Close">
        <span class="sr-only">Close</span>
        <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
        </svg>
      </button>
    </div>
  <% end %>

  <% if alert %>
    <div id="alert-danger" class="flex items-center p-4 mb-4 text-danger-800 rounded-lg bg-danger-50 dark:bg-secondary-800 dark:text-danger-400 mx-4 mt-4" role="alert">
      <svg class="flex-shrink-0 w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
        <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z"/>
      </svg>
      <span class="sr-only">Error</span>
      <div class="ms-3 text-sm font-medium">
        <%= alert %>
      </div>
      <button type="button" class="ms-auto -mx-1.5 -my-1.5 bg-danger-50 text-danger-500 rounded-lg focus:ring-2 focus:ring-danger-400 p-1.5 hover:bg-danger-200 inline-flex items-center justify-center h-8 w-8 dark:bg-secondary-800 dark:text-danger-400 dark:hover:bg-secondary-700" data-dismiss-target="#alert-danger" aria-label="Close">
        <span class="sr-only">Close</span>
        <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
        </svg>
      </button>
    </div>
  <% end %>

  <% if flash[:invitation_link] %>
    <div id="alert-invitation-link" class="flex items-center p-4 mb-4 text-primary-800 bg-primary-50 dark:bg-secondary-800 dark:text-primary-400 mx-4 mt-4" role="alert">
      <svg class="flex-shrink-0 w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
        <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z"/>
      </svg>
      <span class="sr-only">Invitation Link</span>
      <div class="ms-3 text-sm font-medium flex-1">
        <p class="font-medium mb-2">🔗 Invitation Link Generated</p>
        <div class="p-3 bg-white dark:bg-secondary-700 rounded border">
          <div class="flex items-center justify-between">
            <code class="text-sm text-secondary-700 dark:text-secondary-300 break-all" id="flash-invitation-link">
              <%= flash[:invitation_link] %>
            </code>
            <button type="button" 
                    onclick="navigator.clipboard.writeText(document.getElementById('flash-invitation-link').textContent); this.textContent='Copied!'; setTimeout(() => this.textContent='Copy', 2000)"
                    class="ml-3 inline-flex items-center px-3 py-1 border border-transparent text-xs font-medium rounded text-primary-700 bg-primary-100 hover:bg-primary-200 dark:bg-primary-900 dark:text-primary-300 dark:hover:bg-primary-800">
              Copy
            </button>
          </div>
        </div>
        <p class="mt-2 text-xs">Share this link directly with the user to claim their profile</p>
      </div>
      <button type="button" class="ms-auto -mx-1.5 -my-1.5 bg-primary-50 text-primary-500 rounded-lg focus:ring-2 focus:ring-primary-400 p-1.5 hover:bg-primary-200 inline-flex items-center justify-center h-8 w-8 dark:bg-secondary-800 dark:text-primary-400 dark:hover:bg-secondary-700" data-dismiss-target="#alert-invitation-link" aria-label="Close">
        <span class="sr-only">Close</span>
        <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
        </svg>
      </button>
    </div>
  <% end %>

  <% flash.each do |type, message| %>
    <% next if %w[notice alert invitation_link].include?(type) %>
    <% 
      alert_class = case type.to_s
                   when 'warning'
                     'text-warning-800 bg-warning-50 dark:text-warning-400'
                   when 'info'
                     'text-primary-800 bg-primary-50 dark:text-primary-400'
                   else
                     'text-secondary-800 bg-secondary-50 dark:text-secondary-400'
                   end
    %>
    <div id="alert-<%= type %>" class="flex items-center p-4 mb-4 <%= alert_class %> rounded-lg dark:bg-secondary-800 mx-4 mt-4" role="alert">
      <svg class="flex-shrink-0 w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
        <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z"/>
      </svg>
      <span class="sr-only">Info</span>
      <div class="ms-3 text-sm font-medium">
        <%= message %>
      </div>
      <button type="button" class="ms-auto -mx-1.5 -my-1.5 rounded-lg focus:ring-2 p-1.5 hover:bg-opacity-20 inline-flex items-center justify-center h-8 w-8" data-dismiss-target="#alert-<%= type %>" aria-label="Close">
        <span class="sr-only">Close</span>
        <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
        </svg>
      </button>
    </div>
  <% end %>
</div>
