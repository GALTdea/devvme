<nav class="bg-white dark:bg-secondary-900 border-b border-secondary-200 dark:border-secondary-800 sticky top-0 z-50">
  <div class="max-w-screen-xl flex flex-wrap items-center justify-between mx-auto p-4">
    <!-- Logo -->
    <%= link_to root_path, class: "flex items-center space-x-3 rtl:space-x-reverse" do %>
      <div class="w-8 h-8 bg-primary-600 rounded-lg flex items-center justify-center">
        <span class="text-white font-bold text-lg">D</span>
      </div>
      <span class="self-center text-2xl font-semibold whitespace-nowrap text-secondary-900 dark:text-white">DevvMe</span>
    <% end %>

    <!-- Mobile menu button -->
    <button data-collapse-toggle="navbar-default" type="button" 
            class="inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-secondary-500 rounded-lg md:hidden hover:bg-secondary-100 focus:outline-none focus:ring-2 focus:ring-secondary-200 dark:text-secondary-400 dark:hover:bg-secondary-700 dark:focus:ring-secondary-600" 
            aria-controls="navbar-default" aria-expanded="false">
      <span class="sr-only">Open main menu</span>
      <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
      </svg>
    </button>

    <!-- Navigation menu -->
    <div class="hidden w-full md:block md:w-auto" id="navbar-default">
      <ul class="font-medium flex flex-col p-4 md:p-0 mt-4 border border-secondary-100 rounded-lg bg-secondary-50 md:flex-row md:space-x-8 rtl:space-x-reverse md:mt-0 md:border-0 md:bg-white dark:bg-secondary-800 md:dark:bg-secondary-900 dark:border-secondary-700">
        <% if user_signed_in? %>
          <!-- Authenticated user menu -->
          <li>
            <%= link_to "Dashboard", dashboard_path, class: "block py-2 px-3 text-secondary-900 rounded hover:bg-secondary-100 md:hover:bg-transparent md:border-0 md:hover:text-primary-700 md:p-0 dark:text-white md:dark:hover:text-primary-500 dark:hover:bg-secondary-700 dark:hover:text-white md:dark:hover:bg-transparent" %>
          </li>
          <li>
            <%= link_to "Projects", projects_path, class: "block py-2 px-3 text-secondary-900 rounded hover:bg-secondary-100 md:hover:bg-transparent md:border-0 md:hover:text-primary-700 md:p-0 dark:text-white md:dark:hover:text-primary-500 dark:hover:bg-secondary-700 dark:hover:text-white md:dark:hover:bg-transparent" %>
          </li>
          <li>
            <%= link_to "Blog", blog_posts_path, class: "block py-2 px-3 text-secondary-900 rounded hover:bg-secondary-100 md:hover:bg-transparent md:border-0 md:hover:text-primary-700 md:p-0 dark:text-white md:dark:hover:text-primary-500 dark:hover:bg-secondary-700 dark:hover:text-white md:dark:hover:bg-transparent" %>
          </li>
          
          <!-- User dropdown -->
          <li class="relative">
            <button type="button" 
                    class="flex items-center justify-between w-full py-2 px-3 text-secondary-900 rounded hover:bg-secondary-100 md:hover:bg-transparent md:border-0 md:hover:text-primary-700 md:p-0 md:w-auto dark:text-white md:dark:hover:text-primary-500 dark:focus:text-white dark:border-secondary-700 dark:hover:bg-secondary-700 md:dark:hover:bg-transparent"
                    data-dropdown-toggle="user-dropdown" data-dropdown-placement="bottom">
              <div class="flex items-center space-x-2">
                <% if current_user.avatar.attached? %>
                  <%= image_tag current_user.avatar_thumbnail, 
                      class: "w-8 h-8 rounded-full object-cover",
                      alt: "#{current_user.username}'s avatar" %>
                <% else %>
                  <div class="w-8 h-8 bg-primary-600 rounded-full flex items-center justify-center">
                    <span class="text-white text-sm font-medium"><%= current_user.username.first.upcase %></span>
                  </div>
                <% end %>
                <span class="hidden md:block"><%= current_user.username %></span>
              </div>
              <svg class="w-2.5 h-2.5 ms-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 4 4 4-4"/>
              </svg>
            </button>
            
            <!-- Dropdown menu -->
            <div id="user-dropdown" class="z-10 hidden font-normal bg-white divide-y divide-secondary-100 rounded-lg shadow w-44 dark:bg-secondary-700 dark:divide-secondary-600">
              <div class="px-4 py-3 text-sm text-secondary-900 dark:text-white">
                <div class="font-medium truncate"><%= current_user.email %></div>
              </div>
              <ul class="py-2 text-sm text-secondary-700 dark:text-secondary-200">
                <li>
                  <%= link_to profile_path, class: "block px-4 py-2 hover:bg-secondary-100 dark:hover:bg-secondary-600 dark:hover:text-white" do %>
                    My Profile
                  <% end %>
                </li>
                <li>
                  <%= link_to public_profile_path(current_user), class: "block px-4 py-2 hover:bg-secondary-100 dark:hover:bg-secondary-600 dark:hover:text-white", target: "_blank" do %>
                    Public Profile
                    <svg class="inline w-3 h-3 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  <% end %>
                </li>
                <li>
                  <%= link_to edit_profile_path, class: "block px-4 py-2 hover:bg-secondary-100 dark:hover:bg-secondary-600 dark:hover:text-white" do %>
                    Edit Profile
                  <% end %>
                </li>
                <li>
                  <%= link_to edit_user_registration_path, class: "block px-4 py-2 hover:bg-secondary-100 dark:hover:bg-secondary-600 dark:hover:text-white" do %>
                    Account Settings
                  <% end %>
                </li>
              </ul>
              <div class="py-1">
                <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "block px-4 py-2 text-sm text-secondary-700 hover:bg-secondary-100 dark:hover:bg-secondary-600 dark:text-secondary-200 dark:hover:text-white" do %>
                  Sign out
                <% end %>
              </div>
            </div>
          </li>
        <% else %>
          <!-- Guest user menu -->
          <li>
            <%= link_to "Features", "#", class: "block py-2 px-3 text-secondary-900 rounded hover:bg-secondary-100 md:hover:bg-transparent md:border-0 md:hover:text-primary-700 md:p-0 dark:text-white md:dark:hover:text-primary-500 dark:hover:bg-secondary-700 dark:hover:text-white md:dark:hover:bg-transparent" %>
          </li>
          <li>
            <%= link_to "Pricing", "#", class: "block py-2 px-3 text-secondary-900 rounded hover:bg-secondary-100 md:hover:bg-transparent md:border-0 md:hover:text-primary-700 md:p-0 dark:text-white md:dark:hover:text-primary-500 dark:hover:bg-secondary-700 dark:hover:text-white md:dark:hover:bg-transparent" %>
          </li>
          <li>
            <%= link_to new_user_session_path, class: "block py-2 px-3 text-primary-700 rounded hover:bg-secondary-100 md:hover:bg-transparent md:border-0 md:hover:text-primary-700 md:p-0 dark:text-primary-500 md:dark:hover:text-primary-400 dark:hover:bg-secondary-700 dark:hover:text-white md:dark:hover:bg-transparent font-medium" do %>
              Sign In
            <% end %>
          </li>
          <li>
            <%= link_to new_user_registration_path, class: "text-white bg-primary-700 hover:bg-primary-800 focus:ring-4 focus:outline-none focus:ring-primary-300 font-medium rounded-lg text-sm px-4 py-2 text-center dark:bg-primary-600 dark:hover:bg-primary-700 dark:focus:ring-primary-800 block md:inline-block" do %>
              Get Started
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</nav>
