<% content_for :title, @blog_post.title %>

<div class="container mx-auto px-4 py-6 max-w-4xl">
  <!-- Header -->
  <div class="mb-8">
    <!-- Status and Actions -->
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-3">
        <% if @blog_post.featured? %>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200">
            <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
            Featured
          </span>
        <% end %>
        
        <% if @blog_post.published? %>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
            <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            Published
          </span>
        <% else %>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200">
            <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
            </svg>
            Draft
          </span>
        <% end %>
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-2">
        <%= link_to edit_blog_post_path(@blog_post), 
            class: "inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors" do %>
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
          </svg>
          Edit
        <% end %>

        <%= link_to @blog_post, 
            method: :delete,
            data: { 
              confirm: "Are you sure you want to delete '#{@blog_post.title}'? This action cannot be undone.",
              turbo_method: :delete 
            },
            class: "inline-flex items-center px-4 py-2 bg-red-600 hover:bg-red-700 text-white font-medium rounded-lg transition-colors" do %>
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
          Delete
        <% end %>

        <%= link_to blog_posts_path, 
            class: "inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 font-medium rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors" do %>
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          Back to Posts
        <% end %>
      </div>
    </div>

    <!-- Title -->
    <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-4">
      <%= @blog_post.title %>
    </h1>

    <!-- Excerpt -->
    <% if @blog_post.excerpt.present? %>
      <p class="text-xl text-gray-600 dark:text-gray-300 mb-6 leading-relaxed">
        <%= @blog_post.excerpt %>
      </p>
    <% end %>

    <!-- Meta Information -->
    <div class="flex flex-wrap items-center text-sm text-gray-500 dark:text-gray-400 space-x-6 mb-8">
      <div class="flex items-center">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        <span>By <%= @blog_post.user.display_name %></span>
      </div>

      <% if @blog_post.published? %>
        <div class="flex items-center">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3a4 4 0 118 0v4m-4 12v-4m0 0a4 4 0 118 0 4 4 0 11-8 0z"/>
          </svg>
          <span>Published <%= time_ago_in_words(@blog_post.published_at) %> ago</span>
        </div>
      <% else %>
        <div class="flex items-center">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
          </svg>
          <span>Last updated <%= time_ago_in_words(@blog_post.updated_at) %> ago</span>
        </div>
      <% end %>

      <div class="flex items-center">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span><%= @blog_post.reading_time %> min read</span>
      </div>

      <div class="flex items-center">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        <span><%= pluralize(@blog_post.word_count, 'word') %></span>
      </div>
    </div>
  </div>

  <!-- Content -->
  <article class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-8">
    <% if @blog_post.editor_mode == 'rich_text' && @blog_post.content_html.present? %>
      <!-- Rich Text Content (HTML) -->
      <div class="prose dark:prose-invert max-w-none trix-content">
        <%= @blog_post.content_html.to_s.html_safe %>
      </div>
    <% else %>
      <!-- Markdown Content -->
      <div class="prose dark:prose-invert max-w-none" 
           data-controller="blog-viewer" 
           data-blog-viewer-content-value="<%= html_escape(@blog_post.content) %>">
        <!-- Markdown content will be rendered here -->
      </div>
    <% end %>
  </article>

  <!-- Footer Actions -->
  <div class="mt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
    <div class="text-sm text-gray-500 dark:text-gray-400">
      <% if @blog_post.published? %>
        Published on <%= @blog_post.published_at.strftime("%B %d, %Y at %I:%M %p") %>
      <% else %>
        <span class="text-yellow-600 dark:text-yellow-400 font-medium">This is a draft post</span>
      <% end %>
    </div>

    <div class="flex gap-3">
      <%= link_to edit_blog_post_path(@blog_post), 
          class: "px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors" do %>
        Continue Editing
      <% end %>

      <% unless @blog_post.published? %>
        <%= form_with model: @blog_post, local: true, class: "inline" do |form| %>
          <%= form.hidden_field :published, value: true %>
          <%= form.hidden_field :published_at, value: Time.current %>
          <%= form.submit "Publish Now", 
              class: "px-6 py-2 bg-green-600 hover:bg-green-700 text-white font-medium rounded-lg transition-colors" %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<% content_for :head do %>
  <style>
    /* Enhanced prose styles for blog content */
    .prose {
      line-height: 1.75;
    }
    
    .prose h1 {
      @apply text-3xl font-bold text-gray-900 dark:text-white mt-8 mb-4;
    }
    
    .prose h2 {
      @apply text-2xl font-bold text-gray-900 dark:text-white mt-7 mb-3;
    }
    
    .prose h3 {
      @apply text-xl font-bold text-gray-900 dark:text-white mt-6 mb-3;
    }
    
    .prose p {
      @apply text-gray-700 dark:text-gray-300 mb-4;
    }
    
    .prose code {
      @apply bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200 px-2 py-1 rounded text-sm;
    }
    
    .prose pre {
      @apply bg-gray-100 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg p-4 overflow-x-auto;
    }
    
    .prose pre code {
      @apply bg-transparent text-gray-800 dark:text-gray-200 p-0;
    }
    
    .prose blockquote {
      @apply border-l-4 border-blue-500 pl-6 italic text-gray-600 dark:text-gray-400 bg-gray-50 dark:bg-gray-750 py-4 rounded-r-lg;
    }
    
    .prose ul, .prose ol {
      @apply mb-4;
    }
    
    .prose li {
      @apply text-gray-700 dark:text-gray-300 mb-1;
    }
    
    .prose a {
      @apply text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 underline;
    }
    
    .prose img {
      @apply rounded-lg shadow-md max-w-full h-auto;
    }
    
    .prose table {
      @apply w-full border-collapse border border-gray-300 dark:border-gray-600;
    }
    
    .prose th {
      @apply bg-gray-100 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 px-4 py-2 text-left font-semibold;
    }
    
    .prose td {
      @apply border border-gray-300 dark:border-gray-600 px-4 py-2;
    }
  </style>
  
  <!-- Highlight.js CSS -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css" media="(prefers-color-scheme: dark)">
<% end %>