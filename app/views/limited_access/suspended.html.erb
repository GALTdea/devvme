<div class="min-h-screen bg-gray-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <div class="text-center">
      <svg class="mx-auto h-16 w-16 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z" />
      </svg>
      <h2 class="mt-6 text-3xl font-extrabold text-gray-900">
        Account Suspended
      </h2>
      <p class="mt-2 text-sm text-gray-600">
        Your account has been temporarily suspended
      </p>
    </div>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-4 shadow sm:rounded-lg sm:px-10">
      <div class="text-center">
        <div class="mb-6">
          <div class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium bg-red-100 text-red-800">
            <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
            </svg>
            Account Suspended
          </div>
        </div>

        <h3 class="text-lg font-medium text-gray-900 mb-4">
          Account Access Restricted
        </h3>
        
        <div class="space-y-4 text-sm text-gray-600">
          <p>
            Hi <strong><%= current_user.display_name %></strong>, your account has been suspended and access to most features is currently restricted.
          </p>
          
          <div class="bg-red-50 border border-red-200 rounded-lg p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3 text-left">
                <h4 class="text-sm font-medium text-red-800">Suspension Details:</h4>
                <div class="mt-2 text-sm text-red-700">
                  <ul class="list-disc pl-5 space-y-1">
                    <li>Username: <strong><%= current_user.username %></strong></li>
                    <li>Email: <strong><%= current_user.email %></strong></li>
                    <li>Status: Suspended</li>
                    <li>Reason: <strong><%= current_user.suspension_reason || 'No reason provided' %></strong></li>
                    <li>Suspended on: <strong><%= current_user.suspended_at&.strftime("%B %d, %Y at %I:%M %p") || 'Unknown' %></strong></li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3 text-left">
                <h4 class="text-sm font-medium text-yellow-800">What you can do:</h4>
                <div class="mt-2 text-sm text-yellow-700">
                  <ul class="list-disc pl-5 space-y-1">
                    <li>Contact support to appeal the suspension</li>
                    <li>Review our terms of service and community guidelines</li>
                    <li>Wait for the suspension to be lifted by an administrator</li>
                    <li>Browse public content (read-only access)</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <p>
            If you believe this suspension was made in error, please contact our support team for assistance.
          </p>
        </div>

        <div class="mt-8 space-y-4">
          <div class="border-t border-gray-200 pt-6">
            <p class="text-xs text-gray-500">
              Need help? Contact us at 
              <a href="mailto:support@devv.me" class="text-blue-600 hover:text-blue-500">support@devv.me</a>
            </p>
          </div>
          
          <div class="flex justify-center space-x-3">
            <%= link_to destroy_user_session_path, method: :delete, class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
              Sign Out
            <% end %>
            <%= link_to root_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
              Browse Public Content
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>