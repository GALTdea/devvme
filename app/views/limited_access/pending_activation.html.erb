<div class="min-h-screen bg-gray-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <div class="text-center">
      <svg class="mx-auto h-16 w-16 text-yellow-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <h2 class="mt-6 text-3xl font-extrabold text-gray-900">
        Account Pending Activation
      </h2>
      <p class="mt-2 text-sm text-gray-600">
        Your account is waiting for administrator approval
      </p>
    </div>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-4 shadow sm:rounded-lg sm:px-10">
      <div class="text-center">
        <div class="mb-6">
          <div class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium bg-yellow-100 text-yellow-800">
            <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
            </svg>
            Pending Activation
          </div>
        </div>

        <h3 class="text-lg font-medium text-gray-900 mb-4">
          Thanks for signing up! ⏳
        </h3>
        
        <div class="space-y-4 text-sm text-gray-600">
          <p>
            Hi <strong><%= current_user.display_name %></strong>! Your account has been created successfully and is now pending activation by an administrator.
          </p>
          
          <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3 text-left">
                <h4 class="text-sm font-medium text-yellow-800">Your account status:</h4>
                <div class="mt-2 text-sm text-yellow-700">
                  <ul class="list-disc pl-5 space-y-1">
                    <li>Username: <strong><%= current_user.username %></strong> (reserved)</li>
                    <li>Email: <strong><%= current_user.email %></strong></li>
                    <li>Status: Pending activation</li>
                    <li>You'll receive an email notification when activated</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3 text-left">
                <h4 class="text-sm font-medium text-blue-800">What happens next?</h4>
                <div class="mt-2 text-sm text-blue-700">
                  <ul class="list-disc pl-5 space-y-1">
                    <li>An administrator will review your account</li>
                    <li>You'll receive an email notification when activated</li>
                    <li>Once activated, you can access all features</li>
                    <li>This usually takes a few minutes to a few hours</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <p>
            While you wait, you can still browse public profiles and projects on our platform!
          </p>
        </div>

        <div class="mt-8 space-y-4">
          <div class="border-t border-gray-200 pt-6">
            <p class="text-xs text-gray-500">
              Questions about your account? Contact us at 
              <a href="mailto:support@devv.me" class="text-blue-600 hover:text-blue-500">support@devv.me</a>
            </p>
          </div>
          
          <div class="flex justify-center space-x-3">
            <%= link_to destroy_user_session_path, method: :delete, class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
              Sign Out
            <% end %>
            <%= link_to root_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
              Browse Public Content
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>