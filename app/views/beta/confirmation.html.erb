<div class="min-h-screen bg-gray-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <div class="text-center">
      <svg class="mx-auto h-16 w-16 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <h2 class="mt-6 text-3xl font-extrabold text-gray-900">
        Welcome to the Beta!
      </h2>
      <p class="mt-2 text-sm text-gray-600">
        Your account has been successfully created
      </p>
    </div>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-4 shadow sm:rounded-lg sm:px-10">
      <div class="text-center">
        <div class="mb-6">
          <div class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
            <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            Beta Tester
          </div>
        </div>

        <h3 class="text-lg font-medium text-gray-900 mb-4">
          You're on the list! 🎉
        </h3>
        
        <div class="space-y-4 text-sm text-gray-600">
          <p>
            Thank you for signing up! We're currently in <strong>beta testing</strong> with a limited number of active users.
          </p>
          
          <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3 text-left">
                <h4 class="text-sm font-medium text-blue-800">What happens next?</h4>
                <div class="mt-2 text-sm text-blue-700">
                  <ul class="list-disc pl-5 space-y-1">
                    <li>Your username is reserved</li>
                    <li>You'll receive an email when your account is activated</li>
                    <li>We're adding new users regularly</li>
                    <li>Early access to all features when activated</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <p>
            We appreciate your interest and can't wait to have you as part of our community!
          </p>
        </div>

        <div class="mt-8 space-y-4">
          <div class="border-t border-gray-200 pt-6">
            <p class="text-xs text-gray-500">
              Questions? Feel free to reach out to us at 
              <a href="mailto:support@devv.me" class="text-blue-600 hover:text-blue-500">support@devv.me</a>
            </p>
          </div>
          
          <div class="flex justify-center">
            <%= link_to root_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" do %>
              Return to Home
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
