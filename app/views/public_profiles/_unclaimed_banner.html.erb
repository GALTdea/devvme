<!-- Unclaimed Profile Banner -->
<div class="relative overflow-hidden bg-gradient-to-r from-amber-50 to-orange-50 dark:from-amber-900/20 dark:to-orange-900/20 border-2 border-amber-200 dark:border-amber-700 rounded-2xl shadow-lg mb-8 animate-fade-in">
  <!-- Background Pattern -->
  <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="none" fill-rule="evenodd"%3E%3Cg fill="%23f59e0b" fill-opacity="0.1"%3E%3Ccircle cx="30" cy="30" r="2"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')]"></div>
  
  <div class="relative px-6 py-6">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between">
      <!-- Warning Icon and Message -->
      <div class="flex items-start space-x-4 mb-4 lg:mb-0">
        <div class="flex-shrink-0">
          <div class="w-12 h-12 bg-amber-100 dark:bg-amber-800/50 rounded-full flex items-center justify-center border-2 border-amber-300 dark:border-amber-600">
            <svg class="w-6 h-6 text-amber-600 dark:text-amber-400 animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
            </svg>
          </div>
        </div>
        
        <div class="flex-1 min-w-0">
          <h2 class="text-xl font-bold text-amber-900 dark:text-amber-100 mb-2">
            🚨 This profile is unclaimed
          </h2>
          <div class="text-amber-800 dark:text-amber-200 space-y-2">
            <p class="text-base leading-relaxed">
              This developer profile was created by an administrator and is currently <strong>unclaimed</strong>. 
              The profile is publicly visible but the owner hasn't claimed it yet.
            </p>
            
            <% if invitation_data[:expired] %>
              <div class="bg-red-100 dark:bg-red-900/30 border border-red-200 dark:border-red-700 rounded-lg p-3 mt-3">
                <div class="flex items-center">
                  <svg class="w-5 h-5 text-red-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span class="text-red-800 dark:text-red-200 font-medium">
                    Invitation expired on <%= invitation_data[:expires_at].strftime("%B %d, %Y") %>
                  </span>
                </div>
              </div>
            <% elsif invitation_data[:pending] %>
              <div class="bg-blue-100 dark:bg-blue-900/30 border border-blue-200 dark:border-blue-700 rounded-lg p-3 mt-3">
                <div class="flex items-center justify-between">
                  <div class="flex items-center">
                    <svg class="w-5 h-5 text-blue-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span class="text-blue-800 dark:text-blue-200 font-medium">
                      Invitation expires in <%= pluralize(invitation_data[:days_remaining], 'day') %>
                    </span>
                  </div>
                  <span class="text-xs text-blue-600 dark:text-blue-400 font-mono">
                    <%= invitation_data[:expires_at].strftime("%b %d, %Y") %>
                  </span>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
      
      <!-- Action Buttons -->
      <div class="flex flex-col sm:flex-row gap-3 lg:flex-shrink-0">
        <% if invitation_data[:pending] && !invitation_data[:expired] %>
          <!-- Claim Profile Button -->
          <%= link_to "/invitations/#{@user.invitation_token}/claim", 
              class: "inline-flex items-center justify-center px-6 py-3 bg-amber-600 hover:bg-amber-700 dark:bg-amber-500 dark:hover:bg-amber-600 text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-amber-300 dark:focus:ring-amber-800" do %>
            <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v-2l-4.257-4.257A6 6 0 0117 9z" />
            </svg>
            Claim This Profile
          <% end %>
        <% else %>
          <!-- Contact Admin Button for Expired Invitations -->
          <%= link_to "mailto:support@devv.me?subject=Expired Profile Invitation - #{@user.username}", 
              class: "inline-flex items-center justify-center px-6 py-3 bg-gray-600 hover:bg-gray-700 dark:bg-gray-500 dark:hover:bg-gray-600 text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-gray-300 dark:focus:ring-gray-800" do %>
            <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Contact Support
          <% end %>
        <% end %>
        
        <!-- Preview Notice -->
        <div class="inline-flex items-center px-4 py-2 bg-amber-100 dark:bg-amber-800/30 text-amber-800 dark:text-amber-200 rounded-lg border border-amber-200 dark:border-amber-600">
          <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
          <span class="text-sm font-medium">Preview Mode</span>
        </div>
      </div>
    </div>
    
    <!-- Additional Info for Profile Owner -->
    <% if invitation_data[:pending] && !invitation_data[:expired] %>
      <div class="mt-4 pt-4 border-t border-amber-200 dark:border-amber-700">
        <div class="text-sm text-amber-700 dark:text-amber-300">
          <p class="mb-2">
            <strong>Is this your profile?</strong> Click "Claim This Profile" to:
          </p>
          <ul class="list-disc list-inside space-y-1 ml-4">
            <li>Set your password and gain full access</li>
            <li>Add your projects and blog posts</li>
            <li>Customize your profile information</li>
            <li>Remove this banner and make it fully yours</li>
          </ul>
        </div>
      </div>
    <% end %>
  </div>
</div>
