<!-- Profile Stats -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
  <!-- Total Projects -->
  <%= link_to public_projects_path(author: user.username), class: "block bg-white dark:bg-gray-800 rounded-lg shadow-sm hover:shadow-md transition-all duration-300 border border-gray-100 dark:border-gray-700 p-4 group transform hover:-translate-y-0.5" do %>
    <div class="flex items-center">
      <div class="flex-shrink-0 p-2 bg-blue-100 dark:bg-blue-900/50 rounded-lg group-hover:bg-blue-200 dark:group-hover:bg-blue-900/70 transition-colors">
        <svg class="h-5 w-5 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
      </div>
      <div class="ml-3 flex-1 min-w-0">
        <dl>
          <dt class="text-xs font-medium text-gray-500 dark:text-gray-400 truncate">
            Projects
          </dt>
          <dd class="text-xl font-bold text-gray-900 dark:text-white">
            <%= user.published_projects_count %>
          </dd>
        </dl>
      </div>
    </div>
  <% end %>

  <!-- Blog Posts Count -->
  <%= link_to public_blog_index_path(author: user.username), class: "block bg-white dark:bg-gray-800 rounded-lg shadow-sm hover:shadow-md transition-all duration-300 border border-gray-100 dark:border-gray-700 p-4 group transform hover:-translate-y-0.5" do %>
    <div class="flex items-center">
      <div class="flex-shrink-0 p-2 bg-green-100 dark:bg-green-900/50 rounded-lg group-hover:bg-green-200 dark:group-hover:bg-green-900/70 transition-colors">
        <svg class="h-5 w-5 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
        </svg>
      </div>
      <div class="ml-3 flex-1 min-w-0">
        <dl>
          <dt class="text-xs font-medium text-gray-500 dark:text-gray-400 truncate">
            Blog Posts
          </dt>
          <dd class="text-xl font-bold text-gray-900 dark:text-white">
            <%= user.blog_posts.published.count %>
          </dd>
        </dl>
      </div>
    </div>
  <% end %>

  <!-- Followers Count -->
  <%= link_to user_followers_path(user.username), class: "block bg-white dark:bg-gray-800 rounded-lg shadow-sm hover:shadow-md transition-all duration-300 border border-gray-100 dark:border-gray-700 p-4 group transform hover:-translate-y-0.5" do %>
    <div class="flex items-center">
      <div class="flex-shrink-0 p-2 bg-indigo-100 dark:bg-indigo-900/50 rounded-lg group-hover:bg-indigo-200 dark:group-hover:bg-indigo-900/70 transition-colors">
        <svg class="h-5 w-5 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20h6M3 20h5m7-9a4 4 0 100-8 4 4 0 000 8zm-6 0a4 4 0 100-8 4 4 0 000 8z" />
        </svg>
      </div>
      <div class="ml-3 flex-1 min-w-0">
        <dl>
          <dt class="text-xs font-medium text-gray-500 dark:text-gray-400 truncate">Followers</dt>
          <dd id="<%= dom_id(user, :followers_count) %>" class="text-xl font-bold text-gray-900 dark:text-white"><%= user.followers.count %></dd>
        </dl>
      </div>
    </div>
  <% end %>

  <!-- Following Count -->
  <%= link_to user_following_path(user.username), class: "block bg-white dark:bg-gray-800 rounded-lg shadow-sm hover:shadow-md transition-all duration-300 border border-gray-100 dark:border-gray-700 p-4 group transform hover:-translate-y-0.5" do %>
    <div class="flex items-center">
      <div class="flex-shrink-0 p-2 bg-teal-100 dark:bg-teal-900/50 rounded-lg group-hover:bg-teal-200 dark:group-hover:bg-teal-900/70 transition-colors">
        <svg class="h-5 w-5 text-teal-600 dark:text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8M3 7h8m0 0v8m0-8L3 15" />
        </svg>
      </div>
      <div class="ml-3 flex-1 min-w-0">
        <dl>
          <dt class="text-xs font-medium text-gray-500 dark:text-gray-400 truncate">Following</dt>
          <dd id="<%= dom_id(user, :following_count) %>" class="text-xl font-bold text-gray-900 dark:text-white"><%= user.following.count %></dd>
        </dl>
      </div>
    </div>
  <% end %>
</div>
