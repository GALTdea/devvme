<% page_title(@seo_title) %>
<% meta_description(@seo_description) %>
<% meta_keywords(@seo_keywords) %>
<% canonical_url(@seo_profile_url) %>

<%# Enhanced social sharing meta tags %>
<% enhanced_open_graph_tags(
  title: "#{@user.display_name} - Developer Profile | Devv.me",
  description: @seo_description,
  image: @seo_avatar_url,
  url: @seo_profile_url,
  type: "profile",
  image_alt: "#{@user.display_name} - A developer profile worth sharing",
  twitter_creator: @user.twitter_url.present? ? "@#{@user.twitter_url.split('/').last}" : "@devvme_app"
) %>

<%# Enhanced JSON-LD Structured Data %>
<% content_for :structured_data do %>
  <%= profile_structured_data(@user) %>
<% end %>
<%# Print Styles %>
<% content_for :head do %>
  <style media="print">
    @page {
      margin: 1in;
      size: letter;
    }
    
    .no-print {
      display: none !important;
    }
    
    .print-break {
      page-break-after: always;
    }
    
    body {
      font-size: 12pt;
      line-height: 1.4;
      color: #000 !important;
      background: #fff !important;
    }
    
    .bg-white, .bg-charcoal-50, .bg-primary-100 {
      background: #fff !important;
    }
    
    .text-charcoal-900, .text-charcoal-800, .text-charcoal-700 {
      color: #000 !important;
    }
    
    .text-charcoal-600, .text-charcoal-500 {
      color: #333 !important;
    }
    
    .shadow, .shadow-lg, .shadow-md {
      box-shadow: none !important;
    }
    
    .border {
      border: 1px solid #ccc !important;
    }
    
    a {
      color: #000 !important;
      text-decoration: underline !important;
    }
    
    .profile-avatar {
      width: 120px !important;
      height: 120px !important;
    }
    
    .project-card {
      border: 1px solid #ccc !important;
      margin-bottom: 1rem !important;
      page-break-inside: avoid;
    }
  </style>
<% end %>

<div class="min-h-screen bg-gradient-to-br from-cream-50 via-primary-50 to-secondary-50 dark:from-charcoal-900 dark:via-charcoal-800 dark:to-secondary-900 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <!-- Unclaimed Profile Banner -->
    <% if show_unclaimed_banner? %>
      <%= render 'unclaimed_banner' %>
    <% end %>
    
    <!-- Cached Profile Header -->
    <% cache profile_cache_key(@user, 'header'), expires_in: 5.minutes do %>
      <%= render 'profile_header', user: @user %>
                <% end %>
                
    <!-- Cached Profile Stats -->
    <% cache profile_stats_cache_key(@user), expires_in: 30.minutes do %>
      <%= render 'profile_stats', user: @user %>
            <% end %>
            
    <!-- Cached Projects Section -->
    <% cache profile_projects_cache_key(@user, @recent_projects), expires_in: 1.hour do %>
      <%= render 'projects_section', projects: @recent_projects, user: @user %>
    <% end %>

    <!-- Cached Blog Posts Section -->
    <% cache profile_blog_posts_cache_key(@user, @recent_blog_posts), expires_in: 1.hour do %>
      <%= render 'blog_posts_section', blog_posts: @recent_blog_posts, user: @user %>
    <% end %>

    <!-- Empty States -->
    <% if @recent_projects.empty? && @recent_blog_posts.empty? %>
      <div class="text-center py-16">
        <% if unclaimed_profile? %>
          <!-- Unclaimed Profile Empty State -->
          <div class="mx-auto w-24 h-24 bg-amber-100 dark:bg-amber-800/50 rounded-full flex items-center justify-center mb-6 border-2 border-amber-300 dark:border-amber-600">
            <svg class="w-12 h-12 text-amber-600 dark:text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v-2l-4.257-4.257A6 6 0 0117 9z" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-amber-900 dark:text-amber-100 mb-2">Content Coming Soon</h3>
          <p class="text-xl text-amber-700 dark:text-amber-300 max-w-md mx-auto mb-4">
            This profile is waiting to be claimed. Once <%= @user.display_name %> claims it, they'll be able to add projects and blog posts.
          </p>
          <div class="inline-flex items-center px-4 py-2 bg-amber-100 dark:bg-amber-800/30 text-amber-800 dark:text-amber-200 rounded-lg border border-amber-200 dark:border-amber-600">
            <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-sm font-medium">Profile in preview mode</span>
          </div>
        <% else %>
          <!-- Regular Empty State -->
          <div class="mx-auto w-24 h-24 bg-primary-100 dark:bg-charcoal-800 rounded-full flex items-center justify-center mb-6">
            <svg class="w-12 h-12 text-charcoal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-charcoal-900 dark:text-cream-50 mb-2">No Content Yet</h3>
          <p class="text-xl text-charcoal-500 dark:text-charcoal-400 max-w-md mx-auto">
            <%= @user.display_name %> hasn't published any projects or blog posts yet. Check back soon!
          </p>
        <% end %>
      </div>
    <% elsif @recent_projects.empty? %>
      <div class="text-center py-12 bg-white dark:bg-charcoal-800 rounded-2xl shadow-lg border border-primary-100 dark:border-charcoal-700">
        <% if unclaimed_profile? %>
          <!-- Unclaimed Profile Projects Empty State -->
          <svg class="mx-auto h-12 w-12 text-amber-500 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v-2l-4.257-4.257A6 6 0 0117 9z" />
          </svg>
          <h3 class="text-lg font-medium text-amber-900 dark:text-amber-100 mb-2">Projects Coming Soon</h3>
          <p class="text-amber-700 dark:text-amber-300">
            Projects will appear here once <%= @user.display_name %> claims this profile.
          </p>
        <% else %>
          <!-- Regular Projects Empty State -->
          <svg class="mx-auto h-12 w-12 text-charcoal-400 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
          <h3 class="text-lg font-medium text-charcoal-900 dark:text-cream-50 mb-2">No Projects Yet</h3>
          <p class="text-charcoal-500 dark:text-charcoal-400">
              <%= @user.display_name %> hasn't published any projects yet.
            </p>
        <% end %>
        </div>
      <% end %>

  </div>
</div>

<%# Google Analytics tracking for profile view %>
<%= track_profile_view(@user.username, @user.id) if google_analytics_enabled? %>