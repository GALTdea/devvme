<% page_title(@seo_title) %>
<% meta_description(@seo_description) %>
<% meta_keywords(@seo_keywords) %>
<% canonical_url(@seo_profile_url) %>

<% open_graph_tags(
  title: "#{@user.display_name} - Developer Profile",
  description: @seo_description,
  image: @seo_avatar_url,
  url: @seo_profile_url,
  type: "profile"
) %>

<% twitter_card_tags(
  title: @seo_title,
  description: @seo_description,
  image: @seo_avatar_url
) %>

<%# JSON-LD Structured Data %>
<% content_for :structured_data do %>
  <% schema = {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": @user.display_name,
    "alternateName": "@#{@user.username}",
    "description": @user.bio.presence || "Developer on Devvme App",
    "url": @seo_profile_url,
    "memberOf": {
      "@type": "Organization",
      "name": "Devvme App"
    }
  } %>
  
  <% if @user.avatar.attached? %>
    <% schema[:image] = url_for(@user.avatar) %>
  <% end %>
  
  <% same_as = [] %>
  <% same_as << @user.github_url if @user.github_url.present? %>
  <% same_as << @user.linkedin_url if @user.linkedin_url.present? %>
  <% same_as << @user.website_url if @user.website_url.present? %>
  <% same_as << @user.twitter_url if @user.twitter_url.present? %>
  <% schema[:sameAs] = same_as if same_as.any? %>
  
  <% if @recent_projects.any? %>
    <% schema[:hasCreatedWork] = @recent_projects.map do |project| %>
      <% {
        "@type": "CreativeWork",
        "name": project.title,
        "description": project.description,
        "dateCreated": project.created_at.iso8601,
        "creator": {
          "@type": "Person",
          "name": @user.display_name
        }
      } %>
    <% end %>
  <% end %>
  
  <script type="application/ld+json">
    <%= raw schema.to_json %>
  </script>
<% end %>

<%# Print Styles %>
<% content_for :head do %>
  <style media="print">
    @page {
      margin: 1in;
      size: letter;
    }
    
    .no-print {
      display: none !important;
    }
    
    .print-break {
      page-break-after: always;
    }
    
    body {
      font-size: 12pt;
      line-height: 1.4;
      color: #000 !important;
      background: #fff !important;
    }
    
    .bg-white, .bg-gray-50, .bg-gray-100 {
      background: #fff !important;
    }
    
    .text-gray-900, .text-gray-800, .text-gray-700 {
      color: #000 !important;
    }
    
    .text-gray-600, .text-gray-500 {
      color: #333 !important;
    }
    
    .shadow, .shadow-lg, .shadow-md {
      box-shadow: none !important;
    }
    
    .border {
      border: 1px solid #ccc !important;
    }
    
    a {
      color: #000 !important;
      text-decoration: underline !important;
    }
    
    .profile-avatar {
      width: 120px !important;
      height: 120px !important;
    }
    
    .project-card {
      border: 1px solid #ccc !important;
      margin-bottom: 1rem !important;
      page-break-inside: avoid;
    }
  </style>
<% end %>

<div class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-purple-50 dark:from-gray-900 dark:via-gray-800 dark:to-gray-900 transition-all duration-300" 
     data-controller="dark-mode">
  
  <!-- Dark Mode Toggle - Fixed Position -->
  <div class="fixed top-4 right-4 z-50 no-print">
    <button data-action="click->dark-mode#toggle" 
            data-dark-mode-target="toggle"
            class="group p-3 bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm rounded-full shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-200 dark:border-gray-700">
      <svg class="w-6 h-6 text-gray-700 dark:text-gray-300 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors" 
           fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
      </svg>
    </button>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <!-- Hero Section with Profile Header -->
    <div class="relative overflow-hidden bg-white dark:bg-gray-800 rounded-2xl shadow-xl mb-8 border border-gray-100 dark:border-gray-700 transition-all duration-300 hover:shadow-2xl">
      <!-- Background Pattern -->
      <div class="absolute inset-0 bg-gradient-to-r from-blue-600/5 to-purple-600/5 dark:from-blue-400/5 dark:to-purple-400/5"></div>
      <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="none" fill-rule="evenodd"%3E%3Cg fill="%239C92AC" fill-opacity="0.03"%3E%3Ccircle cx="30" cy="30" r="2"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')]"></div>
      
      <div class="relative px-8 py-12">
        <div class="flex flex-col lg:flex-row lg:items-start lg:space-x-8">
          <!-- Avatar and Basic Info -->
          <div class="flex-shrink-0 mb-8 lg:mb-0">
            <div class="relative group">
            <% if @user.avatar.attached? %>
              <%= image_tag @user.avatar_medium, 
                    class: "profile-avatar w-40 h-40 rounded-2xl object-cover border-4 border-white dark:border-gray-700 shadow-xl group-hover:shadow-2xl transition-shadow duration-300",
                  alt: "#{@user.display_name}'s avatar" %>
            <% else %>
                <div class="profile-avatar w-40 h-40 rounded-2xl bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center border-4 border-white dark:border-gray-700 shadow-xl group-hover:shadow-2xl transition-shadow duration-300">
                  <svg class="w-20 h-20 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
            <% end %>
              <div class="absolute -bottom-2 -right-2 w-8 h-8 bg-green-500 rounded-full border-4 border-white dark:border-gray-800 animate-pulse"></div>
            </div>
          </div>
          
          <!-- Profile Info -->
          <div class="flex-1 min-w-0">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-6">
              <div class="mb-4 sm:mb-0">
                <h1 class="text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white mb-2 animate-fade-in">
                  <%= @user.display_name %>
                </h1>
                <p class="text-xl text-gray-600 dark:text-gray-400 mb-2">
                  @<%= @user.username %>
                </p>
                <% if @user.job_title.present? || @user.location.present? %>
                  <div class="flex flex-wrap items-center gap-4 text-gray-500 dark:text-gray-400">
                    <% if @user.job_title.present? %>
                      <div class="flex items-center">
                        <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2-2v2m8 0V6a2 2 0 012 2v6a2 2 0 01-2 2H8a2 2 0 01-2-2V8a2 2 0 012-2h8zM16 10h.01M8 10h.01" />
                        </svg>
                        <%= @user.job_title %>
                      </div>
                    <% end %>
                    <% if @user.location.present? %>
                      <div class="flex items-center">
                        <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        <%= @user.location %>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
              
              <!-- Action Buttons -->
              <div class="flex flex-wrap gap-3 no-print">
                <div data-controller="share-button"
                     data-share-button-url-value="<%= request.original_url %>"
                     data-share-button-title-value="<%= @user.display_name %>'s Profile">
                  <button data-action="click->share-button#share"
                          class="inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 text-white font-medium rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5">
                    <svg class="mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.367 2.684 3 3 0 00-5.367-2.684z" />
                    </svg>
                    Share Profile
                  </button>
                </div>
                
                <% if @user.resume.attached? %>
                  <%= link_to @user.resume, target: "_blank", rel: "noopener noreferrer",
                      class: "inline-flex items-center px-4 py-2 bg-green-600 hover:bg-green-700 dark:bg-green-500 dark:hover:bg-green-600 text-white font-medium rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5" do %>
                    <svg class="mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    Download Resume
                  <% end %>
                <% elsif @user.resume_url.present? %>
                  <%= link_to @user.resume_url, target: "_blank", rel: "noopener noreferrer",
                      class: "inline-flex items-center px-4 py-2 bg-green-600 hover:bg-green-700 dark:bg-green-500 dark:hover:bg-green-600 text-white font-medium rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5" do %>
                    <svg class="mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    View Resume
                  <% end %>
                <% end %>
                
                <button onclick="window.print()" 
                        class="inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 font-medium rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5">
                  <svg class="mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
                  </svg>
                  Print
                </button>
              </div>
            </div>
            
            <!-- Headline -->
            <% if @user.headline.present? %>
              <div class="mb-6">
                <p class="text-xl text-gray-800 dark:text-gray-200 font-medium leading-relaxed">
                  <%= @user.headline %>
                </p>
              </div>
            <% end %>
            
            <!-- Bio -->
            <% if @user.bio.present? %>
              <div class="mb-6">
                <p class="text-gray-700 dark:text-gray-300 text-lg leading-relaxed">
                <%= simple_format(@user.bio, {}, wrapper_tag: "span") %>
              </p>
              </div>
            <% else %>
              <div class="mb-6">
                <p class="text-gray-500 dark:text-gray-400 italic text-lg">
                  This developer hasn't added a bio yet.
                </p>
              </div>
            <% end %>
            
            <!-- Skills -->
            <% if @user.skills.present? && @user.skills.any? %>
              <div class="mb-6">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">Skills & Technologies</h3>
                <div class="flex flex-wrap gap-2">
                  <% @user.skills.each do |skill| %>
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200 hover:bg-blue-200 dark:hover:bg-blue-800 transition-colors">
                      <%= skill %>
                    </span>
                  <% end %>
                </div>
              </div>
            <% end %>
            
            <!-- Social Links and Contact -->
            <div class="flex flex-wrap gap-3">
              <% if @user.github_url.present? %>
                <%= link_to @user.github_url, target: "_blank", rel: "noopener noreferrer",
                    class: "inline-flex items-center px-4 py-2 bg-gray-900 hover:bg-gray-800 dark:bg-gray-700 dark:hover:bg-gray-600 text-white font-medium rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5 no-print" do %>
                  <svg class="mr-2 h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd" />
                  </svg>
                  GitHub
                <% end %>
              <% end %>
              
              <% if @user.linkedin_url.present? %>
                <%= link_to @user.linkedin_url, target: "_blank", rel: "noopener noreferrer",
                    class: "inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-600 text-white font-medium rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5 no-print" do %>
                  <svg class="mr-2 h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M16.338 16.338H13.67V12.16c0-.995-.017-2.277-1.387-2.277-1.39 0-1.601 1.086-1.601 2.207v4.248H8.014v-8.59h2.559v1.174h.037c.356-.675 1.227-1.387 2.526-1.387 2.703 0 3.203 1.778 3.203 4.092v4.711zM5.005 6.575a1.548 1.548 0 11-.003-3.096 1.548 1.548 0 01.003 3.096zm-1.337 9.763H6.34v-8.59H3.668v8.59zM17.668 1H2.328C1.595 1 1 1.581 1 2.298v15.403C1 18.418 1.595 19 2.328 19h15.34c.734 0 1.332-.582 1.332-1.299V2.298C19 1.581 18.402 1 17.668 1z"/>
                  </svg>
                  LinkedIn
                <% end %>
              <% end %>
              
              <% if @user.twitter_url.present? %>
                <%= link_to @user.twitter_url, target: "_blank", rel: "noopener noreferrer",
                    class: "inline-flex items-center px-4 py-2 bg-sky-500 hover:bg-sky-600 dark:bg-sky-400 dark:hover:bg-sky-500 text-white font-medium rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5 no-print" do %>
                  <svg class="mr-2 h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M6.29 18.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0020 3.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.073 4.073 0 01.8 7.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 010 16.407a11.616 11.616 0 006.29 1.84" />
                  </svg>
                  Twitter
                <% end %>
              <% end %>
              
              <% if @user.website_url.present? %>
                <%= link_to @user.website_url, target: "_blank", rel: "noopener noreferrer",
                    class: "inline-flex items-center px-4 py-2 bg-purple-600 hover:bg-purple-700 dark:bg-purple-500 dark:hover:bg-purple-600 text-white font-medium rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5 no-print" do %>
                  <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9v-9m0 9a9 9 0 009-9M3 12a9 9 0 019-9" />
                  </svg>
                  Website
                <% end %>
              <% end %>
              
              <% if @user.contact_email.present? %>
                <%= link_to "mailto:#{@user.contact_email}",
                    class: "inline-flex items-center px-4 py-2 bg-red-600 hover:bg-red-700 dark:bg-red-500 dark:hover:bg-red-600 text-white font-medium rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5" do %>
                  <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  Email
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Profile Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <!-- Total Projects -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100 dark:border-gray-700 p-6 group">
          <div class="flex items-center">
          <div class="flex-shrink-0 p-3 bg-blue-100 dark:bg-blue-900/50 rounded-xl group-hover:bg-blue-200 dark:group-hover:bg-blue-900/70 transition-colors">
            <svg class="h-8 w-8 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
                  Published Projects
                </dt>
              <dd class="text-2xl font-bold text-gray-900 dark:text-white">
                  <%= @user.published_projects_count %>
                </dd>
              </dl>
            </div>
        </div>
      </div>

      <!-- Blog Posts Count -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100 dark:border-gray-700 p-6 group">
        <div class="flex items-center">
          <div class="flex-shrink-0 p-3 bg-green-100 dark:bg-green-900/50 rounded-xl group-hover:bg-green-200 dark:group-hover:bg-green-900/70 transition-colors">
            <svg class="h-8 w-8 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
            </svg>
          </div>
          <div class="ml-5 w-0 flex-1">
            <dl>
              <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
                Blog Posts
              </dt>
              <dd class="text-2xl font-bold text-gray-900 dark:text-white">
                <%= @user.blog_posts.published.count %>
              </dd>
            </dl>
          </div>
        </div>
      </div>

      <!-- Member Since -->
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-100 dark:border-gray-700 p-6 group">
          <div class="flex items-center">
          <div class="flex-shrink-0 p-3 bg-purple-100 dark:bg-purple-900/50 rounded-xl group-hover:bg-purple-200 dark:group-hover:bg-purple-900/70 transition-colors">
            <svg class="h-8 w-8 text-purple-600 dark:text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3a2 2 0 012-2h4a2 2 0 012 2v4m-6 0h6m-6 0l-2 2m8-2l2 2m-2-2v6a2 2 0 01-2 2H6a2 2 0 01-2-2v-6a2 2 0 012-2h8a2 2 0 012 2z" />
              </svg>
            </div>
            <div class="ml-5 w-0 flex-1">
              <dl>
                <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
                  Member Since
                </dt>
              <dd class="text-2xl font-bold text-gray-900 dark:text-white">
                  <%= @user.created_at.strftime("%B %Y") %>
                </dd>
              </dl>
          </div>
        </div>
      </div>
    </div>

    <!-- Projects Section -->
    <% if @recent_projects.any? %>
    <div class="mb-8">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white flex items-center">
            <svg class="w-8 h-8 mr-3 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
            Featured Projects
        </h2>
          <div class="text-sm text-gray-500 dark:text-gray-400">
            <%= @recent_projects.count %> of <%= @user.published_projects_count %> projects
          </div>
      </div>

        <!-- Projects Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <% @recent_projects.each_with_index do |project, index| %>
            <div class="project-card bg-white dark:bg-gray-800 rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-500 border border-gray-100 dark:border-gray-700 group overflow-hidden transform hover:-translate-y-2" 
                 style="animation-delay: <%= index * 100 %>ms">
              <!-- Project Thumbnail -->
              <div class="relative overflow-hidden bg-gradient-to-br from-blue-500 to-purple-600 h-48">
                <% if project.thumbnail.attached? %>
                  <%= image_tag project.thumbnail, class: "w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" %>
                <% else %>
                  <div class="flex items-center justify-center h-full">
                    <svg class="h-16 w-16 text-white/80" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                    </svg>
                  </div>
                <% end %>
                <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent"></div>
                <div class="absolute top-4 right-4">
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-500 text-white shadow-lg">
                    <div class="w-2 h-2 bg-white rounded-full mr-2 animate-pulse"></div>
                    Live
                  </span>
                </div>
              </div>

              <!-- Project Content -->
              <div class="p-6">
                <div class="flex items-start justify-between mb-3">
                  <h3 class="text-xl font-bold text-gray-900 dark:text-white line-clamp-1 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                    <%= project.title %>
                  </h3>
                </div>
                
                <p class="text-gray-600 dark:text-gray-400 mb-4 line-clamp-2 leading-relaxed">
                  <%= truncate(project.description, length: 120) %>
                </p>
                
                <!-- Technologies -->
                <% if project.technologies_used.present? && project.technologies_used.any? %>
                  <div class="mb-4">
                    <div class="flex flex-wrap gap-2">
                      <% project.technologies_used.first(3).each do |tech| %>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200">
                          <%= tech %>
                        </span>
                      <% end %>
                      <% if project.technologies_used.count > 3 %>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400">
                          +<%= project.technologies_used.count - 3 %> more
                        </span>
                      <% end %>
                    </div>
                  </div>
                <% end %>
                
                <div class="flex items-center justify-between">
                  <div class="flex space-x-3">
                    <% if project.github_url.present? %>
                      <%= link_to project.github_url, target: "_blank", rel: "noopener noreferrer", 
                          class: "p-2 text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white bg-gray-100 dark:bg-gray-700 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-all duration-300 no-print",
                          title: "View Source Code" do %>
                        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd" />
                        </svg>
                      <% end %>
                    <% end %>
                    <% if project.demo_url.present? %>
                      <%= link_to project.demo_url, target: "_blank", rel: "noopener noreferrer", 
                          class: "p-2 text-gray-500 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400 bg-gray-100 dark:bg-gray-700 rounded-lg hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-all duration-300 no-print",
                          title: "View Live Demo" do %>
                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                      <% end %>
                    <% end %>
                  </div>
                  <time class="text-sm text-gray-500 dark:text-gray-400">
                    <%= time_ago_in_words(project.created_at) %> ago
                  </time>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Blog Posts Section -->
    <% if @recent_blog_posts.any? %>
      <div class="mb-8">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white flex items-center">
            <svg class="w-8 h-8 mr-3 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
            </svg>
            Latest Blog Posts
          </h2>
          <% if @user.blog_posts.published.count > 3 %>
            <%= link_to public_blog_path(@user.username), 
                class: "text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 font-medium transition-colors no-print" do %>
              View All →
            <% end %>
          <% end %>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          <% @recent_blog_posts.each_with_index do |post, index| %>
            <article class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-500 border border-gray-100 dark:border-gray-700 group overflow-hidden transform hover:-translate-y-2" 
                     style="animation-delay: <%= index * 150 %>ms">
              <div class="p-6">
                <div class="flex items-center justify-between mb-4">
                  <time class="text-sm text-gray-500 dark:text-gray-400">
                    <%= post.published_at.strftime("%B %d, %Y") %>
                  </time>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200">
                    <%= pluralize(post.views_count, 'view') %>
                  </span>
                </div>
                
                <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3 line-clamp-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                  <%= link_to post.title, public_blog_post_path(@user.username, post), class: "hover:underline" %>
                </h3>
                
                <% if post.excerpt.present? %>
                  <p class="text-gray-600 dark:text-gray-400 line-clamp-3 leading-relaxed mb-4">
                    <%= truncate(post.excerpt, length: 150) %>
                  </p>
                <% end %>
                
                <%= link_to public_blog_post_path(@user.username, post), 
                    class: "inline-flex items-center text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 font-medium transition-colors group-hover:underline" do %>
                  Read More
                  <svg class="ml-2 w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                <% end %>
              </div>
            </article>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Empty States -->
    <% if @recent_projects.empty? && @recent_blog_posts.empty? %>
      <div class="text-center py-16">
        <div class="mx-auto w-24 h-24 bg-gray-100 dark:bg-gray-800 rounded-full flex items-center justify-center mb-6">
          <svg class="w-12 h-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">No Content Yet</h3>
        <p class="text-xl text-gray-500 dark:text-gray-400 max-w-md mx-auto">
          <%= @user.display_name %> hasn't published any projects or blog posts yet. Check back soon!
        </p>
      </div>
    <% elsif @recent_projects.empty? %>
      <div class="text-center py-12 bg-white dark:bg-gray-800 rounded-2xl shadow-lg border border-gray-100 dark:border-gray-700">
        <svg class="mx-auto h-12 w-12 text-gray-400 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
        <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">No Projects Yet</h3>
        <p class="text-gray-500 dark:text-gray-400">
            <%= @user.display_name %> hasn't published any projects yet.
          </p>
        </div>
      <% end %>

  </div>
</div>

<!-- Add CSS animations -->
<style>
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 0.6s ease-out;
  }

  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Staggered animation for cards */
  .grid > div {
    animation: fade-in 0.6s ease-out forwards;
    opacity: 0;
  }

  .grid > div:nth-child(1) { animation-delay: 0ms; }
  .grid > div:nth-child(2) { animation-delay: 100ms; }
  .grid > div:nth-child(3) { animation-delay: 200ms; }
  .grid > div:nth-child(4) { animation-delay: 300ms; }
  .grid > div:nth-child(5) { animation-delay: 400ms; }
  .grid > div:nth-child(6) { animation-delay: 500ms; }
</style>