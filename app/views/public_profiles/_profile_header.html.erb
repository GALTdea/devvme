<!-- Hero Section with Profile Header -->
<div class="relative overflow-hidden bg-white dark:bg-charcoal-800 rounded-2xl shadow-xl mb-8 border border-primary-200 dark:border-charcoal-700 transition-all duration-300 hover:shadow-2xl" role="banner" aria-label="Profile header">
  <!-- Background Pattern -->
  <div class="absolute inset-0 bg-gradient-to-r from-primary-600/5 to-secondary-600/5 dark:from-primary-400/5 dark:to-secondary-400/5" aria-hidden="true"></div>
  <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="none" fill-rule="evenodd"%3E%3Cg fill="%2310b981" fill-opacity="0.03"%3E%3Ccircle cx="30" cy="30" r="2"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')]" aria-hidden="true"></div>
  
  <div class="relative px-4 sm:px-6 lg:px-8 py-8 sm:py-10 lg:py-12">
    <div class="flex flex-col lg:flex-row lg:items-start lg:space-x-6 xl:space-x-8">
      <!-- Avatar and Basic Info -->
      <div class="flex-shrink-0 mb-6 sm:mb-8 lg:mb-0 flex justify-center lg:justify-start">
        <!-- Terminal-style frame -->
        <div class="relative bg-charcoal-900 dark:bg-charcoal-950 rounded-lg p-3 sm:p-4 border border-charcoal-600 shadow-lg hover:shadow-xl transition-shadow duration-300" aria-label="Developer terminal">
          <!-- Terminal header -->
          <div class="flex items-center justify-between mb-3 px-2" aria-hidden="true">
            <div class="flex space-x-1.5" role="presentation">
              <div class="w-3 h-3 bg-danger-500 rounded-full" aria-hidden="true"></div>
              <div class="w-3 h-3 bg-warning-500 rounded-full" aria-hidden="true"></div>
              <div class="w-3 h-3 bg-primary-500 rounded-full" aria-hidden="true"></div>
            </div>
            <div class="text-xs font-mono text-charcoal-400">~/developer</div>
          </div>
          
          <!-- Avatar container -->
          <div class="relative group">
            <% if user.avatar.attached? %>
              <%= image_tag user.avatar_medium, 
                    class: "profile-avatar w-28 h-28 sm:w-32 sm:h-32 rounded-xl object-cover border-2 border-primary-400 shadow-lg group-hover:shadow-primary-500/50 group-hover:scale-105 transition-all duration-300",
                    alt: "#{user.display_name}'s avatar",
                    loading: "lazy",
                    decoding: "async",
                    width: "128",
                    height: "128" %>
            <% else %>
              <div class="profile-avatar w-28 h-28 sm:w-32 sm:h-32 rounded-xl bg-gradient-to-br from-primary-500 to-secondary-600 flex items-center justify-center border-2 border-primary-400 shadow-lg group-hover:shadow-primary-500/50 group-hover:scale-105 transition-all duration-300" aria-label="Default avatar">
                <svg class="w-14 h-14 sm:w-16 sm:h-16 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
            <% end %>
            
            <!-- Online status indicator -->
            <div class="absolute -bottom-1 -right-1 w-5 h-5 sm:w-6 sm:h-6 bg-primary-500 rounded-full border-2 border-charcoal-900 dark:border-charcoal-950 flex items-center justify-center shadow-lg" aria-label="Online status">
              <div class="w-2 h-2 bg-white rounded-full animate-pulse" aria-hidden="true"></div>
            </div>
          </div>
          
          <!-- Terminal command -->
          <div class="mt-3 px-2" aria-label="Username">
            <div class="text-xs font-mono text-primary-400" aria-hidden="true">
              <span class="text-charcoal-500">$</span> whoami
            </div>
            <div class="text-xs font-mono text-cream-200 mt-1">
              <%= user.username %>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Profile Info -->
      <div class="flex-1 min-w-0">
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 sm:gap-6 mb-6">
          <div class="flex-1 min-w-0">
            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-charcoal-900 dark:text-cream-50 mb-2 animate-fade-in break-words">
              <%= user.display_name %>
            </h1>
            
            <!-- Headline -->
            <% if user.headline.present? %>
              <h2 class="text-lg sm:text-xl text-charcoal-800 dark:text-cream-200 font-medium leading-relaxed break-words mb-4">
                <%= user.headline %>
              </h2>
            <% end %>
            
            <!-- Location Info -->
            <% if user.location.present? %>
              <div class="flex flex-wrap items-center gap-3 sm:gap-4 text-sm sm:text-base text-charcoal-600 dark:text-charcoal-400 mt-1" role="group" aria-label="Location information">
                <div class="flex items-center group/item">
                  <svg class="w-4 h-4 mr-2 text-charcoal-400 dark:text-charcoal-500 flex-shrink-0 group-hover/item:text-primary-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <span class="break-words"><%= user.location %></span>
                </div>
              </div>
            <% end %>
          </div>
          
          <!-- Right Section: Badges and Action Buttons in a Row -->
          <div class="flex flex-wrap items-start gap-2 sm:gap-3">
            <!-- Developer Status Badges -->
            <div class="flex flex-wrap items-center gap-2 sm:gap-3" role="group" aria-label="Profile status badges">
              <% if unclaimed_profile? %>
                <!-- Unclaimed Status Badge -->
                <div class="inline-flex items-center px-3 py-1.5 rounded-full text-xs sm:text-sm font-medium bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300 border border-amber-200 dark:border-amber-700 shadow-sm" role="status" aria-label="Profile unclaimed">
                  <div class="w-2 h-2 bg-amber-500 rounded-full mr-2 animate-pulse" aria-hidden="true"></div>
                  <span>Profile Unclaimed</span>
                </div>
                
                <!-- Preview Mode Badge -->
                <div class="inline-flex items-center px-3 py-1.5 rounded-full text-xs sm:text-sm font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300 border border-blue-200 dark:border-blue-700 shadow-sm" role="status" aria-label="Preview mode">
                  <svg class="w-3 h-3 mr-1.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/>
                    <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
                  </svg>
                  <span>Preview Mode</span>
                </div>
              <% else %>
                <!-- Regular Status Badges -->
                <!-- Open to Work Badge (Only show when user is open for work) -->
                <% if user.open_to_work? %>
                  <div class="inline-flex items-center px-4 py-2 rounded-full text-sm font-semibold bg-gradient-to-r from-primary-500 to-accent-500 text-white shadow-lg shadow-primary-500/30 dark:shadow-primary-500/50 animate-pulse-slow" role="status" aria-label="Open to work">
                    <svg class="w-4 h-4 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m8 0h-8m8 0v6a2 2 0 01-2 2h-4a2 2 0 01-2-2V6m8 0h2a2 2 0 012 2v6a2 2 0 01-2 2h-2" />
                    </svg>
                    <span>Open to Work</span>
                  </div>
                <% end %>
              <% end %>
            </div>
            
            <!-- Action Buttons -->
            <div class="flex flex-wrap gap-2 sm:gap-3 no-print" role="group" aria-label="Profile actions">
            <% if unclaimed_profile? %>
              <!-- Claim Profile Button (Primary Action) - Now redirects to verification -->
              <% if invitation_data[:pending] && !invitation_data[:expired] %>
                <%= link_to verify_invitation_path(@user.invitation_token), 
                    class: "inline-flex items-center px-4 sm:px-6 py-2.5 sm:py-3 bg-amber-600 hover:bg-amber-700 dark:bg-amber-500 dark:hover:bg-amber-600 text-white font-semibold rounded-lg shadow-lg hover:shadow-xl active:scale-95 transition-all duration-300 transform hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-amber-300 dark:focus:ring-amber-800 focus-visible:outline-none",
                    aria: { label: "Claim this profile" } do %>
                  <svg class="w-4 h-4 sm:w-5 sm:h-5 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v-2l-4.257-4.257A6 6 0 0117 9z" />
                  </svg>
                  <span>Claim Profile</span>
                <% end %>
              <% end %>
              
              <!-- Limited Share Button for Unclaimed Profiles -->
              <div data-tooltip-target="share-unclaimed-tooltip" data-tooltip-trigger="hover">
                <div data-controller="share-button"
                     data-share-button-url-value="<%= request.original_url %>"
                     data-share-button-title-value="<%= user.display_name %>'s Unclaimed Profile">
                  <button data-action="click->share-button#share"
                          class="inline-flex items-center px-3 sm:px-4 py-2 bg-charcoal-800 hover:bg-charcoal-900 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-cream-100 font-mono text-xs sm:text-sm rounded-lg border border-charcoal-600 hover:border-accent-500 shadow-lg hover:shadow-xl active:scale-95 transition-all duration-300 transform hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:ring-offset-2 focus:ring-offset-charcoal-800"
                          aria-label="Share unclaimed profile">
                    <span class="text-accent-400 mr-2">$</span>
                    <span>share --preview</span>
                  </button>
                </div>
                <div id="share-unclaimed-tooltip" role="tooltip" class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-white transition-opacity duration-300 bg-gray-900 rounded-lg shadow-sm opacity-0 tooltip dark:bg-gray-700">
                  Share this unclaimed profile - Let others know about this developer
                  <div class="tooltip-arrow" data-popper-arrow></div>
                </div>
              </div>
            <% else %>
              <!-- Regular Action Buttons for Active Profiles -->
              <%= render 'public_profiles/follow_button', user: user %>
              <div data-tooltip-target="share-tooltip" data-tooltip-trigger="hover">
                <div data-controller="share-button"
                     data-share-button-url-value="<%= request.original_url %>"
                     data-share-button-title-value="<%= user.display_name %>'s Profile">
                  <button data-action="click->share-button#share"
                          class="inline-flex items-center px-3 sm:px-4 py-2 bg-charcoal-800 hover:bg-charcoal-900 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-cream-100 font-mono text-xs sm:text-sm rounded-lg border border-charcoal-600 hover:border-accent-500 shadow-lg hover:shadow-xl active:scale-95 transition-all duration-300 transform hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:ring-offset-2 focus:ring-offset-charcoal-800"
                          aria-label="Share profile">
                    <span class="text-accent-400 mr-2">$</span>
                    <span>share --profile</span>
                  </button>
                </div>
                <div id="share-tooltip" role="tooltip" class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-white transition-opacity duration-300 bg-gray-900 rounded-lg shadow-sm opacity-0 tooltip dark:bg-gray-700">
                  Share this profile - Copy link to share with others
                  <div class="tooltip-arrow" data-popper-arrow></div>
                </div>
              </div>
            <% end %>
            
            <% if user.resume.attached? %>
              <div data-tooltip-target="resume-tooltip" data-tooltip-trigger="hover">
                <%= link_to user.resume, target: "_blank", rel: "noopener noreferrer",
                    class: "inline-flex items-center px-3 sm:px-4 py-2 bg-charcoal-800 hover:bg-charcoal-900 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-cream-100 font-mono text-xs sm:text-sm rounded-lg border border-charcoal-600 hover:border-primary-500 shadow-lg hover:shadow-xl active:scale-95 transition-all duration-300 transform hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 focus:ring-offset-charcoal-800",
                    aria: { label: "Download resume" } do %>
                  <span class="text-primary-400 mr-2">$</span>
                  <span>wget resume.pdf</span>
                <% end %>
                <div id="resume-tooltip" role="tooltip" class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-white transition-opacity duration-300 bg-gray-900 rounded-lg shadow-sm opacity-0 tooltip dark:bg-gray-700">
                  Download my resume - View my professional experience and skills
                  <div class="tooltip-arrow" data-popper-arrow></div>
                </div>
              </div>
            <% elsif user.resume_url.present? %>
              <div data-tooltip-target="resume-url-tooltip" data-tooltip-trigger="hover">
                <%= link_to user.resume_url, target: "_blank", rel: "noopener noreferrer",
                    class: "inline-flex items-center px-3 sm:px-4 py-2 bg-charcoal-800 hover:bg-charcoal-900 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-cream-100 font-mono text-xs sm:text-sm rounded-lg border border-charcoal-600 hover:border-primary-500 shadow-lg hover:shadow-xl active:scale-95 transition-all duration-300 transform hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 focus:ring-offset-charcoal-800",
                    aria: { label: "View resume online" } do %>
                  <span class="text-primary-400 mr-2">$</span>
                  <span>curl resume.pdf</span>
                <% end %>
                <div id="resume-url-tooltip" role="tooltip" class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-white transition-opacity duration-300 bg-gray-900 rounded-lg shadow-sm opacity-0 tooltip dark:bg-gray-700">
                  View my resume online - Access my professional experience and skills
                  <div class="tooltip-arrow" data-popper-arrow></div>
                </div>
              </div>
            <% end %>
            </div>
          </div>
        </div>
        
        <!-- Bio -->
        <% if user.bio.present? %>
          <div class="mb-6">
            <div class="text-base sm:text-lg text-charcoal-700 dark:text-charcoal-300 leading-relaxed prose prose-sm sm:prose-base dark:prose-invert max-w-none break-words">
              <%= simple_format(user.bio, {}, wrapper_tag: "span") %>
            </div>
          </div>
        <% else %>
          <div class="mb-6 p-4 rounded-lg bg-charcoal-50/50 dark:bg-charcoal-900/20 border border-charcoal-200/50 dark:border-charcoal-700/50">
            <p class="text-charcoal-500 dark:text-charcoal-400 italic text-sm sm:text-base font-mono text-center">
              // TODO: Add an awesome bio
            </p>
          </div>
        <% end %>
        
        <!-- Skills -->
        <% if user.skills.present? && user.skills.any? %>
          <div class="mb-6 p-4 sm:p-5 rounded-lg bg-charcoal-50 dark:bg-charcoal-900/30 border border-charcoal-200 dark:border-charcoal-700 shadow-sm">
            <div class="flex items-center text-base sm:text-lg text-charcoal-600 dark:text-charcoal-400 mb-3">
              <svg class="w-5 h-5 mr-2 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
              <h2 class="font-semibold">Skills</h2>
            </div>
            <div class="flex flex-wrap gap-2" role="list" aria-label="Technical skills">
              <% user.skills.each do |skill| %>
                <span class="inline-flex items-center px-3 py-1.5 rounded-md text-xs sm:text-sm font-mono font-medium bg-accent-100 text-accent-700 dark:bg-accent-900/30 dark:text-accent-300 border border-accent-200 dark:border-accent-800 break-words hover:bg-accent-200 dark:hover:bg-accent-900/50 transition-colors" role="listitem">
                  <%= skill %>
                </span>
              <% end %>
            </div>
          </div>
        <% end %>
        
        <!-- Social Links and Contact -->
        <div class="mb-6">
          <div class="flex items-center text-base sm:text-lg text-charcoal-600 dark:text-charcoal-400 mb-4">
            <svg class="w-5 h-5 mr-2 text-primary-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
            <h2 class="font-semibold">Connect</h2>
          </div>
          <div class="flex flex-wrap gap-2 sm:gap-3" role="list" aria-label="Social links and contact information">
            <% if user.github_url.present? %>
              <div data-tooltip-target="github-tooltip" data-tooltip-trigger="hover" class="group">
                <%= link_to user.github_url, target: "_blank", rel: "noopener noreferrer",
                    class: "inline-flex items-center px-4 py-2 bg-charcoal-900 hover:bg-charcoal-800 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-cream-100 font-mono text-sm rounded-lg border border-charcoal-600 group-hover:border-primary-500 shadow-lg group-hover:shadow-xl group-hover:shadow-primary-500/20 transition-all duration-300 transform group-hover:-translate-y-0.5 group-hover:scale-105 no-print" do %>
                  <span class="text-primary-400 group-hover:text-primary-300 mr-2 transition-colors">$</span>
                  <span class="group-hover:text-primary-300 transition-colors">git clone github</span>
                <% end %>
                <div id="github-tooltip" role="tooltip" class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-white transition-opacity duration-300 bg-gray-900 rounded-lg shadow-sm opacity-0 tooltip dark:bg-gray-700">
                  View my GitHub profile - See my code repositories and projects
                  <div class="tooltip-arrow" data-popper-arrow></div>
                </div>
              </div>
            <% end %>
            
            <% if user.linkedin_url.present? %>
              <div data-tooltip-target="linkedin-tooltip" data-tooltip-trigger="hover" class="group">
                <%= link_to user.linkedin_url, target: "_blank", rel: "noopener noreferrer",
                    class: "inline-flex items-center px-4 py-2 bg-charcoal-900 hover:bg-charcoal-800 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-cream-100 font-mono text-sm rounded-lg border border-charcoal-600 group-hover:border-accent-500 shadow-lg group-hover:shadow-xl group-hover:shadow-accent-500/20 transition-all duration-300 transform group-hover:-translate-y-0.5 group-hover:scale-105 no-print" do %>
                  <svg class="w-5 h-5 text-accent-400 group-hover:text-accent-300 mr-2 transition-colors" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                  <span class="group-hover:text-accent-300 transition-colors">open linkedin</span>
                <% end %>
                <div id="linkedin-tooltip" role="tooltip" class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-white transition-opacity duration-300 bg-gray-900 rounded-lg shadow-sm opacity-0 tooltip dark:bg-gray-700">
                  Connect with me on LinkedIn - View my professional experience and network
                  <div class="tooltip-arrow" data-popper-arrow></div>
                </div>
              </div>
            <% end %>
            
            <% if user.twitter_url.present? %>
              <div data-tooltip-target="twitter-tooltip" data-tooltip-trigger="hover" class="group">
                <%= link_to user.twitter_profile_url, target: "_blank", rel: "noopener noreferrer",
                    class: "inline-flex items-center px-4 py-2 bg-charcoal-900 hover:bg-charcoal-800 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-cream-100 font-mono text-sm rounded-lg border border-charcoal-600 group-hover:border-secondary-500 shadow-lg group-hover:shadow-xl group-hover:shadow-secondary-500/20 transition-all duration-300 transform group-hover:-translate-y-0.5 group-hover:scale-105 no-print" do %>
                  <svg class="w-5 h-5 text-secondary-400 group-hover:text-secondary-300 mr-2 transition-colors" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                  </svg>
                  <span class="group-hover:text-secondary-300 transition-colors">@<%= user.twitter_handle %></span>
                <% end %>
                <div id="twitter-tooltip" role="tooltip" class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-white transition-opacity duration-300 bg-gray-900 rounded-lg shadow-sm opacity-0 tooltip dark:bg-gray-700">
                  Follow me on Twitter/X - See my latest updates and thoughts
                  <div class="tooltip-arrow" data-popper-arrow></div>
                </div>
              </div>
            <% end %>
            
            <% if user.website_url.present? %>
              <div data-tooltip-target="website-tooltip" data-tooltip-trigger="hover" class="group">
                <%= link_to user.website_url, target: "_blank", rel: "noopener noreferrer",
                    class: "inline-flex items-center px-4 py-2 bg-charcoal-900 hover:bg-charcoal-800 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-cream-100 font-mono text-sm rounded-lg border border-charcoal-600 group-hover:border-warning-500 shadow-lg group-hover:shadow-xl group-hover:shadow-warning-500/20 transition-all duration-300 transform group-hover:-translate-y-0.5 group-hover:scale-105 no-print" do %>
                  <span class="text-warning-400 group-hover:text-warning-300 mr-2 transition-colors">$</span>
                  <span class="group-hover:text-warning-300 transition-colors">curl -L website</span>
                <% end %>
                <div id="website-tooltip" role="tooltip" class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-white transition-opacity duration-300 bg-gray-900 rounded-lg shadow-sm opacity-0 tooltip dark:bg-gray-700">
                  Visit my personal website - Learn more about me and my work
                  <div class="tooltip-arrow" data-popper-arrow></div>
                </div>
              </div>
            <% end %>
            
            <% if user.contact_email.present? %>
              <% if can_contact_user?(user) %>
                <div data-tooltip-target="email-tooltip" data-tooltip-trigger="hover" class="group" role="listitem">
                  <%= link_to "mailto:#{user.contact_email}",
                      class: "inline-flex items-center px-3 sm:px-4 py-2 bg-charcoal-900 hover:bg-charcoal-800 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-cream-100 font-mono text-xs sm:text-sm rounded-lg border border-charcoal-600 group-hover:border-pink-500 shadow-lg group-hover:shadow-xl group-hover:shadow-pink-500/20 active:scale-95 transition-all duration-300 transform group-hover:-translate-y-0.5 group-hover:scale-105 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:ring-offset-2 focus:ring-offset-charcoal-900",
                      aria: { label: "Send email" } do %>
                    <span class="text-pink-400 group-hover:text-pink-300 mr-2 transition-colors">$</span>
                    <span class="group-hover:text-pink-300 transition-colors">mail -s "hello"</span>
                  <% end %>
                  <div id="email-tooltip" role="tooltip" class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-white transition-opacity duration-300 bg-gray-900 rounded-lg shadow-sm opacity-0 tooltip dark:bg-gray-700">
                    Send me an email - Get in touch for opportunities or collaboration
                    <div class="tooltip-arrow" data-popper-arrow></div>
                  </div>
                </div>
              <% else %>
                <!-- Disabled Contact Button for Unclaimed Profiles -->
                <div data-tooltip-target="email-disabled-tooltip" data-tooltip-trigger="hover" role="listitem">
                  <button disabled
                          class="inline-flex items-center px-3 sm:px-4 py-2 bg-gray-500 dark:bg-gray-600 text-gray-300 dark:text-gray-400 font-mono text-xs sm:text-sm rounded-lg border border-gray-400 dark:border-gray-500 cursor-not-allowed opacity-60"
                          aria-label="Contact unavailable - Profile must be claimed first">
                    <span class="text-gray-400 mr-2">$</span>
                    <span>mail --disabled</span>
                  </button>
                  <div id="email-disabled-tooltip" role="tooltip" class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-white transition-opacity duration-300 bg-gray-900 rounded-lg shadow-sm opacity-0 tooltip dark:bg-gray-700">
                    Contact unavailable - Profile must be claimed first
                    <div class="tooltip-arrow" data-popper-arrow></div>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
