<!-- Hero Section with Profile Header -->
<div class="relative overflow-hidden bg-white dark:bg-charcoal-800 rounded-2xl shadow-xl mb-8 border border-primary-200 dark:border-charcoal-700 transition-all duration-300 hover:shadow-2xl">
  <!-- Background Pattern -->
  <div class="absolute inset-0 bg-gradient-to-r from-primary-600/5 to-secondary-600/5 dark:from-primary-400/5 dark:to-secondary-400/5"></div>
  <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="none" fill-rule="evenodd"%3E%3Cg fill="%2310b981" fill-opacity="0.03"%3E%3Ccircle cx="30" cy="30" r="2"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')]"></div>
  
  <div class="relative px-8 py-12">
    <div class="flex flex-col lg:flex-row lg:items-start lg:space-x-8">
      <!-- Avatar and Basic Info -->
      <div class="flex-shrink-0 mb-8 lg:mb-0">
        <!-- Terminal-style frame -->
        <div class="relative bg-charcoal-900 dark:bg-charcoal-950 rounded-lg p-3 border border-charcoal-600 shadow-lg">
          <!-- Terminal header -->
          <div class="flex items-center justify-between mb-3 px-2">
            <div class="flex space-x-1.5">
              <div class="w-3 h-3 bg-danger-500 rounded-full"></div>
              <div class="w-3 h-3 bg-warning-500 rounded-full"></div>
              <div class="w-3 h-3 bg-primary-500 rounded-full"></div>
            </div>
            <div class="text-xs font-mono text-charcoal-400">~/developer</div>
          </div>
          
          <!-- Avatar container -->
          <div class="relative group">
            <% if user.avatar.attached? %>
              <%= image_tag user.avatar_medium, 
                    class: "profile-avatar w-32 h-32 rounded-xl object-cover border-2 border-primary-400 shadow-lg group-hover:shadow-primary-500/50 transition-all duration-300",
                    alt: "#{user.display_name}'s avatar",
                    loading: "lazy" %>
            <% else %>
              <div class="profile-avatar w-32 h-32 rounded-xl bg-gradient-to-br from-primary-500 to-secondary-600 flex items-center justify-center border-2 border-primary-400 shadow-lg group-hover:shadow-primary-500/50 transition-all duration-300">
                <svg class="w-16 h-16 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
            <% end %>
            
            <!-- Online status indicator -->
            <div class="absolute -bottom-1 -right-1 w-6 h-6 bg-primary-500 rounded-full border-2 border-charcoal-900 flex items-center justify-center">
              <div class="w-2 h-2 bg-white rounded-full animate-pulse"></div>
            </div>
          </div>
          
          <!-- Terminal command -->
          <div class="mt-3 px-2">
            <div class="text-xs font-mono text-primary-400">
              <span class="text-charcoal-500">$</span> whoami
            </div>
            <div class="text-xs font-mono text-cream-200 mt-1">
              <%= user.username %>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Profile Info -->
      <div class="flex-1 min-w-0">
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-6">
          <div class="mb-4 sm:mb-0">
            <h1 class="text-4xl lg:text-5xl font-bold text-charcoal-900 dark:text-cream-50 mb-2 animate-fade-in">
              <%= user.display_name %>
            </h1>
            <p class="text-xl text-charcoal-600 dark:text-charcoal-400 mb-4 font-mono">
              @<%= user.username %>
            </p>
            
            <!-- Developer Status Badges -->
            <div class="flex flex-wrap items-center gap-3 mb-4">
              <% if unclaimed_profile? %>
                <!-- Unclaimed Status Badge -->
                <div class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300 border border-amber-200 dark:border-amber-700">
                  <div class="w-2 h-2 bg-amber-500 rounded-full mr-2 animate-pulse"></div>
                  Profile Unclaimed
                </div>
                
                <!-- Preview Mode Badge -->
                <div class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300 border border-blue-200 dark:border-blue-700">
                  <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/>
                    <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
                  </svg>
                  Preview Mode
                </div>
              <% else %>
                <!-- Regular Status Badges -->
                <!-- Availability Status -->
                <div class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-primary-100 text-primary-800 dark:bg-primary-900/30 dark:text-primary-300 border border-primary-200 dark:border-primary-700">
                  <div class="w-2 h-2 bg-primary-500 rounded-full mr-2 animate-pulse"></div>
                  Available for hire
                </div>
                
                <!-- Years Coding -->
                <div class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-secondary-100 text-secondary-800 dark:bg-secondary-900/30 dark:text-secondary-300 border border-secondary-200 dark:border-secondary-700">
                  <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  3+ years coding
                </div>
              <% end %>
            </div>
            
            <!-- Currently Coding In -->
            <% if user.skills.present? && user.skills.any? %>
              <div class="mb-4">
                <div class="flex items-center text-sm text-charcoal-600 dark:text-charcoal-400 mb-2">
                  <svg class="w-4 h-4 mr-2 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                  </svg>
                  <span class="font-medium">Currently coding in:</span>
                </div>
                <div class="flex flex-wrap gap-1 ml-6">
                  <% user.skills.first(4).each do |skill| %>
                    <span class="inline-flex items-center px-2 py-1 rounded text-xs font-mono font-medium bg-accent-100 text-accent-700 dark:bg-accent-900/30 dark:text-accent-300">
                      <%= skill %>
                    </span>
                  <% end %>
                  <% if user.skills.length > 4 %>
                    <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium text-charcoal-500 dark:text-charcoal-400">
                      +<%= user.skills.length - 4 %> more
                    </span>
                  <% end %>
                </div>
              </div>
            <% end %>
            
            <!-- Traditional Job/Location Info -->
            <% if user.job_title.present? || user.location.present? %>
              <div class="flex flex-wrap items-center gap-4 text-charcoal-500 dark:text-charcoal-400">
                <% if user.job_title.present? %>
                  <div class="flex items-center">
                    <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2-2v2m8 0V6a2 2 0 012 2v6a2 2 0 01-2 2H8a2 2 0 01-2-2V8a2 2 0 012-2h8zM16 10h.01M8 10h.01" />
                    </svg>
                    <%= user.job_title %>
                  </div>
                <% end %>
                <% if user.location.present? %>
                  <div class="flex items-center">
                    <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <%= user.location %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
          
          <!-- Action Buttons -->
          <div class="flex flex-wrap gap-3 no-print">
            <% if unclaimed_profile? %>
              <!-- Claim Profile Button (Primary Action) -->
              <% if invitation_data[:pending] && !invitation_data[:expired] %>
                <%= link_to "/invitations/#{@user.invitation_token}/claim", 
                    class: "inline-flex items-center px-6 py-3 bg-amber-600 hover:bg-amber-700 dark:bg-amber-500 dark:hover:bg-amber-600 text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-amber-300 dark:focus:ring-amber-800" do %>
                  <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v-2l-4.257-4.257A6 6 0 0117 9z" />
                  </svg>
                  Claim Profile
                <% end %>
              <% end %>
              
              <!-- Limited Share Button for Unclaimed Profiles -->
              <div data-tooltip-target="share-unclaimed-tooltip" data-tooltip-trigger="hover">
                <div data-controller="share-button"
                     data-share-button-url-value="<%= request.original_url %>"
                     data-share-button-title-value="<%= user.display_name %>'s Unclaimed Profile">
                  <button data-action="click->share-button#share"
                          class="inline-flex items-center px-4 py-2 bg-charcoal-800 hover:bg-charcoal-900 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-cream-100 font-mono text-sm rounded-lg border border-charcoal-600 hover:border-accent-500 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5">
                    <span class="text-accent-400 mr-2">$</span>
                    <span>share --preview</span>
                  </button>
                </div>
                <div id="share-unclaimed-tooltip" role="tooltip" class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-white transition-opacity duration-300 bg-gray-900 rounded-lg shadow-sm opacity-0 tooltip dark:bg-gray-700">
                  Share this unclaimed profile - Let others know about this developer
                  <div class="tooltip-arrow" data-popper-arrow></div>
                </div>
              </div>
            <% else %>
              <!-- Regular Action Buttons for Active Profiles -->
              <div data-tooltip-target="share-tooltip" data-tooltip-trigger="hover">
                <div data-controller="share-button"
                     data-share-button-url-value="<%= request.original_url %>"
                     data-share-button-title-value="<%= user.display_name %>'s Profile">
                  <button data-action="click->share-button#share"
                          class="inline-flex items-center px-4 py-2 bg-charcoal-800 hover:bg-charcoal-900 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-cream-100 font-mono text-sm rounded-lg border border-charcoal-600 hover:border-accent-500 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5">
                    <span class="text-accent-400 mr-2">$</span>
                    <span>share --profile</span>
                  </button>
                </div>
                <div id="share-tooltip" role="tooltip" class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-white transition-opacity duration-300 bg-gray-900 rounded-lg shadow-sm opacity-0 tooltip dark:bg-gray-700">
                  Share this profile - Copy link to share with others
                  <div class="tooltip-arrow" data-popper-arrow></div>
                </div>
              </div>
            <% end %>
            
            <% if user.resume.attached? %>
              <div data-tooltip-target="resume-tooltip" data-tooltip-trigger="hover">
                <%= link_to user.resume, target: "_blank", rel: "noopener noreferrer",
                    class: "inline-flex items-center px-4 py-2 bg-charcoal-800 hover:bg-charcoal-900 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-cream-100 font-mono text-sm rounded-lg border border-charcoal-600 hover:border-primary-500 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5" do %>
                  <span class="text-primary-400 mr-2">$</span>
                  <span>wget resume.pdf</span>
                <% end %>
                <div id="resume-tooltip" role="tooltip" class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-white transition-opacity duration-300 bg-gray-900 rounded-lg shadow-sm opacity-0 tooltip dark:bg-gray-700">
                  Download my resume - View my professional experience and skills
                  <div class="tooltip-arrow" data-popper-arrow></div>
                </div>
              </div>
            <% elsif user.resume_url.present? %>
              <div data-tooltip-target="resume-url-tooltip" data-tooltip-trigger="hover">
                <%= link_to user.resume_url, target: "_blank", rel: "noopener noreferrer",
                    class: "inline-flex items-center px-4 py-2 bg-charcoal-800 hover:bg-charcoal-900 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-cream-100 font-mono text-sm rounded-lg border border-charcoal-600 hover:border-primary-500 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5" do %>
                  <span class="text-primary-400 mr-2">$</span>
                  <span>curl resume.pdf</span>
                <% end %>
                <div id="resume-url-tooltip" role="tooltip" class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-white transition-opacity duration-300 bg-gray-900 rounded-lg shadow-sm opacity-0 tooltip dark:bg-gray-700">
                  View my resume online - Access my professional experience and skills
                  <div class="tooltip-arrow" data-popper-arrow></div>
                </div>
              </div>
            <% end %>
            
            <div data-tooltip-target="print-tooltip" data-tooltip-trigger="hover">
              <button onclick="window.print()" 
                      class="inline-flex items-center px-4 py-2 bg-charcoal-800 hover:bg-charcoal-900 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-cream-100 font-mono text-sm rounded-lg border border-charcoal-600 hover:border-warning-500 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5">
                <span class="text-warning-400 mr-2">$</span>
                <span>lp profile</span>
              </button>
              <div id="print-tooltip" role="tooltip" class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-white transition-opacity duration-300 bg-gray-900 rounded-lg shadow-sm opacity-0 tooltip dark:bg-gray-700">
                Print this profile - Save or print a copy of this page
                <div class="tooltip-arrow" data-popper-arrow></div>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Headline -->
        <% if user.headline.present? %>
          <div class="mb-6">
            <p class="text-xl text-charcoal-800 dark:text-cream-200 font-medium leading-relaxed">
              <%= user.headline %>
            </p>
          </div>
        <% end %>
        
        <!-- Bio -->
        <% if user.bio.present? %>
          <div class="mb-6">
            <p class="text-charcoal-700 dark:text-charcoal-300 text-lg leading-relaxed">
            <%= simple_format(user.bio, {}, wrapper_tag: "span") %>
          </p>
          </div>
        <% else %>
          <div class="mb-6">
            <p class="text-charcoal-500 dark:text-charcoal-400 italic text-lg">
              // TODO: Add an awesome bio
            </p>
          </div>
        <% end %>
        
        <!-- Skills -->
        <% if user.skills.present? && user.skills.any? %>
          <div class="mb-6">
            <h3 class="text-lg font-semibold text-charcoal-900 dark:text-cream-50 mb-3 flex items-center">
              <svg class="w-5 h-5 mr-2 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Tech Stack
            </h3>
            <div class="flex flex-wrap gap-2">
              <% user.skills.each_with_index do |skill, index| %>
                <% color_classes = [
                  "bg-primary-100 text-primary-800 dark:bg-primary-900/30 dark:text-primary-300 border-primary-200 dark:border-primary-700",
                  "bg-secondary-100 text-secondary-800 dark:bg-secondary-900/30 dark:text-secondary-300 border-secondary-200 dark:border-secondary-700",
                  "bg-accent-100 text-accent-800 dark:bg-accent-900/30 dark:text-accent-300 border-accent-200 dark:border-accent-700",
                  "bg-warning-100 text-warning-800 dark:bg-warning-900/30 dark:text-warning-300 border-warning-200 dark:border-warning-700",
                  "bg-pink-100 text-pink-800 dark:bg-pink-900/30 dark:text-pink-300 border-pink-200 dark:border-pink-700"
                ] %>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-mono font-medium border <%= color_classes[index % color_classes.length] %> hover:scale-105 transition-transform cursor-default">
                  <%= skill %>
                </span>
              <% end %>
            </div>
          </div>
        <% end %>
        
        <!-- Social Links and Contact -->
        <div class="flex flex-wrap gap-3">
          <% if user.github_url.present? %>
            <div data-tooltip-target="github-tooltip" data-tooltip-trigger="hover">
              <%= link_to user.github_url, target: "_blank", rel: "noopener noreferrer",
                  class: "inline-flex items-center px-4 py-2 bg-charcoal-900 hover:bg-charcoal-800 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-cream-100 font-mono text-sm rounded-lg border border-charcoal-600 hover:border-primary-500 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5 no-print" do %>
                <span class="text-primary-400 mr-2">$</span>
                <span>git clone github</span>
              <% end %>
              <div id="github-tooltip" role="tooltip" class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-white transition-opacity duration-300 bg-gray-900 rounded-lg shadow-sm opacity-0 tooltip dark:bg-gray-700">
                View my GitHub profile - See my code repositories and projects
                <div class="tooltip-arrow" data-popper-arrow></div>
              </div>
            </div>
          <% end %>
          
          <% if user.linkedin_url.present? %>
            <div data-tooltip-target="linkedin-tooltip" data-tooltip-trigger="hover">
              <%= link_to user.linkedin_url, target: "_blank", rel: "noopener noreferrer",
                  class: "inline-flex items-center px-4 py-2 bg-charcoal-900 hover:bg-charcoal-800 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-cream-100 font-mono text-sm rounded-lg border border-charcoal-600 hover:border-accent-500 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5 no-print" do %>
                <svg class="w-5 h-5 text-accent-400 mr-2" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                <span>open linkedin</span>
              <% end %>
              <div id="linkedin-tooltip" role="tooltip" class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-white transition-opacity duration-300 bg-gray-900 rounded-lg shadow-sm opacity-0 tooltip dark:bg-gray-700">
                Connect with me on LinkedIn - View my professional experience and network
                <div class="tooltip-arrow" data-popper-arrow></div>
              </div>
            </div>
          <% end %>
          
          <% if user.twitter_url.present? %>
            <div data-tooltip-target="twitter-tooltip" data-tooltip-trigger="hover">
              <%= link_to user.twitter_profile_url, target: "_blank", rel: "noopener noreferrer",
                  class: "inline-flex items-center px-4 py-2 bg-charcoal-900 hover:bg-charcoal-800 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-cream-100 font-mono text-sm rounded-lg border border-charcoal-600 hover:border-secondary-500 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5 no-print" do %>
                <svg class="w-5 h-5 text-secondary-400 mr-2" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
                <span>@<%= user.twitter_handle %></span>
              <% end %>
              <div id="twitter-tooltip" role="tooltip" class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-white transition-opacity duration-300 bg-gray-900 rounded-lg shadow-sm opacity-0 tooltip dark:bg-gray-700">
                Follow me on Twitter/X - See my latest updates and thoughts
                <div class="tooltip-arrow" data-popper-arrow></div>
              </div>
            </div>
          <% end %>
          
          <% if user.website_url.present? %>
            <div data-tooltip-target="website-tooltip" data-tooltip-trigger="hover">
              <%= link_to user.website_url, target: "_blank", rel: "noopener noreferrer",
                  class: "inline-flex items-center px-4 py-2 bg-charcoal-900 hover:bg-charcoal-800 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-cream-100 font-mono text-sm rounded-lg border border-charcoal-600 hover:border-warning-500 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5 no-print" do %>
                <span class="text-warning-400 mr-2">$</span>
                <span>curl -L website</span>
              <% end %>
              <div id="website-tooltip" role="tooltip" class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-white transition-opacity duration-300 bg-gray-900 rounded-lg shadow-sm opacity-0 tooltip dark:bg-gray-700">
                Visit my personal website - Learn more about me and my work
                <div class="tooltip-arrow" data-popper-arrow></div>
              </div>
            </div>
          <% end %>
          
          <% if user.contact_email.present? %>
            <% if can_contact_user?(user) %>
              <div data-tooltip-target="email-tooltip" data-tooltip-trigger="hover">
                <%= link_to "mailto:#{user.contact_email}",
                    class: "inline-flex items-center px-4 py-2 bg-charcoal-900 hover:bg-charcoal-800 dark:bg-charcoal-700 dark:hover:bg-charcoal-600 text-cream-100 font-mono text-sm rounded-lg border border-charcoal-600 hover:border-pink-500 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5" do %>
                  <span class="text-pink-400 mr-2">$</span>
                  <span>mail -s "hello"</span>
                <% end %>
                <div id="email-tooltip" role="tooltip" class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-white transition-opacity duration-300 bg-gray-900 rounded-lg shadow-sm opacity-0 tooltip dark:bg-gray-700">
                  Send me an email - Get in touch for opportunities or collaboration
                  <div class="tooltip-arrow" data-popper-arrow></div>
                </div>
              </div>
            <% else %>
              <!-- Disabled Contact Button for Unclaimed Profiles -->
              <div data-tooltip-target="email-disabled-tooltip" data-tooltip-trigger="hover">
                <button disabled
                        class="inline-flex items-center px-4 py-2 bg-gray-500 dark:bg-gray-600 text-gray-300 dark:text-gray-400 font-mono text-sm rounded-lg border border-gray-400 dark:border-gray-500 cursor-not-allowed opacity-60">
                  <span class="text-gray-400 mr-2">$</span>
                  <span>mail --disabled</span>
                </button>
                <div id="email-disabled-tooltip" role="tooltip" class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-white transition-opacity duration-300 bg-gray-900 rounded-lg shadow-sm opacity-0 tooltip dark:bg-gray-700">
                  Contact unavailable - Profile must be claimed first
                  <div class="tooltip-arrow" data-popper-arrow></div>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
