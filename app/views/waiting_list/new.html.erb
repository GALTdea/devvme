<%# SEO Meta Tags %>
<% content_for :title, "Join the Waiting List - Devv.me" %>
<% content_for :meta_description, "Be among the first to join Devv.me, the premier platform for developers to showcase their work, connect with peers, and grow their careers." %>

<div class="min-h-screen bg-gradient-to-br from-cream-50 via-primary-50 to-secondary-50 dark:bg-gradient-to-br dark:from-charcoal-900 dark:via-secondary-900 dark:to-charcoal-800 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-2xl w-full space-y-8">
    <!-- Header -->
    <div class="text-center">
      <%= link_to root_path, class: "inline-block mb-6" do %>
        <h1 class="text-3xl font-bold bg-gradient-to-r from-primary-600 via-secondary-600 to-pink-600 bg-clip-text text-transparent">
          Devv.me
        </h1>
      <% end %>
      
      <h2 class="text-4xl font-extrabold text-charcoal-900 dark:text-cream-50 mb-4">
        Join the Waiting List
      </h2>
      
      <p class="text-lg text-charcoal-600 dark:text-charcoal-300 mb-8">
        We're preparing something special for developers. Be among the first to experience the next generation of developer portfolios.
      </p>
    </div>

    <!-- Main Card -->
    <div class="bg-white dark:bg-charcoal-800 shadow-2xl rounded-2xl overflow-hidden border border-primary-200 dark:border-secondary-700">
      <!-- Benefits Section -->
      <div class="bg-gradient-to-r from-primary-500 to-secondary-600 px-8 py-6">
        <h3 class="text-xl font-semibold text-white mb-4">Early Access Benefits</h3>
        <ul class="space-y-3 text-white">
          <li class="flex items-start">
            <svg class="w-6 h-6 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span>Priority access when we launch</span>
          </li>
          <li class="flex items-start">
            <svg class="w-6 h-6 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span>Exclusive features for early adopters</span>
          </li>
          <li class="flex items-start">
            <svg class="w-6 h-6 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span>Shape the platform with your feedback</span>
          </li>
          <li class="flex items-start">
            <svg class="w-6 h-6 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span>Updates on our progress and launch date</span>
          </li>
        </ul>
      </div>

      <!-- Form Section -->
      <div class="px-8 py-8">
        <%= form_with model: @waiting_list_entry, url: waiting_list_path, local: true, class: "space-y-6" do |f| %>
          <!-- Error Messages -->
          <% if @waiting_list_entry.errors.any? %>
            <div class="bg-red-50 dark:bg-red-900/20 border-l-4 border-red-500 p-4 rounded-r-lg" role="alert">
              <div class="flex">
                <svg class="w-6 h-6 text-red-500 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <h3 class="text-sm font-medium text-red-800 dark:text-red-200">
                    <%= pluralize(@waiting_list_entry.errors.count, "error") %> prevented you from joining:
                  </h3>
                  <ul class="mt-2 text-sm text-red-700 dark:text-red-300 list-disc list-inside">
                    <% @waiting_list_entry.errors.full_messages.each do |message| %>
                      <li><%= message %></li>
                    <% end %>
                  </ul>
                </div>
              </div>
            </div>
          <% end %>

          <!-- Email Field -->
          <div>
            <%= f.label :email, class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-200 mb-2" do %>
              Email Address <span class="text-red-500">*</span>
            <% end %>
            <%= f.email_field :email, 
                placeholder: "your@email.com",
                required: true,
                autocomplete: "email",
                class: "w-full px-4 py-3 rounded-lg border border-charcoal-300 dark:border-charcoal-600 bg-white dark:bg-charcoal-700 text-charcoal-900 dark:text-cream-50 placeholder-charcoal-400 dark:placeholder-charcoal-500 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all duration-200" %>
          </div>

          <!-- Full Name Field -->
          <div>
            <%= f.label :full_name, class: "block text-sm font-medium text-charcoal-700 dark:text-charcoal-200 mb-2" do %>
              Full Name <span class="text-charcoal-400 text-xs">(Optional)</span>
            <% end %>
            <%= f.text_field :full_name, 
                placeholder: "John Doe",
                autocomplete: "name",
                class: "w-full px-4 py-3 rounded-lg border border-charcoal-300 dark:border-charcoal-600 bg-white dark:bg-charcoal-700 text-charcoal-900 dark:text-cream-50 placeholder-charcoal-400 dark:placeholder-charcoal-500 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all duration-200" %>
            <p class="mt-1 text-xs text-charcoal-500 dark:text-charcoal-400">
              Help us personalize your invitation
            </p>
          </div>

          <!-- Submit Button -->
          <div>
            <%= f.submit "Join the Waiting List", 
                class: "w-full flex justify-center items-center py-3 px-6 text-base font-medium text-white rounded-lg bg-gradient-to-r from-primary-600 to-primary-700 hover:from-primary-700 hover:to-primary-800 focus:ring-4 focus:ring-primary-300 dark:focus:ring-primary-900 shadow-lg hover:shadow-xl transition-all duration-300 cursor-pointer" %>
          </div>

          <!-- Privacy Notice -->
          <p class="text-xs text-center text-charcoal-500 dark:text-charcoal-400">
            We respect your privacy. Your information will only be used to notify you about Devv.me updates.
          </p>
        <% end %>
      </div>
    </div>

    <!-- Back to Home -->
    <div class="text-center">
      <%= link_to root_path, class: "inline-flex items-center text-sm text-charcoal-600 dark:text-charcoal-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors duration-200" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Back to Home
      <% end %>
    </div>
  </div>
</div>
