<%# SEO Meta Tags %>
<% content_for :title, "You're on the List! - Devv.me" %>
<% content_for :meta_description, "Thank you for joining the Devv.me waiting list. We'll notify you when we launch." %>

<div class="min-h-screen bg-gradient-to-br from-cream-50 via-primary-50 to-secondary-50 dark:bg-gradient-to-br dark:from-charcoal-900 dark:via-secondary-900 dark:to-charcoal-800 flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-2xl w-full text-center">
    <!-- Success Icon -->
    <div class="mx-auto w-24 h-24 bg-gradient-to-br from-green-400 to-green-600 rounded-full flex items-center justify-center shadow-2xl mb-8 animate-bounce-once">
      <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
      </svg>
    </div>

    <!-- Success Message -->
    <div class="bg-white dark:bg-charcoal-800 shadow-2xl rounded-2xl overflow-hidden border border-primary-200 dark:border-secondary-700 p-8 md:p-12">
      <h1 class="text-4xl font-extrabold text-charcoal-900 dark:text-cream-50 mb-4">
        You're on the List! 🎉
      </h1>
      
      <p class="text-lg text-charcoal-600 dark:text-charcoal-300 mb-8">
        Thank you for joining our waiting list. We're excited to have you as part of our early community!
      </p>

      <!-- What's Next Section -->
      <div class="bg-gradient-to-r from-primary-50 to-secondary-50 dark:bg-gradient-to-r dark:from-primary-900/20 dark:to-secondary-900/20 rounded-xl p-6 mb-8 text-left">
        <h2 class="text-xl font-semibold text-charcoal-900 dark:text-cream-50 mb-4 flex items-center">
          <svg class="w-6 h-6 mr-2 text-primary-600" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
          </svg>
          What happens next?
        </h2>
        
        <ul class="space-y-3 text-charcoal-700 dark:text-charcoal-300">
          <li class="flex items-start">
            <span class="flex-shrink-0 w-6 h-6 rounded-full bg-primary-600 text-white text-xs flex items-center justify-center mr-3 mt-0.5">1</span>
            <span>We'll send you a confirmation email shortly</span>
          </li>
          <li class="flex items-start">
            <span class="flex-shrink-0 w-6 h-6 rounded-full bg-primary-600 text-white text-xs flex items-center justify-center mr-3 mt-0.5">2</span>
            <span>You'll receive regular updates about our progress</span>
          </li>
          <li class="flex items-start">
            <span class="flex-shrink-0 w-6 h-6 rounded-full bg-primary-600 text-white text-xs flex items-center justify-center mr-3 mt-0.5">3</span>
            <span>When we launch, you'll get priority access with an invitation link</span>
          </li>
        </ul>
      </div>

      <!-- Social Share Section -->
      <div class="border-t border-charcoal-200 dark:border-charcoal-700 pt-8">
        <h3 class="text-lg font-semibold text-charcoal-900 dark:text-cream-50 mb-4">
          Help us grow! Share with fellow developers
        </h3>
        
        <div class="flex justify-center space-x-4">
          <%= link_to "https://twitter.com/intent/tweet?text=I%20just%20joined%20the%20waiting%20list%20for%20Devv.me%20-%20the%20next%20generation%20developer%20portfolio%20platform!&url=#{request.base_url}", 
              target: "_blank",
              rel: "noopener noreferrer",
              class: "inline-flex items-center px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white rounded-lg transition-colors duration-200" do %>
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
            </svg>
            Share on Twitter
          <% end %>
          
          <%= link_to "https://www.linkedin.com/sharing/share-offsite/?url=#{request.base_url}", 
              target: "_blank",
              rel: "noopener noreferrer",
              class: "inline-flex items-center px-4 py-2 bg-blue-700 hover:bg-blue-800 text-white rounded-lg transition-colors duration-200" do %>
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            Share on LinkedIn
          <% end %>
        </div>
      </div>

      <!-- CTA Buttons -->
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <%= link_to root_path, class: "inline-flex justify-center items-center py-3 px-6 text-base font-medium text-white rounded-lg bg-gradient-to-r from-primary-600 to-primary-700 hover:from-primary-700 hover:to-primary-800 focus:ring-4 focus:ring-primary-300 dark:focus:ring-primary-900 shadow-lg hover:shadow-xl transition-all duration-300" do %>
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
          Back to Home
        <% end %>
        
        <%= link_to public_projects_path, class: "inline-flex justify-center items-center py-3 px-6 text-base font-medium text-charcoal-700 dark:text-cream-100 rounded-lg border border-charcoal-300 dark:border-charcoal-600 hover:bg-charcoal-50 dark:hover:bg-charcoal-700 focus:ring-4 focus:ring-charcoal-100 dark:focus:ring-charcoal-700 transition-all duration-300" do %>
          Explore Projects
        <% end %>
      </div>
    </div>

    <!-- Additional Info -->
    <p class="mt-8 text-sm text-charcoal-600 dark:text-charcoal-400">
      Check your email (including spam folder) for confirmation
    </p>
  </div>
</div>

<!-- Custom Animation -->
<style>
  @keyframes bounce-once {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-25px);
    }
  }
  
  .animate-bounce-once {
    animation: bounce-once 0.8s ease-in-out;
  }
</style>


