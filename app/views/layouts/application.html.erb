<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Devvme App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    
    <%# SEO Meta Tags %>
    <% if content_for?(:meta_description) %>
      <meta name="description" content="<%= content_for(:meta_description) %>">
    <% end %>
    
    <% if content_for?(:meta_keywords) %>
      <meta name="keywords" content="<%= content_for(:meta_keywords) %>">
    <% end %>
    
    <%# Canonical URL %>
    <%= content_for(:canonical) if content_for?(:canonical) %>
    
    <%# Open Graph Tags %>
    <%= content_for(:open_graph) if content_for?(:open_graph) %>
    
    <%# Twitter Card Tags %>
    <%= content_for(:twitter_cards) if content_for?(:twitter_cards) %>
    
    <%# Enhanced Social Meta Tags %>
    <%= content_for(:social_meta) if content_for?(:social_meta) %>
    
    <%# Structured Data %>
    <%= content_for(:structured_data) if content_for?(:structured_data) %>
    
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    
    <%# RSS Feed %>
    <link rel="alternate" type="application/rss+xml" title="Devvme App Blog" href="<%= public_blog_rss_url %>" />

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    
    <%# Flowbite JavaScript %>
    <script src="https://cdn.jsdelivr.net/npm/flowbite@2.5.2/dist/flowbite.min.js"></script>
    
    <%# Performance Resource Hints %>
    <%= performance_resource_hints %>
    
    <%# Google Analytics %>
    <%= google_analytics_tag if google_analytics_enabled? %>
    
    <%# Performance Monitoring %>
    <%= performance_monitoring_scripts %>
    <%= track_performance_metrics %>
  </head>

  <body class="bg-secondary-50 dark:bg-secondary-900 min-h-screen flex flex-col">
    <!-- Navigation -->
    <%= render 'shared/navigation' %>

    <!-- Flash Messages -->
    <%= render 'shared/flash_messages' %>

    <!-- Main Content -->
    <main class="flex-grow">
      <%= yield %>
    </main>

    <!-- Footer -->
    <%= render 'shared/footer' %>
  </body>
</html>
