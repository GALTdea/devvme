<div class="max-w-md mx-auto bg-white shadow-md rounded px-8 pt-6 pb-8 mb-4">
  <h2 class="text-2xl font-bold mb-6 text-center">Sign up</h2>
  
  <!-- Beta Testing Notice -->
  <div class="mb-6 p-4 bg-blue-50 border-l-4 border-blue-400 rounded-r">
    <div class="flex">
      <div class="flex-shrink-0">
        <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
        </svg>
      </div>
      <div class="ml-3">
        <p class="text-sm text-blue-700">
          <strong>Beta Testing Phase:</strong> We're currently in beta with limited access. Sign up now to secure your username and you'll receive an email notification as soon as your account is activated!
        </p>
      </div>
    </div>
  </div>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="mb-4">
      <%= f.label :username, class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= f.text_field :username, autofocus: true, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline", placeholder: "Enter your username" %>
      <p class="text-xs text-gray-600 mt-1">3-30 characters, letters, numbers, hyphens, and underscores only</p>
    </div>

    <div class="mb-4">
      <%= f.label :email, class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= f.email_field :email, autocomplete: "email", class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline", placeholder: "Enter your email" %>
    </div>

    <div class="mb-4">
      <%= f.label :full_name, class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= f.text_field :full_name, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline", placeholder: "Enter your full name" %>
    </div>

    <div class="mb-4">
      <%= f.label :bio, class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= f.text_area :bio, rows: 3, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline", placeholder: "Tell us about yourself (optional)" %>
    </div>

    <div class="mb-4">
      <%= f.label :github_url, "GitHub URL", class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= f.url_field :github_url, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline", placeholder: "https://github.com/yourusername" %>
    </div>

    <div class="mb-4">
      <%= f.label :linkedin_url, "LinkedIn URL", class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= f.url_field :linkedin_url, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline", placeholder: "https://linkedin.com/in/yourusername" %>
    </div>

    <div class="mb-4">
      <%= f.label :website_url, "Website URL", class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= f.url_field :website_url, class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline", placeholder: "https://yourwebsite.com" %>
    </div>

    <div class="mb-4">
      <%= f.label :avatar, class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= f.file_field :avatar, accept: "image/*", class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
    </div>

    <div class="mb-4">
      <%= f.label :password, class: "block text-gray-700 text-sm font-bold mb-2" %>
      <% if @minimum_password_length %>
      <em class="text-xs text-gray-600">(<%= @minimum_password_length %> characters minimum)</em>
      <% end %>
      <%= f.password_field :password, autocomplete: "new-password", class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
    </div>

    <div class="mb-6">
      <%= f.label :password_confirmation, class: "block text-gray-700 text-sm font-bold mb-2" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %>
    </div>

    <div class="flex items-center justify-between">
      <%= f.submit "Sign up", class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline w-full" %>
    </div>
  <% end %>

  <div class="text-center mt-4">
    <%= render "devise/shared/links" %>
  </div>
</div>
