<%= turbo_stream.replace dom_id(user, :follow_button) do %>
  <% if user_signed_in? && current_user != user %>
    <% if current_user.following?(user) %>
      <%= button_to unfollow_user_path(user.username), method: :delete, form: { data: { turbo: true } }, class: "inline-flex items-center px-4 py-2 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg shadow transition-all" do %>
        <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 12H6" />
        </svg>
        Unfollow
      <% end %>
    <% else %>
      <%= button_to follow_user_path(user.username), method: :post, form: { data: { turbo: true } }, class: "inline-flex items-center px-4 py-2 bg-primary-600 hover:bg-primary-700 text-white font-semibold rounded-lg shadow transition-all" do %>
        <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Follow
      <% end %>
    <% end %>
  <% end %>
<% end %>
