<%# Replaces the thinking indicator when the job reports an error (LLM failure, finalize failure, etc.). %>
<div id="architect_thinking_indicator" data-architect-status="error" data-architect-error="true" class="architect-error rounded-2xl border border-red-200 bg-red-50 p-4 dark:border-red-800 dark:bg-red-950/50">
  <p class="text-sm font-medium text-red-800 dark:text-red-200">
    <%= message %>
  </p>
  <p class="mt-2 text-xs text-red-600 dark:text-red-400">
    <%= t("architect.errors.try_again") %>
  </p>
</div>
