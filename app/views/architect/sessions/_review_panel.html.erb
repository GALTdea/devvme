<%# Shown when the interview is complete. Preview generated bio/headline and Accept / Edit & Accept / Discard. %>
<% session = local_assigns[:session] || @architect_session %>
<div class="architect-review-panel rounded-xl border border-secondary-200 bg-secondary-50 p-4 dark:border-secondary-700 dark:bg-secondary-800/80">
  <h3 class="text-sm font-semibold text-secondary-900 dark:text-white mb-3">
    <%= t("architect.sessions.review_title") %>
  </h3>

  <% if session.generated_bio.present? && (session.goal_bio? || session.goal_both?) %>
    <div class="mb-4">
      <p class="text-xs font-medium text-secondary-500 dark:text-secondary-400 mb-1">
        <%= t("architect.sessions.preview_bio") %>
      </p>
      <div class="rounded-lg border border-secondary-200 bg-white p-3 text-sm text-secondary-800 dark:border-secondary-600 dark:bg-secondary-800 dark:text-secondary-200 whitespace-pre-wrap"><%= session.generated_bio %></div>
    </div>
  <% end %>

  <% if session.generated_headline.present? && (session.goal_headline? || session.goal_both?) %>
    <div class="mb-4">
      <p class="text-xs font-medium text-secondary-500 dark:text-secondary-400 mb-1">
        <%= t("architect.sessions.preview_headline") %>
      </p>
      <div class="rounded-lg border border-secondary-200 bg-white p-3 text-sm text-secondary-800 dark:border-secondary-600 dark:bg-secondary-800 dark:text-secondary-200"><%= session.generated_headline %></div>
    </div>
  <% end %>

  <div class="flex flex-wrap items-center gap-2 pt-2">
    <%= button_to t("architect.sessions.accept_button"),
                  accept_architect_session_path(session),
                  method: :patch,
                  class: "inline-flex items-center justify-center rounded-lg bg-primary-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-primary-500 dark:bg-primary-500 dark:hover:bg-primary-400" %>
    <%= button_to t("architect.sessions.edit_and_accept"),
                  accept_architect_session_path(session, edit: true),
                  method: :patch,
                  class: "inline-flex items-center justify-center rounded-lg border border-primary-600 bg-white px-3 py-2 text-sm font-medium text-primary-600 hover:bg-primary-50 dark:border-primary-500 dark:bg-secondary-800 dark:text-primary-400 dark:hover:bg-primary-900/20" %>
    <%= button_to t("architect.sessions.discard"),
                  architect_session_path(session),
                  method: :delete,
                  form: { data: { turbo_confirm: t("architect.sessions.confirm_discard") } },
                  class: "inline-flex items-center justify-center rounded-lg border border-secondary-300 bg-white px-3 py-2 text-sm font-medium text-secondary-700 hover:bg-secondary-50 dark:border-secondary-600 dark:bg-secondary-800 dark:text-secondary-300 dark:hover:bg-secondary-700" %>
  </div>
</div>
