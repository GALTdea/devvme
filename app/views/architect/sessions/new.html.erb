<% content_for :title, t("architect.sessions.title") %>

<div class="max-w-2xl mx-auto px-4 py-8 sm:px-6 lg:px-8">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-secondary-900 dark:text-white">
      <%= t("architect.sessions.new_title") %>
    </h1>
    <p class="mt-1 text-sm text-secondary-600 dark:text-secondary-400">
      <%= t("architect.sessions.new_subtitle") %>
    </p>
  </div>

  <%= form_with model: @architect_session,
                url: architect_sessions_path,
                method: :post,
                class: "space-y-6 rounded-xl border border-secondary-200 bg-white p-6 shadow-sm dark:border-secondary-700 dark:bg-secondary-800" do |f| %>
    <% if @architect_session.errors.any? %>
      <div class="rounded-lg border border-red-200 bg-red-50 p-4 dark:border-red-800 dark:bg-red-900/20">
        <p class="text-sm text-red-700 dark:text-red-300">
          <%= @architect_session.errors.full_messages.to_sentence %>
        </p>
      </div>
    <% end %>

    <div>
      <%= f.label :goal, t("architect.sessions.goal_label"), class: "block text-sm font-medium text-secondary-700 dark:text-secondary-300" %>
      <div class="mt-2 space-y-2">
        <% ArchitectSession.goals.each_key do |goal_key| %>
          <label class="flex cursor-pointer items-center rounded-lg border border-secondary-200 p-3 transition-colors has-[:checked]:border-primary-500 has-[:checked]:bg-primary-50 dark:border-secondary-600 dark:has-[:checked]:bg-primary-900/20">
            <%= f.radio_button :goal, goal_key, class: "h-4 w-4 border-secondary-300 text-primary-600 focus:ring-primary-500 dark:border-secondary-600 dark:bg-secondary-700" %>
            <span class="ml-3 text-sm font-medium text-secondary-900 dark:text-white">
              <%= t("architect.sessions.goal_#{goal_key}") %>
            </span>
          </label>
        <% end %>
      </div>
    </div>

    <div>
      <%= f.label :pasted_content, t("architect.sessions.pasted_content_label"), class: "block text-sm font-medium text-secondary-700 dark:text-secondary-300" %>
      <%= f.text_area :pasted_content,
                      rows: 5,
                      placeholder: t("architect.sessions.pasted_content_placeholder"),
                      class: "mt-2 block w-full rounded-lg border border-secondary-300 bg-secondary-50 px-3 py-2 text-secondary-900 placeholder-secondary-500 focus:border-primary-500 focus:ring-primary-500 dark:border-secondary-600 dark:bg-secondary-700 dark:text-white dark:placeholder-secondary-400 sm:text-sm" %>
      <p class="mt-1 text-xs text-secondary-500 dark:text-secondary-400">
        <%= t("architect.sessions.pasted_content_hint") %>
      </p>
    </div>

    <div class="flex flex-wrap items-center gap-3 pt-2">
      <%= f.submit t("architect.sessions.start_session"),
                  class: "inline-flex items-center justify-center rounded-lg bg-primary-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-primary-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600 dark:bg-primary-500 dark:hover:bg-primary-400" %>
      <%= link_to t("architect.sessions.back"),
                  dashboard_path,
                  class: "text-sm font-medium text-secondary-600 hover:text-secondary-500 dark:text-secondary-400 dark:hover:text-secondary-300" %>
    </div>
  <% end %>
</div>
